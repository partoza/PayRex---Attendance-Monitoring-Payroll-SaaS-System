# Visual Studio
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# Build folders
bin/
obj/

# ASP.NET/Python/node
wwwroot/lib/
node_modules/

# Logs
*.log
dberror.txt

# JetBrains Rider
.idea/

# OS files
.DS_Store
Thumbs.db

# NuGet
*.nupkg
packages/

# Secret files
.env
secrets.json
*.env.local
*.env.production

# Others
.vscode/

# PuppeteerSharp downloaded Chromium browser
.local-chromium/
**/.local-chromium/

# Ignore appsettings files (global and in subfolders)
appsettings.json
appsettings.*.json
**/appsettings.json
**/appsettings.*.json
# But allow template files
!appsettings.TEMPLATE.json
!**/appsettings.TEMPLATE.json

# Ignore Program.cs files (contains sensitive configuration)
**/Program.cs

# Database files
*.db
*.db-shm
*.db-wal
*.mdf
*.ldf

# Temporary SQL files
*.sql

# Migration snapshots (optional - remove if you want to keep them)
# **/Migrations/*ModelSnapshot.cs

# Ignore Markdown files (except specific documentation)
*.md
**/*.md
!SONARQUBE_*.md
!SONARLINT_*.md
!README.md
!SETUP_GUIDE.md
!PRE_PUSH_CHECKLIST.md
!MIGRATION_GUIDE.md
!MIGRATION_SUMMARY.md

# SonarQube/SonarLint
.sonarqube/
.sonarlint/**/*
!.sonarlint/PayRexApplication/
!.sonarlint/PayRexApplication/settings.json
TestResults/

# Compiled CSS (Tailwind)
**/wwwroot/css/site.css
**/wwwroot/css/site.css.map

# NPM package lock (optional - uncomment if you want to ignore)
# package-lock.json

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Mono auto generated files
mono_crash.*

# Windows image file caches
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on file shares
$RECYCLE.BIN/
