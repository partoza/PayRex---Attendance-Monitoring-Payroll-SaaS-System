@page
@model PayRex.Web.Pages.EditEmployeeModel
@{
    ViewData["Title"] = "Edit Employee";
    Layout = "_Layout";
}

<div class="max-w-8xl mx-auto px-4 sm:px-6 lg:px-8 py-6 space-y-6">
    <!-- Header Section - matching Add Employee style -->
    <div class="bg-gradient-to-r from-blue-50 via-white to-blue-50 rounded-2xl border border-blue-100 shadow-sm relative overflow-hidden">
        <div class="absolute top-0 right-0 -mt-16 -mr-16 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
        <div class="px-8 py-6 relative z-10 text-gray-900">
            <div class="flex items-center justify-between">
                <div>
                    <h1 class="text-3xl font-extrabold tracking-tight flex items-center gap-3">
                        <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
                        </svg>
                        Edit Employee
                    </h1>
                    <p class="mt-2 text-gray-600 text-lg">Modify employee profile. Changes will be saved to the employee record.</p>
                </div>
                <button type="button" onclick="window.history.back()" 
                    class="inline-flex items-center px-6 py-3 rounded-xl text-sm font-medium text-gray-700 bg-white border border-gray-200 hover:bg-gray-50 transition-all shadow-sm hover:shadow-md">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                    Back
                </button>
            </div>
        </div>
    </div>

    <form id="editEmployeeForm" enctype="multipart/form-data" class="space-y-6">
        <input type="hidden" id="employeeNumber" name="EmployeeNumber" value="@Model.EmployeeNumber" />
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <div class="lg:col-span-2 space-y-6">
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                    <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
                        <h2 class="text-lg font-semibold text-gray-900">Personal Information</h2>
                    </div>
                    <div class="p-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="block mb-2 text-sm font-medium text-gray-900">Employee Code</label>
                                <input type="text" id="employeeCode" name="EmployeeCode" readonly value="@Model.EmployeeCode" class="bg-gray-100 border border-gray-300 text-gray-900 text-sm rounded-lg block w-full p-2.5 cursor-not-allowed" />
                            </div>

                            <div>
                                <label class="block mb-2 text-sm font-medium text-gray-900">Company Name</label>
                                <input type="text" id="companyName" name="CompanyName" readonly value="@Model.CompanyName" class="bg-gray-100 border border-gray-300 text-gray-900 text-sm rounded-lg block w-full p-2.5 cursor-not-allowed" />
                            </div>

                            <div>
                                <label class="block mb-2 text-sm font-medium text-gray-900">First Name</label>
                                <input type="text" id="firstName" name="FirstName" required maxlength="100" value="@Model.FirstName" class="bg-white border border-gray-300 text-gray-900 text-sm rounded-lg block w-full p-2.5" />
                            </div>

                            <div>
                                <label class="block mb-2 text-sm font-medium text-gray-900">Last Name</label>
                                <input type="text" id="lastName" name="LastName" required maxlength="100" value="@Model.LastName" class="bg-white border border-gray-300 text-gray-900 text-sm rounded-lg block w-full p-2.5" />
                            </div>

                            <div class="md:col-span-2">
                                <label class="block mb-2 text-sm font-medium text-gray-900">Email Address</label>
                                <input type="email" id="email" name="Email" required maxlength="256" value="@Model.Email" class="bg-white border border-gray-300 text-gray-900 text-sm rounded-lg block w-full p-2.5" />
                            </div>

                            <div>
                                <label class="block mb-2 text-sm font-medium text-gray-900">Contact Number</label>
                                <input type="tel" id="contactNumber" name="ContactNumber" maxlength="20" value="@Model.ContactNumber" class="bg-white border border-gray-300 text-gray-900 text-sm rounded-lg block w-full p-2.5" />
                            </div>

                            <div>
                                <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</label>
                                <select id="status" name="Status" class="mt-1 block w-full border border-gray-200 rounded-xl shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm px-3 py-2.5">
                                    @if (Model.Status == PayRexApplication.Enums.EmployeeStatus.Active) {
                                        <option value="0" selected>Active</option>
                                    } else {
                                        <option value="0">Active</option>
                                    }
                                    @if (Model.Status == PayRexApplication.Enums.EmployeeStatus.Inactive) {
                                        <option value="1" selected>Inactive</option>
                                    } else {
                                        <option value="1">Inactive</option>
                                    }
                                    @if (Model.Status == PayRexApplication.Enums.EmployeeStatus.Resigned) {
                                        <option value="2" selected>Resigned</option>
                                    } else {
                                        <option value="2">Resigned</option>
                                    }
                                    @if (Model.Status == PayRexApplication.Enums.EmployeeStatus.Terminated) {
                                        <option value="3" selected>Terminated</option>
                                    } else {
                                        <option value="3">Terminated</option>
                                    }
                                </select>
                            </div>

                            <div>
                                <label class="block mb-2 text-sm font-medium text-gray-900">Civil Status</label>
                                <select id="civilStatus" name="CivilStatus" class="bg-white border border-gray-300 text-gray-900 text-sm rounded-lg block w-full p-2.5">
                                    <option value="">Select status</option>
                                    @if (Model.CivilStatus == "Single")
                                    {
                                        @:<option value="Single" selected>Single</option>
                                    }
                                    else
                                    {
                                        @:<option value="Single">Single</option>
                                    }
                                    @if (Model.CivilStatus == "Married")
                                    {
                                        @:<option value="Married" selected>Married</option>
                                    }
                                    else
                                    {
                                        @:<option value="Married">Married</option>
                                    }
                                </select>
                            </div>

                            <div>
                                <label class="block mb-2 text-sm font-medium text-gray-900">Birthdate</label>
                                <input type="date" id="birthdate" name="Birthdate" value="@(Model.Birthdate?.ToString("yyyy-MM-dd") ?? "")" class="bg-white border border-gray-300 text-gray-900 text-sm rounded-lg block w-full p-2.5" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                    <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
                        <h2 class="text-lg font-semibold text-gray-900">Employment Details</h2>
                    </div>
                    <div class="p-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="md:col-span-2">
                                <label class="block mb-2 text-sm font-medium text-gray-900">Role / Position</label>
                                <select id="roleId" name="RoleId" class="bg-white border border-gray-300 text-gray-900 text-sm rounded-lg block w-full p-2.5" data-selected="@Model.RoleId">
                                    <option value="">Select role</option>
                                </select>
                            </div>

                            <div>
                                <label class="block mb-2 text-sm font-medium text-gray-900">Salary</label>
                                <div class="p-3 bg-blue-50 border border-blue-200 rounded-lg">
                                    <span id="salaryDisplay" class="text-lg font-bold text-blue-700">₱ @(Model.BasicRate.ToString("N2"))</span>
                                </div>
                            </div>

                            <div>
                                <label class="block mb-2 text-sm font-medium text-gray-900">Start Date</label>
                                <input type="date" id="startDate" name="StartDate" value="@(Model.StartDate.ToString("yyyy-MM-dd"))" class="bg-white border border-gray-300 text-gray-900 text-sm rounded-lg block w-full p-2.5" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                    <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
                        <h2 class="text-lg font-semibold text-gray-900">Government Identifiers</h2>
                    </div>
                    <div class="p-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="block mb-2 text-sm font-medium text-gray-900">TIN</label>
                                <input type="text" id="tin" name="TIN" maxlength="15" value="@Model.Tin" class="bg-white border border-gray-300 text-gray-900 text-sm rounded-lg block w-full p-2.5" />
                            </div>

                            <div>
                                <label class="block mb-2 text-sm font-medium text-gray-900">SSS Number</label>
                                <input type="text" id="sss" name="SSS" maxlength="12" value="@Model.Sss" class="bg-white border border-gray-300 text-gray-900 text-sm rounded-lg block w-full p-2.5" />
                            </div>

                            <div>
                                <label class="block mb-2 text-sm font-medium text-gray-900">PhilHealth ID</label>
                                <input type="text" id="philHealth" name="PhilHealth" maxlength="14" value="@Model.PhilHealth" class="bg-white border border-gray-300 text-gray-900 text-sm rounded-lg block w-full p-2.5" />
                            </div>

                            <div>
                                <label class="block mb-2 text-sm font-medium text-gray-900">Pag-IBIG MID</label>
                                <input type="text" id="pagIbig" name="PagIbig" maxlength="14" value="@Model.PagIbig" class="bg-white border border-gray-300 text-gray-900 text-sm rounded-lg block w-full p-2.5" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="flex flex-col sm:flex-row gap-3 justify-end">
                    <button type="button" onclick="window.history.back()" class="text-gray-700 bg-white border border-gray-300 hover:bg-gray-50 font-medium rounded-lg text-sm px-5 py-2.5 inline-flex items-center">Cancel</button>
                    <button type="submit" id="submitBtn" class="text-white bg-green-600 hover:bg-green-700 font-medium rounded-lg text-sm px-5 py-2.5 inline-flex items-center"><i class="fas fa-save mr-2"></i>Update Employee</button>
                </div>
            </div>

            <div class="space-y-6">
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                    <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
                        <h3 class="font-semibold text-gray-900">Profile Photo</h3>
                    </div>
                    <div class="p-6">
                        <div class="flex flex-col items-center">
                            <div class="w-40 h-40 rounded-full overflow-hidden border-4 border-gray-200 mb-4 bg-gray-100 flex items-center justify-center">
                                @if (!string.IsNullOrEmpty(Model.ProfileImageUrl))
                                {
                                    <img id="profilePreview" src="@Model.ProfileImageUrl" class="w-full h-full object-cover" />
                                }
                                else
                                {
                                    <div id="profilePlaceholder" class="text-center text-gray-400"><i class="fas fa-user text-5xl"></i><p class="text-xs mt-2">No image</p></div>
                                }
                            </div>

                            <div class="w-full">
                                <label for="profilePhoto" class="flex flex-col items-center justify-center w-full h-32 border-2 border-gray-300 border-dashed rounded-lg cursor-pointer bg-gray-50 hover:bg-gray-100">
                                    <div class="flex flex-col items-center justify-center pt-5 pb-6">
                                        <i class="fas fa-cloud-upload-alt text-2xl text-gray-400 mb-2"></i>
                                        <p class="mb-1 text-sm text-gray-500"><span class="font-semibold">Click to upload</span></p>
                                        <p class="text-xs text-gray-400">JPG, PNG or WebP (max 2MB)</p>
                                    </div>
                                    <input id="profilePhoto" name="profilePhoto" type="file" class="hidden" accept="image/*" />
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                    <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
                        <h3 class="font-semibold text-gray-900">Signature</h3>
                    </div>
                    <div class="p-6">
                        <div class="flex flex-col items-center">
                            <div class="w-full h-32 border-2 border-gray-300 rounded-lg mb-4 bg-gray-50 flex items-center justify-center p-2">
                                <img id="signaturePreview" class="max-h-full max-w-full object-contain" src="@Model.SignatureUrl" />
                            </div>

                            <div class="w-full">
                                <label for="signature" class="flex flex-col items-center justify-center w-full h-24 border-2 border-gray-300 border-dashed rounded-lg cursor-pointer bg-gray-50 hover:bg-gray-100">
                                    <div class="flex flex-col items-center justify-center pt-4 pb-5">
                                        <i class="fas fa-cloud-upload-alt text-xl text-gray-400 mb-1"></i>
                                        <p class="mb-1 text-xs text-gray-500"><span class="font-semibold">Upload signature</span></p>
                                        <p class="text-xs text-gray-400">PNG with transparency</p>
                                    </div>
                                    <input id="signature" name="signature" type="file" class="hidden" accept="image/*" />
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        const API_URL = (window.ApiBaseUrl || '@ViewData["ApiBaseUrl"]' || '').replace(/"/g, '');
        let token = '';

        document.addEventListener('DOMContentLoaded', () => {
            token = localStorage.getItem('jwtToken') || sessionStorage.getItem('jwtToken') || '';
            fetchRoles();
            // Set role after roles loaded by using data-selected attribute
        });

        async function fetchRoles() {
            try {
                const headers = {};
                if (token) headers['Authorization'] = `Bearer ${token}`;
                const res = await fetch(`${API_URL}/api/EmployeeRoles`, { headers, credentials: 'include' });
                if (res.ok) {
                    const roles = await res.json();
                    const select = document.getElementById('roleId');
                    select.innerHTML = '<option value="">Select role</option>';
                    roles.filter(r => r.isActive).forEach(r => {
                        const opt = document.createElement('option');
                        opt.value = r.roleId;
                        opt.textContent = r.roleName;
                        opt.dataset.rate = r.basicRate || 0;
                        opt.dataset.rateType = r.rateType || '';
                        select.appendChild(opt);
                    });
                    // set selected if present
                    const selected = select.dataset.selected;
                    if (selected) select.value = selected;
                    // update salary display
                    const sel = select.options[select.selectedIndex];
                    if (sel) {
                        const rate = parseFloat(sel.dataset.rate) || 0;
                        const rateType = sel.dataset.rateType || '';
                        const label = rateType ? ` / ${rateType}` : '';
                        document.getElementById('salaryDisplay').textContent = `₱ ${rate.toLocaleString('en-PH', { minimumFractionDigits: 2 })}${label}`;
                    }
                    select.addEventListener('change', function () {
                        const selected = this.options[this.selectedIndex];
                        const rate = parseFloat(selected.dataset.rate) || 0;
                        const rateType = selected.dataset.rateType || '';
                        const label = rateType ? ` / ${rateType}` : '';
                        document.getElementById('salaryDisplay').textContent = `₱ ${rate.toLocaleString('en-PH', { minimumFractionDigits: 2 })}${label}`;
                    });
                }
            } catch (e) { console.error('Error fetching roles', e); }
        }

        document.getElementById('editEmployeeForm').addEventListener('submit', async function (e) {
            e.preventDefault();
            const submitBtn = document.getElementById('submitBtn');
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Updating...';

            const formData = new FormData(this);
            const empNum = document.getElementById('employeeNumber').value;
            try {
                const headers = {};
                if (token) headers['Authorization'] = `Bearer ${token}`;
                const res = await fetch(`${API_URL}/api/Employees/${empNum}`, { method: 'PUT', headers, credentials: 'include', body: formData });
                if (res.ok) {
                    const data = await res.json().catch(() => ({}));
                    showToast((data && data.message) ? data.message : 'Employee updated', 'success');
                    setTimeout(() => window.location.href = '/Employees', 1500);
                } else {
                    try { const err = await res.json(); showToast(err.message || 'Failed to update', 'error'); } catch { showToast('Failed to update', 'error'); }
                }
            } catch (err) { showToast('Network error. Please try again.', 'error'); console.error(err); }
            finally { submitBtn.disabled = false; submitBtn.innerHTML = '<i class="fas fa-save mr-2"></i>Update Employee'; }
        });
    </script>
}
