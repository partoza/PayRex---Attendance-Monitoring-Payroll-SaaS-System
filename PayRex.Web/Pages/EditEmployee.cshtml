@page
@model PayRex.Web.Pages.EditEmployeeModel
@{
    ViewData["Title"] = "Edit Employee";
    Layout = "_Layout";
}

<div class="max-w-8xl mx-auto px-4 sm:px-6 lg:px-8 py-6 space-y-6">
    <!-- Header Section - matching Add Employee style -->
    <div class="bg-gradient-to-r from-blue-50 via-white to-blue-50 rounded-2xl border border-blue-100 shadow-sm relative overflow-hidden">
        <div class="absolute top-0 right-0 -mt-16 -mr-16 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
        <div class="px-8 py-10 relative z-10 text-gray-900">
            <div class="flex items-center justify-between">
                <div>
                    <h1 class="text-3xl font-extrabold tracking-tight flex items-center gap-3">
                      
                        Edit Employee
                    </h1>
                    <p class="mt-2 text-gray-600 text-lg">Modify employee profile. Changes will be saved to the employee record.</p>
                </div>
                <button type="button" onclick="window.history.back()" 
                    class="inline-flex items-center px-6 py-3 rounded-xl text-sm font-medium text-gray-700 bg-white border border-gray-200 hover:bg-gray-50 transition-all shadow-sm hover:shadow-md">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                    Back
                </button>
            </div>
        </div>
    </div>

    <form id="editEmployeeForm" enctype="multipart/form-data" class="space-y-6">
        <input type="hidden" id="employeeNumber" name="EmployeeNumber" value="@Model.EmployeeNumber" />
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <div class="lg:col-span-2 space-y-6">
                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                    <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50">
                        <div class="flex items-center gap-3">
                            <div class="p-2 bg-blue-50 rounded-xl text-blue-600">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6">
                                <path fill-rule="evenodd" d="M7.5 6a4.5 4.5 0 1 1 9 0 4.5 4.5 0 0 1-9 0ZM3.751 20.105a8.25 8.25 0 0 1 16.498 0 .75.75 0 0 1-.437.695A18.683 18.683 0 0 1 12 22.5c-2.786 0-5.433-.608-7.812-1.7a.75.75 0 0 1-.437-.695Z" clip-rule="evenodd" />
                                </svg>
                            </div>
                            <h2 class="text-lg font-bold text-gray-900">Personal Information</h2>
                        </div>
                    </div>
                    <div class="p-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Employee Code</label>
                                <input type="text" id="employeeCode" name="EmployeeCode" readonly value="@Model.EmployeeCode"
                                    class="mt-1 block w-full bg-gray-50 border border-gray-200 text-gray-900 text-sm rounded-xl px-3 py-2.5 cursor-not-allowed"
                                    placeholder="Loading...">
                            </div>

                            <div>
                                <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Company Name</label>
                                <input type="text" id="companyName" name="CompanyName" readonly value="@Model.CompanyName"
                                    class="mt-1 block w-full bg-gray-50 border border-gray-200 text-gray-900 text-sm rounded-xl px-3 py-2.5 cursor-not-allowed">
                            </div>

                            <div    >
                                <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider flex items-center gap-1">First Name <span class="text-red-500">*</span></label>
                                <input type="text" id="firstName" name="FirstName" required maxlength="100" value="@Model.FirstName"
                                    class="mt-1 block w-full border border-gray-200 rounded-xl shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm px-3 py-2.5"
                                    placeholder="Enter first name">
                            </div>

                            <div>
                                <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider flex items-center gap-1">Last Name <span class="text-red-500">*</span></label>
                                <input type="text" id="lastName" name="LastName" required maxlength="100" value="@Model.LastName"
                                    class="mt-1 block w-full border border-gray-200 rounded-xl shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm px-3 py-2.5"
                                    placeholder="Enter last name">
                            </div>

                            <div class="md:col-span-2">
                                <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider flex items-center gap-1">Email Address <span class="text-red-500">*</span></label>
                                <input type="email" id="email" name="Email" required maxlength="256" value="@Model.Email"
                                    class="mt-1 block w-full border border-gray-200 rounded-xl shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm px-3 py-2.5"
                                    placeholder="name@company.com">
                            </div>

                            <div>
                                <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Contact Number</label>
                                <input type="tel" id="contactNumber" name="ContactNumber" maxlength="20" value="@Model.ContactNumber"
                                    class="mt-1 block w-full border border-gray-200 rounded-xl shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm px-3 py-2.5"
                                    placeholder="+63 9XX XXX XXXX">
                            </div>

                            <div>
                                <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</label>
                                <select id="status" name="Status" class="mt-1 block w-full border border-gray-200 rounded-xl shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm px-3 py-2.5">
                                    @if (Model.Status == PayRexApplication.Enums.EmployeeStatus.Active) {
                                        <option value="0" selected>Active</option>
                                    } else {
                                        <option value="0">Active</option>
                                    }
                                    @if (Model.Status == PayRexApplication.Enums.EmployeeStatus.Inactive) {
                                        <option value="1" selected>Inactive</option>
                                    } else {
                                        <option value="1">Inactive</option>
                                    }
                                    @if (Model.Status == PayRexApplication.Enums.EmployeeStatus.Resigned) {
                                        <option value="2" selected>Resigned</option>
                                    } else {
                                        <option value="2">Resigned</option>
                                    }
                                    @if (Model.Status == PayRexApplication.Enums.EmployeeStatus.Terminated) {
                                        <option value="3" selected>Terminated</option>
                                    } else {
                                        <option value="3">Terminated</option>
                                    }
                                </select>
                            </div>

                            <div>
                                <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider flex items-center gap-1">Civil Status <span class="text-red-500">*</span></label>
                                <select id="civilStatus" name="CivilStatus" required
                                    class="mt-1 block w-full border border-gray-200 rounded-xl shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm px-3 py-2.5">
                                    <option value="">Select status</option>
                                    @if (Model.CivilStatus == "Single")
                                    {
                                        @:<option value="Single" selected>Single</option>
                                    }
                                    else
                                    {
                                        @:<option value="Single">Single</option>
                                    }
                                    @if (Model.CivilStatus == "Married")
                                    {
                                        @:<option value="Married" selected>Married</option>
                                    }
                                    else
                                    {
                                        @:<option value="Married">Married</option>
                                    }
                                </select>
                            </div>

                            <div>
                                <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Birthdate</label>
                                <div class="relative mt-1">
                                    <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                        </svg>
                                    </div>
                                    <input type="text" id="birthdate" name="Birthdate" datepicker datepicker-autohide value="@(Model.Birthdate?.ToString("yyyy-MM-dd") ?? "")" data-original="@(Model.Birthdate?.ToString("yyyy-MM-dd") ?? "")"
                                        class="block w-full pl-10 border border-gray-200 rounded-xl shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm px-3 py-2.5"
                                        placeholder="Select date">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                    <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50">
                        <div class="flex items-center gap-3">
                            <div class="p-2 bg-blue-50 rounded-xl text-blue-600">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6">
                                <path fill-rule="evenodd" d="M7.5 5.25a3 3 0 0 1 3-3h3a3 3 0 0 1 3 3v.205c.933.085 1.857.197 2.774.334 1.454.218 2.476 1.483 2.476 2.917v3.033c0 1.211-.734 2.352-1.936 2.752A24.726 24.726 0 0 1 12 15.75c-2.73 0-5.357-.442-7.814-1.259-1.202-.4-1.936-1.541-1.936-2.752V8.706c0-1.434 1.022-2.7 2.476-2.917A48.814 48.814 0 0 1 7.5 5.455V5.25Zm7.5 0v.09a49.488 49.488 0 0 0-6 0v-.09a1.5 1.5 0 0 1 1.5-1.5h3a1.5 1.5 0 0 1 1.5 1.5Zm-3 8.25a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Z" clip-rule="evenodd" />
                                <path d="M3 18.4v-2.796a4.3 4.3 0 0 0 .713.31A26.226 26.226 0 0 0 12 17.25c2.892 0 5.68-.468 8.287-1.335.252-.084.49-.189.713-.311V18.4c0 1.452-1.047 2.728-2.523 2.923-2.12.282-4.282.427-6.477.427a49.19 49.19 0 0 1-6.477-.427C4.047 21.128 3 19.852 3 18.4Z" />
                                </svg>
                            </div>
                            <h2 class="text-lg font-bold text-gray-900">Employment Details</h2>
                        </div>
                    </div>
                    <div class="p-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="md:col-span-2">
                                <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider flex items-center gap-1">Role / Position <span class="text-red-500">*</span></label>
                                <select id="roleId" name="RoleId" required class="mt-1 block w-full border border-gray-200 rounded-xl shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm px-3 py-2.5" data-selected="@Model.RoleId">
                                    <option value="">Select role</option>
                                </select>
                            </div>

                            <div>
                                <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Salary</label>
                                <div class="mt-1 p-3 bg-blue-50 rounded-xl border border-blue-100">
                                    <span id="salaryDisplay" class="text-lg font-bold text-blue-700">₱ @(Model.BasicRate.ToString("N2"))</span>
                                </div>
                            </div>

                            <div>
                                <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider flex items-center gap-1">Start Date <span class="text-red-500">*</span></label>
                                <div class="relative mt-1">
                                    <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                        </svg>
                                    </div>
                                    <input type="text" id="startDate" name="StartDate" required datepicker datepicker-autohide value="@(Model.StartDate.ToString("yyyy-MM-dd"))" data-original="@(Model.StartDate.ToString("yyyy-MM-dd"))"
                                        class="block w-full pl-10 border border-gray-200 rounded-xl shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm px-3 py-2.5"
                                        placeholder="Select start date">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                    <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50">
                        <div class="flex items-center gap-3">
                            <div class="p-2 bg-blue-50 rounded-xl text-blue-600">
                                 <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6">
  <path fill-rule="evenodd" d="M4.5 3.75a3 3 0 0 0-3 3v10.5a3 3 0 0 0 3 3h15a3 3 0 0 0 3-3V6.75a3 3 0 0 0-3-3h-15Zm4.125 3a2.25 2.25 0 1 0 0 4.5 2.25 2.25 0 0 0 0-4.5Zm-3.873 8.703a4.126 4.126 0 0 1 7.746 0 .75.75 0 0 1-.351.92 7.47 7.47 0 0 1-3.522.877 7.47 7.47 0 0 1-3.522-.877.75.75 0 0 1-.351-.92ZM15 8.25a.75.75 0 0 0 0 1.5h3.75a.75.75 0 0 0 0-1.5H15ZM14.25 12a.75.75 0 0 1 .75-.75h3.75a.75.75 0 0 1 0 1.5H15a.75.75 0 0 1-.75-.75Zm.75 2.25a.75.75 0 0 0 0 1.5h3.75a.75.75 0 0 0 0-1.5H15Z" clip-rule="evenodd" />
</svg>
                            </div>
                            <h2 class="text-lg font-bold text-gray-900">Government Identifiers</h2>
                        </div>
                    </div>
                    <div class="p-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider">TIN</label>
                                <input type="text" id="tin" name="TIN" maxlength="15" value="@Model.Tin"
                                    class="mt-1 block w-full border border-gray-200 rounded-xl shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm px-3 py-2.5" placeholder="XXX-XXX-XXX-XXX" />
                            </div>

                            <div>
                                <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider flex items-center gap-1">SSS Number <span class="text-red-500">*</span></label>
                                <input type="text" id="sss" name="SSS" maxlength="12" value="@Model.Sss"
                                    class="mt-1 block w-full border border-gray-200 rounded-xl shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm px-3 py-2.5" />
                                <span id="sssError" class="text-xs text-red-600 mt-1"></span>
                            </div>

                            <div>
                                <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider flex items-center gap-1">PhilHealth ID <span class="text-red-500">*</span></label>
                                <input type="text" id="philHealth" name="PhilHealth" maxlength="14" value="@Model.PhilHealth"
                                    class="mt-1 block w-full border border-gray-200 rounded-xl shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm px-3 py-2.5" />
                                <span id="philHealthError" class="text-xs text-red-600 mt-1"></span>
                            </div>

                            <div>
                                <label class="text-xs font-semibold text-gray-500 uppercase tracking-wider flex items-center gap-1">Pag-IBIG MID <span class="text-red-500">*</span></label>
                                <input type="text" id="pagIbig" name="PagIbig" maxlength="14" value="@Model.PagIbig"
                                    class="mt-1 block w-full border border-gray-200 rounded-xl shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm px-3 py-2.5" />
                                <span id="pagIbigError" class="text-xs text-red-600 mt-1"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Buttons moved to Signature card to match AddEmployee layout -->
            </div>

            <div class="space-y-6">
                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                    <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50">
                        <div class="flex items-center gap-3">
                            <div class="p-2 bg-blue-50 rounded-xl text-blue-600">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6">
  <path d="M12 9a3.75 3.75 0 1 0 0 7.5A3.75 3.75 0 0 0 12 9Z" />
  <path fill-rule="evenodd" d="M9.344 3.071a49.52 49.52 0 0 1 5.312 0c.967.052 1.83.585 2.332 1.39l.821 1.317c.24.383.645.643 1.11.71.386.054.77.113 1.152.177 1.432.239 2.429 1.493 2.429 2.909V18a3 3 0 0 1-3 3h-15a3 3 0 0 1-3-3V9.574c0-1.416.997-2.67 2.429-2.909.382-.064.766-.123 1.151-.178a1.56 1.56 0 0 0 1.11-.71l.822-1.315a2.942 2.942 0 0 1 2.332-1.39ZM6.75 12.75a5.25 5.25 0 1 1 10.5 0 5.25 5.25 0 0 1-10.5 0Zm12-1.5a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Z" clip-rule="evenodd" />
</svg>

                            </div>    

                            <h3 class="font-bold text-gray-900">Profile Photo</h3>
                        </div>
                        
                    </div>
                    <div class="p-6">
                        <div class="flex flex-col items-center">
                            <div class="relative mb-4 group">
                                <div class="p-2 rounded-xl inline-block">
                                    <div class="w-40 h-40 rounded-full overflow-hidden">
                                        <img id="profilePreview" src="@(Model.ProfileImageUrl ?? "")" class="w-full h-full object-cover @(string.IsNullOrEmpty(Model.ProfileImageUrl) ? "hidden" : "")" alt="Profile Preview" />
                                        <div id="profilePlaceholder" class="w-full h-full flex items-center justify-center bg-gray-100 @(!string.IsNullOrEmpty(Model.ProfileImageUrl) ? "hidden" : "")">
                                            <svg class="w-20 h-20 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                            </svg>
                                        </div>
                                    </div>
                                </div>

                            <div class="w-full mt-2">
                                <label for="profilePhoto" class="w-full inline-flex items-center justify-center px-4 py-3 bg-blue-50 hover:bg-blue-100 text-blue-700 text-sm font-medium rounded-xl border-2 border-blue-200 border-dashed transition-all cursor-pointer">
                                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" /></svg>
                                    Choose Photo
                                </label>
                                <input id="profilePhoto" name="profilePhoto" type="file" class="hidden" accept="image/*" onchange="previewImage(this, 'profilePreview', 'profilePlaceholder')" />
                                <p class="text-xs text-gray-400 text-center mt-2">JPG, PNG or WebP (max 2MB)</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                    <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50">

                         <div class="flex items-center gap-3">
                            <div class="p-2 bg-blue-50 rounded-xl text-blue-600">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6">
                                         <path d="M21.731 2.269a2.625 2.625 0 0 0-3.712 0l-1.157 1.157 3.712 3.712 1.157-1.157a2.625 2.625 0 0 0 0-3.712ZM19.513 8.199l-3.712-3.712-12.15 12.15a5.25 5.25 0 0 0-1.32 2.214l-.8 2.685a.75.75 0 0 0 .933.933l2.685-.8a5.25 5.25 0 0 0 2.214-1.32L19.513 8.2Z" />
                                </svg>

                            </div>
                            <h3 class="font-bold text-gray-900">Signature</h3>
                        </div>

                    </div>
                    <div class="p-6">
                        <div class="flex flex-col items-center">
                            <div class="relative mb-4 group">
                                <div class="p-2 rounded-xl bg-gradient-to-br from-gray-50 to-gray-100 border border-gray-200 shadow-sm inline-block w-full">
                                    <div class="w-full flex items-center justify-center">
                                        <img id="signaturePreview" class="max-w-full h-auto object-contain @(string.IsNullOrEmpty(Model.SignatureUrl) ? "hidden" : "")" src="@(Model.SignatureUrl ?? "")" alt="Signature Preview" />
                                        <div id="signaturePlaceholder" class="text-center text-gray-400 @(!string.IsNullOrEmpty(Model.SignatureUrl) ? "hidden" : "")">
                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-16 h-16 mx-auto">
                                              <path d="M21.731 2.269a2.625 2.625 0 0 0-3.712 0l-1.157 1.157 3.712 3.712 1.157-1.157a2.625 2.625 0 0 0 0-3.712ZM19.513 8.199l-3.712-3.712-12.15 12.15a5.25 5.25 0 0 0-1.32 2.214l-.8 2.685a.75.75 0 0 0 .933.933l2.685-.8a5.25 5.25 0 0 0 2.214-1.32L19.513 8.2Z" />
                                            </svg>
                                            <p class="text-md mt-1">No signature</p>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="w-full">
                                <label for="signature" class="w-full inline-flex items-center justify-center px-4 py-3 bg-blue-50 hover:bg-blue-100 text-blue-700 text-sm font-medium rounded-xl border-2 border-blue-200 border-dashed transition-all cursor-pointer">
                                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" /></svg>
                                    Upload Signature
                                </label>
                                <input id="signature" name="signature" type="file" class="hidden" accept="image/*" onchange="previewImage(this, 'signaturePreview', 'signaturePlaceholder')" />
                                <p class="text-xs text-gray-400 text-center mt-2">PNG with transparency recommended</p>
                            </div>

                        <!-- Update + Reset buttons placed under Signature card (stacked, full-width) -->
                        <div class="mt-6 space-y-3 w-full">
                            <button type="submit" id="submitBtn"
                                class="w-full px-6 py-3 rounded-xl text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 transition-all shadow-sm">
                                Update Employee
                            </button>

                            <button type="button" id="resetBtn" onclick="resetForm()"
                                class="w-full px-6 py-3 rounded-xl text-sm font-medium text-gray-700 bg-white border border-gray-200 hover:bg-gray-50 transition-all shadow-sm">
                                Reset
                            </button>
                        </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <!-- Flowbite JS for datepicker -->
    <script src="https://cdn.jsdelivr.net/npm/flowbite@2.5.2/dist/flowbite.min.js"></script>
    <script>
        const API_URL = (window.ApiBaseUrl || '@ViewData["ApiBaseUrl"]' || '').replace(/"/g, '');
        let token = '';
        let initialProfileSrc = '';
        let initialSignatureSrc = '';

        // Global toast helpers are provided by the shared layout (showToast / showUploadToast / hideUploadToast)
        document.addEventListener('DOMContentLoaded', () => {
            token = localStorage.getItem('jwtToken') || sessionStorage.getItem('jwtToken') || '';
            fetchRoles();
            setupGovIdMasking();

            // Initialize Flowbite datepickers
            let birthdateInput = document.getElementById('birthdate');
            let startDateInput = document.getElementById('startDate');
            if (typeof Datepicker !== 'undefined') {
                if (birthdateInput) {
                    new Datepicker(birthdateInput, { autohide: true, format: 'yyyy-mm-dd', todayBtn: true, clearBtn: true, todayHighlight: true });
                }
                if (startDateInput) {
                    new Datepicker(startDateInput, { autohide: true, format: 'yyyy-mm-dd', todayBtn: true, clearBtn: true, todayHighlight: true });
                }
            }

            // Capture initial preview sources so reset can restore edit state
            const p = document.getElementById('profilePreview');
            const pp = document.getElementById('profilePlaceholder');
            if (p && p.src) initialProfileSrc = p.src;
            const s = document.getElementById('signaturePreview');
            const sp = document.getElementById('signaturePlaceholder');
            if (s && s.src) initialSignatureSrc = s.src;
        });

        async function fetchRoles() {
            try {
                const headers = {};
                if (token) headers['Authorization'] = `Bearer ${token}`;
                const res = await fetch(`${API_URL}/api/EmployeeRoles`, { headers, credentials: 'include' });
                if (res.ok) {
                    const roles = await res.json();
                    const select = document.getElementById('roleId');
                    select.innerHTML = '<option value="">Select role</option>';
                    roles.filter(r => r.isActive).forEach(r => {
                        const opt = document.createElement('option');
                        opt.value = r.roleId;
                        opt.textContent = r.roleName;
                        opt.dataset.rate = r.basicRate || 0;
                        opt.dataset.rateType = r.rateType || '';
                        select.appendChild(opt);
                    });
                    // set selected if present
                    const selected = select.dataset.selected;
                    if (selected) select.value = selected;
                    // update salary display
                    const sel = select.options[select.selectedIndex];
                    if (sel) {
                        const rate = parseFloat(sel.dataset.rate) || 0;
                        const rateType = sel.dataset.rateType || '';
                        const label = rateType ? ` / ${rateType}` : '';
                        document.getElementById('salaryDisplay').textContent = `₱ ${rate.toLocaleString('en-PH', { minimumFractionDigits: 2 })}${label}`;
                    }
                    select.addEventListener('change', function () {
                        const selected = this.options[this.selectedIndex];
                        const rate = parseFloat(selected.dataset.rate) || 0;
                        const rateType = selected.dataset.rateType || '';
                        const label = rateType ? ` / ${rateType}` : '';
                        document.getElementById('salaryDisplay').textContent = `₱ ${rate.toLocaleString('en-PH', { minimumFractionDigits: 2 })}${label}`;
                    });
                }
            } catch (e) { console.error('Error fetching roles', e); }
        }

        function setupGovIdMasking() {
            maskInput('tin', [3,3,3,3], '-');
            maskInput('sss', [2,7,1], '-');
            maskInput('philHealth', [2,9,1], '-');
            maskInput('pagIbig', [4,4,4], '-');
        }

        function maskInput(id, groups, separator) {
            const input = document.getElementById(id);
            if (!input) return;
            input.addEventListener('input', function (e) {
                let value = this.value.replace(/[^0-9]/g, '');
                const totalDigits = groups.reduce((a, b) => a + b, 0);
                value = value.substring(0, totalDigits);

                let formatted = '';
                let pos = 0;
                for (let i = 0; i < groups.length; i++) {
                    if (pos >= value.length) break;
                    if (i > 0) formatted += separator;
                    formatted += value.substring(pos, pos + groups[i]);
                    pos += groups[i];
                }
                this.value = formatted;
            });
        }

        function previewImage(input, previewId, placeholderId) {
            const preview = document.getElementById(previewId);
            const placeholder = document.getElementById(placeholderId);
            if (input.files && input.files[0]) {
                const file = input.files[0];
                if (file.size > 2 * 1024 * 1024) {
                    showToast('File size exceeds 2MB. Please choose a smaller file.', 'error');
                    input.value = '';
                    return;
                }
                if (!file.type.match('image.*')) {
                    showToast('Please select an image file.', 'error');
                    input.value = '';
                    return;
                }

                showUploadToast();

                const reader = new FileReader();
                reader.onload = (e) => {
                    if (preview) { preview.src = e.target.result; preview.classList.remove('hidden'); }
                    if (placeholder) placeholder.classList.add('hidden');
                    hideUploadToast();
                    showToast('Image uploaded successfully!', 'success');
                };
                reader.readAsDataURL(file);
            } else {
                if (preview) { preview.src = ''; preview.classList.add('hidden'); }
                if (placeholder) placeholder.classList.remove('hidden');
            }
        }

        function resetForm() {
            const form = document.getElementById('editEmployeeForm');
            if (!form) return;
            form.reset();

            // Restore profile preview to initial src or placeholder
            const profilePreview = document.getElementById('profilePreview');
            const profilePlaceholder = document.getElementById('profilePlaceholder');
            if (profilePreview) {
                if (initialProfileSrc) { profilePreview.src = initialProfileSrc; profilePreview.classList.remove('hidden'); if (profilePlaceholder) profilePlaceholder.classList.add('hidden'); }
                else { profilePreview.src = ''; profilePreview.classList.add('hidden'); if (profilePlaceholder) profilePlaceholder.classList.remove('hidden'); }
            }

            // Restore signature preview
            const signaturePreview = document.getElementById('signaturePreview');
            const signaturePlaceholder = document.getElementById('signaturePlaceholder');
            if (signaturePreview) {
                if (initialSignatureSrc) { signaturePreview.src = initialSignatureSrc; signaturePreview.classList.remove('hidden'); if (signaturePlaceholder) signaturePlaceholder.classList.add('hidden'); }
                else { signaturePreview.src = ''; signaturePreview.classList.add('hidden'); if (signaturePlaceholder) signaturePlaceholder.classList.remove('hidden'); }
            }

            // Reset salary display based on selected role
            const select = document.getElementById('roleId');
            if (select) {
                const sel = select.options[select.selectedIndex];
                const rate = sel ? (parseFloat(sel.dataset.rate) || 0) : 0;
                const rateType = sel ? (sel.dataset.rateType || '') : '';
                const label = rateType ? ` / ${rateType}` : '';
                const sd = document.getElementById('salaryDisplay');
                if (sd) sd.textContent = `₱ ${rate.toLocaleString('en-PH', { minimumFractionDigits: 2 })}${label}`;
            }

            // Clear gov id error texts and styles
            ['tinError','sssError','philHealthError','pagIbigError'].forEach(id => { const el = document.getElementById(id); if (el) el.textContent = ''; });
            ['tin','sss','philHealth','pagIbig'].forEach(id => { const el = document.getElementById(id); if (el) el.classList.remove('border-red-500'); });

            // Reset start date to original value if present
            const startDateInput = document.getElementById('startDate');
            if (startDateInput && startDateInput.dataset && startDateInput.dataset.original) startDateInput.value = startDateInput.dataset.original;
        }

        document.getElementById('editEmployeeForm').addEventListener('submit', async function (e) {
            e.preventDefault();
            const submitBtn = document.getElementById('submitBtn');
            submitBtn.disabled = true;
            // show centralized loading toast (reuse layout's loading toast)
            if (typeof showLoadingToast === 'function') showLoadingToast('Updating employee...');
            submitBtn.innerHTML = '<svg class="w-5 h-5 mr-2 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>Updating...';

            const formData = new FormData(this);
            const empNum = document.getElementById('employeeNumber').value;
            try {
                const headers = {};
                if (token) headers['Authorization'] = `Bearer ${token}`;
                const res = await fetch(`${API_URL}/api/Employees/${empNum}`, { method: 'PUT', headers, credentials: 'include', body: formData });
                if (res.ok) {
                    const data = await res.json().catch(() => ({}));
                    showToast((data && data.message) ? data.message : 'Employee updated', 'success');
                    setTimeout(() => window.location.href = '/Employees', 1500);
                } else {
                    try { const err = await res.json(); showToast(err.message || 'Failed to update', 'error'); } catch { showToast('Failed to update', 'error'); }
                }
            } catch (err) { showToast('Network error. Please try again.', 'error'); console.error(err); }
            finally { 
                // hide centralized loading toast
                if (typeof hideUploadToast === 'function') hideUploadToast();
                submitBtn.disabled = false; 
                submitBtn.innerHTML = 'Update Employee'; 
            }
        });
    </script>
}
