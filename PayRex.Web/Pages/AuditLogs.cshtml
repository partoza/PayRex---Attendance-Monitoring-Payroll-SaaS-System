@page
@model PayRex.Web.Pages.AuditLogsModel
@{
    ViewData["Title"] = "Audit Logs";

    string getActionColor(string action) => action switch {
        "Failed Login" => "bg-red-100 text-red-700",
        "Login" => "bg-green-100 text-green-700",
        "Register" or "Registration" => "bg-blue-100 text-blue-700",
        "ResetPassword" or "Password Reset" => "bg-yellow-100 text-yellow-700",
        "ForgotPassword" or "Forgot Password" => "bg-blue-100 text-blue-700",
        "TotpEnabled" or "TotpDisabled" or "2FA Changed" => "bg-yellow-100 text-yellow-700",
        "SetUserStatus" or "Status Change" or "SetCompanyStatus" => "bg-gray-100 text-gray-700",
        "PaymentReceived" or "CheckoutCreated" => "bg-green-100 text-green-700",
        _ => "bg-gray-100 text-gray-700"
    };

    string formatActionName(string action) =>
        System.Text.RegularExpressions.Regex.Replace(action, "(?<=[a-z])([A-Z])", " $1").Trim();
}

<div class="max-w-8xl mx-auto px-4 py-6 sm:px-6 lg:px-8 space-y-6">
    <!-- Welcome Header -->
    <div class="bg-gradient-to-r from-blue-50 via-white to-blue-50 rounded-2xl border border-blue-100 shadow-sm overflow-hidden relative">
        <div class="absolute top-0 right-0 -mt-16 -mr-16 w-64 h-64 bg-yellow-100 rounded-full blur-3xl opacity-20"></div>
        <div class="absolute bottom-0 left-0 -mb-16 -ml-16 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
        <div class="px-6 py-8 sm:px-10 relative z-10">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <div>
                    <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight">Audit Logs</h1>
                    <p class="mt-2 text-gray-600">System activity trail and security events</p>
                </div>
                <span class="inline-flex items-center px-4 py-2 rounded-xl text-sm font-semibold bg-blue-100 text-blue-700">
                    <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20"><path d="M10 12a2 2 0 100-4 2 2 0 000 4z" /><path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd" /></svg>
                    View Only
                </span>
            </div>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-4 gap-4">
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 flex items-center gap-4">
            <div class="w-10 h-10 bg-red-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-red-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd" /></svg>
            </div>
            <div>
                <p class="text-xs text-gray-500">Failed Logins</p>
                <p class="text-lg font-bold text-gray-900">@Model.Stats.FailedLogins</p>
            </div>
        </div>
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 flex items-center gap-4">
            <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" /></svg>
            </div>
            <div>
                <p class="text-xs text-gray-500">Successful Logins</p>
                <p class="text-lg font-bold text-gray-900">@Model.Stats.SuccessfulLogins</p>
            </div>
        </div>
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 flex items-center gap-4">
            <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-blue-600" fill="currentColor" viewBox="0 0 20 20"><path d="M8 9a3 3 0 100-6 3 3 0 000 6zM8 11a6 6 0 016 6H2a6 6 0 016-6zM16 7a1 1 0 10-2 0v1h-1a1 1 0 100 2h1v1a1 1 0 102 0v-1h1a1 1 0 100-2h-1V7z" /></svg>
            </div>
            <div>
                <p class="text-xs text-gray-500">Registrations</p>
                <p class="text-lg font-bold text-gray-900">@Model.Stats.Registrations</p>
            </div>
        </div>
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 flex items-center gap-4">
            <div class="w-10 h-10 bg-yellow-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-yellow-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" /></svg>
            </div>
            <div>
                <p class="text-xs text-gray-500">Password Resets</p>
                <p class="text-lg font-bold text-gray-900">@Model.Stats.PasswordResets</p>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <form method="get" class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 bg-gradient-to-r from-gray-50 to-white">
            <h2 class="text-base font-semibold text-gray-900 flex items-center">
                <svg class="w-5 h-5 mr-2 text-blue-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3 3a1 1 0 011-1h12a1 1 0 011 1v3a1 1 0 01-.293.707L12 11.414V15a1 1 0 01-.293.707l-2 2A1 1 0 018 17v-5.586L3.293 6.707A1 1 0 013 6V3z" clip-rule="evenodd" /></svg>
                Filters
            </h2>
        </div>
        <div class="p-4 sm:p-6">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Search</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <svg class="w-4 h-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" /></svg>
                        </div>
                        <input type="text" name="Search" value="@Model.Search" placeholder="Name or details..." class="w-full pl-10 pr-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all">
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Action Type</label>
                    <select name="Action" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all bg-white">
                        <option value="">All Actions</option>
                        <option value="Failed Login" selected="@(Model.Action == "Failed Login")">Failed Login</option>
                        <option value="Login" selected="@(Model.Action == "Login")">Login</option>
                        <option value="Register" selected="@(Model.Action == "Register")">Registration</option>
                        <option value="ResetPassword" selected="@(Model.Action == "ResetPassword")">Password Reset</option>
                        <option value="SetUserStatus" selected="@(Model.Action == "SetUserStatus")">Status Change</option>
                        <option value="SetUserRole" selected="@(Model.Action == "SetUserRole")">Role Change</option>
                        <option value="PaymentReceived" selected="@(Model.Action == "PaymentReceived")">Payment</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">From Date</label>
                    <input type="date" name="FromDate" value="@Model.FromDate" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">To Date</label>
                    <input type="date" name="ToDate" value="@Model.ToDate" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all">
                </div>
            </div>
            <div class="flex items-center gap-3 mt-4">
                <button type="submit" class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-xl hover:bg-blue-700 transition-colors">
                    <svg class="w-4 h-4 mr-1.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" /></svg>
                    Apply Filters
                </button>
                <a href="/AuditLogs" class="inline-flex items-center px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-xl hover:bg-gray-200 transition-colors border border-gray-200">
                    <svg class="w-4 h-4 mr-1.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                    Clear Filters
                </a>
            </div>
        </div>
    </form>

    <!-- Logs Table -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 bg-gradient-to-r from-gray-50 to-white">
            <div class="flex items-center justify-between">
                <div>
                    <h2 class="text-base font-semibold text-gray-900">Activity Log</h2>
                    <p class="text-sm text-gray-500 mt-0.5">Showing @Model.TotalCount events</p>
                </div>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-gray-50/80">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Timestamp</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Action</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Name</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Company</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Role</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Details</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @if (Model.AuditItems.Any())
                    {
                        @foreach (var log in Model.AuditItems)
                        {
                            <tr class="hover:bg-gray-50/50 transition-colors">
                                <td class="px-6 py-3 text-sm text-gray-500 whitespace-nowrap font-mono">@log.Timestamp.ToString("MMM dd, yyyy hh:mm tt")</td>
                                <td class="px-6 py-3">
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg text-xs font-semibold @getActionColor(log.Action)">
                                        @formatActionName(log.Action)
                                    </span>
                                </td>
                                <td class="px-6 py-3 text-sm text-gray-900 font-medium truncate max-w-[180px]">@(log.UserName ?? log.UserEmail ?? "—")</td>
                                <td class="px-6 py-3 text-sm text-gray-600 truncate max-w-[150px]">@(log.CompanyName ?? "—")</td>
                                <td class="px-6 py-3">
                                    @if (!string.IsNullOrEmpty(log.Role))
                                    {
                                        var displayRole = (log.Role == "HR" || log.Role == "Hr") ? "Human Resource Manager" : log.Role;
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-lg text-xs font-semibold bg-blue-100 text-blue-700">@displayRole</span>
                                    }
                                    else
                                    {
                                        <span class="text-sm text-gray-400">—</span>
                                    }
                                </td>
                                <td class="px-6 py-3 text-sm text-gray-600 truncate max-w-[250px]">@(log.Details ?? "—")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="px-6 py-12 text-center">
                                <div class="flex flex-col items-center">
                                    <svg class="w-12 h-12 text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                    </svg>
                                    <p class="text-gray-500 font-medium">No audit log entries found</p>
                                    <p class="text-gray-400 text-sm mt-1">Try adjusting your filters</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div class="px-6 py-4 border-t border-gray-100 bg-gray-50/50">
                <div class="flex flex-col sm:flex-row items-center justify-between gap-3">
                    <div class="text-sm text-gray-600">
                        Showing <span class="font-semibold">@(((Model.CurrentPage - 1) * Model.PageSize) + 1)</span> to
                        <span class="font-semibold">@Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCount)</span> of
                        <span class="font-semibold">@Model.TotalCount</span> events
                    </div>
                    <nav class="flex items-center gap-1">
                        @if (Model.CurrentPage > 1)
                        {
                            <a href="/AuditLogs?CurrentPage=@(Model.CurrentPage-1)&PageSize=@Model.PageSize&Search=@Model.Search&Action=@Model.Action&FromDate=@Model.FromDate&ToDate=@Model.ToDate"
                               class="px-3 py-1.5 text-sm font-medium text-gray-700 hover:bg-gray-100 rounded-lg border border-gray-200 transition-all">&#8249;</a>
                        }
                        @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                        {
                            var pageNum = i;
                            <a href="/AuditLogs?CurrentPage=@pageNum&PageSize=@Model.PageSize&Search=@Model.Search&Action=@Model.Action&FromDate=@Model.FromDate&ToDate=@Model.ToDate"
                               class="px-3 py-1.5 text-sm font-medium rounded-lg border transition-all @(pageNum == Model.CurrentPage ? "bg-blue-600 text-white border-blue-600 shadow-sm" : "text-gray-700 hover:bg-gray-100 border-gray-200")">@pageNum</a>
                        }
                        @if (Model.CurrentPage < Model.TotalPages)
                        {
                            <a href="/AuditLogs?CurrentPage=@(Model.CurrentPage+1)&PageSize=@Model.PageSize&Search=@Model.Search&Action=@Model.Action&FromDate=@Model.FromDate&ToDate=@Model.ToDate"
                               class="px-3 py-1.5 text-sm font-medium text-gray-700 hover:bg-gray-100 rounded-lg border border-gray-200 transition-all">&#8250;</a>
                        }
                    </nav>
                </div>
            </div>
        }
    </div>
</div>
