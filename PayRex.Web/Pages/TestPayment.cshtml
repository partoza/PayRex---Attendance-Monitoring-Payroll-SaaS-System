@page
@model PayRex.Web.Pages.TestPaymentModel
@{
    Layout = null;
    ViewData["Title"] = "Test Payment - PayRex";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@@1.11.1/font/bootstrap-icons.css" />
    <link rel="icon" type="image/x-icon" href="~/images/icon/payrexiconofficial.ico" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>

<body class="min-h-screen flex flex-col justify-center items-center py-10 px-4" style="font-family:'Inter',ui-sans-serif,system-ui,-apple-system,sans-serif">
    <style>
        body { background: white; }
        body::before {
            content: ''; position: fixed;
            top:0; left:0; width:100%; height:100%;
            background: url('/images/loginbg.png') center/cover no-repeat;
            opacity:0.2; z-index: -1;
        }
    </style>

    <div class="w-full max-w-5xl mx-auto">

        <!-- Header -->
        <div class="flex flex-col items-center mb-8">
            <a href="/">
                <img src="/images/logo.png" alt="PayRex Logo" class="h-14 w-auto mb-3" />
            </a>
            <h1 class="text-3xl md:text-4xl font-semibold text-gray-800 mb-2">Test Payment</h1>
            <p class="text-gray-500 text-base max-w-md text-center">Complete your payment in test mode — no real charges</p>
        </div>

        <!-- Main Card -->
        <div class="bg-white rounded-2xl shadow-md w-full max-w-2xl mx-auto overflow-hidden">

            <!-- Amount Header -->
            <div class="px-6 py-5 border-b border-gray-100" style="background: linear-gradient(135deg, #eff6ff 0%, #f0f9ff 100%)">
                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-xl bg-blue-600 flex items-center justify-center text-white shadow-sm flex-shrink-0">
                            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path d="M4 4a2 2 0 00-2 2v1h16V6a2 2 0 00-2-2H4z" /><path fill-rule="evenodd" d="M18 9H2v5a2 2 0 002 2h12a2 2 0 002-2V9zM4 13a1 1 0 011-1h1a1 1 0 110 2H5a1 1 0 01-1-1zm5-1a1 1 0 100 2h1a1 1 0 100-2H9z" clip-rule="evenodd" /></svg>
                        </div>
                        <div>
                            <h2 class="text-lg font-bold text-gray-900">₱@Model.Amount.ToString("N2")</h2>
                            <p class="text-sm text-gray-500">@Model.Description</p>
                        </div>
                    </div>
                    <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-bold uppercase tracking-wider text-yellow-700 bg-yellow-100 rounded-full">
                        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" /></svg>
                        Test Mode
                    </span>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="mx-6 mt-4 bg-red-50 border border-red-200 rounded-xl p-3 flex items-center gap-2">
                    <svg class="w-4 h-4 text-red-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd" /></svg>
                    <p class="text-sm text-red-700">@Model.ErrorMessage</p>
                </div>
            }

            <div class="p-6 md:p-8 space-y-6">

                <!-- Payment Method Selection -->
                <div>
                    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Select Payment Method</p>

                    <form method="post" id="paymentForm">
                        <input type="hidden" name="paymentId" value="@Model.PaymentId" />
                        <input type="hidden" name="amount" value="@Model.Amount" />
                        <input type="hidden" name="description" value="@Model.Description" />
                        <input type="hidden" name="paymentMethod" id="selectedMethod" value="gcash" />

                        <div class="grid grid-cols-2 sm:grid-cols-4 gap-2" id="paymentMethods">
                            <!-- GCash -->
                            <label class="payment-method-option flex items-center justify-center gap-1.5 p-3 rounded-lg border-2 border-blue-500 bg-blue-50 cursor-pointer transition-all hover:shadow-md" data-method="gcash">
                                <input type="radio" name="methodRadio" value="gcash" checked class="sr-only" />
                                <img src="https://logodix.com/logo/2206207.png" alt="GCash" class="h-5 w-auto object-contain" />
                                <span class="text-xs font-medium text-gray-700">GCash</span>
                            </label>

                            <!-- GrabPay -->
                            <label class="payment-method-option flex items-center justify-center gap-1.5 p-3 rounded-lg border-2 border-gray-200 bg-white cursor-pointer transition-all hover:shadow-md" data-method="grab_pay">
                                <input type="radio" name="methodRadio" value="grab_pay" class="sr-only" />
                                <img src="https://logowik.com/content/uploads/images/grabpay-wallet8796.logowik.com.webp" alt="GrabPay" class="h-5 w-auto object-contain" />
                                <span class="text-xs font-medium text-gray-700">GrabPay</span>
                            </label>

                            <!-- Maya -->
                            <label class="payment-method-option flex items-center justify-center gap-1.5 p-3 rounded-lg border-2 border-gray-200 bg-white cursor-pointer transition-all hover:shadow-md" data-method="maya">
                                <input type="radio" name="methodRadio" value="maya" class="sr-only" />
                                <img src="https://cdn.manilastandard.net/wp-content/uploads/2025/02/maya-logo-black.png" alt="Maya" class="h-5 w-auto object-contain" />
                                <span class="text-xs font-medium text-gray-700">Maya</span>
                            </label>

                            <!-- Card -->
                            <label class="payment-method-option flex items-center justify-center gap-1.5 p-3 rounded-lg border-2 border-gray-200 bg-white cursor-pointer transition-all hover:shadow-md" data-method="card">
                                <input type="radio" name="methodRadio" value="card" class="sr-only" />
                                <img src="https://www.paymentscardsandmobile.com/wp-content/uploads/2020/05/visa-mastercard.png" alt="Visa/Mastercard" class="h-5 w-auto object-contain" />
                                <span class="text-xs font-medium text-gray-700">Card</span>
                            </label>
                        </div>

                        <!-- Wallet Phone Input (shown for e-wallet methods) -->
                        <div class="mt-5" id="walletSection">
                            <label class="block text-sm font-medium text-gray-700 mb-2" id="walletLabel">GCash Number</label>
                            <div class="flex items-center border border-gray-300 rounded-xl overflow-hidden focus-within:ring-2 focus-within:ring-blue-500 focus-within:border-blue-500">
                                <span class="px-4 py-3 bg-gray-50 text-gray-500 text-sm font-medium border-r border-gray-300">+63</span>
                                <input type="text" id="phoneInput" placeholder="9XX XXX XXXX" maxlength="13"
                                       class="flex-1 px-4 py-3 text-sm text-gray-900 focus:outline-none" />
                            </div>
                            <p class="text-xs text-gray-400 mt-1.5">Test mode — enter any number</p>
                        </div>

                        <!-- Card Inputs (hidden by default) -->
                        <div class="mt-5 hidden" id="cardSection">
                            <div class="space-y-3">
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Card Number</label>
                                    <input type="text" placeholder="4242 4242 4242 4242" maxlength="19"
                                           class="w-full px-4 py-3 text-sm text-gray-900 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                                </div>
                                <div class="grid grid-cols-2 gap-3">
                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-1.5">Expiry</label>
                                        <input type="text" placeholder="MM/YY" maxlength="5"
                                               class="w-full px-4 py-3 text-sm text-gray-900 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                                    </div>
                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-1.5">CVC</label>
                                        <input type="text" placeholder="123" maxlength="4"
                                               class="w-full px-4 py-3 text-sm text-gray-900 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                                    </div>
                                </div>
                            </div>
                            <p class="text-xs text-gray-400 mt-1.5">Test mode — enter any card details</p>
                        </div>

                        <!-- Pay Button -->
                        <button type="submit" id="payBtn"
                                class="w-full mt-6 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-xl px-4 py-4 text-base transition-all flex items-center justify-center gap-2 shadow-md hover:shadow-lg transform hover:-translate-y-0.5 active:translate-y-0">
                            <span id="payBtnText">Pay ₱@Model.Amount.ToString("N2") with GCash</span>
                        </button>
                    </form>
                </div>

                <!-- Security Notice -->
                <div class="flex items-start gap-3 bg-blue-50 rounded-xl p-4 border border-blue-100">
                    <svg class="w-5 h-5 text-blue-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                    <div>
                        <p class="text-sm font-medium text-blue-800">PayRex Test Environment</p>
                        <p class="text-xs text-blue-600 mt-0.5">No real charges will be made. This is a sandbox payment simulation.</p>
                    </div>
                </div>

                <!-- Back -->
                <p class="text-center">
                    <a href="/Billing" class="text-sm text-gray-400 hover:text-gray-600 transition-colors inline-flex items-center gap-1">
                        <i class="bi bi-arrow-left"></i> Back to Billing
                    </a>
                </p>
            </div>
        </div>

        <!-- Footer -->
        <p class="text-center text-gray-400 text-xs mt-6 flex items-center justify-center gap-2">
            <i class="bi bi-shield-check text-gray-300"></i>
            PayRex © 2025 · Secure test checkout
        </p>
    </div>

    <!-- Processing Overlay -->
    <div id="processingOverlay" class="fixed inset-0 bg-black/50 backdrop-blur-sm flex items-center justify-center z-50 hidden">
        <div class="bg-white rounded-2xl p-8 shadow-2xl max-w-sm w-full mx-4 text-center">
            <div class="w-16 h-16 border-4 border-blue-200 border-t-blue-600 rounded-full animate-spin mx-auto mb-4"></div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">Processing Payment</h3>
            <p class="text-sm text-gray-500" id="processingText">Connecting to GCash...</p>
            <div class="mt-4 bg-gray-100 rounded-full h-2 overflow-hidden">
                <div class="bg-blue-600 h-full rounded-full animate-progress-bar"></div>
            </div>
        </div>
    </div>

    <style>
        @@keyframes progress-bar {
            0% { width: 0%; }
            50% { width: 70%; }
            90% { width: 90%; }
            100% { width: 100%; }
        }
        .animate-progress-bar {
            animation: progress-bar 3s ease-in-out forwards;
        }
    </style>

    <script>
        (function () {
            var methods = document.querySelectorAll('.payment-method-option');
            var selectedInput = document.getElementById('selectedMethod');
            var walletSection = document.getElementById('walletSection');
            var cardSection = document.getElementById('cardSection');
            var walletLabel = document.getElementById('walletLabel');
            var payBtn = document.getElementById('payBtn');
            var payBtnText = document.getElementById('payBtnText');
            var form = document.getElementById('paymentForm');
            var overlay = document.getElementById('processingOverlay');
            var processingText = document.getElementById('processingText');
            var amount = '@Model.Amount.ToString("N2")';

            var methodNames = {
                'gcash': 'GCash',
                'grab_pay': 'GrabPay',
                'maya': 'Maya',
                'card': 'Card'
            };

            var walletLabels = {
                'gcash': 'GCash Number',
                'grab_pay': 'GrabPay Number',
                'maya': 'Maya Number'
            };

            function selectMethod(method) {
                selectedInput.value = method;

                methods.forEach(function (el) {
                    var m = el.dataset.method;
                    if (m === method) {
                        el.classList.remove('border-gray-200', 'bg-white');
                        el.classList.add('border-blue-500', 'bg-blue-50');
                    } else {
                        el.classList.remove('border-blue-500', 'bg-blue-50');
                        el.classList.add('border-gray-200', 'bg-white');
                    }
                });

                if (method === 'card') {
                    walletSection.classList.add('hidden');
                    cardSection.classList.remove('hidden');
                } else {
                    walletSection.classList.remove('hidden');
                    cardSection.classList.add('hidden');
                    walletLabel.textContent = walletLabels[method] || 'Phone Number';
                }

                payBtnText.textContent = 'Pay \u20b1' + amount + ' with ' + methodNames[method];
            }

            methods.forEach(function (el) {
                el.addEventListener('click', function () {
                    selectMethod(el.dataset.method);
                });
            });

            form.addEventListener('submit', function (e) {
                payBtn.disabled = true;
                payBtn.classList.add('opacity-70', 'cursor-not-allowed');
                overlay.classList.remove('hidden');

                var name = methodNames[selectedInput.value] || 'payment provider';
                processingText.textContent = 'Connecting to ' + name + '...';

                setTimeout(function () {
                    processingText.textContent = 'Verifying payment...';
                }, 1000);

                setTimeout(function () {
                    processingText.textContent = 'Confirming transaction...';
                }, 2000);
            });

            // Format phone input
            var phoneInput = document.getElementById('phoneInput');
            if (phoneInput) {
                phoneInput.addEventListener('input', function () {
                    var val = this.value.replace(/\D/g, '');
                    if (val.length > 10) val = val.substring(0, 10);
                    if (val.length > 3 && val.length <= 6) {
                        val = val.substring(0, 3) + ' ' + val.substring(3);
                    } else if (val.length > 6) {
                        val = val.substring(0, 3) + ' ' + val.substring(3, 6) + ' ' + val.substring(6);
                    }
                    this.value = val;
                });
            }
        })();
    </script>
</body>
</html>
