@page
@model PayRex.Web.Pages.EmployeesModel
@{
    ViewData["Title"] = "Employee Management";
}

<div class="max-w-8xl mx-auto px-4 py-6 sm:px-6 lg:px-8 space-y-6">
    <!-- Welcome Header (Dashboard Style) -->
    <div class="bg-gradient-to-r from-blue-50 via-white to-blue-50 rounded-2xl border border-blue-100 shadow-sm overflow-hidden relative">
        <div class="absolute top-0 right-0 -mt-16 -mr-16 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
        <div class="absolute bottom-0 left-0 -mb-16 -ml-16 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
        <div class="px-6 py-8 sm:px-10 relative z-10">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <div>
                    <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight">Employee Management</h1>
                    <p class="mt-2 text-gray-600">Manage employee details, compensation rates, and employment status</p>
                </div>
                <div class="flex items-center gap-3">
                    <span class="inline-flex items-center px-4 py-2 rounded-xl text-sm font-semibold bg-blue-100 text-blue-700">
                        <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z" />
                        </svg>
                        @Model.Employees.Count Total Employees
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters Card -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 bg-gradient-to-r from-gray-50 to-white">
            <h2 class="text-base font-semibold text-gray-900 flex items-center">
                <svg class="w-5 h-5 mr-2 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M3 3a1 1 0 011-1h12a1 1 0 011 1v3a1 1 0 01-.293.707L12 11.414V15a1 1 0 01-.293.707l-2 2A1 1 0 018 17v-5.586L3.293 6.707A1 1 0 013 6V3z" clip-rule="evenodd" />
                </svg>
                Filters & Search
            </h2>
        </div>
        <div class="p-4 sm:p-6">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                <!-- Search -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Search</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <svg class="w-4 h-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
                            </svg>
                        </div>
                        <input type="text" id="searchInput" onkeyup="filterTable()"
                               class="w-full pl-10 pr-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all" 
                               placeholder="Search employees...">
                    </div>
                </div>
                <!-- Position Filter -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Position</label>
                    <select id="positionFilter" onchange="filterTable()" 
                            class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all bg-white">
                        <option value="">All Positions</option>
                        @foreach(var pos in Model.Employees.Select(e => e.Position).Where(p => !string.IsNullOrWhiteSpace(p)).Distinct().OrderBy(p => p))
                        {
                            <option value="@pos">@pos</option>
                        }
                    </select>
                </div>
                <!-- Status Filter -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Status</label>
                    <select id="statusFilter" onchange="filterTable()" 
                            class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all bg-white">
                        <option value="">All Statuses</option>
                        @foreach(var st in Model.Employees.Select(e => e.EmploymentStatus).Where(s => !string.IsNullOrWhiteSpace(s)).Distinct().OrderBy(s => s))
                        {
                            <option value="@st">@st</option>
                        }
                    </select>
                </div>
                <!-- Add Employee Button (moved here) -->
                <div class="flex items-end">
                    <a href="/AddEmployee" class="w-full inline-flex items-center justify-center px-4 py-2.5 text-sm font-medium text-white bg-blue-600 rounded-xl hover:bg-blue-700 transition-colors shadow-sm border border-transparent">
                        <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
                        </svg>
                        Add Employee
                    </a>
                </div>
            </div>
            <div class="flex items-center gap-3 mt-4">
                <button onclick="clearFilters()" class="inline-flex items-center px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-xl hover:bg-gray-200 transition-colors border border-gray-200">
                    <svg class="w-4 h-4 mr-1.5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                    Clear Filters
                </button>
            </div>
        </div>
    </div>

    <!-- Employee List Card -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 bg-gradient-to-r from-gray-50 to-white">
            <div class="flex items-center justify-between">
                <div>
                    <h2 class="text-base font-semibold text-gray-900">All Employees</h2>
                    <p class="text-sm text-gray-500 mt-0.5">Showing @Model.Employees.Count employees</p>
                </div>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full" id="employeeTable">
                <thead class="bg-gray-50/80">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Employee</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Position & Dept</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Salary Rate</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Pay Type</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
                        <th class="px-6 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var emp in Model.Employees)
                    {
                        <tr class="hover:bg-gray-50/50 transition-colors">
                            <!-- Employee -->
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center">
                                    <div class="w-9 h-9 rounded-full bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center mr-3 shadow-sm">
                                        <span class="text-xs font-bold text-white">@emp.Name.Substring(0, 1)</span>
                                    </div>
                                    <div>
                                        <div class="text-sm font-semibold text-gray-900 search-name">@emp.Name</div>
                                        <div class="text-xs text-gray-500">ID: @emp.Id</div>
                                    </div>
                                </div>
                            </td>
                            <!-- Position & Dept -->
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="text-sm font-medium text-gray-900 search-position">@emp.Position</div>
                                <div class="text-xs text-gray-500">@emp.Department</div>
                            </td>
                            <!-- Salary Rate -->
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="text-sm font-semibold text-gray-900">₱@emp.BasicRate.ToString("N2")</span>
                            </td>
                            <!-- Pay Type -->
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="text-sm font-semibold text-gray-900">@emp.PayType</span>
                            </td>
                            <!-- Status -->
                            <td class="px-6 py-4 whitespace-nowrap">
                                @{
                                    var statusClass = emp.EmploymentStatus == "Active" ? "text-green-700" : (emp.EmploymentStatus == "Resigned" || emp.EmploymentStatus == "Terminated" ? "text-red-700" : "text-yellow-700");
                                }
                                <span class="text-sm font-semibold @statusClass search-status">@emp.EmploymentStatus</span>
                            </td>
                            <!-- Actions -->
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center justify-center gap-1">
                                    <button onclick="openModal(@emp.EmployeeNumber)" 
                                            class="p-2 text-gray-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-all"
                                            title="View Details">
                                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                            <path d="M10 12a2 2 0 100-4 2 2 0 000 4z" />
                                            <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd" />
                                        </svg>
                                    </button>
                                    <div class="flex items-center gap-2">
                                        <button onclick="openModal(@emp.EmployeeNumber)" class="text-blue-600 hover:text-blue-800 text-sm">View</button>
                                        <a href="/EditEmployee?employeeNumber=@emp.EmployeeNumber" class="text-blue-600 hover:text-blue-800 text-sm">Edit</a>
                                        @{
                                            var isActive = (emp.EmploymentStatus == "Active");
                                        }
                                        @if (isActive)
                                        {
                                            <button onclick="deactivateEmployee(@emp.EmployeeNumber)" class="text-red-700 bg-red-50/60 px-2 py-1 rounded text-sm">Inactive</button>
                                        }
                                        else
                                        {
                                            <span class="text-red-700 bg-red-50/40 px-2 py-1 rounded text-sm opacity-70 cursor-not-allowed">Inactive</span>
                                        }
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Employee Details Modal (Updated styling) -->
<div id="viewModal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
        <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" aria-hidden="true" onclick="closeModal()"></div>
        <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
        <div class="inline-block align-bottom bg-white rounded-2xl text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full">
            <div class="bg-gradient-to-r from-blue-50 to-white px-6 py-4 border-b border-gray-100">
                <h3 class="text-lg font-bold text-gray-900" id="modal-title">Employee Details</h3>
            </div>
            <div class="bg-white px-6 pt-5 pb-4 sm:p-6 sm:pb-4">
                <div class="space-y-5">
                    <!-- Employee header with avatar -->
                    <div class="flex items-center gap-4">
                        <div class="w-14 h-14 rounded-full bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center shadow-md">
                            <span class="text-lg font-bold text-white" id="modalInitials">EM</span>
                        </div>
                        <div>
                            <h4 class="text-lg font-bold text-gray-900" id="modalName">Name</h4>
                            <p class="text-sm text-gray-500" id="modalPosition">Position</p>
                        </div>
                    </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div class="bg-gray-50 rounded-xl p-3">
                                <p class="text-xs text-gray-500 mb-1">Email</p>
                                <p class="text-sm font-semibold text-gray-900" id="modalEmail">name@company.com</p>
                            </div>
                            <div class="bg-gray-50 rounded-xl p-3">
                                <p class="text-xs text-gray-500 mb-1">Contact</p>
                                <p class="text-sm font-semibold text-gray-900" id="modalContact">+63 9XX XXX XXXX</p>
                            </div>
                            <div class="bg-gray-50 rounded-xl p-3">
                                <p class="text-xs text-gray-500 mb-1">Civil Status</p>
                                <p class="text-sm font-semibold text-gray-900" id="modalCivil">Single</p>
                            </div>
                            <div class="bg-gray-50 rounded-xl p-3">
                                <p class="text-xs text-gray-500 mb-1">Age</p>
                                <p class="text-sm font-semibold text-gray-900" id="modalAge">30</p>
                            </div>
                            <div class="bg-gray-50 rounded-xl p-3">
                                <p class="text-xs text-gray-500 mb-1">Start Date</p>
                                <p class="text-sm font-semibold text-gray-900" id="modalStart">2024-01-01</p>
                            </div>
                            <div class="bg-gray-50 rounded-xl p-3">
                                <p class="text-xs text-gray-500 mb-1">Salary Rate Status</p>
                                <p class="text-sm font-semibold text-gray-900" id="modalSalaryStatus">₱0.00 / Monthly</p>
                            </div>
                        </div>

                    <!-- Details grid -->
                    <div class="grid grid-cols-2 gap-4">
                        <div class="bg-gray-50 rounded-xl p-3">
                            <p class="text-xs text-gray-500 mb-1">Employment</p>
                            <p class="text-sm font-semibold text-gray-900" id="modalStatus">Regular</p>
                        </div>
                        <div class="bg-gray-50 rounded-xl p-3">
                            <p class="text-xs text-gray-500 mb-1">Department</p>
                            <p class="text-sm font-semibold text-gray-900" id="modalDept">Engineering</p>
                        </div>
                    </div>

                    <!-- Compensation card -->
                    <div class="bg-blue-50 rounded-xl p-4">
                        <p class="text-xs text-blue-600 font-medium mb-1">Basic Rate</p>
                        <div class="flex items-center justify-between">
                            <p class="text-2xl font-bold text-blue-900" id="modalRate">₱0.00</p>
                            <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-semibold bg-white text-blue-700 border border-blue-100" id="modalPayType">
                                Monthly
                            </span>
                                <div class="mt-3 grid grid-cols-2 gap-2">
                                    <div class="bg-white rounded-xl p-2">
                                        <p class="text-xs text-gray-500">TIN</p>
                                        <p class="text-sm font-medium" id="modalTIN">-</p>
                                    </div>
                                    <div class="bg-white rounded-xl p-2">
                                        <p class="text-xs text-gray-500">SSS</p>
                                        <p class="text-sm font-medium" id="modalSSS">-</p>
                                    </div>
                                    <div class="bg-white rounded-xl p-2">
                                        <p class="text-xs text-gray-500">PhilHealth</p>
                                        <p class="text-sm font-medium" id="modalPhil">-</p>
                                    </div>
                                    <div class="bg-white rounded-xl p-2">
                                        <p class="text-xs text-gray-500">Pag-IBIG</p>
                                        <p class="text-sm font-medium" id="modalPag">-</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="bg-gray-50 px-6 py-4 flex flex-row-reverse">
                <button type="button" class="w-full inline-flex justify-center rounded-xl border border-transparent shadow-sm px-4 py-2 bg-blue-600 text-base font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 sm:ml-3 sm:w-auto sm:text-sm" onclick="closeModal()">
                    Close
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    // Keep your exact existing filter function
    function filterTable() {
        var input = document.getElementById("searchInput");
        var filter = input.value.toUpperCase();
        var positionFilter = document.getElementById("positionFilter").value.toUpperCase();
        var statusFilter = document.getElementById("statusFilter").value.toUpperCase();
        var table = document.getElementById("employeeTable");
        var tr = table.getElementsByTagName("tr");

        for (var i = 1; i < tr.length; i++) {
            var nameTd = tr[i].querySelector(".search-name");
            var posTd = tr[i].querySelector(".search-position");
            var statusTd = tr[i].querySelector(".search-status");

            if (nameTd && posTd && statusTd) {
                var nameText = nameTd.textContent || nameTd.innerText;
                var posText = posTd.textContent || posTd.innerText;
                var statusText = statusTd.textContent || statusTd.innerText;

                var matchesSearch = nameText.toUpperCase().indexOf(filter) > -1;
                var matchesPos = positionFilter === "" || posText.toUpperCase().indexOf(positionFilter) > -1;
                var matchesStatus = statusFilter === "" || statusText.toUpperCase().indexOf(statusFilter) > -1;

                if (matchesSearch && matchesPos && matchesStatus) {
                    tr[i].style.display = "";
                } else {
                    tr[i].style.display = "none";
                }
            }
        }
    }

    // Clear filters function
    function clearFilters() {
        document.getElementById('searchInput').value = '';
        document.getElementById('positionFilter').value = '';
        document.getElementById('statusFilter').value = '';
        filterTable();
    }

    // Keep your exact existing modal function
    function openModal(name, position, dept, status, rate, payType) {
        // Set initials
        document.getElementById('modalInitials').textContent = (name || '').substring(0, 2).toUpperCase();
        
        // Set basic info
        document.getElementById('modalName').textContent = name;
        document.getElementById('modalPosition').textContent = position;
        document.getElementById('modalDept').textContent = dept;
        document.getElementById('modalStatus').textContent = status;
        document.getElementById('modalRate').textContent = "₱" + parseFloat(rate).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2});
        document.getElementById('modalPayType').textContent = payType;
        
        document.getElementById('viewModal').classList.remove('hidden');
    }

    function closeModal() {
        document.getElementById('viewModal').classList.add('hidden');
    }

    // Fetch details for a single employee from internal endpoint and populate modal
    async function openModal(employeeNumber) {
        try {
            const res = await fetch(`/_internal/employees/${employeeNumber}`, { credentials: 'include' });
            if (!res.ok) throw new Error('Failed to load employee');
            const data = await res.json();
            populateModal(data);
        } catch (err) {
            console.error('Failed to open modal:', err);
            alert('Failed to load employee details');
        }
    }

    function populateModal(data) {
        document.getElementById('modalInitials').textContent = (data.name || '').substring(0, 2).toUpperCase();
        document.getElementById('modalName').textContent = data.name || '';
        document.getElementById('modalPosition').textContent = data.position || '';
        document.getElementById('modalDept').textContent = data.department || '';
        document.getElementById('modalStatus').textContent = data.employmentStatus || '';
        document.getElementById('modalRate').textContent = '₱' + (data.basicRate || 0).toLocaleString('en-US', { minimumFractionDigits: 2 });
        document.getElementById('modalPayType').textContent = data.payType || '';
        document.getElementById('modalEmail').textContent = data.email || '';
        document.getElementById('modalContact').textContent = data.contactNumber || '';
        document.getElementById('modalCivil').textContent = data.civilStatus || '';
        document.getElementById('modalStart').textContent = data.dateHired ? new Date(data.dateHired).toLocaleDateString() : '';
        const birth = data.birthdate ? new Date(data.birthdate) : null;
        if (birth) {
            const age = Math.floor((new Date() - birth) / (365.25 * 24 * 3600 * 1000));
            document.getElementById('modalAge').textContent = age;
        }
        document.getElementById('modalTIN').textContent = data.tin || '-';
        document.getElementById('modalSSS').textContent = data.sss || '-';
        document.getElementById('modalPhil').textContent = data.philHealth || '-';
        document.getElementById('modalPag').textContent = data.pagIbig || '-';

        // Profile image
        const imgContainer = document.getElementById('modalInitials').parentElement.parentElement.querySelector('div.w-14');
        if (data.profileImageUrl) {
            imgContainer.innerHTML = `<img src="${data.profileImageUrl}" class="w-14 h-14 rounded-full object-cover" alt="Profile">`;
        } else {
            imgContainer.innerHTML = `<div class="w-14 h-14 rounded-full bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center shadow-md"><span class="text-lg font-bold text-white">${(data.name||'').substring(0,2).toUpperCase()}</span></div>`;
        }

        document.getElementById('viewModal').classList.remove('hidden');
    }

    async function deactivateEmployee(employeeNumber) {
        if (!confirm('Mark this employee as inactive?')) return;
        try {
            const res = await fetch(`/_internal/employees/${employeeNumber}/deactivate`, { method: 'POST', credentials: 'include' });
            if (!res.ok) throw new Error('Failed');
            location.reload();
        } catch (e) { alert('Failed to deactivate employee'); }
    }
</script>