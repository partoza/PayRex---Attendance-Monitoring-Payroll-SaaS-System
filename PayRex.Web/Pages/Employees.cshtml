@page
@model PayRex.Web.Pages.EmployeesModel
@{
    ViewData["Title"] = "Employee Management";
}

<div class="max-w-8xl mx-auto px-4 py-6 sm:px-6 lg:px-8 space-y-6">
    <!-- Header -->
     <div class="bg-gradient-to-r from-blue-50 via-white to-blue-50 rounded-2xl border border-blue-100 shadow-sm relative overflow-hidden">
        <div class="absolute top-0 right-0 -mt-16 -mr-16 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
        <div class="px-8 py-10 relative z-10">
            <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Employee Management</h1>
            <p class="mt-2 text-gray-600 text-lg">Manage employee details, compensation rates, and employment status.</p>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="flex flex-col sm:flex-row justify-between gap-4 bg-white p-4 rounded-2xl border border-gray-100 shadow-sm">
        <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
            <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <svg class="h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                         <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
                    </svg>
                </div>
                 <input type="text" id="searchInput" 
                       class="pl-10 block w-full sm:w-64 rounded-xl border-gray-300 shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm" 
                       placeholder="Search employees..." onkeyup="filterTable()">
            </div>
            
            <select id="positionFilter" onchange="filterTable()" 
                    class="block w-full sm:w-48 rounded-xl border-gray-300 shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
                <option value="">All Positions</option>
                <option value="Software Engineer">Software Engineer</option>
                <option value="HR Manager">HR Manager</option>
                <option value="Accountant">Accountant</option>
                <option value="Sales Executive">Sales Executive</option>
            </select>

             <select id="statusFilter" onchange="filterTable()" 
                    class="block w-full sm:w-48 rounded-xl border-gray-300 shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
                <option value="">All Statuses</option>
                <option value="Regular">Regular</option>
                <option value="Probationary">Probationary</option>
            </select>
        </div>
        
         <a href="/AddEmployee" class="inline-flex items-center justify-center px-4 py-2 border border-transparent text-sm font-medium rounded-xl text-white bg-blue-600 hover:bg-blue-700 shadow-sm transition-colors">
            <svg class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
            </svg>
            Add Employee
        </a>
    </div>

    <!-- Employee List -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200" id="employeeTable">
                <thead class="bg-gray-50">
                    <tr>
                         <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Employee</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Position & Dept</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Salary Rate</th>
                         <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Pay Type</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                        <th scope="col" class="relative px-6 py-3"><span class="sr-only">Details</span></th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    @foreach (var emp in Model.Employees)
                    {
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center">
                                     <div class="h-10 w-10 rounded-full bg-blue-100 flex items-center justify-center text-blue-700 font-bold text-sm">
                                        @emp.Name.Substring(0, 1)
                                    </div>
                                    <div class="ml-4">
                                        <div class="text-sm font-medium text-gray-900 search-name">@emp.Name</div>
                                        <div class="text-sm text-gray-500">ID: @emp.Id</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="text-sm text-gray-900 search-position">@emp.Position</div>
                                <div class="text-sm text-gray-500">@emp.Department</div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                                ₱@emp.BasicRate.ToString("N2")
                            </td>
                             <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                @emp.PayType
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="px-2.5 py-0.5 rounded-full text-xs font-medium @(emp.EmploymentStatus == "Regular" ? "bg-green-100 text-green-800" : "bg-yellow-100 text-yellow-800") search-status">
                                    @emp.EmploymentStatus
                                </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                <button onclick="openModal('@emp.Name', '@emp.Position', '@emp.Department', '@emp.EmploymentStatus', '@emp.BasicRate', '@emp.PayType')" class="text-blue-600 hover:text-blue-900">Details</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Employee Details Modal -->
<div id="viewModal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
  <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
    <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" aria-hidden="true" onclick="closeModal()"></div>
    <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
    <div class="inline-block align-bottom bg-white rounded-2xl text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full">
      <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
        <div class="sm:flex sm:items-start">
          <div class="mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full bg-blue-100 sm:mx-0 sm:h-10 sm:w-10">
            <svg class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0c0 .884-.896 1.79-2.296 2.062a4.996 4.996 0 01-5.32 0A3.996 3.996 0 014 8h16c.773 0 1.5.176 2.13.483.565.275 1.08.647 1.505 1.08" />
            </svg>
          </div>
          <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left w-full">
            <h3 class="text-lg leading-6 font-medium text-gray-900" id="modal-title">Employee Compensation</h3>
            <div class="mt-4 space-y-4">
               <div>
                   <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide">Employee Information</label>
                   <div class="mt-2 bg-gray-50 rounded-lg p-3">
                       <p class="text-sm font-bold text-gray-900" id="modalName">Name</p>
                       <p class="text-sm text-gray-500" id="modalPosition">Position</p>
                   </div>
               </div>
               
               <div class="grid grid-cols-2 gap-4">
                    <div>
                       <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide">Employment</label>
                       <p class="mt-1 text-sm font-medium text-gray-900" id="modalStatus">Regular</p>
                       <p class="text-xs text-gray-500">Status</p>
                   </div>
                   <div>
                       <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide">Department</label>
                       <p class="mt-1 text-sm font-medium text-gray-900" id="modalDept">Engineering</p>
                   </div>
               </div>

                <div class="border-t border-gray-200 pt-4">
                    <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">Compensation Details</label>
                    <div class="flex justify-between items-center bg-blue-50 p-3 rounded-lg">
                        <div>
                            <p class="text-xs text-blue-600 font-medium">Basic Rate</p>
                            <p class="text-lg font-bold text-blue-900" id="modalRate">₱0.00</p>
                        </div>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-white text-blue-800 border border-blue-100 shadow-sm" id="modalPayType">
                            Monthly
                        </span>
                    </div>
                </div>
            </div>
          </div>
        </div>
      </div>
      <div class="bg-gray-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse">
        <button type="button" class="w-full inline-flex justify-center rounded-xl border border-transparent shadow-sm px-4 py-2 bg-blue-600 text-base font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 sm:ml-3 sm:w-auto sm:text-sm" onclick="closeModal()">
          Close
        </button>
      </div>
    </div>
  </div>
</div>

<script>
    function filterTable() {
        var input = document.getElementById("searchInput");
        var filter = input.value.toUpperCase();
        var positionFilter = document.getElementById("positionFilter").value.toUpperCase();
        var statusFilter = document.getElementById("statusFilter").value.toUpperCase();
        var table = document.getElementById("employeeTable");
        var tr = table.getElementsByTagName("tr");

        for (var i = 1; i < tr.length; i++) {
            var nameTd = tr[i].querySelector(".search-name");
            var posTd = tr[i].querySelector(".search-position");
            var statusTd = tr[i].querySelector(".search-status");

            if (nameTd && posTd && statusTd) {
                var nameText = nameTd.textContent || nameTd.innerText;
                var posText = posTd.textContent || posTd.innerText;
                var statusText = statusTd.textContent || statusTd.innerText;

                var matchesSearch = nameText.toUpperCase().indexOf(filter) > -1;
                var matchesPos = positionFilter === "" || posText.toUpperCase().indexOf(positionFilter) > -1;
                var matchesStatus = statusFilter === "" || statusText.toUpperCase().indexOf(statusFilter) > -1;

                if (matchesSearch && matchesPos && matchesStatus) {
                    tr[i].style.display = "";
                } else {
                    tr[i].style.display = "none";
                }
            }
        }
    }

    function openModal(name, position, dept, status, rate, payType) {
        document.getElementById('modalName').textContent = name;
        document.getElementById('modalPosition').textContent = position;
        document.getElementById('modalDept').textContent = dept;
        document.getElementById('modalStatus').textContent = status;
        document.getElementById('modalRate').textContent = "₱" + parseFloat(rate).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2});
        document.getElementById('modalPayType').textContent = payType;
        
        document.getElementById('viewModal').classList.remove('hidden');
    }

    function closeModal() {
        document.getElementById('viewModal').classList.add('hidden');
    }
</script>
