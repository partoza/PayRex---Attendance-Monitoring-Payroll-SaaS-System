<script>
    // Global variables for pagination
    let currentPage = 1;
    let pageSize = 10;
    let filteredData = [];
    let allEmployees = [];

    // Initialize on page load
    document.addEventListener('DOMContentLoaded', function() {
        // Set page size from selector
        const ps = document.getElementById('pageSizeSelect');
        if (ps) {
            pageSize = parseInt(ps.value) || 10;
            ps.addEventListener('change', function() {
                pageSize = parseInt(this.value) || 10;
                currentPage = 1;
                filterTable();
            });
        }

        // Collect all employee data for mobile view
        collectEmployeeData();

        // Initialize filters
        syncSalaryRange();
        filterTable();
    });

    // Collect employee data from the table for mobile view
    function collectEmployeeData() {
        const tableRows = document.querySelectorAll('#employeeTable tbody tr.data-row');
        allEmployees = [];

        tableRows.forEach(row => {
            if (row.querySelector('td[colspan]')) return; // Skip empty state row

            const nameEl = row.querySelector('.search-name');
            const positionEl = row.querySelector('.search-position');
            const statusEl = row.querySelector('.search-status');
            const rateEl = row.querySelector('[data-rate]');
            // Use data attribute — NOT querySelector('img').src which picked up gov agency logos
            const profileImg = row.dataset.profileImage || null;
            const signatureUrl = row.dataset.signatureUrl || null;
            const employeeId = row.querySelector('.text-gray-500') ? row.querySelector('.text-gray-500').textContent.replace('ID: ', '') : '';

            allEmployees.push({
                name: nameEl ? nameEl.textContent : '',
                position: positionEl ? positionEl.textContent : '',
                status: statusEl ? statusEl.textContent : '',
                rate: rateEl ? parseFloat(rateEl.getAttribute('data-rate')) || 0 : 0,
                profileImage: profileImg,
                signatureUrl: signatureUrl,
                employeeNumber: row.querySelector('[onclick^="openModal"]') ?
                    parseInt(row.querySelector('[onclick^="openModal"]').getAttribute('onclick').match(/\d+/)[0]) : 0,
                id: employeeId,
                payType: row.cells[3] ? row.cells[3].textContent.trim() : '',
                viewAction: row.querySelector('[onclick^="openModal"]') ?
                    row.querySelector('[onclick^="openModal"]').getAttribute('onclick') : '',
                editLink: row.querySelector('a[href^="/EditEmployee"]') ?
                    row.querySelector('a[href^="/EditEmployee"]').getAttribute('href') : '',
                deactivateAction: row.querySelector('[onclick^="deactivateEmployee"]') ?
                    row.querySelector('[onclick^="deactivateEmployee"]').getAttribute('onclick') : '',
                deactivateName: row.querySelector('[data-name]') ?
                    row.querySelector('[data-name]').getAttribute('data-name') : ''
            });
        });
    }

    // Filter table function
    function filterTable() {
        var input = document.getElementById("searchInput");
        var filter = input ? input.value.toUpperCase() : '';
        var positionFilter = document.getElementById("positionFilter") ? document.getElementById("positionFilter").value.toUpperCase() : '';
        var salaryMinEl = document.getElementById('salaryMinRange');
        var salaryMaxEl = document.getElementById('salaryMaxRange');
        var salaryMinVal = salaryMinEl ? parseFloat(salaryMinEl.value) : NaN;
        var salaryMaxVal = salaryMaxEl ? parseFloat(salaryMaxEl.value) : NaN;

        // Handle desktop table rows
        var table = document.getElementById("employeeTable");
        if (table) {
            var tr = table.getElementsByTagName("tr");
            for (var i = 1; i < tr.length; i++) {
                // Skip empty state row
                if (tr[i].querySelector('td[colspan]')) continue;

                var nameTd = tr[i].querySelector(".search-name");
                var posTd = tr[i].querySelector(".search-position");

                var nameText = nameTd ? (nameTd.textContent || nameTd.innerText) : '';
                var posText = posTd ? (posTd.textContent || posTd.innerText) : '';

                var matchesSearch = filter === '' || nameText.toUpperCase().indexOf(filter) > -1;
                var matchesPos = positionFilter === '' || posText.toUpperCase().indexOf(positionFilter) > -1;

                var rateEl = tr[i].querySelector('[data-rate]');
                var rate = rateEl ? parseFloat(rateEl.getAttribute('data-rate')) || 0 : 0;
                var matchesSalary = (isNaN(salaryMinVal) || rate >= salaryMinVal) && (isNaN(salaryMaxVal) || rate <= salaryMaxVal);

                if (matchesSearch && matchesPos && matchesSalary) {
                    tr[i].style.display = '';
                    tr[i].dataset.match = '1';
                } else {
                    tr[i].style.display = 'none';
                    tr[i].dataset.match = '0';
                }
            }
        }

        // Filter mobile data
        filteredData = allEmployees.filter(emp => {
            var matchesSearch = filter === '' || emp.name.toUpperCase().indexOf(filter) > -1;
            var matchesPos = positionFilter === '' || emp.position.toUpperCase().indexOf(positionFilter) > -1;
            var matchesSalary = (isNaN(salaryMinVal) || emp.rate >= salaryMinVal) && (isNaN(salaryMaxVal) || emp.rate <= salaryMaxVal);
            return matchesSearch && matchesPos && matchesSalary;
        });

        // Update mobile view and ensure correct pagination is applied for current viewport
        renderMobileView();
        // call updateView so desktop pagination (applyDesktopPagination) runs when needed
        updateView();
    }

    // Render mobile card view
    function renderMobileView() {
        const container = document.getElementById('employeesMobileContainer');
        if (!container) return;

        if (filteredData.length === 0) {
            container.innerHTML = `
                <div class="p-6 text-center">
                    <div class="flex flex-col items-center justify-center">
                        <div class="w-12 h-12 bg-blue-50 rounded-full flex items-center justify-center mb-3">
                            <svg class="w-6 h-6 text-blue-400" fill="currentColor" viewBox="0 0 20 20"><path d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" /></svg>
                        </div>
                        <p class="text-sm text-gray-500 font-medium">No employees found</p>
                        <p class="text-xs text-gray-400 mt-1">Try adjusting your filters</p>
                    </div>
                </div>
            `;
            return;
        }

        const start = (currentPage - 1) * pageSize;
        const end = Math.min(start + pageSize, filteredData.length);
        const pageData = filteredData.slice(start, end);

        let html = '<div class="divide-y divide-gray-100">';

        pageData.forEach(emp => {
            const statusClass = emp.status === 'Active' ? 'text-green-700' : (emp.status === 'Inactive' ? 'text-red-700' : 'text-yellow-700');
            const initials = emp.name.substring(0, 1).toUpperCase();

            html += `
                <div class="p-4 hover:bg-gray-50 transition-colors">
                    <!-- Employee header with image and name (status moved below) -->
                    <div class="flex items-center mb-3">
                        <div class="w-10 h-10 rounded-full overflow-hidden flex items-center justify-center mr-3 shadow-sm flex-shrink-0">
                            ${emp.profileImage ?
                                `<img src="${emp.profileImage}" alt="Profile" class="w-10 h-10 object-cover rounded-full" />` :
                                `<div class="w-10 h-10 rounded-full bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center">
                                    <span class="text-sm font-bold text-white">${initials}</span>
                                </div>`
                            }
                        </div>
                        <div class="flex-1">
                            <div class="text-sm font-semibold text-gray-900 search-name">${emp.name}</div>
                            <div class="text-xs text-gray-500">ID: ${emp.id}</div>
                        </div>
                    </div>

                    <!-- Employee details grid -->
                    <div class="grid grid-cols-2 gap-3 mb-3 text-xs">
                        <div>
                            <span class="text-gray-500">Position:</span>
                            <span class="font-medium text-gray-900 block search-position">${emp.position}</span>
                        </div>
                        <div>
                            <span class="text-gray-500">Pay Type:</span>
                            <span class="font-medium text-gray-900 block">${emp.payType}</span>
                        </div>
                        <div>
                            <span class="text-gray-500">Salary:</span>
                            <span class="font-medium text-gray-900 block" data-rate="${emp.rate}">₱${emp.rate.toFixed(2)}</span>
                        </div>
                        <div>
                            <span class="text-gray-500">Status:</span>
                            <span class="font-semibold ${statusClass} block mt-1 search-status">${emp.status}</span>
                        </div>
                    </div>

                    <!-- Action buttons -->
                    <div class="flex items-center gap-2 border-t border-gray-100 pt-3">
                        <button onclick="openModal(${emp.employeeNumber})" class="flex-1 py-2 text-xs font-medium text-blue-600 bg-blue-50 rounded-lg hover:bg-blue-100 transition-colors">View</button>
                        <a href="${emp.editLink}" class="flex-1 py-2 text-xs font-medium text-blue-600 bg-blue-50 rounded-lg hover:bg-blue-100 transition-colors text-center">Edit</a>
                        ${emp.status === 'Active' ?
                            `<button data-name="${emp.deactivateName}" onclick="deactivateEmployee(this, ${emp.employeeNumber})" class="flex-1 py-2 text-xs font-medium text-red-600 bg-red-50 rounded-lg hover:bg-red-100 transition-colors">Inactive</button>` :
                            `<span class="flex-1 py-2 text-xs font-medium text-gray-400 bg-gray-50 rounded-lg text-center cursor-not-allowed">Inactive</span>`
                        }
                    </div>
                </div>
            `;
        });

        html += '</div>';
        container.innerHTML = html;
    }

    // Update pagination for both views
    function updatePagination() {
        // Use filteredData length as the authoritative total count for pagination
        // This ensures desktop/tablet pagination matches mobile behavior
        const totalCount = filteredData.length;

        const totalPages = Math.max(1, Math.ceil(totalCount / pageSize));
        if (currentPage > totalPages) currentPage = totalPages;
        if (currentPage < 1) currentPage = 1;

        const start = totalCount === 0 ? 0 : (currentPage - 1) * pageSize + 1;
        const end = Math.min(currentPage * pageSize, totalCount);

        // Update pagination info
        const infoEl = document.getElementById('employeesPaginationInfo');
        if (infoEl) {
            infoEl.textContent = `Showing ${start} to ${end} of ${totalCount} employees`;
        }

        // Update total count in header
        const totalEl = document.getElementById('totalEmployeesCount');
        if (totalEl) {
            totalEl.textContent = totalCount;
        }

        // Render pagination buttons
        renderPaginationButtons(totalPages);
    }

    // Render pagination buttons
    function renderPaginationButtons(totalPages) {
        const nav = document.getElementById('employeesPaginationNav');
        if (!nav) return;

        nav.innerHTML = '';

        if (totalPages <= 1) return;

        const btn = (label, page, active = false, disabled = false) => {
            const b = document.createElement('button');
            b.innerHTML = label;
            b.className = `px-3 py-1.5 text-sm font-medium border rounded-lg transition-all ${
                active    ? 'bg-blue-600 text-white border-blue-600' :
                disabled  ? 'opacity-40 cursor-not-allowed bg-gray-100 border-gray-200' :
                            'bg-white text-gray-700 border-gray-200 hover:bg-gray-100'
            }`;
            if (!disabled && !active) b.onclick = () => { 
                currentPage = page; 
                updateView(); 
            };
            return b;
        };

        // Previous button
        nav.appendChild(btn('‹', currentPage - 1, false, currentPage === 1));

        // Page numbers
        function getPageNumbers(c, t) {
            if (t <= 5) return Array.from({length: t}, (_,i) => i+1);
            if (c <= 3) return [1,2,3,4,'...',t];
            if (c >= t - 2) return [1,'...',t-3,t-2,t-1,t];
            return [1,'...',c-1,c,c+1,'...',t];
        }

        getPageNumbers(currentPage, totalPages).forEach(p => {
            if (p === '...') {
                const dots = document.createElement('span');
                dots.className = 'px-2 py-1.5 text-gray-400 text-sm';
                dots.textContent = '…';
                nav.appendChild(dots);
            } else {
                nav.appendChild(btn(p, p, p === currentPage));
            }
        });

        // Next button
        nav.appendChild(btn('›', currentPage + 1, false, currentPage === totalPages));
    }

    // Update view based on current page
    function updateView() {
        if (window.innerWidth < 640) {
            renderMobileView();
        } else {
            // For desktop, just ensure correct rows are visible
            applyDesktopPagination();
        }
        updatePagination();
    }

    // Apply pagination to desktop view
    function applyDesktopPagination() {
        const table = document.getElementById('employeeTable');
        if (!table) return;

        // Select rows that are part of the dataset and currently match filters
        const rows = Array.from(table.querySelectorAll('tbody tr')).filter(tr =>
            !tr.querySelector('td[colspan]') && tr.dataset && tr.dataset.match === '1'
        );

        const start = (currentPage - 1) * pageSize;
        const end = start + pageSize;

        // Hide all rows first
        rows.forEach(row => row.style.display = 'none');

        // Show only current page
        for (let i = start; i < end && i < rows.length; i++) {
            rows[i].style.display = '';
        }
    }

    // Helper function to get page numbers for pagination
    function getPageNumbers(current, total) {
        if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);

        const pages = [];
        if (current <= 4) {
            for (let i = 1; i <= 5; i++) pages.push(i);
            pages.push('...', total);
        } else if (current >= total - 3) {
            pages.push(1, '...');
            for (let i = total - 4; i <= total; i++) pages.push(i);
        } else {
            pages.push(1, '...', current - 1, current, current + 1, '...', total);
        }
        return pages;
    }

    // Clear filters function
    function clearFilters() {
        var searchInput = document.getElementById('searchInput');
        if (searchInput) searchInput.value = '';

        var positionFilter = document.getElementById('positionFilter');
        if (positionFilter) positionFilter.value = '';

        var minR = document.getElementById('salaryMinRange');
        var maxR = document.getElementById('salaryMaxRange');
        if (minR && maxR) {
            minR.value = minR.min;
            maxR.value = maxR.max;
        }

        syncSalaryRange();
        currentPage = 1;
        filterTable();
        updateView();
    }

    function syncSalaryRange() {
        var minEl = document.getElementById('salaryMinRange');
        var maxEl = document.getElementById('salaryMaxRange');
        var minDisp = document.getElementById('salaryMinDisplay');
        var maxDisp = document.getElementById('salaryMaxDisplay');

        if (!minEl || !maxEl || !minDisp || !maxDisp) return;

        var minVal = parseFloat(minEl.value) || 0;
        var maxVal = parseFloat(maxEl.value) || 0;

        // enforce min <= max
        if (minVal > maxVal) {
            maxVal = minVal;
            maxEl.value = minEl.value;
        }
        if (maxVal < minVal) {
            minVal = maxVal;
            minEl.value = maxEl.value;
        }

        minDisp.textContent = minVal.toFixed(2);
        maxDisp.textContent = maxVal.toFixed(2);
    }

    // Prepare export form values before submitting
    function prepareExport() {
        const search = document.getElementById('searchInput') ? document.getElementById('searchInput').value : '';
        const position = document.getElementById('positionFilter') ? document.getElementById('positionFilter').value : '';
        const min = document.getElementById('salaryMinRange') ? document.getElementById('salaryMinRange').value : '';
        const max = document.getElementById('salaryMaxRange') ? document.getElementById('salaryMaxRange').value : '';

        const eSearch = document.getElementById('exportSearch'); if (eSearch) eSearch.value = search;
        const ePos = document.getElementById('exportPosition'); if (ePos) ePos.value = position;
        const eMin = document.getElementById('exportSalaryMin'); if (eMin) eMin.value = min;
        const eMax = document.getElementById('exportSalaryMax'); if (eMax) eMax.value = max;
    }

    // Modal functions
    function closeModal() {
        document.getElementById('viewModal').classList.add('hidden');
    }

    async function openModal(employeeNumber) {
        try {
            const res = await fetch(`/_internal/employees/${employeeNumber}`, { credentials: 'include' });
            if (!res.ok) throw new Error('Failed to load employee');
            const data = await res.json();
            populateModal(data);
        } catch (err) {
            console.error('Failed to open modal:', err);
            if (typeof showToast === 'function') {
                showToast('Failed to load employee details', 'error');
            }
        }
    }

    function populateModal(data) {
        function setText(id, value) {
            const el = document.getElementById(id);
            if (el) el.textContent = value || '-';
        }

        // Mask all but the last 4 characters of a government ID
        function maskId(value) {
            if (!value) return '-';
            const digits = value.replace(/\D/g, '');
            if (digits.length <= 4) return value;
            const last4 = digits.slice(-4);
            return '●●●●-' + last4;
        }

        const initials = (data.name || '').substring(0, 2).toUpperCase() || 'EM';
        setText('modalName', data.name || '');
        setText('modalPosition', data.position || '');
        setText('modalStatus', data.employmentStatus || '');

        const rate = (typeof data.basicRate === 'number' ? data.basicRate : parseFloat(data.basicRate) || 0);
        const payType = data.payType || '';
        setText('modalSalaryStatus', '₱' + rate.toLocaleString('en-US', { minimumFractionDigits: 2 }) + (payType ? (' / ' + payType) : ''));

        setText('modalEmail', data.email || '');
        setText('modalContact', data.contactNumber || '');
        setText('modalCivil', data.civilStatus || '');
        setText('modalStart', data.dateHired ? new Date(data.dateHired).toLocaleDateString() : '');

        const birth = data.birthdate ? new Date(data.birthdate) : null;
        let age = null;
        if (birth && !isNaN(birth.getTime())) {
            age = Math.floor((new Date() - birth) / (365.25 * 24 * 3600 * 1000));
            setText('modalAge', age);
        } else {
            setText('modalAge', '-');
        }

        setText('modalTIN', maskId(data.tin));
        setText('modalSSS', maskId(data.sss));
        setText('modalPhil', maskId(data.philHealth));
        setText('modalPag', maskId(data.pagIbig));

        // Profile photo — show real image or generated initials avatar
        const profileImg = document.getElementById('modalProfileImage');
        if (profileImg) {
            if (data.profileImageUrl) {
                profileImg.src = data.profileImageUrl;
                profileImg.style.display = '';
            } else {
                // Generate initials avatar as data-uri using canvas
                const canvas = document.createElement('canvas');
                canvas.width = 96; canvas.height = 96;
                const ctx = canvas.getContext('2d');
                ctx.fillStyle = '#2563EB';
                ctx.beginPath();
                ctx.arc(48, 48, 48, 0, Math.PI * 2);
                ctx.fill();
                ctx.fillStyle = '#FFFFFF';
                ctx.font = 'bold 36px sans-serif';
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';
                ctx.fillText(initials, 48, 48);
                profileImg.src = canvas.toDataURL();
                profileImg.style.display = '';
            }
        }



        const ageBadge = document.getElementById('modalRetirementBadgeAge');
        const status = (data.employmentStatus || '').toString().toLowerCase();
        if (ageBadge) {
            if (age !== null && age >= 60 && status === 'active') {
                ageBadge.classList.remove('hidden');
            } else {
                ageBadge.classList.add('hidden');
            }
        }

        const viewModalEl = document.getElementById('viewModal');
        if (viewModalEl) viewModalEl.classList.remove('hidden');
    }

    // Open modal to confirm deactivation
    async function deactivateEmployee(el, employeeNumber) {
        const name = el && el.dataset && el.dataset.name ? el.dataset.name : 'Employee';
        window.__deactivateEmployeeNumber = employeeNumber;
        window.__deactivateEmployeeName = name;
        showConfirmModal(name);
    }

    function showConfirmModal(name) {
        const modal = document.getElementById('popup-modal');
        if (!modal) return;
        const nameEl = modal.querySelector('.confirm-emp-name');
        if (nameEl) nameEl.textContent = name;
        modal.classList.remove('hidden');
    }

    function hideConfirmModal() {
        const modal = document.getElementById('popup-modal');
        if (!modal) return;
        modal.classList.add('hidden');
    }

    async function confirmDeactivate() {
        const employeeNumber = window.__deactivateEmployeeNumber;
        const name = window.__deactivateEmployeeName || 'Employee';
        // show spinner on confirm button
        const confirmBtn = document.getElementById('confirmDeactivateBtn');
        if (confirmBtn) {
            confirmBtn.disabled = true;
            confirmBtn.innerHTML = '<svg class="w-4 h-4 mr-2 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>Processing...';
        }
        hideConfirmModal();

        try {
            const res = await fetch(`/_internal/employees/${employeeNumber}/deactivate`, {
                method: 'POST',
                credentials: 'include'
            });

            if (!res.ok) throw new Error('Failed');

            if (typeof showToast === 'function') {
                showToast('Successfully Inactive, View Archive', 'success');
            }

            setTimeout(() => location.reload(), 1500);
        } catch (e) {
            console.error(e);
            if (typeof showToast === 'function') {
                showToast(`Failed to mark ${name} inactive`, 'error');
            }
            // restore confirm button state on failure
            const confirmBtnFail = document.getElementById('confirmDeactivateBtn');
            if (confirmBtnFail) {
                confirmBtnFail.disabled = false;
                confirmBtnFail.innerHTML = "Yes, I'm sure";
            }
        }
    }

    // Handle window resize
    window.addEventListener('resize', function() {
        if (window.innerWidth < 640) {
            renderMobileView();
        } else {
            // On desktop, just ensure table shows correctly
            const mobileContainer = document.getElementById('employeesMobileContainer');
            if (mobileContainer) mobileContainer.innerHTML = '';
            applyDesktopPagination();
        }
        updatePagination();
    });

    // Make functions globally available
    function showExportModal() {
        document.getElementById('exportModal').classList.remove('hidden');
    }

    function hideExportModal() {
        document.getElementById('exportModal').classList.add('hidden');
    }

    function executeExport() {
        document.getElementById('exportIncludeSalary').value = document.getElementById('chkIncludeSalary').checked ? "true" : "false";
        document.getElementById('exportIncludeGovIds').value = document.getElementById('chkIncludeGovIds').checked ? "true" : "false";
        prepareExport();
        
        if (typeof showToast === 'function') {
            showToast('Generating PDF, please wait...', 'info');
        }
        
        document.getElementById('exportForm').submit();
        hideExportModal();
    }

    window.prepareExport = prepareExport;
    window.showExportModal = showExportModal;
    window.openModal = openModal;
    window.closeModal = closeModal;
    window.deactivateEmployee = deactivateEmployee;
</script>