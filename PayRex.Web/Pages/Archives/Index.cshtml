@page
@model PayRex.Web.Pages.Archives.IndexModel
@{
    ViewData["Title"] = "Archives";
}


                           
                                                <div class="max-w-8xl mx-auto px-4 py-6 sm:px-6 lg:px-8 space-y-6">
                                                    <!-- Header (dashboard style like other pages) -->
                                                    <div class="bg-gradient-to-r from-blue-50 via-white to-blue-50 rounded-2xl border border-blue-100 shadow-sm overflow-hidden relative">
                                                        <div class="absolute top-0 right-0 -mt-16 -mr-16 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
                                                        <div class="px-6 py-8 sm:px-10 relative z-10">
                                                            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                                                                <div>
                                                                    <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight">Archives</h1>
                                                                    <p class="mt-2 text-gray-600">Manage inactive employee records and payroll batches</p>
                                                                </div>
                                                                <div class="flex items-center gap-3">
                                                                    <span class="inline-flex items-center px-4 py-2 rounded-xl text-sm font-semibold bg-blue-100 text-blue-700">
                                                                        <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
                                                                            <path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z" />
                                                                        </svg>
                                                                        @Model.InactiveEmployees.Count Inactive
                                                                    </span>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <!-- Tabs Container (like Compensation page) -->
                                                    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                                                        <div class="border-b border-gray-100 px-6">
                                                            <nav class="-mb-px flex space-x-8" aria-label="Tabs">
                                                                <button onclick="switchTab('inactive')" id="tab-inactive-btn"
                                                                        class="border-blue-500 text-blue-600 whitespace-nowrap py-4 px-1 border-b-2 font-bold text-sm transition-all">
                                                                    Inactive Employees
                                                                </button>
                                                                <button onclick="switchTab('batches')" id="tab-batches-btn"
                                                                        class="border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition-all">
                                                                    Payroll Batches
                                                                </button>
                                                                <button onclick="switchTab('attendance')" id="tab-attendance-btn"
                                                                        class="border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition-all">
                                                                    Attendance Archives
                                                                </button>
                                                                <button onclick="switchTab('leaves')" id="tab-leaves-btn"
                                                                        class="border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition-all">
                                                                    Leave Requests
                                                                </button>
                                                            </nav>
                                                        </div>

                                                        <div id="inactive-content" class="p-6 space-y-6">
                                                            <div class="flex items-center gap-4">
                                                                <div>
                                                                    <h3 class="text-sm font-medium text-gray-900">Inactive Employees</h3>
                                                                </div>
                                                            </div>

                                                            <div class="mt-4">
                                                                <form method="post" asp-page-handler="Activate" id="activateForm">
                                                                    <input type="hidden" name="employeeNumber" id="activateEmployeeNumber" />
                                                                </form>
                                                                <div class="overflow-x-auto rounded-xl border border-gray-100">
                                                                    <table class="min-w-full divide-y divide-gray-200" id="archivesInactiveTable">
                                                                        <thead class="bg-gray-50">
                                                                            <tr>
                                                                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Employee</th>
                                                                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Role/Position</th>
                                                                                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Salary Rate</th>
                                                                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Pay Type</th>
                                                                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                                                                                <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                                                                            </tr>
                                                                        </thead>
                                                                        <tbody class="bg-white divide-y divide-gray-200">
                                                                            @foreach(var emp in Model.InactiveEmployees)
                                                                            {
                                                                                <tr class="hover:bg-gray-50 transition-colors">
                                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">@emp.Name</td>
                                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@emp.Position</td>
                                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-right font-semibold text-gray-900">₱@emp.BasicRate.ToString("N2")</td>
                                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@emp.PayType</td>
                                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@emp.EmploymentStatus</td>
                                                                                    <td class="px-6 py-4 whitespace-nowrap text-center">
                                                                                        <button type="button" onclick="activateEmployee(@emp.EmployeeNumber)" class="inline-flex items-center px-3 py-1.5 bg-green-600 text-white rounded-lg">Restore</button>
                                                                                    </td>
                                                                                </tr>
                                                                            }
                                                                        </tbody>
                                                                    </table>
                                                                </div>
                                                            </div>
                                                        </div>

                                                        <div id="batches-content" class="hidden p-6 space-y-6">
                                                            <div class="flex flex-col sm:flex-row justify-between gap-4">
                                                                <div class="relative w-full sm:w-64">
                                                                    <input type="text" id="batchSearch" placeholder="Search payroll batches..."
                                                                           class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-xl focus:ring-blue-500 focus:border-blue-500 sm:text-sm"
                                                                           onkeyup="filterBatches()">
                                                                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                                                        <svg class="h-4 w-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" /></svg>
                                                                    </div>
                                                                </div>
                                                                <button class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-xl text-white bg-blue-600 hover:bg-blue-700 shadow-sm transition-colors">
                                                                    Add Payroll Batch
                                                                </button>
                                                            </div>

                                                            <div class="overflow-x-auto rounded-xl border border-gray-100">
                                                                <table class="min-w-full divide-y divide-gray-200" id="batchTable">
                                                                    <thead class="bg-gray-50">
                                                                        <tr>
                                                                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Batch ID</th>
                                                                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Period</th>
                                                                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                                                                            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Total</th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody class="bg-white divide-y divide-gray-200">
                                                                        <tr>
                                                                            <td colspan="4" class="px-6 py-12 text-center text-gray-500">No payroll batches available</td>
                                                                        </tr>
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                        </div>

                                                        <div id="attendance-content" class="hidden p-6 space-y-6">
                                                            <div class="flex flex-col sm:flex-row justify-between gap-4">
                                                                <h3 class="text-sm font-medium text-gray-900">Archived Attendance (Older than 7 days)</h3>
                                                                <div class="flex items-center gap-2">
                                                                    <span class="text-xs text-gray-500">Total: @Model.AttendanceArchives.TotalCount records</span>
                                                                </div>
                                                            </div>

                                                            <div class="overflow-x-auto rounded-xl border border-gray-100">
                                                                <table class="min-w-full divide-y divide-gray-200">
                                                                    <thead class="bg-gray-50">
                                                                        <tr>
                                                                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
                                                                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Employee</th>
                                                                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Logged Hours</th>
                                                                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                                                                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Remarks</th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody class="bg-white divide-y divide-gray-200">
                                                                        @if (Model.AttendanceArchives.Records == null || !Model.AttendanceArchives.Records.Any())
                                                                        {
                                                                            <tr>
                                                                                <td colspan="5" class="px-6 py-12 text-center text-gray-500">No archived attendance records found</td>
                                                                            </tr>
                                                                        }
                                                                        else
                                                                        {
                                                                            @foreach(var record in Model.AttendanceArchives.Records)
                                                                            {
                                                                                <tr class="hover:bg-gray-50 transition-colors">
                                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@record.Date</td>
                                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">@record.EmployeeName</td>
                                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@(record.TotalHoursWorked.ToString("F2"))h</td>
                                                                                    <td class="px-6 py-4 whitespace-nowrap">
                                                                                        <span class="px-2 py-0.5 rounded-full text-xs font-medium @(record.Status == "Present" ? "bg-green-100 text-green-800" : "bg-yellow-100 text-yellow-800")">
                                                                                            @record.Status
                                                                                        </span>
                                                                                    </td>
                                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@record.Remarks</td>
                                                                                </tr>
                                                                            }
                                                                        }
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                        </div>

                                                        <div id="leaves-content" class="hidden p-6 space-y-6">
                                                            <div class="flex flex-col sm:flex-row justify-between gap-4">
                                                                <h3 class="text-sm font-medium text-gray-900">Archived Leave Requests</h3>
                                                                <div class="flex items-center gap-2">
                                                                    <span class="text-xs text-gray-500">Total: @Model.ArchivedLeaves.Count records</span>
                                                                </div>
                                                            </div>

                                                            <div class="overflow-x-auto rounded-xl border border-gray-100">
                                                                <table class="min-w-full divide-y divide-gray-200">
                                                                    <thead class="bg-gray-50">
                                                                        <tr>
                                                                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Employee</th>
                                                                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
                                                                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">From</th>
                                                                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">To</th>
                                                                            <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Days</th>
                                                                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                                                                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Reason/Remarks</th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody class="bg-white divide-y divide-gray-200">
                                                                        @if (!Model.ArchivedLeaves.Any())
                                                                        {
                                                                            <tr>
                                                                                <td colspan="7" class="px-6 py-12 text-center text-gray-500">No archived leave requests found</td>
                                                                            </tr>
                                                                        }
                                                                        else
                                                                        {
                                                                            @foreach(var lr in Model.ArchivedLeaves)
                                                                            {
                                                                                var stClass = lr.Status == "Approved" ? "bg-green-100 text-green-700" : (lr.Status == "Rejected" ? "bg-red-100 text-red-700" : "bg-gray-100 text-gray-700");
                                                                                <tr class="hover:bg-gray-50 transition-colors">
                                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">@lr.EmployeeName</td>
                                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@lr.LeaveType</td>
                                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@lr.StartDate</td>
                                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@lr.EndDate</td>
                                                                                    <td class="px-6 py-4 whitespace-nowrap text-center text-sm font-bold text-blue-600">@lr.TotalDays</td>
                                                                                    <td class="px-6 py-4 whitespace-nowrap">
                                                                                        <span class="px-2 py-0.5 rounded-full text-xs font-semibold @stClass">@lr.Status</span>
                                                                                    </td>
                                                                                    <td class="px-6 py-4 text-xs text-gray-500 max-w-xs">
                                                                                        <div class="truncate">@(lr.Reason ?? "—")</div>
                                                                                        @if (!string.IsNullOrEmpty(lr.ReviewRemarks))
                                                                                        {
                                                                                            <div class="text-xs text-gray-400 italic mt-0.5">"@lr.ReviewRemarks"</div>
                                                                                        }
                                                                                    </td>
                                                                                </tr>
                                                                            }
                                                                        }
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <script>
                                                    function switchTab(tab) {
                                                        const inactive = document.getElementById('inactive-content');
                                                        const batches = document.getElementById('batches-content');
                                                        const attendance = document.getElementById('attendance-content');
                                                        const leaves = document.getElementById('leaves-content');
                                                        const iBtn = document.getElementById('tab-inactive-btn');
                                                        const bBtn = document.getElementById('tab-batches-btn');
                                                        const aBtn = document.getElementById('tab-attendance-btn');
                                                        const lBtn = document.getElementById('tab-leaves-btn');

                                                        // Reset all tabs
                                                        [inactive, batches, attendance, leaves].forEach(el => el?.classList.add('hidden'));
                                                        [iBtn, bBtn, aBtn, lBtn].forEach(el => {
                                                            if(el) el.className = "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition-all";
                                                        });

                                                        if (tab === 'inactive') {
                                                            inactive?.classList.remove('hidden');
                                                            if(iBtn) iBtn.className = "border-blue-500 text-blue-600 whitespace-nowrap py-4 px-1 border-b-2 font-bold text-sm transition-all";
                                                        } else if (tab === 'batches') {
                                                            batches?.classList.remove('hidden');
                                                            if(bBtn) bBtn.className = "border-blue-500 text-blue-600 whitespace-nowrap py-4 px-1 border-b-2 font-bold text-sm transition-all";
                                                        } else if (tab === 'attendance') {
                                                            attendance?.classList.remove('hidden');
                                                            if(aBtn) aBtn.className = "border-blue-500 text-blue-600 whitespace-nowrap py-4 px-1 border-b-2 font-bold text-sm transition-all";
                                                        } else if (tab === 'leaves') {
                                                            leaves?.classList.remove('hidden');
                                                            if(lBtn) lBtn.className = "border-blue-500 text-blue-600 whitespace-nowrap py-4 px-1 border-b-2 font-bold text-sm transition-all";
                                                        }
                                                    }

                                                    function activateEmployee(empNo) {
                                                        const f = document.getElementById('activateForm');
                                                        const i = document.getElementById('activateEmployeeNumber');
                                                        if (i) i.value = empNo;
                                                        if (f) f.submit();
                                                    }

                                                    function filterBatches() {
                                                        const input = document.getElementById('batchSearch');
                                                        const filter = input ? input.value.toUpperCase() : '';
                                                        const table = document.getElementById('batchTable');
                                                        if (!table) return;
                                                        const tr = table.getElementsByTagName('tr');
                                                        for (let i = 1; i < tr.length; i++) {
                                                            const txt = (tr[i].textContent || tr[i].innerText || '').toUpperCase();
                                                            tr[i].style.display = txt.indexOf(filter) > -1 ? '' : 'none';
                                                        }
                                                    }

                                                    // initialize default tab
                                                    document.addEventListener('DOMContentLoaded', () => switchTab('inactive'));
                                                </script>
