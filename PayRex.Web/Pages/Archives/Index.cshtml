@page
@model PayRex.Web.Pages.Archives.IndexModel
@{
    ViewData["Title"] = "Archives";
}


                           
                                                <div class="max-w-8xl mx-auto px-4 py-6 sm:px-6 lg:px-8 space-y-6">
                                                    <!-- Header (dashboard style like other pages) -->
                                                    <div class="bg-gradient-to-r from-blue-50 via-white to-blue-50 rounded-2xl border border-blue-100 shadow-sm overflow-hidden relative">
                                                        <div class="absolute top-0 right-0 -mt-16 -mr-16 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
                                                        <div class="px-6 py-8 sm:px-10 relative z-10">
                                                            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                                                                <div>
                                                                    <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight">Archives</h1>
                                                                    <p class="mt-2 text-gray-600">Manage inactive employee records and payroll batches</p>
                                                                </div>
                                                                <div class="flex items-center gap-3">
                                                                    <span class="inline-flex items-center px-4 py-2 rounded-xl text-sm font-semibold bg-blue-100 text-blue-700">
                                                                        <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
                                                                            <path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z" />
                                                                        </svg>
                                                                        @Model.InactiveEmployees.Count Inactive
                                                                    </span>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <!-- Tabs Container (like Compensation page) -->
                                                    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                                                        <div class="border-b border-gray-100 px-6">
                                                            <nav class="-mb-px flex space-x-8" aria-label="Tabs">
                                                                <button onclick="switchTab('inactive')" id="tab-inactive-btn"
                                                                        class="border-blue-500 text-blue-600 whitespace-nowrap py-4 px-1 border-b-2 font-bold text-sm transition-all">
                                                                    Inactive Employees
                                                                </button>
                                                                <button onclick="switchTab('batches')" id="tab-batches-btn"
                                                                        class="border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition-all">
                                                                    Payroll Batches
                                                                </button>
                                                                <button onclick="switchTab('attendance')" id="tab-attendance-btn"
                                                                        class="border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition-all">
                                                                    Attendance Archives
                                                                </button>
                                                                <button onclick="switchTab('leaves')" id="tab-leaves-btn"
                                                                        class="border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition-all">
                                                                    Leave Requests
                                                                </button>
                                                                <button onclick="switchTab('payslips')" id="tab-payslips-btn"
                                                                        class="border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition-all">
                                                                    Payslips
                                                                </button>
                                                            </nav>
                                                        </div>

                                                        <div id="inactive-content" class="p-6 space-y-6">
                                                            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                                                                <div>
                                                                    <h3 class="text-sm font-medium text-gray-900">Inactive Employees</h3>
                                                                </div>
                                                                <div class="relative w-full sm:w-64">
                                                                    <input type="text" id="inactiveSearch" placeholder="Search employees..."
                                                                           class="w-full pl-9 pr-3 py-2 border border-gray-300 rounded-xl focus:ring-blue-500 focus:border-blue-500 sm:text-sm"
                                                                           onkeyup="filterTable('inactiveTable','inactiveSearch','inactiveEmpty')">
                                                                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                                                        <svg class="h-4 w-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" /></svg>
                                                                    </div>
                                                                </div>
                                                            </div>

                                                            <div class="mt-4">
                                                                <form method="post" asp-page-handler="Activate" id="activateForm">
                                                                    <input type="hidden" name="employeeNumber" id="activateEmployeeNumber" />
                                                                </form>
                                                                <div class="overflow-x-auto rounded-xl border border-gray-100">
                                                                    <table class="min-w-full divide-y divide-gray-200" id="inactiveTable">
                                                                        <thead class="bg-gray-50">
                                                                            <tr>
                                                                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Employee</th>
                                                                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Role/Position</th>
                                                                                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Salary Rate</th>
                                                                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Pay Type</th>
                                                                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                                                                                <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                                                                            </tr>
                                                                        </thead>
                                                                        <tbody class="bg-white divide-y divide-gray-200">
                                                                            @if (!Model.InactiveEmployees.Any())
                                                                            {
                                                                                <tr id="inactiveEmpty">
                                                                                    <td colspan="6" class="px-6 py-12 text-center">
                                                                                        <div class="flex flex-col items-center">
                                                                                            <div class="w-16 h-16 bg-green-50 rounded-full flex items-center justify-center mb-4">
                                                                                                <svg class="w-8 h-8 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
                                                                                            </div>
                                                                                            <p class="text-gray-500 font-medium">No inactive employees</p>
                                                                                            <p class="text-sm text-gray-400 mt-1">All employees are currently active</p>
                                                                                        </div>
                                                                                    </td>
                                                                                </tr>
                                                                            }
                                                                            else
                                                                            {
                                                                                @foreach(var emp in Model.InactiveEmployees)
                                                                                {
                                                                                    <tr class="hover:bg-gray-50 transition-colors">
                                                                                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">@emp.Name</td>
                                                                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@emp.Position</td>
                                                                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-right font-semibold text-gray-900">₱@emp.BasicRate.ToString("N2")</td>
                                                                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@emp.PayType</td>
                                                                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@emp.EmploymentStatus</td>
                                                                                        <td class="px-6 py-4 whitespace-nowrap text-center">
                                                                                            <button type="button" onclick="activateEmployee(@emp.EmployeeNumber)" class="inline-flex items-center px-3 py-1.5 bg-green-600 text-white rounded-lg">Restore</button>
                                                                                        </td>
                                                                                    </tr>
                                                                                }
                                                                                <tr id="inactiveEmpty" class="hidden"><td colspan="6" class="px-6 py-8 text-center text-gray-500 text-sm">No matching employees</td></tr>
                                                                            }
                                                                        </tbody>
                                                                    </table>
                                                                </div>
                                                            </div>
                                                        </div>

                                                        <div id="batches-content" class="hidden p-6 space-y-6">
                                                            <div class="flex flex-col sm:flex-row justify-between gap-4">
                                                                <div class="relative w-full sm:w-64">
                                                                    <input type="text" id="batchSearch" placeholder="Search payroll batches..."
                                                                           class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-xl focus:ring-blue-500 focus:border-blue-500 sm:text-sm"
                                                                           onkeyup="filterBatches()">
                                                                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                                                        <svg class="h-4 w-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" /></svg>
                                                                    </div>
                                                                </div>
                                                                <button class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-xl text-white bg-blue-600 hover:bg-blue-700 shadow-sm transition-colors">
                                                                    Add Payroll Batch
                                                                </button>
                                                            </div>

                                                            <div class="overflow-x-auto rounded-xl border border-gray-100">
                                                                <table class="min-w-full divide-y divide-gray-200" id="batchTable">
                                                                    <thead class="bg-gray-50">
                                                                        <tr>
                                                                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Batch ID</th>
                                                                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Period</th>
                                                                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                                                                            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Total</th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody class="bg-white divide-y divide-gray-200">
                                                                        <tr>
                                                                            <td colspan="4" class="px-6 py-12 text-center text-gray-500">No payroll batches available</td>
                                                                        </tr>
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                        </div>

                                                        <div id="attendance-content" class="hidden p-6 space-y-6">
                                                            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                                                                <div>
                                                                    <h3 class="text-sm font-medium text-gray-900">Archived Attendance (Older than 7 days)</h3>
                                                                    <span class="text-xs text-gray-500">Total: @Model.AttendanceArchives.TotalCount records</span>
                                                                </div>
                                                                <div class="relative w-full sm:w-64">
                                                                    <input type="text" id="attendanceSearch" placeholder="Search attendance..."
                                                                           class="w-full pl-9 pr-3 py-2 border border-gray-300 rounded-xl focus:ring-blue-500 focus:border-blue-500 sm:text-sm"
                                                                           onkeyup="filterTable('attendanceTable','attendanceSearch','attendanceEmpty')">
                                                                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                                                        <svg class="h-4 w-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" /></svg>
                                                                    </div>
                                                                </div>
                                                            </div>

                                                            <div class="overflow-x-auto rounded-xl border border-gray-100">
                                                                <table class="min-w-full divide-y divide-gray-200" id="attendanceTable">
                                                                    <thead class="bg-gray-50">
                                                                        <tr>
                                                                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
                                                                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Employee</th>
                                                                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Logged Hours</th>
                                                                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                                                                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Remarks</th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody class="bg-white divide-y divide-gray-200">
                                                                        @if (Model.AttendanceArchives.Records == null || !Model.AttendanceArchives.Records.Any())
                                                                        {
                                                                            <tr id="attendanceEmpty">
                                                                                <td colspan="5" class="px-6 py-12 text-center">
                                                                                    <div class="flex flex-col items-center">
                                                                                        <div class="w-16 h-16 bg-gray-50 rounded-full flex items-center justify-center mb-4">
                                                                                            <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                                                                                        </div>
                                                                                        <p class="text-gray-500 font-medium">No archived attendance records</p>
                                                                                        <p class="text-sm text-gray-400 mt-1">Records older than 7 days will appear here</p>
                                                                                    </div>
                                                                                </td>
                                                                            </tr>
                                                                        }
                                                                        else
                                                                        {
                                                                            @foreach(var record in Model.AttendanceArchives.Records)
                                                                            {
                                                                                <tr class="hover:bg-gray-50 transition-colors">
                                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@record.Date</td>
                                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">@record.EmployeeName</td>
                                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@(record.TotalHoursWorked.ToString("F2"))h</td>
                                                                                    <td class="px-6 py-4 whitespace-nowrap">
                                                                                        <span class="px-2 py-0.5 rounded-full text-xs font-medium @(record.Status == "Present" ? "bg-green-100 text-green-800" : "bg-yellow-100 text-yellow-800")">@record.Status</span>
                                                                                    </td>
                                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@record.Remarks</td>
                                                                                </tr>
                                                                            }
                                                                            <tr id="attendanceEmpty" class="hidden"><td colspan="5" class="px-6 py-8 text-center text-gray-500 text-sm">No matching records</td></tr>
                                                                        }
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                        </div>

                                                        <div id="leaves-content" class="hidden p-6 space-y-6">
                                                            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                                                                <div>
                                                                    <h3 class="text-sm font-medium text-gray-900">Archived Leave Requests</h3>
                                                                    <span class="text-xs text-gray-500">Total: @Model.ArchivedLeaves.Count records</span>
                                                                </div>
                                                                <div class="relative w-full sm:w-64">
                                                                    <input type="text" id="leavesSearch" placeholder="Search leave requests..."
                                                                           class="w-full pl-9 pr-3 py-2 border border-gray-300 rounded-xl focus:ring-blue-500 focus:border-blue-500 sm:text-sm"
                                                                           onkeyup="filterTable('leavesTable','leavesSearch','leavesEmpty')">
                                                                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                                                        <svg class="h-4 w-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" /></svg>
                                                                    </div>
                                                                </div>
                                                            </div>

                                                            <div class="overflow-x-auto rounded-xl border border-gray-100">
                                                                <table class="min-w-full divide-y divide-gray-200" id="leavesTable">
                                                                    <thead class="bg-gray-50">
                                                                        <tr>
                                                                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Employee</th>
                                                                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
                                                                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">From</th>
                                                                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">To</th>
                                                                            <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Days</th>
                                                                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                                                                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Reason/Remarks</th>
                                                                            <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody class="bg-white divide-y divide-gray-200">
                                                                        @if (!Model.ArchivedLeaves.Any())
                                                                        {
                                                                            <tr id="leavesEmpty">
                                                                                <td colspan="8" class="px-6 py-12 text-center">
                                                                                    <div class="flex flex-col items-center">
                                                                                        <div class="w-16 h-16 bg-green-50 rounded-full flex items-center justify-center mb-4">
                                                                                            <svg class="w-8 h-8 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
                                                                                        </div>
                                                                                        <p class="text-gray-500 font-medium">No archived leave requests</p>
                                                                                        <p class="text-sm text-gray-400 mt-1">Leave requests will appear here once archived</p>
                                                                                    </div>
                                                                                </td>
                                                                            </tr>
                                                                        }
                                                                        else
                                                                        {
                                                                            @foreach(var lr in Model.ArchivedLeaves)
                                                                            {
                                                                                var stClass = lr.Status == "Approved" ? "bg-green-100 text-green-700" : (lr.Status == "Rejected" ? "bg-red-100 text-red-700" : "bg-gray-100 text-gray-700");
                                                                                <tr class="hover:bg-gray-50 transition-colors">
                                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">@lr.EmployeeName</td>
                                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@lr.LeaveType</td>
                                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@lr.StartDate</td>
                                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@lr.EndDate</td>
                                                                                    <td class="px-6 py-4 whitespace-nowrap text-center text-sm font-bold text-blue-600">@lr.TotalDays</td>
                                                                                    <td class="px-6 py-4 whitespace-nowrap">
                                                                                        <span class="px-2 py-0.5 rounded-full text-xs font-semibold @stClass">@lr.Status</span>
                                                                                    </td>
                                                                                    <td class="px-6 py-4 text-xs text-gray-500 max-w-xs">
                                                                                        <div class="truncate">@(lr.Reason ?? "—")</div>
                                                                                        @if (!string.IsNullOrEmpty(lr.ReviewRemarks))
                                                                                        {
                                                                                            <div class="text-xs text-gray-400 italic mt-0.5">"@lr.ReviewRemarks"</div>
                                                                                        }
                                                                                    </td>
                                                                                    <td class="px-6 py-4 whitespace-nowrap text-center">
                                                                                        <button type="button" onclick="openRestoreLeaveModal(@lr.LeaveRequestId, '@lr.EmployeeName')"
                                                                                                class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-green-700 bg-green-50 rounded-lg hover:bg-green-100 transition-colors">
                                                                                            <svg class="w-3.5 h-3.5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m0 0H1" /></svg>
                                                                                            Restore
                                                                                        </button>
                                                                                    </td>
                                                                                </tr>
                                                                            }
                                                                            <tr id="leavesEmpty" class="hidden"><td colspan="8" class="px-6 py-8 text-center text-gray-500 text-sm">No matching leave requests</td></tr>
                                                                        }
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                        </div>

                                                        <div id="payslips-content" class="hidden p-6 space-y-6">
                                                            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                                                                <div>
                                                                    <h3 class="text-sm font-medium text-gray-900">Archived Payslips</h3>
                                                                    <span class="text-xs text-gray-500">Total: @Model.ArchivedPayslips.Count records</span>
                                                                </div>
                                                                <div class="relative w-full sm:w-64">
                                                                    <input type="text" id="payslipsSearch" placeholder="Search payslips..."
                                                                           class="w-full pl-9 pr-3 py-2 border border-gray-300 rounded-xl focus:ring-blue-500 focus:border-blue-500 sm:text-sm"
                                                                           onkeyup="filterTable('payslipsTable','payslipsSearch','payslipsEmpty')">
                                                                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                                                        <svg class="h-4 w-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" /></svg>
                                                                    </div>
                                                                </div>
                                                            </div>

                                                            <div class="overflow-x-auto rounded-xl border border-gray-100">
                                                                <table class="min-w-full divide-y divide-gray-200" id="payslipsTable">
                                                                    <thead class="bg-gray-50">
                                                                        <tr>
                                                                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Employee</th>
                                                                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Period</th>
                                                                            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Gross Pay</th>
                                                                            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Deductions</th>
                                                                            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Net Pay</th>
                                                                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Archived On</th>
                                                                            <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody class="bg-white divide-y divide-gray-200">
                                                                        @if (!Model.ArchivedPayslips.Any())
                                                                        {
                                                                            <tr id="payslipsEmpty">
                                                                                <td colspan="7" class="px-6 py-12 text-center">
                                                                                    <div class="flex flex-col items-center">
                                                                                        <div class="w-16 h-16 bg-green-50 rounded-full flex items-center justify-center mb-4">
                                                                                            <svg class="w-8 h-8 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
                                                                                        </div>
                                                                                        <p class="text-gray-500 font-medium">No archived payslips</p>
                                                                                        <p class="text-sm text-gray-400 mt-1">Payslip batches you archive will appear here</p>
                                                                                    </div>
                                                                                </td>
                                                                            </tr>
                                                                        }
                                                                        else
                                                                        {
                                                                            @foreach(var p in Model.ArchivedPayslips)
                                                                            {
                                                                                <tr class="hover:bg-gray-50 transition-colors">
                                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">@p.EmployeeName</td>
                                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@p.PeriodName</td>
                                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-right font-semibold text-gray-900">₱@p.GrossPay.ToString("N2")</td>
                                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-right text-red-600">₱@p.TotalDeductions.ToString("N2")</td>
                                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-right font-bold text-blue-700">₱@p.NetPay.ToString("N2")</td>
                                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@(p.ArchivedAt?.ToString("MMM d, yyyy") ?? "—")</td>
                                                                                    <td class="px-6 py-4 whitespace-nowrap text-center">
                                                                                        <form method="post" asp-page-handler="RestorePayslipPeriod" style="display:inline">
                                                                                            @Html.AntiForgeryToken()
                                                                                            <input type="hidden" name="periodName" value="@p.PeriodName" />
                                                                                            <button type="submit" class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-green-700 bg-green-50 rounded-lg hover:bg-green-100 transition-colors">
                                                                                                <svg class="w-3.5 h-3.5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m0 0H1" /></svg>
                                                                                                Restore Period
                                                                                            </button>
                                                                                        </form>
                                                                                    </td>
                                                                                </tr>
                                                                            }
                                                                            <tr id="payslipsEmpty" class="hidden"><td colspan="7" class="px-6 py-8 text-center text-gray-500 text-sm">No matching payslips</td></tr>
                                                                        }
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>

<!-- Restore Leave Modal (Matches Employees.cshtml Inactive style but GREEN) -->
<div id="restoreLeaveModal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-hidden="true">
    <div class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm transition-opacity" aria-hidden="true" onclick="closeRestoreLeaveModal()"></div>

    <div class="flex min-h-full items-center justify-center p-2 sm:p-4 text-center">
        <div class="relative transform overflow-hidden rounded-lg bg-white text-left shadow-xl transition-all w-full sm:w-[90%] md:w-[60%] lg:w-[50%] max-w-md mx-auto">
            
            <!-- Header -->
            <div class="flex items-center justify-between border-b border-gray-200 bg-white px-4 py-3 sm:px-6 sm:py-4 md:px-6 md:py-4">
                <h3 class="text-base sm:text-lg font-semibold text-gray-900">
                    Confirm Restore
                </h3>
                <button type="button" onclick="closeRestoreLeaveModal()" class="rounded-lg p-1.5 text-gray-400 hover:bg-gray-100 hover:text-gray-500">
                    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
                </button>
            </div>

            <div class="px-4 py-4 sm:px-6 sm:py-5 md:px-6 md:py-6 text-center">
                <form method="post" asp-page-handler="RestoreLeave" id="formRestoreLeave">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="restoreLeaveId" />
                    
                    <p class="mb-5 text-sm text-gray-700" id="restoreLeaveQuestion">
                        Are you sure you want to restore this leave request?
                    </p>
                    
                    <div class="flex justify-center gap-3">
                        <button type="button" onclick="closeRestoreLeaveModal()" class="inline-flex items-center justify-center px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-lg hover:bg-gray-200">
                            No, Cancel
                        </button>
                        <button id="confirmRestoreLeaveBtn" type="submit" class="inline-flex items-center justify-center px-4 py-2 text-sm font-medium text-white bg-green-600 rounded-lg hover:bg-green-700">
                            Yes, I'm sure
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

                                                <script>
                                                    function switchTab(tab) {
                                                        const inactive = document.getElementById('inactive-content');
                                                        const batches = document.getElementById('batches-content');
                                                        const attendance = document.getElementById('attendance-content');
                                                        const leaves = document.getElementById('leaves-content');
                                                        const payslips = document.getElementById('payslips-content');
                                                        const iBtn = document.getElementById('tab-inactive-btn');
                                                        const bBtn = document.getElementById('tab-batches-btn');
                                                        const aBtn = document.getElementById('tab-attendance-btn');
                                                        const lBtn = document.getElementById('tab-leaves-btn');
                                                        const pBtn = document.getElementById('tab-payslips-btn');

                                                        [inactive, batches, attendance, leaves, payslips].forEach(el => el?.classList.add('hidden'));
                                                        [iBtn, bBtn, aBtn, lBtn, pBtn].forEach(el => {
                                                            if(el) el.className = "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition-all";
                                                        });

                                                        const active = "border-blue-500 text-blue-600 whitespace-nowrap py-4 px-1 border-b-2 font-bold text-sm transition-all";
                                                        if (tab === 'inactive') { inactive?.classList.remove('hidden'); if(iBtn) iBtn.className = active; }
                                                        else if (tab === 'batches') { batches?.classList.remove('hidden'); if(bBtn) bBtn.className = active; }
                                                        else if (tab === 'attendance') { attendance?.classList.remove('hidden'); if(aBtn) aBtn.className = active; }
                                                        else if (tab === 'leaves') { leaves?.classList.remove('hidden'); if(lBtn) lBtn.className = active; }
                                                        else if (tab === 'payslips') { payslips?.classList.remove('hidden'); if(pBtn) pBtn.className = active; }
                                                    }

                                                    function filterTable(tableId, inputId, emptyRowId) {
                                                        const input = document.getElementById(inputId);
                                                        const filter = input ? input.value.toUpperCase() : '';
                                                        const table = document.getElementById(tableId);
                                                        const emptyRow = document.getElementById(emptyRowId);
                                                        if (!table) return;
                                                        const rows = table.querySelectorAll('tbody tr:not(#' + emptyRowId + ')');
                                                        let visibleCount = 0;
                                                        rows.forEach(row => {
                                                            const txt = (row.textContent || row.innerText || '').toUpperCase();
                                                            const show = txt.indexOf(filter) > -1;
                                                            row.style.display = show ? '' : 'none';
                                                            if (show) visibleCount++;
                                                        });
                                                        if (emptyRow) emptyRow.style.display = (visibleCount === 0 && filter !== '') ? '' : 'none';
                                                    }

                                                    function activateEmployee(empNo) {
                                                        const f = document.getElementById('activateForm');
                                                        const i = document.getElementById('activateEmployeeNumber');
                                                        if (i) i.value = empNo;
                                                        if (f) f.submit();
                                                    }

                                                    function filterBatches() {
                                                        filterTable('batchTable', 'batchSearch', 'batchEmpty');
                                                    }

                                                    function openRestoreLeaveModal(id, name) {
                                                        const modal = document.getElementById('restoreLeaveModal');
                                                        const idInput = document.getElementById('restoreLeaveId');
                                                        const question = document.getElementById('restoreLeaveQuestion');
                                                        if (idInput) idInput.value = id;
                                                        if (question) question.innerHTML = `Are you sure you want to restore the leave request for <span class="font-semibold">${name}</span>?`;
                                                        if (modal) modal.classList.remove('hidden');
                                                    }

                                                    function closeRestoreLeaveModal() {
                                                        const modal = document.getElementById('restoreLeaveModal');
                                                        if (modal) modal.classList.add('hidden');
                                                    }

                                                    document.addEventListener('DOMContentLoaded', () => switchTab('inactive'));
                                                </script>
