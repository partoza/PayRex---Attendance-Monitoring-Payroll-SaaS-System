@page
@model PayRex.Web.Pages.Auth.ChangePasswordModel
@{
 ViewData["Title"] = "Change Password";
 Layout = "~/Pages/Shared/_AuthLayout.cshtml";
}

<div class="w-full max-w-md px-4">
 <div class="bg-white rounded-2xl shadow-lg border border-gray-200 p-8">
 <div class="text-center mb-6">
 <img src="~/images/logo.png" class="h-12 mx-auto mb-4 drop-shadow-md" alt="PayRex Logo" />
 <h1 class="text-2xl font-bold text-gray-900">Change Password</h1>
 @if (Model.IsForced)
 {
 <p class="text-sm text-amber-600 mt-2">You must change your password before continuing.</p>
 }
 else
 {
 <p class="text-sm text-gray-500 mt-2">Enter your current password and choose a new one.</p>
 }
 </div>

 @if (!string.IsNullOrEmpty(Model.ErrorMessage))
 {
 <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg">
 <p class="text-sm text-red-600">@Model.ErrorMessage</p>
 </div>
 }

 <form method="post">
 <div class="space-y-4">
 <div>
 <label for="currentPassword" class="block text-sm font-medium text-gray-700 mb-1">Current Password</label>
 <input asp-for="Input.CurrentPassword" type="password" id="currentPassword" class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm" placeholder="Enter current password" />
 <span asp-validation-for="Input.CurrentPassword" class="text-xs text-red-500"></span>
 </div>

 <div>
 <label for="newPassword" class="block text-sm font-medium text-gray-700 mb-1">New Password</label>
 <input asp-for="Input.NewPassword" type="password" id="newPassword" class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm" placeholder="Enter new password" />
 <span asp-validation-for="Input.NewPassword" class="text-xs text-red-500"></span>
 </div>

 <div>
 <label for="confirmPassword" class="block text-sm font-medium text-gray-700 mb-1">Confirm New Password</label>
 <input asp-for="Input.ConfirmPassword" type="password" id="confirmPassword" class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm" placeholder="Confirm new password" />
 <span asp-validation-for="Input.ConfirmPassword" class="text-xs text-red-500"></span>
 </div>

 <!-- CAPTCHA partial -->
 <partial name="_Captcha" />

 <button type="submit" class="w-full py-2.5 px-4 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg text-sm transition-colors">Change Password</button>
 </div>
 </form>

 @if (!Model.IsForced)
 {
 <div class="mt-4 text-center">
 <a href="/Dashboard" class="text-sm text-gray-500 hover:text-gray-700">? Back to Dashboard</a>
 </div>
 }
 </div>
</div>

@section Scripts {
 <partial name="_ValidationScriptsPartial" />
}
