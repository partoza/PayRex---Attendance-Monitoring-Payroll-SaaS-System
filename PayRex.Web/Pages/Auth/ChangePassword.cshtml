@page
@model PayRex.Web.Pages.Auth.ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
    Layout = "~/Pages/Shared/_AuthLayout.cshtml";
}

<div class="min-h-screen lg:col-span-2 flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="w-full max-w-md">
        <!-- Header -->
        <div class="text-center mb-8">
            <h1 class="text-3xl font-bold text-blue-600">Change Password</h1>
            <p class="text-gray-600 mt-2">Enter your current password and choose a new one</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg">
                <p class="text-sm text-red-600">@Model.ErrorMessage</p>
            </div>
        }

        <!-- Form -->
        <div class="bg-white rounded-lg shadow-lg border border-gray-200 p-6 sm:p-8">
            <form method="post" class="space-y-5">
                <!-- Current Password -->
                <div>
                    <label for="currentPassword" class="block text-sm font-medium text-gray-700 mb-1">Current Password</label>
                    <div class="relative">
                           <input asp-for="Input.CurrentPassword" type="password" id="currentPassword" 
                               class="w-full rounded-xl border border-gray-300 px-4 py-4 pr-12 focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none placeholder:text-gray-400"
                               placeholder="Enter current password" />
                        <button type="button" onclick="togglePassword('currentPassword')" 
                                class="absolute right-3 top-1/2 transform -translate-y-1/2 text-gray-400 hover:text-gray-600">
                            <svg id="currentPassword-eye-open" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="w-6 h-6 hidden" viewBox="0 0 24 24">
                                <path fill-rule="evenodd" d="M4.998 7.78C6.729 6.345 9.198 5 12 5c2.802 0 5.27 1.345 7.002 2.78a12.713 12.713 0 0 1 2.096 2.183c.253.344.465.682.618.997.14.286.284.658.284 1.04s-.145.754-.284 1.04a6.6 6.6 0 0 1-.618.997 12.712 12.712 0 0 1-2.096 2.183C17.271 17.655 14.802 19 12 19c-2.802 0-5.27-1.345-7.002-2.78a12.712 12.712 0 0 1-2.096-2.183 6.6 6.6 0 0 1-.618-.997C2.144 12.754 2 12.382 2 12s.145-.754.284-1.04c.153-.315.365-.653.618-.997A12.714 12.714 0 0 1 4.998 7.78ZM12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" clip-rule="evenodd" />
                            </svg>
                            <svg id="currentPassword-eye-slash" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="w-6 h-6" viewBox="0 0 24 24">
                                <path d="m4 15.6 3.055-3.056A4.913 4.913 0 0 1 7 12.012a5.006 5.006 0 0 1 5-5c.178.009.356.027.532.054l1.744-1.744A8.973 8.973 0 0 0 12 5.012c-5.388 0-10 5.336-10 7A6.49 6.49 0 0 0 4 15.6Z" />
                                <path d="m14.7 10.726 4.995-5.007A.998.998 0 0 0 18.99 4a1 1 0 0 0-.71.305l-4.995 5.007a2.98 2.98 0 0 0-.588-.21l-.035-.01a2.981 2.981 0 0 0-3.584 3.583c0 .012.008.022.01.033.05.204.12.402.211.59l-4.995 4.983a1 1 0 1 0 1.414 1.414l4.995-4.983c.189.091.386.162.59.211.011 0 .021.007.033.01a2.982 2.982 0 0 0 3.584-3.584c0-.012-.008-.023-.011-.035a3.05 3.05 0 0 0-.21-.588Z" />
                                <path d="m19.821 8.605-2.857 2.857a4.952 4.952 0 0 1-5.514 5.514l-1.785 1.785c.767.166 1.55.25 2.335.251 6.453 0 10-5.258 10-7 0-1.166-1.637-2.874-2.179-3.407Z" />
                            </svg>
                        </button>
                    </div>
                    <span asp-validation-for="Input.CurrentPassword" class="text-xs text-red-500"></span>
                </div>

                <!-- New Password -->
                <div>
                    <label for="newPassword" class="block text-sm font-medium text-gray-700 mb-1">New Password</label>
                    <div class="relative">
                           <input asp-for="Input.NewPassword" type="password" id="newPassword" 
                               class="w-full rounded-xl border border-gray-300 px-4 py-4 pr-12 focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none placeholder:text-gray-400"
                               placeholder="Enter new password" />
                        <button type="button" onclick="togglePassword('newPassword')" 
                                class="absolute right-3 top-1/2 transform -translate-y-1/2 text-gray-400 hover:text-gray-600">
                            <svg id="newPassword-eye-open" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="w-6 h-6 hidden" viewBox="0 0 24 24">
                                <path fill-rule="evenodd" d="M4.998 7.78C6.729 6.345 9.198 5 12 5c2.802 0 5.27 1.345 7.002 2.78a12.713 12.713 0 0 1 2.096 2.183c.253.344.465.682.618.997.14.286.284.658.284 1.04s-.145.754-.284 1.04a6.6 6.6 0 0 1-.618.997 12.712 12.712 0 0 1-2.096 2.183C17.271 17.655 14.802 19 12 19c-2.802 0-5.27-1.345-7.002-2.78a12.712 12.712 0 0 1-2.096-2.183 6.6 6.6 0 0 1-.618-.997C2.144 12.754 2 12.382 2 12s.145-.754.284-1.04c.153-.315.365-.653.618-.997A12.714 12.714 0 0 1 4.998 7.78ZM12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" clip-rule="evenodd" />
                            </svg>
                            <svg id="newPassword-eye-slash" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="w-6 h-6" viewBox="0 0 24 24">
                                <path d="m4 15.6 3.055-3.056A4.913 4.913 0 0 1 7 12.012a5.006 5.006 0 0 1 5-5c.178.009.356.027.532.054l1.744-1.744A8.973 8.973 0 0 0 12 5.012c-5.388 0-10 5.336-10 7A6.49 6.49 0 0 0 4 15.6Z" />
                                <path d="m14.7 10.726 4.995-5.007A.998.998 0 0 0 18.99 4a1 1 0 0 0-.71.305l-4.995 5.007a2.98 2.98 0 0 0-.588-.21l-.035-.01a2.981 2.981 0 0 0-3.584 3.583c0 .012.008.022.01.033.05.204.12.402.211.59l-4.995 4.983a1 1 0 1 0 1.414 1.414l4.995-4.983c.189.091.386.162.59.211.011 0 .021.007.033.01a2.982 2.982 0 0 0 3.584-3.584c0-.012-.008-.023-.011-.035a3.05 3.05 0 0 0-.21-.588Z" />
                                <path d="m19.821 8.605-2.857 2.857a4.952 4.952 0 0 1-5.514 5.514l-1.785 1.785c.767.166 1.55.25 2.335.251 6.453 0 10-5.258 10-7 0-1.166-1.637-2.874-2.179-3.407Z" />
                            </svg>
                        </button>
                    </div>
                    <span asp-validation-for="Input.NewPassword" class="text-xs text-red-500"></span>
                </div>

                <!-- Confirm Password -->
                <div>
                    <label for="confirmPassword" class="block text-sm font-medium text-gray-700 mb-1">Confirm New Password</label>
                    <div class="relative">
                           <input asp-for="Input.ConfirmPassword" type="password" id="confirmPassword" 
                               class="w-full rounded-xl border border-gray-300 px-4 py-4 pr-12 focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none placeholder:text-gray-400"
                               placeholder="Confirm new password" />
                        <button type="button" onclick="togglePassword('confirmPassword')" 
                                class="absolute right-3 top-1/2 transform -translate-y-1/2 text-gray-400 hover:text-gray-600">
                            <svg id="confirmPassword-eye-open" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="w-6 h-6 hidden" viewBox="0 0 24 24">
                                <path fill-rule="evenodd" d="M4.998 7.78C6.729 6.345 9.198 5 12 5c2.802 0 5.27 1.345 7.002 2.78a12.713 12.713 0 0 1 2.096 2.183c.253.344.465.682.618.997.14.286.284.658.284 1.04s-.145.754-.284 1.04a6.6 6.6 0 0 1-.618.997 12.712 12.712 0 0 1-2.096 2.183C17.271 17.655 14.802 19 12 19c-2.802 0-5.27-1.345-7.002-2.78a12.712 12.712 0 0 1-2.096-2.183 6.6 6.6 0 0 1-.618-.997C2.144 12.754 2 12.382 2 12s.145-.754.284-1.04c.153-.315.365-.653.618-.997A12.714 12.714 0 0 1 4.998 7.78ZM12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" clip-rule="evenodd" />
                            </svg>
                            <svg id="confirmPassword-eye-slash" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="w-6 h-6" viewBox="0 0 24 24">
                                <path d="m4 15.6 3.055-3.056A4.913 4.913 0 0 1 7 12.012a5.006 5.006 0 0 1 5-5c.178.009.356.027.532.054l1.744-1.744A8.973 8.973 0 0 0 12 5.012c-5.388 0-10 5.336-10 7A6.49 6.49 0 0 0 4 15.6Z" />
                                <path d="m14.7 10.726 4.995-5.007A.998.998 0 0 0 18.99 4a1 1 0 0 0-.71.305l-4.995 5.007a2.98 2.98 0 0 0-.588-.21l-.035-.01a2.981 2.981 0 0 0-3.584 3.583c0 .012.008.022.01.033.05.204.12.402.211.59l-4.995 4.983a1 1 0 1 0 1.414 1.414l4.995-4.983c.189.091.386.162.59.211.011 0 .021.007.033.01a2.982 2.982 0 0 0 3.584-3.584c0-.012-.008-.023-.011-.035a3.05 3.05 0 0 0-.21-.588Z" />
                                <path d="m19.821 8.605-2.857 2.857a4.952 4.952 0 0 1-5.514 5.514l-1.785 1.785c.767.166 1.55.25 2.335.251 6.453 0 10-5.258 10-7 0-1.166-1.637-2.874-2.179-3.407Z" />
                            </svg>
                        </button>
                    </div>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-xs text-red-500"></span>
                    <div id="passwordMatch" class="text-xs mt-1 hidden"></div>
                </div>

                <!-- Password Requirements - Exact style from your example -->
                <div class="mt-4 p-4 bg-gray-50 rounded-xl border border-gray-100">
                    <h4 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Password Requirements</h4>
                    <ul class="space-y-1 text-sm text-gray-600">
                        <li class="flex items-center gap-2">
                            <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                            </svg>
                            At least 12 characters
                        </li>
                        <li class="flex items-center gap-2">
                            <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                            </svg>
                            One uppercase letter & one lowercase letter
                        </li>
                        <li class="flex items-center gap-2">
                            <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                            </svg>
                            One number & one special character
                        </li>
                    </ul>
                </div>

                <!-- CAPTCHA partial (only if not forced) -->
                @if (!Model.IsForced)
                {
                    <div class="mt-4">
                        <partial name="_Captcha" />
                    </div>
                }

                <!-- Submit Button -->
                <button type="submit" 
                        class="w-full py-2.5 px-4 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg text-sm transition-colors">
                    <i class="fas fa-key mr-2"></i>
                    Change Password
                </button>
            </form>

            <!-- Back to Dashboard Link -->
            @if (!Model.IsForced)
            {
                <div class="mt-4 text-center">
                    <a href="/Auth/Logout" class="text-sm text-gray-500 hover:text-gray-700">
                        <i class="fas fa-sign-out-alt mr-1"></i>
                        Sign Out
                    </a>
                </div>
            }
        </div>

        <!-- Bottom Logo -->
        <div class="mt-6 text-center">
            <img src="~/images/logo.png" class="h-8 mx-auto opacity-75" alt="PayRex Logo" />
            <p class="text-xs text-gray-400 mt-2">© 2026 PayRex. All rights reserved.</p>
        </div>

        <!-- Password Change Success Modal (copied style from Employees.cshtml) -->
        <div id="passwordSuccessModal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-hidden="true">
            <div class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm transition-opacity" aria-hidden="true" onclick="hidePasswordSuccessModal()"></div>
            <div class="flex min-h-full items-center justify-center p-2 sm:p-4 text-center">
                <div class="relative transform overflow-hidden rounded-lg bg-white text-left shadow-xl transition-all w-full sm:w-[90%] md:w-[60%] lg:w-[50%] max-w-md mx-auto">
                    <!-- Header -->
                    <div class="flex items-center justify-between border-b border-gray-200 bg-white px-4 py-3 sm:px-6 sm:py-4 md:px-6 md:py-4">
                        <h3 class="text-base sm:text-lg font-semibold text-gray-900">
                            Password Changed
                        </h3>
                        <button type="button" onclick="hidePasswordSuccessModal()" class="rounded-lg p-1.5 text-gray-400 hover:bg-gray-100 hover:text-gray-500">
                            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
                        </button>
                    </div>
                    <!-- Body -->
                    <div class="px-4 py-4 sm:px-6 sm:py-5 md:px-6 md:py-6">
                        <div class="text-center">
                            <p class="mb-4 text-sm text-gray-700">
                                Your password has been changed successfully.<br />
                                You will be logged out and need to log in with your new credentials.
                            </p>
                            <div class="flex justify-center gap-3">
                                <button type="button" onclick="proceedLogoutAfterPasswordChange()" class="inline-flex items-center justify-center px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 focus:ring-2 focus:ring-blue-300">
                                    Continue to Login
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Password toggle using SVG eye icons (same behavior as Login)
        function togglePassword(inputId) {
            var input = document.getElementById(inputId);
            var eyeOpen = document.getElementById(inputId + '-eye-open');
            var eyeSlash = document.getElementById(inputId + '-eye-slash');

            if (!input) return;

            if (input.type === 'password') {
                input.type = 'text';
                if (eyeOpen) eyeOpen.classList.remove('hidden');
                if (eyeSlash) eyeSlash.classList.add('hidden');
            } else {
                input.type = 'password';
                if (eyeOpen) eyeOpen.classList.add('hidden');
                if (eyeSlash) eyeSlash.classList.remove('hidden');
            }
        }

        // Simple password match checker
        var newPwd = document.getElementById('newPassword');
        var confirmPwd = document.getElementById('confirmPassword');
        var matchMsg = document.getElementById('passwordMatch');

        if (newPwd && confirmPwd && matchMsg) {
            function checkMatch() {
                if (confirmPwd.value.length > 0) {
                    if (newPwd.value === confirmPwd.value) {
                        matchMsg.className = 'text-xs text-green-500 mt-1 block';
                        matchMsg.textContent = '✓ Passwords match';
                    } else {
                        matchMsg.className = 'text-xs text-red-500 mt-1 block';
                        matchMsg.textContent = '✗ Passwords do not match';
                    }
                } else {
                    matchMsg.className = 'text-xs mt-1 hidden';
                }
            }
            
            newPwd.addEventListener('input', checkMatch);
            confirmPwd.addEventListener('input', checkMatch);
        }

        @if (Model.IsForced)
        {
            <text>
            // Load company branding for forced password change
            document.addEventListener('DOMContentLoaded', function() {
                var token = localStorage.getItem('jwtToken') || sessionStorage.getItem('jwtToken');
                
                if (token) {
                    try {
                        var parts = token.split('.');
                        var payload = JSON.parse(atob(parts[1]));
                        
                        // Update company name if element exists
                        var companyNameEl = document.getElementById('companyNameText');
                        if (companyNameEl && payload.companyName) {
                            companyNameEl.innerHTML = payload.companyName;
                        }
                        
                        // Update company logo if element exists
                        var logoImg = document.getElementById('companyLogoImg');
                        if (logoImg && payload.companyLogo) {
                            logoImg.src = payload.companyLogo;
                            logoImg.style.display = 'block';
                        }
                        
                        // Update employee name if element exists
                        var employeeNameEl = document.getElementById('employeeNameText');
                        if (employeeNameEl) {
                            var firstName = payload.given_name || payload.firstName || '';
                            var lastName = payload.family_name || payload.lastName || '';
                            if (firstName || lastName) {
                                employeeNameEl.innerHTML = 'Hello, ' + firstName + ' ' + lastName;
                            }
                        }
                    } catch (e) {
                        console.log('Error parsing token:', e);
                    }
                }
            });
            </text>
        }
    </script>
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                showPasswordSuccessModal();
            });
        </script>
    }
    <script>
        function showPasswordSuccessModal() {
            document.getElementById('passwordSuccessModal').classList.remove('hidden');
        }
        function hidePasswordSuccessModal() {
            document.getElementById('passwordSuccessModal').classList.add('hidden');
        }
        function proceedLogoutAfterPasswordChange() {
            window.location.href = '/Auth/Logout';
        }
    </script>
}