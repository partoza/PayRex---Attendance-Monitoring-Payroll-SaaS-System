@page
@model PayRex.Web.Pages.Auth.LoginModel
@inject Microsoft.Extensions.Configuration.IConfiguration AppConfig
@{
    Layout = "~/Pages/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Login";
}

<!-- Left brand panel (kept from original page) -->
<div class="flex flex-col justify-center px-4 lg:px-16 brand-panel-bg items-center h-48 lg:h-auto">
 <div class="text-center w-full flex justify-center items-center">
 <img src="~/images/logo.png" class="w-1/3 lg:w-3/4 max-w-xs lg:max-w-none drop-shadow-[0_0_60px_rgba(255,255,255,1)]" />
 </div>
</div>

<!-- Right login panel (kept from original page) -->
<div class="flex flex-col justify-center items-center px-6 lg:px-12 py-12`">
 <div class="w-10/12 lg:w-8/12 mx-3 mx-lg-5 px-4">
 <div class="login-container">
 <h1 class="text-4xl font-bold text-primary mb-2 text-md-center">Welcome Back</h1>
 <p class="text-gray-500 text-lg mb-8">Log in to access your payroll and attendance dashboard.</p>

 <div class="bg-white rounded-2xl shadow-lg p-8 text-left">
 <div id="globalError" class="mb-4 rounded-lg bg-red-100 text-red-700 px-4 py-3 text-sm @((string.IsNullOrEmpty(Model.ErrorMessage) || Model.IsLockedOut) ? "hidden" : "")">
 @Model.ErrorMessage
 </div>

 @if (Model.IsLockedOut)
 {
 <div id="lockoutMessage" class="mb-4 rounded-lg bg-yellow-100 text-yellow-700 px-4 py-3 text-sm">
 <p><strong>Account Locked. </strong>Too many logged in attempts.</p>
 <div class="text-sm text-yellow-800 mt-1">Try again in <span id="lockoutTimer" data-seconds="@Model.LockoutRemainingSeconds">@Model.LockoutRemainingSeconds</span> seconds.</div>
 </div>
 }

 <form id="loginForm" method="post" class="space-y-6">
 @Html.AntiForgeryToken()
 <div id="captchaError" class="hidden"></div>

 <div>
 <label asp-for="Input.Email" class="block text-base font-medium text-gray-700 mb-1">Email</label>
                        <input asp-for="Input.Email" class="w-full rounded-xl border border-gray-300 px-4 py-4 focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none placeholder:text-gray-400" placeholder="john@example.com" />
 <span asp-validation-for="Input.Email" class="text-red-500 text-sm"></span>
 </div>

 <div>
 <label asp-for="Input.Password" class="block text-base font-medium text-gray-700 mb-1">Password</label>
 <div class="relative">
                            <input asp-for="Input.Password" id="password" type="password" class="w-full rounded-xl border border-gray-300 px-4 py-4 pr-12 focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none placeholder:text-gray-400" placeholder="Enter your password" />
                            <button type="button" id="togglePasswordBtn" onclick="togglePassword()" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
                                <!-- Eye Open (visible when password is hidden) -->
                                <svg id="eye-open" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="w-6 h-6 hidden" viewBox="0 0 24 24">
                                    <path fill-rule="evenodd" d="M4.998 7.78C6.729 6.345 9.198 5 12 5c2.802 0 5.27 1.345 7.002 2.78a12.713 12.713 0 0 1 2.096 2.183c.253.344.465.682.618.997.14.286.284.658.284 1.04s-.145.754-.284 1.04a6.6 6.6 0 0 1-.618.997 12.712 12.712 0 0 1-2.096 2.183C17.271 17.655 14.802 19 12 19c-2.802 0-5.27-1.345-7.002-2.78a12.712 12.712 0 0 1-2.096-2.183 6.6 6.6 0 0 1-.618-.997C2.144 12.754 2 12.382 2 12s.145-.754.284-1.04c.153-.315.365-.653.618-.997A12.714 12.714 0 0 1 4.998 7.78ZM12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" clip-rule="evenodd" />
                                </svg>

                                <!-- Eye Slash (visible when password is visible) -->
                                <svg id="eye-slash" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="w-6 h-6" viewBox="0 0 24 24">
                                    <path d="m4 15.6 3.055-3.056A4.913 4.913 0 0 1 7 12.012a5.006 5.006 0 0 1 5-5c.178.009.356.027.532.054l1.744-1.744A8.973 8.973 0 0 0 12 5.012c-5.388 0-10 5.336-10 7A6.49 6.49 0 0 0 4 15.6Z" />
                                    <path d="m14.7 10.726 4.995-5.007A.998.998 0 0 0 18.99 4a1 1 0 0 0-.71.305l-4.995 5.007a2.98 2.98 0 0 0-.588-.21l-.035-.01a2.981 2.981 0 0 0-3.584 3.583c0 .012.008.022.01.033.05.204.12.402.211.59l-4.995 4.983a1 1 0 1 0 1.414 1.414l4.995-4.983c.189.091.386.162.59.211.011 0 .021.007.033.01a2.982 2.982 0 0 0 3.584-3.584c0-.012-.008-.023-.011-.035a3.05 3.05 0 0 0-.21-.588Z" />
                                    <path d="m19.821 8.605-2.857 2.857a4.952 4.952 0 0 1-5.514 5.514l-1.785 1.785c.767.166 1.55.25 2.335.251 6.453 0 10-5.258 10-7 0-1.166-1.637-2.874-2.179-3.407Z" />
                                </svg>
                            </button>
 </div>
 <span asp-validation-for="Input.Password" class="text-red-500 text-sm"></span>
 </div>

 <div class="flex flex-col sm:flex-row justify-between items-start gap-2">
 <div class="mt-4">
 </div>
 <div>
 <a asp-page="/Auth/ForgotPassword" class="text-sm text-primary hover:underline">Forgot password?</a>
 </div>
 </div>
  <div class="g-recaptcha my-4" data-sitekey="@AppConfig["Recaptcha:SiteKey"]"></div>

 <button id="submitButton" type="submit" class="w-full bg-primary text-white py-4 rounded-xl font-semibold hover:brightness-95 transition shadow flex items-center justify-center @(Model.IsLockedOut ? "opacity-60 pointer-events-none cursor-not-allowed" : "")" @(Model.IsLockedOut ? "disabled=\"disabled\"" : "") aria-disabled="@(Model.IsLockedOut ? "true" : "false")">
 <div role="status" id="spinner" class="hidden">
 <svg aria-hidden="true" class="w-4 h-4 me-2 text-primary animate-spin fill-white" viewBox="00100101" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M10050.5908C10078.205177.6142100.59150100.591C22.3858100.591078.2051050.5908C022.976622.38580.59082500.59082C77.61420.5908210022.976610050.5908ZM9.0814450.5908C9.0814473.189527.401391.50945091.5094C72.598791.509490.918673.189590.918650.5908C90.918627.992172.59879.67226509.67226C27.40139.672269.0814427.99219.0814450.5908Z" fill="currentColor" /><path d="M93.967639.0409C96.39338.403897.862435.911697.007933.5539C95.293228.822792.87124.369289.816720.348C85.845215.119280.882610.723875.21247.41289C69.54224.1019463.27541.9402556.76981.05124C51.76660.36754146.69760.44684341.73451.27873C39.26131.6932837.8134.1977838.45016.62326C39.08739.0487441.569410.471744.050510.1071C47.85119.5485551.71919.5268955.540210.0491C60.864210.776665.992812.545770.633115.2552C75.273517.964879.334721.561982.584925.841C84.917528.912186.799732.291388.181135.8758C89.08338.215891.542139.678193.967639.0409Z" fill="currentFill" /></svg>
 </div>
 <span id="btnText">Log in</span>
 </button>
 </form>
 </div>

 <div class="mt-8 text-center">
                <p class="text-gray-500">
Don't have an account?
<a asp-page="/Auth/Register" class="text-primary font-bold hover:underline">Sign up for free</a>
                </p>
            </div>
 </div>
 </div>
</div>

<!-- TOTP Modal with Backdrop -->
<div id="totpModal" tabindex="-1" aria-hidden="true" class="fixed inset-0 z-50 hidden overflow-y-auto overflow-x-hidden flex items-center justify-center">
    <!-- Backdrop with blur effect -->
    <div class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm transition-opacity" data-modal-hide="totpModal"></div>

    <!-- Modal content -->
    <div class="relative p-4 w-full max-w-md">
        <div class="relative bg-white rounded-2xl shadow-xl border border-gray-100 transform transition-all">
            <!-- Header -->
            <div class="flex items-center justify-between p-5 border-b border-gray-100">
                <div class="flex items-center gap-2">
                    <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                    </svg>
                    <h3 class="text-xl font-semibold text-gray-900">Two-Factor Authentication</h3>
                </div>
                <button type="button" class="text-gray-400 hover:text-gray-600 rounded-lg text-sm p-2 transition-colors duration-200" data-modal-hide="totpModal" onclick="window.location.href='https://localhost:7002/Auth/Login'">
                    
                    <span class="sr-only">Close</span>
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>

            <!-- Body -->
            <div class="p-6">
                <!-- Error message -->
                @if (!string.IsNullOrEmpty(Model.TotpErrorMessage))
                {
                    <div class="mb-4 rounded-xl bg-red-50 border border-red-200 text-red-700 px-4 py-3 text-sm flex items-center gap-2">
                        <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                        </svg>
                        <span>@Model.TotpErrorMessage</span>
                    </div>
                }

                <div class="flex justify-center mb-4">
                    <img src="~/images/auth-illustration.png"
                         alt="Two-factor authentication illustration"
                         class="w-32 h-32 object-contain"
                         onerror="this.onerror=null; this.src='~/images/totp-illustration.png';">
                </div>

                <!-- Info text -->
                <p class="text-sm text-gray-600 mb-6">
                    Enter the 6-digit code from your authenticator app to continue.
                </p>

                <form method="post" asp-page-handler="Totp" class="space-y-6">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="TotpEmail" value="@Model.TotpEmail" />

                    <div class="space-y-3">
                        <label class="block text-sm font-medium text-gray-700">
                            Verification Code
                        </label>

                        <!-- 6-digit input boxes -->
                        <div class="flex items-center justify-between gap-2">
                            <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*"
                                   autocomplete="off" aria-label="Digit 1"
                                   class="totp-digit w-12 h-14 text-center text-2xl font-semibold rounded-xl
                            border border-gray-200 focus:border-blue-500 focus:ring-2
                            focus:ring-blue-200 outline-none transition-all duration-200
                            bg-gray-50 focus:bg-white" />
                            <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*"
                                   autocomplete="off" aria-label="Digit 2"
                                   class="totp-digit w-12 h-14 text-center text-2xl font-semibold rounded-xl
                            border border-gray-200 focus:border-blue-500 focus:ring-2
                            focus:ring-blue-200 outline-none transition-all duration-200
                            bg-gray-50 focus:bg-white" />
                            <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*"
                                   autocomplete="off" aria-label="Digit 3"
                                   class="totp-digit w-12 h-14 text-center text-2xl font-semibold rounded-xl
                            border border-gray-200 focus:border-blue-500 focus:ring-2
                            focus:ring-blue-200 outline-none transition-all duration-200
                            bg-gray-50 focus:bg-white" />

                            <div class="w-2 text-center text-gray-400 font-bold">•</div>

                            <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*"
                                   autocomplete="off" aria-label="Digit 4"
                                   class="totp-digit w-12 h-14 text-center text-2xl font-semibold rounded-xl
                            border border-gray-200 focus:border-blue-500 focus:ring-2
                            focus:ring-blue-200 outline-none transition-all duration-200
                            bg-gray-50 focus:bg-white" />
                            <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*"
                                   autocomplete="off" aria-label="Digit 5"
                                   class="totp-digit w-12 h-14 text-center text-2xl font-semibold rounded-xl
                            border border-gray-200 focus:border-blue-500 focus:ring-2
                            focus:ring-blue-200 outline-none transition-all duration-200
                            bg-gray-50 focus:bg-white" />
                            <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*"
                                   autocomplete="off" aria-label="Digit 6"
                                   class="totp-digit w-12 h-14 text-center text-2xl font-semibold rounded-xl
                            border border-gray-200 focus:border-blue-500 focus:ring-2
                            focus:ring-blue-200 outline-none transition-all duration-200
                            bg-gray-50 focus:bg-white" />
                        </div>

                        <!-- Hint text -->
                        <div class="flex items-center gap-1 text-xs text-gray-500">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            <span>Only numbers allowed. Code auto-fills as you type.</span>
                        </div>

                        <!-- Hidden combined input -->
                        <input asp-for="TotpInput.TotpCode" id="totpCombined" type="hidden" />
                        <span asp-validation-for="TotpInput.TotpCode" class="text-red-500 text-sm block mt-1"></span>
                    </div>

                    <!-- Actions -->
                    <div class="flex flex-col sm:flex-row gap-3 justify-center">

                        <button type="submit" 
                                class="px-6 py-2.5 rounded-xl bg-gray-100 text-gray-700 font-medium
                           hover:bg-gray-200 focus:ring-4 focus:ring-gray-100
                           transition-all duration-200 border border-gray-200
                           flex items-center justify-center gap-2 order-1 sm:order-2" onclick="window.location.href='https://localhost:7002/Auth/Login'" data-modal-hide="totpModal">
                           

                            Cancel
                        </button>

                        <button type="submit"
                                class="px-6 py-2.5 rounded-xl bg-blue-600 text-white font-medium
                           hover:bg-blue-700 focus:ring-4 focus:ring-blue-200
                           transition-all duration-200 shadow-lg shadow-blue-600/20
                           flex items-center justify-center gap-2 order-2 sm:order-1">
                            
                            Verify
                        </button>

                        
                    </div>

                    <!-- Additional help -->
                    <p class="text-xs text-center text-gray-400 pt-2">
                        Having trouble? Contact support for assistance.
                    </p>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
 <script>
    document.addEventListener('DOMContentLoaded', function() {
        var form = document.getElementById('loginForm');
        if (!form) return;

        form.addEventListener('submit', function(e) {
            var resp = (typeof grecaptcha !== 'undefined') ? grecaptcha.getResponse() : '';
            if (!resp) {
                // If there's an element for sitekey but it's empty, warn the dev
                if (!document.querySelector('.g-recaptcha').getAttribute('data-sitekey')) {
                    console.error('reCAPTCHA SiteKey is missing from configuration');
                    return true; // Allow submission for debugging if key is missing
                }
                
                e.preventDefault();
                var capErr = document.getElementById('captchaError');
                if (capErr) {
                    capErr.classList.remove('hidden');
                    capErr.classList.add('mb-4','rounded-lg','bg-red-100','text-red-700','px-4','py-3','text-sm');
                    capErr.textContent = 'Please complete the CAPTCHA';
                }
                return false;
            }
        });
    });
         function togglePassword() {
            var pwd = document.getElementById('password');
            var eyeOpen = document.getElementById('eye-open');
            var eyeSlash = document.getElementById('eye-slash');

            if (!pwd) return;

            if (pwd.type === 'password') {
                pwd.type = 'text';
                if (eyeOpen) eyeOpen.classList.remove('hidden');
                if (eyeSlash) eyeSlash.classList.add('hidden');
            } else {
                pwd.type = 'password';
                if (eyeOpen) eyeOpen.classList.add('hidden');
                if (eyeSlash) eyeSlash.classList.remove('hidden');
            }
        }

        document.addEventListener('DOMContentLoaded', function() {
            // ========== MODAL INITIALIZATION ==========
            initializeModal();

            // ========== TOTP DIGIT HANDLING ==========
            initializeTotpInputs();
        });

        /**
         * Initialize and show TOTP modal if required
         */
        function initializeModal() {
            const requiresTotp = @(Model.RequireTotp.ToString().ToLower());

            if (!requiresTotp) return;

            const modalEl = document.getElementById('totpModal');
            if (!modalEl) return;

            // Try using Flowbite Modal if available
            if (typeof Modal !== 'undefined') {
                try {
                    const modal = new Modal(modalEl, {
                        backdrop: 'static',
                        closable: false // Prevent closing by clicking outside
                    });

                    modal.show();

                    // Enhance backdrop with blur effect
                    setTimeout(() => {
                        const backdrop = document.querySelector('[modal-backdrop]');
                        if (backdrop) {
                            backdrop.classList.add('backdrop-blur-sm', 'bg-black/40', 'transition-all', 'duration-300');
                        }
                    }, 0);

                    // Focus first digit after modal animation
                    setTimeout(() => {
                        focusFirstDigit();
                    }, 150);

                } catch (error) {
                    console.error('Modal initialization error:', error);
                    // Fallback: just show the modal
                    modalEl.classList.remove('hidden');
                    focusFirstDigit();
                }
            } else {
                // Fallback if Flowbite Modal is not defined
                modalEl.classList.remove('hidden');
                focusFirstDigit();
            }
        }

        // ========== LOCKOUT COUNTDOWN HANDLER ==========
        function startLockoutTimer(initialSeconds) {
            const timerEl = document.getElementById('lockoutTimer');
            const submitBtn = document.getElementById('submitButton');
            const lockMsg = document.getElementById('lockoutMessage');

            let seconds = Number(initialSeconds || (timerEl ? timerEl.dataset.seconds : 0));
            if (!timerEl || seconds <= 0) return;

            // Update display immediately
            timerEl.textContent = seconds;

            const iv = setInterval(() => {
                seconds = Math.max(0, seconds - 1);
                if (seconds <= 0) {
                    clearInterval(iv);
                    // Hide lockout message and re-enable submit
                    if (lockMsg) lockMsg.classList.add('hidden');
                    if (submitBtn) {
                        // Remove native disabled attribute
                        submitBtn.removeAttribute('disabled');
                        // Remove aria-disabled for accessibility
                        submitBtn.setAttribute('aria-disabled', 'false');
                        // Remove visual disabled styles added server-side
                        submitBtn.classList.remove('opacity-60', 'pointer-events-none', 'cursor-not-allowed');
                    }
                    // Clear timer display
                    if (timerEl) {
                        timerEl.textContent = '0';
                        timerEl.removeAttribute('data-seconds');
                    }
                } else {
                    timerEl.textContent = seconds;
                }
            }, 1000);
        }

        // Kick off lockout timer if server indicated lockout
        document.addEventListener('DOMContentLoaded', function() {
            const timerEl = document.getElementById('lockoutTimer');
            if (timerEl) {
                const secs = parseInt(timerEl.dataset.seconds || '0', 10);
                if (secs > 0) {
                    // ensure submit is disabled while locked
                    const submitBtn = document.getElementById('submitButton');
                    if (submitBtn) submitBtn.setAttribute('disabled', '');
                    startLockoutTimer(secs);
                }
            }
        });

        /**
         * Focus the first TOTP digit input
         */
        function focusFirstDigit() {
            const firstDigit = document.querySelector('#totpModal .totp-digit');
            if (firstDigit) {
                firstDigit.focus();
            }
        }

        /**
         * Initialize TOTP digit inputs with auto-advance and validation
         */
        function initializeTotpInputs() {
            const digits = Array.from(document.querySelectorAll('#totpModal .totp-digit'));
            const hiddenInput = document.getElementById('totpCombined');

            if (!digits.length || !hiddenInput) return;

            // Constants for key handling
            const ALLOWED_KEYS = [
                'Backspace', 'Tab', 'ArrowLeft', 'ArrowRight',
                'Delete', 'Home', 'End', 'Enter'
            ];

            /**
             * Update hidden input with combined code
             */
            function updateHiddenCode() {
                const code = digits
                    .map(d => (d.value || '').replace(/\D/g, ''))
                    .join('');
                hiddenInput.value = code;

                // Dispatch custom event for validation
                hiddenInput.dispatchEvent(new Event('input', { bubbles: true }));

                return code;
            }

            /**
             * Handle input event for each digit
             */
            function handleInput(e) {
                const input = e.target;
                const index = digits.indexOf(input);

                // Clean value - only keep first digit if multiple pasted
                let value = input.value.replace(/\D/g, '');

                if (value.length > 1) {
                    // Handle case where user types fast and enters multiple digits
                    const remainingChars = value.split('');
                    for (let i = index; i < digits.length && remainingChars.length; i++) {
                        digits[i].value = remainingChars.shift();
                    }
                    // Focus on appropriate next field
                    const nextFocusIndex = Math.min(index + value.length, digits.length - 1);
                    digits[nextFocusIndex].focus();
                } else {
                    input.value = value.slice(0, 1);

                    // Auto-advance to next digit if available
                    if (value && index < digits.length - 1) {
                        digits[index + 1].focus();
                    }
                }

                updateHiddenCode();
            }

            /**
             * Handle keydown events for navigation and validation
             */
            function handleKeyDown(e) {
                const input = e.target;
                const index = digits.indexOf(input);
                const key = e.key;

                // Allow navigation keys
                if (ALLOWED_KEYS.includes(key)) {
                    // Handle backspace navigation
                    if (key === 'Backspace' && !input.value && index > 0) {
                        digits[index - 1].focus();
                    }
                    // Handle arrow keys
                    if (key === 'ArrowLeft' && index > 0) {
                        digits[index - 1].focus();
                        e.preventDefault();
                    }
                    if (key === 'ArrowRight' && index < digits.length - 1) {
                        digits[index + 1].focus();
                        e.preventDefault();
                    }
                    return;
                }

                // Prevent non-numeric input
                if (!/^[0-9]$/.test(key)) {
                    e.preventDefault();
                }
            }

            /**
             * Handle paste events
             */
            function handlePaste(e) {
                e.preventDefault();

                // Get pasted text and clean it
                const pastedText = (e.clipboardData || window.clipboardData).getData('text');
                const numbers = (pastedText || '').replace(/\D/g, '').split('');

                if (!numbers.length) return;

                // Fill digits with pasted numbers
                digits.forEach((digit, i) => {
                    digit.value = numbers[i] || '';
                });

                // Update hidden input
                updateHiddenCode();

                // Focus appropriate field
                const focusIndex = Math.min(numbers.length, digits.length - 1);
                digits[focusIndex].focus();
            }

            /**
             * Handle form submission
             */
            function handleFormSubmit(e) {
                updateHiddenCode();

                // Optional: Validate all digits are filled
                const code = hiddenInput.value;
                if (code.length !== digits.length) {
                    e.preventDefault();
                    highlightEmptyDigits();
                    showValidationMessage('Please enter all 6 digits of your verification code');
                    return false;
                }
            }

            /**
             * Highlight empty digits for visual feedback
             */
            function highlightEmptyDigits() {
                digits.forEach(digit => {
                    if (!digit.value) {
                        digit.classList.add('border-red-500', 'bg-red-50');
                        setTimeout(() => {
                            digit.classList.remove('border-red-500', 'bg-red-50');
                        }, 2000);
                    }
                });
            }

            /**
             * Show validation message
             */
            function showValidationMessage(message) {
                // Check if error message already exists
                let errorMsg = document.querySelector('#totpModal .totp-error-message');

                if (!errorMsg) {
                    errorMsg = document.createElement('div');
                    errorMsg.className = 'totp-error-message text-sm text-red-600 mt-2 text-center';
                    const form = document.querySelector('#totpModal form');
                    if (form) {
                        form.appendChild(errorMsg);
                    }
                }

                errorMsg.textContent = message;

                // Remove after 3 seconds
                setTimeout(() => {
                    if (errorMsg) {
                        errorMsg.remove();
                    }
                }, 3000);
            }

            // Attach event listeners to each digit input
            digits.forEach((input, index) => {
                // Remove any existing listeners (cleanup)
                input.removeEventListener('input', handleInput);
                input.removeEventListener('keydown', handleKeyDown);
                input.removeEventListener('paste', handlePaste);

                // Add fresh listeners
                input.addEventListener('input', handleInput);
                input.addEventListener('keydown', handleKeyDown);
                input.addEventListener('paste', handlePaste);

                // Set input attributes for better mobile experience
                input.setAttribute('inputmode', 'numeric');
                input.setAttribute('pattern', '[0-9]*');
                input.setAttribute('autocomplete', 'off');
                input.setAttribute('aria-label', `Digit ${index + 1}`);
            });

            // Find and attach form submit handler
            const form = document.querySelector('#totpModal form[asp-page-handler="Totp"]') ||
                         document.querySelector('#totpModal form');

            if (form) {
                form.removeEventListener('submit', handleFormSubmit);
                form.addEventListener('submit', handleFormSubmit);
            }

            // Optional: Add reset functionality
            const cancelButton = document.querySelector('#totpModal button[asp-page-handler="CancelTotp"]');
            if (cancelButton) {
                cancelButton.addEventListener('click', () => {
                    // Clear all digits when cancel is clicked
                    digits.forEach(d => d.value = '');
                    updateHiddenCode();
                });
            }

            // Initialize by clearing any existing values
            digits.forEach(d => d.value = '');
            updateHiddenCode();
        }

        /**
         * Optional: Add event listener for modal close to reset form
         */
        document.addEventListener('modalHidden', function() {
            // Reset all inputs when modal is hidden
            const digits = document.querySelectorAll('#totpModal .totp-digit');
            digits.forEach(d => d.value = '');

            const hiddenInput = document.getElementById('totpCombined');
            if (hiddenInput) hiddenInput.value = '';
        })
 </script>
}
