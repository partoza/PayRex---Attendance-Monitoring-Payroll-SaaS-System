@page
@model PayRex.Web.Pages.Auth.LogoutModel
@{
    ViewData["Title"] = "Logout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <h2>You have been logged out</h2>
            <p class="text-muted">Thank you for using PayRex.</p>
            <a asp-page="/Index" class="btn btn-primary mt-3">Return to Home</a>
        </div>
    </div>
</div>

<!-- Logout page intentionally left minimal; client-side clearing happens pre-submit -->
