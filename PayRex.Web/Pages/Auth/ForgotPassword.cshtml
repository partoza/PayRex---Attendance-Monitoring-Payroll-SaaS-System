@page
@model PayRex.Web.Pages.Auth.ForgotPasswordModel
@inject Microsoft.Extensions.Configuration.IConfiguration AppConfig
@{
    Layout = "~/Pages/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Forgot Password";
}

<!-- Left brand panel -->
<div class="flex flex-col justify-center px-4 lg:px-16 brand-panel-bg items-center h-48 lg:h-auto">
    <div class="text-center w-full flex justify-center items-center">
        <img src="~/images/logo.png" class="w-1/3 lg:w-3/4 max-w-xs lg:max-w-none drop-shadow-[0_0_60px_rgba(255,255,255,1)]" />
    </div>
</div>

<!-- Right forgot panel -->
<div class="flex flex-col justify-center items-center px-6 lg:px-12 py-12 forgot-panel-bg panel-glow">
    <div class="w-10/12 lg:w-8/12 mx-3 mx-lg-5 px-4">
        <div class="forgot-container">
            <h1 class="text-4xl font-bold text-primary mb-2 text-md-center">Forgot Password?</h1>
            <p class="text-gray-500 text-lg mb-8">Enter your email to receive a password reset link.</p>

            <div class="bg-white rounded-2xl shadow-lg p-8 text-left">
                @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                {
                    <div class="mb-4 rounded-lg bg-green-100 text-green-700 px-4 py-3 text-sm">
                        @Model.SuccessMessage
                    </div>
                }

                <div id="globalError" class="mb-4 rounded-lg bg-red-100 text-red-700 px-4 py-3 text-sm @(string.IsNullOrEmpty(Model.ErrorMessage) ? "hidden" : "")">
                    @Model.ErrorMessage
                </div>

                <form id="forgotForm" method="post" class="space-y-6">
                    @Html.AntiForgeryToken()
                    
                    <div>
                        <label asp-for="Input.Email" class="block text-base font-medium text-gray-700 mb-1">Email Address</label>
                        <input asp-for="Input.Email" class="w-full rounded-xl border border-gray-300 px-4 py-4 focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none placeholder:text-gray-400" placeholder="john@example.com" />
                        <span asp-validation-for="Input.Email" class="text-red-500 text-sm"></span>
                    </div>

                    <div class="g-recaptcha mt-4" data-sitekey="@AppConfig["Recaptcha:SiteKey"]"></div>

                    <button id="submitButton" type="submit" class="w-full bg-primary text-white py-4 rounded-xl font-semibold hover:brightness-95 transition shadow flex items-center justify-center">
                        <span id="btnText">Send Reset Link</span>
                    </button>
                </form>
            </div>

            <div class="mt-8 text-center">
                <p class="text-gray-500">
                    Remember your password? 
                    <a asp-page="/Auth/Login" class="text-primary font-bold hover:underline">Sign in</a>
                </p>
            </div>
        </div>
    </div>

            @section Scripts {
                <script>
                        document.addEventListener('DOMContentLoaded', function() {
                            var form = document.getElementById('forgotForm');
                            if (!form) return;
                            form.addEventListener('submit', function(e) {
                                var resp = (typeof grecaptcha !== 'undefined') ? grecaptcha.getResponse() : '';
                                if (!resp) {
                                    if (!document.querySelector('.g-recaptcha').getAttribute('data-sitekey')) {
                                        console.error('reCAPTCHA SiteKey is missing from configuration');
                                        return true;
                                    }
                                    e.preventDefault();
                                    alert('Please complete the CAPTCHA');
                                    return false;
                                }
                            });
                        });
                </script>
            }
</div>
