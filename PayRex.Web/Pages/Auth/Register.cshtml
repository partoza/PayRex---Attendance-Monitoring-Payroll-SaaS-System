@page
@model PayRex.Web.Pages.Auth.RegisterModel
@{
 Layout = "~/Pages/Shared/_AuthLayout.cshtml";
 ViewData["Title"] = "Create Account";
}

<!-- Left brand panel -->
<div class="flex flex-col justify-center px-4 lg:px-16 brand-panel-bg items-center h-48 lg:h-auto">
 <div class="text-center w-full flex justify-center items-center">
 <img src="~/images/logo.png" class="w-1/3 lg:w-3/4 max-w-xs lg:max-w-none drop-shadow-[0_0_60px_rgba(255,255,255,1)]" />
 </div>
</div>

<!-- Right register panel -->
<div class="flex flex-col justify-center items-center px-6 lg:px-12 py-12 register-panel-bg panel-glow">
 <div class="w-10/12 lg:w-8/12 mx-3 mx-lg-5 px-4">
 <div class="register-container">
 <h1 class="text-4xl font-bold text-primary mb-2 text-md-center">Create Account</h1>
 <p class="text-gray-500 text-lg mb-8">Join PayRex today and simplify your payroll.</p>

 <div class="bg-white rounded-2xl shadow-lg p-8 text-left">
 <div id="globalError" class="mb-4 rounded-lg bg-red-100 text-red-700 px-4 py-3 text-sm @(string.IsNullOrEmpty(Model.ErrorMessage) ? "hidden" : "")">
 @Model.ErrorMessage
 </div>

 <form id="registerForm" method="post" class="space-y-6">
 @Html.AntiForgeryToken()
 
 <div class="grid grid-cols-2 gap-4">
 <div>
 <label asp-for="Input.FirstName" class="block text-base font-medium text-gray-700 mb-1">First Name</label>
 <input asp-for="Input.FirstName" class="w-full rounded-xl border border-gray-300 px-4 py-4 focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none placeholder:text-gray-400" placeholder="John" />
 <span asp-validation-for="Input.FirstName" class="text-red-500 text-sm"></span>
 </div>
 <div>
 <label asp-for="Input.LastName" class="block text-base font-medium text-gray-700 mb-1">Last Name</label>
 <input asp-for="Input.LastName" class="w-full rounded-xl border border-gray-300 px-4 py-4 focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none placeholder:text-gray-400" placeholder="Doe" />
 <span asp-validation-for="Input.LastName" class="text-red-500 text-sm"></span>
 </div>
 </div>

 <div>
 <label asp-for="Input.Email" class="block text-base font-medium text-gray-700 mb-1">Email Address</label>
 <input asp-for="Input.Email" class="w-full rounded-xl border border-gray-300 px-4 py-4 focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none placeholder:text-gray-400" placeholder="john@example.com" />
 <span asp-validation-for="Input.Email" class="text-red-500 text-sm"></span>
 </div>

 <div>
 <label asp-for="Input.Password" class="block text-base font-medium text-gray-700 mb-1">Password</label>
 <div class="relative">
 <input asp-for="Input.Password" id="password" type="password" class="w-full rounded-xl border border-gray-300 px-4 py-4 pr-12 focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none placeholder:text-gray-400" placeholder="Create password" />
 <button type="button" onclick="togglePassword('password')" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
 <!-- Eye Open (visible when password is hidden) -->
 <svg id="password-eye-open" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="w-6 h-6 hidden" viewBox="0 0 24 24">
                                    <path fill-rule="evenodd" d="M4.998 7.78C6.729 6.345 9.198 5 12 5c2.802 0 5.27 1.345 7.002 2.78a12.713 12.713 0 0 1 2.096 2.183c.253.344.465.682.618.997.14.286.284.658.284 1.04s-.145.754-.284 1.04a6.6 6.6 0 0 1-.618.997 12.712 12.712 0 0 1-2.096 2.183C17.271 17.655 14.802 19 12 19c-2.802 0-5.27-1.345-7.002-2.78a12.712 12.712 0 0 1-2.096-2.183 6.6 6.6 0 0 1-.618-.997C2.144 12.754 2 12.382 2 12s.145-.754.284-1.04c.153-.315.365-.653.618-.997A12.714 12.714 0 0 1 4.998 7.78ZM12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" clip-rule="evenodd" />
 </svg>

 <!-- Eye Slash (visible when password is visible) -->
    <svg id="password-eye-slash" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="w-6 h-6" viewBox="0 0 24 24">
        <path d="m4 15.6 3.055-3.056A4.913 4.913 0 0 1 7 12.012a5.006 5.006 0 0 1 5-5c.178.009.356.027.532.054l1.744-1.744A8.973 8.973 0 0 0 12 5.012c-5.388 0-10 5.336-10 7A6.49 6.49 0 0 0 4 15.6Z" />
        <path d="m14.7 10.726 4.995-5.007A.998.998 0 0 0 18.99 4a1 1 0 0 0-.71.305l-4.995 5.007a2.98 2.98 0 0 0-.588-.21l-.035-.01a2.981 2.981 0 0 0-3.584 3.583c0 .012.008.022.01.033.05.204.12.402.211.59l-4.995 4.983a1 1 0 1 0 1.414 1.414l4.995-4.983c.189.091.386.162.59.211.011 0 .021.007.033.01a2.982 2.982 0 0 0 3.584-3.584c0-.012-.008-.023-.011-.035a3.05 3.05 0 0 0-.21-.588Z" />
        <path d="m19.821 8.605-2.857 2.857a4.952 4.952 0 0 1-5.514 5.514l-1.785 1.785c.767.166 1.55.25 2.335.251 6.453 0 10-5.258 10-7 0-1.166-1.637-2.874-2.179-3.407Z" />
    </svg>
 </button>
 </div>
 <span asp-validation-for="Input.Password" class="text-red-500 text-sm"></span>
 </div>

 <div>
 <label asp-for="Input.ConfirmPassword" class="block text-base font-medium text-gray-700 mb-1">Confirm Password</label>
 <div class="relative">
 <input asp-for="Input.ConfirmPassword" id="confirmPassword" type="password" class="w-full rounded-xl border border-gray-300 px-4 py-4 pr-12 focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none placeholder:text-gray-400" placeholder="Confirm password" />
 <button type="button" onclick="togglePassword('confirmPassword')" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
 <!-- Eye Open (visible when password is hidden) -->
 <svg id="confirmPassword-eye-open" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="w-6 h-6 hidden" viewBox="0 0 24 24">
                                    <path fill-rule="evenodd" d="M4.998 7.78C6.729 6.345 9.198 5 12 5c2.802 0 5.27 1.345 7.002 2.78a12.713 12.713 0 0 1 2.096 2.183c.253.344.465.682.618.997.14.286.284.658.284 1.04s-.145.754-.284 1.04a6.6 6.6 0 0 1-.618.997 12.712 12.712 0 0 1-2.096 2.183C17.271 17.655 14.802 19 12 19c-2.802 0-5.27-1.345-7.002-2.78a12.712 12.712 0 0 1-2.096-2.183 6.6 6.6 0 0 1-.618-.997C2.144 12.754 2 12.382 2 12s.145-.754.284-1.04c.153-.315.365-.653.618-.997A12.714 12.714 0 0 1 4.998 7.78ZM12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" clip-rule="evenodd" />

 </svg>

 <!-- Eye Slash (visible when password is visible) -->
 <svg id="confirmPassword-eye-slash" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="w-6 h-6" viewBox="0 0 24 24">
                                    <path d="m4 15.6 3.055-3.056A4.913 4.913 0 0 1 7 12.012a5.006 5.006 0 0 1 5-5c.178.009.356.027.532.054l1.744-1.744A8.973 8.973 0 0 0 12 5.012c-5.388 0-10 5.336-10 7A6.49 6.49 0 0 0 4 15.6Z" />
                                    <path d="m14.7 10.726 4.995-5.007A.998.998 0 0 0 18.99 4a1 1 0 0 0-.71.305l-4.995 5.007a2.98 2.98 0 0 0-.588-.21l-.035-.01a2.981 2.981 0 0 0-3.584 3.583c0 .012.008.022.01.033.05.204.12.402.211.59l-4.995 4.983a1 1 0 1 0 1.414 1.414l4.995-4.983c.189.091.386.162.59.211.011 0 .021.007.033.01a2.982 2.982 0 0 0 3.584-3.584c0-.012-.008-.023-.011-.035a3.05 3.05 0 0 0-.21-.588Z" />
                                    <path d="m19.821 8.605-2.857 2.857a4.952 4.952 0 0 1-5.514 5.514l-1.785 1.785c.767.166 1.55.25 2.335.251 6.453 0 10-5.258 10-7 0-1.166-1.637-2.874-2.179-3.407Z" />

                                </svg>
 </button>
 </div>
 <span asp-validation-for="Input.ConfirmPassword" class="text-red-500 text-sm"></span>
 </div>

 <div class="flex items-start gap-2">
 <input asp-for="Input.AcceptTerms" class="h-4 w-4 cursor-pointer rounded border-gray-300 text-primary focus:ring-primary" />
 <label asp-for="Input.AcceptTerms" class="text-sm text-gray-600">I agree to the <a href="/terms" class="text-primary hover:underline">terms and conditions</a></label>
 </div>
 <span asp-validation-for="Input.AcceptTerms" class="text-red-500 text-sm"></span>

 @* 
 <div class="mt-4">
 <partial name="_Captcha" />
 </div>
 *@

 <button id="submitButton" type="submit" class="w-full bg-primary text-white py-4 rounded-xl font-semibold hover:brightness-95 transition shadow flex items-center justify-center">
 <span id="btnText">Create Account</span>
 </button>
 </form>
 </div>

 <div class="mt-8 text-center">
 <p class="text-gray-500">
 Already have an account? 
 <a asp-page="/Auth/Login" class="text-primary font-bold hover:underline">Sign in</a>
 </p>
 </div>
 </div>
 </div>
</div>

@section Scripts {
 <script>
 function togglePassword(id) {
 const input = document.getElementById(id);
 const eyeOpen = document.getElementById(id + "-eye-open");
 const eyeSlash = document.getElementById(id + "-eye-slash");

 if (!input) return;

 if (input.type === "password") {
 input.type = "text";
 if (eyeOpen) eyeOpen.classList.remove('hidden');
 if (eyeSlash) eyeSlash.classList.add('hidden');
 } else {
 input.type = "password";
 if (eyeOpen) eyeOpen.classList.add('hidden');
 if (eyeSlash) eyeSlash.classList.remove('hidden');
 }
 }
 </script>
}
