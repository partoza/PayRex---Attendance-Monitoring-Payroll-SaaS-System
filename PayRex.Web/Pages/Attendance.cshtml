@page
@model PayRex.Web.Pages.AttendanceModel
@{
    ViewData["Title"] = "Attendance Monitoring";
}

<div class="max-w-8xl mx-auto px-4 sm:px-6 lg:px-8 space-y-4 sm:space-y-6">
    <input type="hidden" id="authToken" value="@Request.Cookies["PayRex.AuthToken"]" />
    <input type="hidden" id="isAttendanceConfigured" value="@Model.IsAttendanceConfigured.ToString().ToLower()" />

    <!-- ── HEADER ── -->
    <div class="bg-gradient-to-r from-blue-50 via-white to-blue-50 rounded-xl sm:rounded-2xl border border-blue-100 shadow-sm overflow-hidden relative">
        <div class="absolute top-0 right-0 -mt-16 -mr-16 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
        <div class="absolute bottom-0 left-0 -mb-16 -ml-16 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
        <div class="px-4 py-5 sm:px-8 sm:py-8 relative z-10">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                <div>
                    <h1 class="text-xl sm:text-2xl lg:text-3xl font-extrabold text-gray-900 tracking-tight">Attendance Monitoring</h1>
                    <p class="mt-1 sm:mt-2 text-sm sm:text-base text-gray-600">Track employee time logs, attendance status, and work hours.</p>
                </div>
                <div class="flex items-center gap-2 sm:gap-3 flex-wrap">
                    @if (Model.Stats.IsHoliday)
                    {
                        <span class="inline-flex items-center px-3 py-1.5 rounded-lg text-xs sm:text-sm font-bold bg-red-100 text-red-700">
                            @Model.Stats.HolidayName
                        </span>
                    }
                    <span class="inline-flex items-center px-3 sm:px-4 py-1.5 sm:py-2 rounded-lg sm:rounded-xl text-xs sm:text-sm font-semibold bg-blue-100 text-blue-700">
                        <svg class="w-3 h-3 sm:w-4 sm:h-4 mr-1.5 sm:mr-2" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
                        </svg>
                        @Model.CurrentDateRange
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- ── QUICK STATS ── -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
        <div class="bg-white rounded-xl sm:rounded-2xl p-3 sm:p-4 border border-gray-100 shadow-sm flex items-center justify-between overflow-hidden relative">
            @if (Model.Stats.IsHoliday)
            {
                <div class="absolute top-0 right-0">
                    <div class="bg-red-500 text-white text-[10px] font-bold px-2 py-0.5 rounded-bl-lg uppercase tracking-tighter">Holiday</div>
                </div>
            }
            <div>
                <p class="text-xs sm:text-sm font-medium text-gray-500">Present</p>
                <p class="text-xl sm:text-2xl font-bold text-gray-900">@Model.Stats.Present</p>
            </div>
            <div class="p-2 sm:p-3 bg-green-50 rounded-xl text-green-600">
                <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
        </div>
        <div class="bg-white rounded-xl sm:rounded-2xl p-3 sm:p-4 border border-gray-100 shadow-sm flex items-center justify-between">
            <div>
                <p class="text-xs sm:text-sm font-medium text-gray-500">Late</p>
                <p class="text-xl sm:text-2xl font-bold text-gray-900">@Model.Stats.Late</p>
            </div>
            <div class="p-2 sm:p-3 bg-yellow-50 rounded-xl text-yellow-600">
                <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
        </div>
        <div class="bg-white rounded-xl sm:rounded-2xl p-3 sm:p-4 border border-gray-100 shadow-sm flex items-center justify-between">
            <div>
                <p class="text-xs sm:text-sm font-medium text-gray-500">Absent</p>
                <p class="text-xl sm:text-2xl font-bold text-gray-900">@Model.Stats.Absent</p>
            </div>
            <div class="p-2 sm:p-3 bg-red-50 rounded-xl text-red-600">
                <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
        </div>
        <div class="bg-white rounded-xl sm:rounded-2xl p-3 sm:p-4 border border-gray-100 shadow-sm flex items-center justify-between">
            <div>
                <p class="text-xs sm:text-sm font-medium text-gray-500">On Leave</p>
                <p class="text-xl sm:text-2xl font-bold text-gray-900">@Model.Stats.OnLeave</p>
            </div>
            <div class="p-2 sm:p-3 bg-blue-50 rounded-xl text-blue-600">
                <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
            </div>
        </div>
    </div>

    <!-- ── FILTERS CARD ── -->
    <div class="bg-white rounded-xl sm:rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-4 sm:px-6 py-3 sm:py-4 border-b border-gray-100 bg-gradient-to-r from-gray-50 to-white">
            <h2 class="text-sm sm:text-base font-semibold text-gray-900 flex items-center">
                <svg class="w-4 h-4 sm:w-5 sm:h-5 mr-1.5 sm:mr-2 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M3 3a1 1 0 011-1h12a1 1 0 011 1v3a1 1 0 01-.293.707L12 11.414V15a1 1 0 01-.293.707l-2 2A1 1 0 018 17v-5.586L3.293 6.707A1 1 0 013 6V3z" clip-rule="evenodd" />
                </svg>
                Filters & Search
            </h2>
        </div>
        <div class="p-4 sm:p-5 lg:p-6">
            <div class="flex flex-col space-y-3 sm:space-y-4 md:space-y-0 md:flex-row md:items-end md:gap-3">
                <!-- Search -->
                <div class="w-full lg:flex-1">
                    <label class="block text-xs sm:text-sm font-medium text-gray-700 mb-1">Search</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-2.5 sm:pl-3 flex items-center pointer-events-none">
                            <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
                            </svg>
                        </div>
                        <input type="text" id="searchInput" onkeyup="applyFilters()"
                               class="w-full pl-8 sm:pl-10 pr-3 sm:pr-4 py-2 sm:py-2.5 border border-gray-300 rounded-lg sm:rounded-xl text-xs sm:text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all"
                               placeholder="Search by employee name or ID...">
                    </div>
                </div>

                <!-- From Date -->
                <div class="w-full md:w-36">
                    <label class="block text-xs sm:text-sm font-medium text-gray-700 mb-1">From Date</label>
                    <input type="date" id="fromDateFilter" onchange="applyFilters()"
                           class="w-full px-3 sm:px-4 py-2 sm:py-2.5 border border-gray-300 rounded-lg sm:rounded-xl text-xs sm:text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all bg-white">
                </div>
                
                <!-- To Date -->
                <div class="w-full md:w-36">
                    <label class="block text-xs sm:text-sm font-medium text-gray-700 mb-1">To Date</label>
                    <input type="date" id="toDateFilter" onchange="applyFilters()"
                           class="w-full px-3 sm:px-4 py-2 sm:py-2.5 border border-gray-300 rounded-lg sm:rounded-xl text-xs sm:text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all bg-white">
                </div>

                <!-- Status filter -->
                <div class="w-full md:w-44">
                    <label class="block text-xs sm:text-sm font-medium text-gray-700 mb-1">Status</label>
                    <select id="statusFilter" onchange="applyFilters()"
                            class="w-full px-3 sm:px-4 py-2 sm:py-2.5 border border-gray-300 rounded-lg sm:rounded-xl text-xs sm:text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all bg-white">
                        <option value="">All Statuses</option>
                        <option value="Present">Present</option>
                        <option value="Late">Late</option>
                        <option value="Absent">Absent</option>
                        <option value="On Leave">On Leave</option>
                    </select>
                </div>

                <!-- Clear -->
                <div class="w-full md:w-auto">
                    <label class="block text-xs sm:text-sm font-medium text-transparent mb-1 hidden md:block">.</label>
                    <button onclick="clearFilters()" class="w-full lg:w-auto inline-flex items-center justify-center px-4 sm:px-5 py-2 sm:py-2.5 text-xs sm:text-sm font-medium text-gray-700 bg-gray-100 rounded-lg sm:rounded-xl hover:bg-gray-200 transition-colors border border-gray-200">
                        <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 mr-1.5" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                        </svg>
                        Clear Filters
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- ── ATTENDANCE TABLE CARD ── -->
    <div class="bg-white rounded-xl sm:rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <!-- Card header -->
        <div class="px-4 sm:px-6 py-3 sm:py-4 border-b border-gray-100 bg-gradient-to-r from-gray-50 to-white">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                <div>
                    <h2 class="text-sm sm:text-base font-semibold text-gray-900">Attendance Records</h2>
                    <p class="text-xs sm:text-sm text-gray-500 mt-0.5">Current Payroll Period — @Model.CurrentDateRange</p>
                </div>
                <div class="flex flex-row items-center gap-2">
                    <!-- Page size -->
                    <select id="pageSizeSelect" class="px-3 py-2 border border-gray-300 rounded-lg text-xs sm:text-sm bg-white focus:ring-2 focus:ring-blue-500">
                        <option value="10" selected>10 per page</option>
                        <option value="25">25 per page</option>
                        <option value="50">50 per page</option>
                        <option value="100">100 per page</option>
                    </select>
                    <!-- Export PDF button -->
                    <button type="button" onclick="executeExport()" class="px-3 sm:px-4 py-2 text-xs sm:text-sm font-medium text-gray-700 bg-gray-100 rounded-lg sm:rounded-xl hover:bg-gray-200 transition-colors border border-gray-200 flex items-center shadow-sm">
                        <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 mr-1.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M5.625 1.5c-1.036 0-1.875.84-1.875 1.875v17.25c0 1.035.84 1.875 1.875 1.875h12.75c1.035 0 1.875-.84 1.875-1.875V12.75A3.75 3.75 0 0 0 16.5 9h-1.875a1.875 1.875 0 0 1-1.875-1.875V5.25A3.75 3.75 0 0 0 9 1.5H5.625Z" />
                            <path d="M12.971 1.816A5.23 5.23 0 0 1 14.25 5.25v1.875c0 .207.168.375.375.375H16.5a5.23 5.23 0 0 1 3.434 1.279 9.768 9.768 0 0 0-6.963-6.963Z" />
                        </svg>
                        Export <span class="hidden sm:inline ml-1">PDF</span>
                    </button>
                    <!-- Time In/Out button -->
                    <button type="button" onclick="openQrModal()"
                            class="inline-flex items-center justify-center px-3 sm:px-4 py-2 text-xs sm:text-sm font-medium text-white bg-blue-600 rounded-lg sm:rounded-xl hover:bg-blue-700 transition-colors border border-transparent shadow-sm">
                        <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z" />
                        </svg>
                        <span class="hidden sm:inline">Time In / </span>Time Out
                    </button>
                </div>
            </div>
        </div>

        <!-- Table -->
        <div class="overflow-x-auto">
            <table class="w-full" id="attendanceTable">
                <thead class="bg-gray-50/80">
                    <tr>
                        <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Date</th>
                        <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Employee</th>
                        <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Time In</th>
                        <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Time Out</th>
                        <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Hours</th>
                        <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
                        <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Remarks</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100" id="attendanceBody">
                    @if (Model.Records == null || !Model.Records.Any())
                    {
                        <tr>
                            <td colspan="7" class="px-4 sm:px-6 py-8 sm:py-12 text-center">
                                <div class="flex flex-col items-center justify-center">
                                    <div class="w-12 h-12 sm:w-16 sm:h-16 bg-blue-50 rounded-full flex items-center justify-center mb-3 sm:mb-4">
                                        <svg class="w-6 h-6 sm:w-8 sm:h-8 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                                        </svg>
                                    </div>
                                    <p class="text-sm sm:text-base text-gray-500 font-medium">No attendance records found</p>
                                    <p class="text-xs sm:text-sm text-gray-400 mt-1">Records will appear here after employees check in</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var record in Model.Records.OrderByDescending(r => r.Date))
                        {
                            var initial = (record.EmployeeName ?? "?").Length > 0 ? record.EmployeeName[0].ToString() : "?";
                            var statusClass = record.Status == "Present" ? "bg-green-100 text-green-700" :
                                              record.Status == "Late"    ? "bg-yellow-100 text-yellow-700" :
                                              record.Status == "Absent"  ? "bg-red-100 text-red-700" :
                                                                           "bg-blue-100 text-blue-700";
                            <tr class="hover:bg-gray-50/50 transition-colors data-row"
                                data-name="@((record.EmployeeName ?? "").ToUpper())"
                                data-date="@record.Date"
                                data-status="@record.Status">
                                <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap text-xs sm:text-sm text-gray-500 search-date">
                                    @{
                                        DateTime parsedDate;
                                        var dateDisplay = DateTime.TryParse(record.Date, out parsedDate)
                                            ? parsedDate.ToString("MMMM dd, yyyy")
                                            : record.Date;
                                    }
                                    @dateDisplay
                                </td>
                                <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap">
                                    <div class="flex items-center">
                                        <div class="w-8 h-8 sm:w-9 sm:h-9 rounded-full bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center mr-2 sm:mr-3 shadow-sm flex-shrink-0">
                                            <span class="text-xs font-bold text-white">@initial</span>
                                        </div>
                                        <div>
                                            <div class="text-xs sm:text-sm font-semibold text-gray-900 search-name">@record.EmployeeName</div>
                                            <div class="text-xs text-gray-500">ID: @record.EmployeeId</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap text-xs sm:text-sm font-medium text-gray-700">
                                    @(record.TimeIn ?? "—")
                                </td>
                                <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap text-xs sm:text-sm font-medium text-gray-700">
                                    @(record.TimeOut ?? "—")
                                </td>
                                <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap">
                                    <div class="text-xs sm:text-sm font-semibold text-gray-900">
                                        @(record.TotalHoursWorked > 0 ? record.TotalHoursWorked.ToString("F2") + "h" : "—")
                                    </div>
                                    @if (record.OvertimeHours > 0)
                                    {
                                        <div class="text-[10px] text-orange-600 font-bold">+@record.OvertimeHours.ToString("F2") OT</div>
                                    }
                                </td>
                                <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap search-status">
                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold @statusClass">
                                        @record.Status
                                    </span>
                                </td>
                                <td class="px-4 sm:px-6 py-3 sm:py-4 text-xs sm:text-sm text-gray-500">
                                    <div class="flex flex-col gap-0.5">
                                        <span>@(string.IsNullOrWhiteSpace(record.Remarks) ? "None" : record.Remarks)</span>
                                        @if (record.IsHoliday)
                                        {
                                            <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-bold bg-red-100 text-red-600 uppercase tracking-tight w-fit">
                                                @record.HolidayName
                                            </span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="px-4 sm:px-6 py-3 sm:py-4 border-t border-gray-100 bg-gray-50/50">
            <div class="flex flex-col sm:flex-row items-center justify-between gap-3">
                <div class="text-xs sm:text-sm text-gray-600" id="paginationInfo">Showing 0 to 0 of 0 records</div>
                <nav class="flex items-center gap-1 flex-wrap justify-center" id="paginationNav"></nav>
            </div>
        </div>
    </div>
</div>

<!-- ═══════════════════════════════════════════════════
     QR SCANNER MODAL  (Flowbite-style backdrop)
═══════════════════════════════════════════════════ -->
<div id="qrModal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-labelledby="qrModalTitle" role="dialog" aria-modal="true">
    <!-- Backdrop -->
    <div class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm transition-opacity" aria-hidden="true" onclick="closeQrModal()"></div>

    <div class="flex min-h-full items-center justify-center p-2 sm:p-4 text-center">
        <div class="relative transform overflow-hidden rounded-2xl bg-white text-left shadow-xl transition-all w-full max-w-sm mx-auto">
            <!-- Header -->
            <div class="flex items-center justify-between border-b border-gray-200 px-5 py-4">
                <div class="flex items-center gap-3">
                    <div class="p-2 bg-blue-50 rounded-xl text-blue-600">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z" />
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-base font-bold text-gray-900" id="qrModalTitle">Scan Employee QR</h3>
                        <p class="text-xs text-gray-500 mt-0.5">Point camera at employee QR code</p>
                    </div>
                </div>
                <button onclick="closeQrModal()" class="rounded-lg p-1.5 text-gray-400 hover:bg-gray-100 hover:text-gray-500 transition-colors">
                    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                </button>
            </div>

            <!-- Body -->
            <div class="p-5 space-y-4">
                <!-- Camera view -->
                <div>
                    <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Camera</label>
                    <div id="qrReader" class="w-full rounded-xl border-2 border-dashed border-blue-200 bg-gray-50 overflow-hidden" style="min-height:220px;"></div>
                    <div id="qrScannerStatus" class="mt-1.5 text-xs text-gray-400 text-center">Starting camera...</div>
                </div>

                <!-- Manual entry -->
                <div>
                    <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Or enter QR value manually</label>
                    <div class="flex gap-2">
                        <input type="text" id="qrInputValue"
                               class="block w-full rounded-xl border border-gray-300 shadow-sm focus:ring-blue-500 focus:border-blue-500 text-sm h-10 px-3 bg-white"
                               placeholder="e.g. 1001-0002">
                        <button type="button" onclick="previewFromInput()"
                                class="inline-flex items-center px-4 py-2 text-sm font-semibold rounded-xl text-white bg-blue-600 hover:bg-blue-700 shadow-sm transition-all whitespace-nowrap">
                            Look Up
                        </button>
                    </div>
                </div>

                <!-- Close -->
                <button onclick="closeQrModal()" class="w-full py-2.5 text-sm font-semibold text-gray-700 bg-gray-100 rounded-xl hover:bg-gray-200 transition-colors">
                    Close
                </button>
            </div>
        </div>
    </div>
</div>

