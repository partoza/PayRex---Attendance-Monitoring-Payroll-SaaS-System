<style>
@@keyframes scan {
    0%   { transform: translateY(-90px); opacity: 0; }
    50%  { opacity: 1; }
    100% { transform: translateY(90px); opacity: 0; }
}
.animate-scan { animation: scan 2s infinite linear; }
</style>

<script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>

<script>
    // ─── STATE ────────────────────────────────────────────────────────────────
    let qrScannerInstance = null;
    let qrScannerRunning  = false;
    let scanLocked     = false;
    let pendingQrValue = null;
    let currentPage    = 1;
    let pageSize       = 10;
    let filteredRows   = [];

    // ─── INIT ─────────────────────────────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', () => {
        const ps = document.getElementById('pageSizeSelect');
        if (ps) {
            pageSize = parseInt(ps.value) || 10;
            ps.addEventListener('change', () => {
                pageSize = parseInt(ps.value) || 10;
                currentPage = 1;
                applyFilters();
            });
        }
        applyFilters();
    });

    // ─── FILTERS + PAGINATION ─────────────────────────────────────────────────
    function applyFilters() {
        const search = (document.getElementById('searchInput')?.value || '').toUpperCase();
        const fromDate = document.getElementById('fromDateFilter')?.value || '';
        const toDate   = document.getElementById('toDateFilter')?.value || '';
        const status = (document.getElementById('statusFilter')?.value || '').toUpperCase();

        const table = document.getElementById('attendanceTable');
        if (!table) return;

        const rows = Array.from(table.querySelectorAll('tbody tr.data-row'));
        filteredRows = [];

        rows.forEach(row => {
            const name   = (row.dataset.name   || '');
            const rd     = (row.dataset.date   || '');
            const rs     = (row.dataset.status || '').toUpperCase();

            const matchSearch = search === '' || name.indexOf(search) > -1;
            
            let matchDate = true;
            if (fromDate || toDate) {
                const rowDate = new Date(rd);
                rowDate.setHours(0,0,0,0);
                
                if (fromDate) {
                    const fD = new Date(fromDate); fD.setHours(0,0,0,0);
                    if (rowDate < fD) matchDate = false;
                }
                if (toDate) {
                    const tD = new Date(toDate); tD.setHours(0,0,0,0);
                    if (rowDate > tD) matchDate = false;
                }
            }
            
            const matchStatus = status === '' || rs.indexOf(status) > -1;

            if (matchSearch && matchDate && matchStatus) {
                filteredRows.push(row);
            }
        });

        // Reset to page 1 if filters changed
        const totalPages = Math.max(1, Math.ceil(filteredRows.length / pageSize));
        if (currentPage > totalPages) currentPage = totalPages;
        if (currentPage < 1) currentPage = 1;

        renderPage();
        renderPagination();
    }

    function renderPage() {
        const table = document.getElementById('attendanceTable');
        if (!table) return;

        // Hide all data rows first
        table.querySelectorAll('tbody tr.data-row').forEach(r => r.style.display = 'none');

        const start = (currentPage - 1) * pageSize;
        const end   = Math.min(start + pageSize, filteredRows.length);
        for (let i = start; i < end; i++) {
            filteredRows[i].style.display = '';
        }

        // Update info
        const info = document.getElementById('paginationInfo');
        const total = filteredRows.length;
        const from  = total === 0 ? 0 : start + 1;
        const to    = Math.min(start + pageSize, total);
        if (info) info.textContent = `Showing ${from} to ${to} of ${total} records`;
    }

    function renderPagination() {
        const nav = document.getElementById('paginationNav');
        if (!nav) return;
        nav.innerHTML = '';

        const totalPages = Math.max(1, Math.ceil(filteredRows.length / pageSize));
        if (totalPages <= 1) return;

        const btn = (label, page, active = false, disabled = false) => {
            const b = document.createElement('button');
            b.innerHTML = label;
            b.className = `px-3 py-1.5 text-sm font-medium border rounded-lg transition-all ${
                active    ? 'bg-blue-600 text-white border-blue-600' :
                disabled  ? 'opacity-40 cursor-not-allowed bg-gray-100 border-gray-200' :
                            'bg-white text-gray-700 border-gray-200 hover:bg-gray-100'
            }`;
            if (!disabled && !active) b.onclick = () => { currentPage = page; renderPage(); renderPagination(); };
            return b;
        };

        nav.appendChild(btn('‹', currentPage - 1, false, currentPage === 1));

        const pages = getPageNumbers(currentPage, totalPages);
        pages.forEach(p => {
            if (p === '...') {
                const dots = document.createElement('span');
                dots.className = 'px-2 py-1.5 text-gray-400 text-sm';
                dots.textContent = '…';
                nav.appendChild(dots);
            } else {
                nav.appendChild(btn(p, p, p === currentPage));
            }
        });

        nav.appendChild(btn('›', currentPage + 1, false, currentPage === totalPages));
    }

    function getPageNumbers(current, total) {
        if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
        if (current <= 4) return [1,2,3,4,5,'...',total];
        if (current >= total - 3) return [1,'...',total-4,total-3,total-2,total-1,total];
        return [1,'...',current-1,current,current+1,'...',total];
    }

    function clearFilters() {
        const s = document.getElementById('searchInput');  if (s) s.value = '';
        const f = document.getElementById('fromDateFilter'); if (f) f.value = '';
        const t = document.getElementById('toDateFilter'); if (t) t.value = '';
        const st = document.getElementById('statusFilter'); if (st) st.value = '';
        currentPage = 1;
        applyFilters();
    }

    // ─── CONFIG MODAL ───────────────────────────────────────────────────────
    function openConfigModal() {
        document.getElementById('configRequiredModal').classList.remove('hidden');
    }
    function closeConfigModal() {
        document.getElementById('configRequiredModal').classList.add('hidden');
    }

    // ─── QR MODAL ─────────────────────────────────────────────────────────────
    function openQrModal() {
        // Block scanning if attendance schedule is not configured
        var configured = document.getElementById('isAttendanceConfigured')?.value === 'true';
        if (!configured) {
            openConfigModal();
            return;
        }
        document.getElementById('qrModal').classList.remove('hidden');
        document.getElementById('qrInputValue').value = '';
        scanLocked = false;
        startCameraScan();
    }

    function closeQrModal() {
        document.getElementById('qrModal').classList.add('hidden');
        stopCameraScan();
        scanLocked = false;
    }

    async function startCameraScan() {
        if (qrScannerRunning) return;
        const container = document.getElementById('qrReader');
        const statusEl  = document.getElementById('qrScannerStatus');
        if (!container || !window.Html5Qrcode) {
            if (statusEl) statusEl.textContent = 'Camera library failed. Use manual entry below.';
            return;
        }
        try {
            qrScannerInstance = new Html5Qrcode('qrReader');
            qrScannerRunning  = true;
            if (statusEl) statusEl.textContent = 'Camera active – point at employee QR code.';
            await qrScannerInstance.start(
                { facingMode: 'environment' },
                { fps: 10, qrbox: { width: 230, height: 230 } },
                async (decodedText) => {
                    if (scanLocked) return;
                    scanLocked = true;
                    const input = document.getElementById('qrInputValue');
                    if (input) input.value = decodedText;
                    await previewEmployee(decodedText);
                },
                () => {}
            );
        } catch (err) {
            console.error('Camera start error:', err);
            if (statusEl) statusEl.textContent = `Camera unavailable: ${err?.message || err}. Use manual entry.`;
            await stopCameraScan();
        }
    }

    async function stopCameraScan() {
        if (!qrScannerInstance) return;
        try {
            if (qrScannerRunning) await qrScannerInstance.stop();
            await qrScannerInstance.clear();
        } catch { /* ignore */ } finally {
            qrScannerInstance = null;
            qrScannerRunning  = false;
            const statusEl = document.getElementById('qrScannerStatus');
            if (statusEl) statusEl.textContent = 'Camera stopped.';
        }
    }

    // ─── PREVIEW ──────────────────────────────────────────────────────────────
    async function previewFromInput() {
        const val = document.getElementById('qrInputValue')?.value.trim();
        if (!val) { showToast('Please enter a QR code value.', 'error'); return; }
        await previewEmployee(val);
    }

    async function previewEmployee(qrValue) {
        try {
            const res = await fetch(`/Attendance?handler=Preview&qrValue=${encodeURIComponent(qrValue)}`);
            if (!res.ok) {
                const err = await res.json().catch(() => ({}));
                if (err.message === 'ATTENDANCE_NOT_CONFIGURED') {
                    closeQrModal();
                    openConfigModal();
                    return;
                }
                showToast(err.message || 'Employee not found for this QR code.', 'error');
                scanLocked = false;
                return;
            }
            const data = await res.json();
            pendingQrValue = qrValue;
            showConfirmModal(data);
        } catch (e) {
            console.error('Preview error:', e);
            showToast('Could not connect to server. Please try again.', 'error');
            scanLocked = false;
        }
    }

    // ─── CONFIRM MODAL ────────────────────────────────────────────────────────
    function showConfirmModal(data) {
        document.getElementById('empName').textContent = data.employeeName || '—';
        document.getElementById('empId').textContent   = 'ID: ' + (data.employeeId || '—');
        document.getElementById('empCurrentTime').textContent = data.currentTime || '—';
        document.getElementById('empDate').textContent = data.date || '—';

        const photo   = document.getElementById('empPhoto');
        const initial = document.getElementById('empInitial');
        if (data.profilePictureUrl) {
            photo.src = data.profilePictureUrl;
            photo.classList.remove('hidden');
            initial.classList.add('hidden');
        } else {
            photo.classList.add('hidden');
            initial.classList.remove('hidden');
            initial.textContent = (data.employeeName || '?').charAt(0).toUpperCase();
        }

        const actionEl  = document.getElementById('empAction');
        const barEl     = document.getElementById('confirmAccentBar');
        const btnLog    = document.getElementById('btnConfirmLog');
        const doneEl    = document.getElementById('empAlreadyDone');
        const timeInRow = document.getElementById('empTimeInRow');

        doneEl.classList.add('hidden');
        timeInRow.classList.add('hidden');
        btnLog.disabled = false;

        if (data.pendingAction === 'Time In') {
            actionEl.textContent = '☀️ Time In';
            actionEl.className = 'text-sm font-bold text-green-600';
            barEl.className = 'h-1.5 w-full bg-green-500';
        } else if (data.pendingAction === 'Time Out') {
            actionEl.textContent = '🌙 Time Out';
            actionEl.className = 'text-sm font-bold text-blue-600';
            barEl.className = 'h-1.5 w-full bg-blue-500';
            if (data.existingTimeIn) {
                document.getElementById('empTimeIn').textContent = data.existingTimeIn;
                timeInRow.classList.remove('hidden');
            }
        } else {
            actionEl.textContent = '✅ Already Completed';
            actionEl.className = 'text-sm font-bold text-yellow-600';
            barEl.className = 'h-1.5 w-full bg-yellow-400';
            doneEl.classList.remove('hidden');
            btnLog.disabled = true;
        }

        document.getElementById('employeeConfirmModal').classList.remove('hidden');
    }

    function cancelConfirm() {
        document.getElementById('employeeConfirmModal').classList.add('hidden');
        pendingQrValue = null;
        scanLocked = false;
        document.getElementById('qrInputValue').value = '';
    }

    // ─── LOG ATTENDANCE ───────────────────────────────────────────────────────
    async function confirmLog() {
        if (!pendingQrValue) return;
        const btn = document.getElementById('btnConfirmLog');
        btn.disabled = true;
        btn.innerHTML = '<svg class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path></svg> Logging...';

        try {
            const res = await fetch('/Attendance?handler=Scan', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ qrValue: pendingQrValue })
            });
            const data = await res.json();
            document.getElementById('employeeConfirmModal').classList.add('hidden');
            if (res.ok) {
                showToast(`✅ ${data.message}`, 'success');
                setTimeout(() => window.location.reload(), 1800);
            } else {
                if (data.message === 'ATTENDANCE_NOT_CONFIGURED') {
                    closeQrModal();
                    openConfigModal();
                } else {
                    showToast(data.message || 'Failed to log attendance.', 'error');
                }
            }
        } catch (err) {
            console.error('Log error:', err);
            showToast('Connection error. Please try again.', 'error');
        } finally {
            pendingQrValue = null;
            scanLocked = false;
            document.getElementById('qrInputValue').value = '';
            btn.disabled = false;
            btn.innerHTML = '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg> Log Attendance';
        }
    }

    // ─── EXPORT PDF ───────────────────────────────────────────────────────────
    function executeExport() {
        const search = document.getElementById('searchInput')?.value || '';
        const fromDate = document.getElementById('fromDateFilter')?.value || '';
        const toDate = document.getElementById('toDateFilter')?.value || '';
        const status = document.getElementById('statusFilter')?.value || '';
        
        document.getElementById('exportSearch').value = search;
        document.getElementById('exportFromDate').value = fromDate;
        document.getElementById('exportToDate').value = toDate;
        document.getElementById('exportStatus').value = status;
        
        if (typeof showToast === 'function') {
            showToast('Generating PDF, please wait...', 'info');
        }
        
        document.getElementById('exportForm').submit();
    }
    
    window.executeExport = executeExport;

    // ─── ENTER KEY shortcut ───────────────────────────────────────────────────
    document.getElementById('qrInputValue')?.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') previewFromInput();
    });
</script>

<form id="exportForm" method="post" asp-page-handler="ExportPdf" class="hidden">
    <input type="hidden" name="search" id="exportSearch" />
    <input type="hidden" name="fromDate" id="exportFromDate" />
    <input type="hidden" name="toDate" id="exportToDate" />
    <input type="hidden" name="status" id="exportStatus" />
</form>
