                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                Secure payment via PayMongo
            </p>
            @if (Model.Subscription?.IsExpired != true)
            {
            <button onclick="closeRenewalModal()" class="text-sm text-gray-500 hover:text-gray-700 transition-colors">Maybe later</button>
            }
        </div>
    </div>
</div>
}

@section Scripts {
<script>
    // ── Eye Toggle for Sensitive Values ──────────────────────────────────────
    const _eyeOpen = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"/><path fill-rule="evenodd" d="M1.323 11.447C2.811 6.976 7.028 3.75 12.001 3.75c4.97 0 9.185 3.223 10.675 7.69.12.362.12.752 0 1.113-1.487 4.471-5.705 7.697-10.677 7.697-4.97 0-9.186-3.223-10.675-7.69a1.762 1.762 0 0 1 0-1.113ZM17.25 12a5.25 5.25 0 1 1-10.5 0 5.25 5.25 0 0 1 10.5 0Z" clip-rule="evenodd"/></svg>`;
    const _eyeSlash = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M3.53 2.47a.75.75 0 0 0-1.06 1.06l18 18a.75.75 0 1 0 1.06-1.06l-18-18ZM22.676 12.553a11.249 11.249 0 0 1-2.631 4.31l-3.099-3.099a5.25 5.25 0 0 0-6.71-6.71L7.759 4.577a11.217 11.217 0 0 1 4.242-.827c4.97 0 9.185 3.223 10.675 7.69.12.362.12.752 0 1.113Z"/><path d="M15.75 12c0 .18-.013.357-.037.53l-4.244-4.243A3.75 3.75 0 0 1 15.75 12ZM12.53 15.713l-4.243-4.244a3.75 3.75 0 0 0 4.244 4.243Z"/><path d="M6.75 12c0-.619.107-1.213.304-1.764l-3.1-3.1a11.25 11.25 0 0 0-2.63 4.31c-.12.362-.12.752 0 1.114 1.489 4.467 5.704 7.69 10.675 7.69 1.5 0 2.933-.294 4.242-.827l-2.477-2.477A5.25 5.25 0 0 1 6.75 12Z"/></svg>`;

    function toggleVisibility(id, btn) {
        const el = document.getElementById(id);
        if (!el) return;
        const isHidden = el.dataset.hidden === 'true';
        if (isHidden) {
            el.textContent = el.dataset.value;
            el.dataset.hidden = 'false';
            btn.innerHTML = _eyeOpen;
        } else {
            el.dataset.value = el.textContent;
            el.textContent = '₱ ••••••';
            el.dataset.hidden = 'true';
            btn.innerHTML = _eyeSlash;
        }
    }

    // ── Finance Date Range Filter (Flowbite Datepicker) ──────────────────────
    document.addEventListener('DOMContentLoaded', function () {
        const fromDisplay = document.getElementById('finDateFromDisplay');
        const toDisplay = document.getElementById('finDateToDisplay');
        const fromValue = document.getElementById('finDateFromValue');
        const toValue = document.getElementById('finDateToValue');
        if (!fromDisplay || !toDisplay) return;

        fromDisplay.addEventListener('changeDate', function (e) {
            const d = e.detail.date;
            if (!d) return;
            fromValue.value = d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0');
        });

        toDisplay.addEventListener('changeDate', function (e) {
            const d = e.detail.date;
            if (!d) return;
            toValue.value = d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0');
        });
    });

    // ── Payroll Period Modal ──────────────────────────────────────────────────
    function openPeriodModal(name, startDate, endDate, status, empCount, totalNetPay) {
        document.getElementById('periodModalTitle').textContent = name || 'Payroll Period';
        const fmtDate = (d) => {
            try { return new Date(d).toLocaleDateString('en-US', { month: 'short', day: '2-digit', year: 'numeric' }); }
            catch (e) { return d || '—'; }
        };
        document.getElementById('periodModalStart').textContent = fmtDate(startDate);
        document.getElementById('periodModalEnd').textContent = fmtDate(endDate);
        document.getElementById('periodModalStatus').textContent = status || '—';
        document.getElementById('periodModalEmpCount').textContent = empCount || '—';
        const netPayEl = document.getElementById('periodModalNetPay');
        const formatted = '₱' + Number(totalNetPay).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        netPayEl.textContent = formatted;
        netPayEl.dataset.value = formatted;
        netPayEl.dataset.hidden = 'false';
        const eyeBtn = document.getElementById('periodModalEyeBtn');
        if (eyeBtn) eyeBtn.innerHTML = _eyeSlash;
        document.getElementById('periodModal').classList.remove('hidden');
    }
    function closePeriodModal() {
        document.getElementById('periodModal').classList.add('hidden');
    }

    // ── Renewal Plan Modal ──────────────────────────────────────────────────
    function openRenewalModal() {
        var modal = document.getElementById('renewalModal');
        if (modal) modal.classList.remove('hidden');
    }
    function closeRenewalModal() {
        var modal = document.getElementById('renewalModal');
        if (modal) modal.classList.add('hidden');
    }
</script>

@if (Model.UserRole == "SuperAdmin" || Model.UserRole == "Admin" || Model.UserRole == "Accountant")
{
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    if (typeof Chart === 'undefined') return;
    Chart.defaults.font.family = "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif";
    Chart.defaults.color = '#64748b';

    // ── SuperAdmin Growth Analysis Chart ──────────────────────────────
    var saCtx = document.getElementById('saGrowthChart');
    if (saCtx) {
        var growthData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SuperAdminGrowthData));
        if (growthData && growthData.length > 0) {
            var labels = growthData.map(function(d) { return d.Label || d.label; });
            var usersData = growthData.map(function(d) { return d.UserCount || d.userCount || 0; });
            var revenueData = growthData.map(function(d) { return d.Revenue || d.revenue || 0; });

            new Chart(saCtx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [
                        {
                            label: 'Total Users',
                            data: usersData,
                            borderColor: '#3b82f6',
                            backgroundColor: 'rgba(59, 130, 246, 0.08)',
                            fill: true,
                            tension: 0.4,
                            borderWidth: 3,
                            pointRadius: 0,
                            pointHoverRadius: 6,
                            pointHoverBackgroundColor: '#3b82f6',
                            pointHoverBorderColor: '#fff',
                            pointHoverBorderWidth: 3
                        },
                        {
                            label: 'Revenue (₱)',
                            data: revenueData,
                            borderColor: '#0ea5e9',
                            backgroundColor: 'rgba(14, 165, 233, 0.08)',
                            fill: true,
                            tension: 0.4,
                            borderWidth: 3,
                            pointRadius: 0,
                            pointHoverRadius: 6,
                            pointHoverBackgroundColor: '#0ea5e9',
                            pointHoverBorderColor: '#fff',
                            pointHoverBorderWidth: 3,
                            yAxisID: 'y1'
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: true,
                            position: 'top',
                            align: 'end',
                            labels: {
                                usePointStyle: true,
                                pointStyle: 'circle',
                                padding: 20,
                                font: { size: 12, weight: '600' }
                            }
                        },
                        tooltip: {
                            backgroundColor: '#fff',
                            titleColor: '#111827',
                            bodyColor: '#6b7280',
                            borderColor: '#e5e7eb',
                            borderWidth: 1,
                            padding: 12,
                            cornerRadius: 12,
                            displayColors: true,
                            callbacks: {
                                label: function(ctx) {
                                    if (ctx.dataset.yAxisID === 'y1')
                                        return ctx.dataset.label + ': ₱' + ctx.raw.toLocaleString();
                                    return ctx.dataset.label + ': ' + ctx.raw.toLocaleString();
                                }
                            }
                        }
                    },
                    interaction: { intersect: false, mode: 'index' },
                    scales: {
                        x: { grid: { display: false }, ticks: { font: { size: 11 }, color: '#94a3b8' } },
                        y: {
                            type: 'linear',
                            position: 'left',
                            grid: { color: '#f1f5f9' },
                            ticks: { font: { size: 11 } },
                            beginAtZero: true
                        },
                        y1: {
                            type: 'linear',
                            position: 'right',
                            grid: { drawOnChartArea: false },
                            ticks: {
                                font: { size: 11 },
                                callback: function(value) { return '₱' + value.toLocaleString(); }
                            },
                            beginAtZero: true
                        }
                    }
                }
            });
        } else {
            saCtx.parentElement.innerHTML = '<div class="flex items-center justify-center h-full text-sm text-gray-400">No growth data collected yet</div>';
        }
    }

    // ── Admin Yearly Finance Bar Chart ────────────────────────────────
    var finCtx = document.getElementById('yearlyFinanceChart');
    if (finCtx) {
        var yearlyData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.YearlyFinanceData));
        if (yearlyData && yearlyData.length > 0) {
            var finLabels = yearlyData.map(function(d) { return d.Month || d.month; });
            var incomeData = yearlyData.map(function(d) { return d.Income || d.income || 0; });
            var costData = yearlyData.map(function(d) { return d.Cost || d.cost || 0; });
            var profitData = yearlyData.map(function(d) { return d.Profit || d.profit || 0; });
            var govtData = yearlyData.map(function(d) { return d.GovtContributions || d.govtContributions || 0; });

            // Update legend totals
            var sum = function(arr) { return arr.reduce(function(a,b){return a+b;},0); };
            var fmtK = function(n) {
                if (n >= 1000000) return '\u20B1' + (n/1000000).toFixed(1) + 'M';
                if (n >= 1000) return '\u20B1' + (n/1000).toFixed(1) + 'K';
                return '\u20B1' + n.toLocaleString();
            };
            var elI = document.getElementById('legendYearIncome');
            var elC = document.getElementById('legendYearCost');
            var elP = document.getElementById('legendYearProfit');
            var elG = document.getElementById('legendYearGovt');
            if (elI) elI.textContent = fmtK(sum(incomeData));
            if (elC) elC.textContent = fmtK(sum(costData));
            if (elP) elP.textContent = fmtK(sum(profitData));
            if (elG) elG.textContent = fmtK(sum(govtData));

            new Chart(finCtx, {
                type: 'bar',
                data: {
                    labels: finLabels,
                    datasets: [
                        {
                            label: 'Income',
                            data: incomeData,
                            backgroundColor: '#3b82f6',
                            borderWidth: 0,
                            borderRadius: 6,
                            borderSkipped: false,
                            barPercentage: 0.75,
                            categoryPercentage: 0.8
                        },
                        {
                            label: 'Cost',
                            data: costData,
                            backgroundColor: '#ef4444',
                            borderWidth: 0,
                            borderRadius: 6,
                            borderSkipped: false,
                            barPercentage: 0.75,
                            categoryPercentage: 0.8
                        },
                        {
                            label: 'Profit',
                            data: profitData,
                            backgroundColor: '#22c55e',
                            borderWidth: 0,
                            borderRadius: 6,
                            borderSkipped: false,
                            barPercentage: 0.75,
                            categoryPercentage: 0.8
                        },
                        {
                            label: "Gov't Contributions",
                            data: govtData,
                            backgroundColor: '#f59e0b',
                            borderWidth: 0,
                            borderRadius: 6,
                            borderSkipped: false,
                            barPercentage: 0.75,
                            categoryPercentage: 0.8
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#fff',
                            titleColor: '#111827',
                            bodyColor: '#6b7280',
                            borderColor: '#e5e7eb',
                            borderWidth: 1,
                            padding: 12,
                            cornerRadius: 12,
                            displayColors: true,
                            boxWidth: 10,
                            boxHeight: 10,
                            boxPadding: 4,
                            callbacks: {
                                label: function(ctx) {
                                    return '  ' + ctx.dataset.label + ': \u20B1' + ctx.raw.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                                }
                            }
                        }
                    },
                    interaction: { intersect: false, mode: 'index' },
                    scales: {
                        x: {
                            grid: { display: false },
                            border: { display: false },
                            ticks: { font: { size: 11, weight: '500' }, color: '#94a3b8' }
                        },
                        y: {
                            grid: { color: '#f1f5f9' },
                            border: { display: false },
                            ticks: {
                                font: { size: 11 },
                                color: '#94a3b8',
                                callback: function(value) { return '\u20B1' + value.toLocaleString(); }
                            },
                            beginAtZero: true
                        }
                    }
                }
            });
        } else {
            finCtx.parentElement.innerHTML = '<div class="flex flex-col items-center justify-center h-full gap-3"><svg class="w-10 h-10 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg><p class="text-sm text-gray-400">No finance data for ' + (new Date().getFullYear()) + '</p></div>';
        }
    }
});
</script>
}
