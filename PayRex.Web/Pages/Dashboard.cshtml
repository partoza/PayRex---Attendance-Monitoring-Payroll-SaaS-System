                            <span class="text-sm font-semibold text-gray-700 group-hover:text-yellow-700">Tax &amp; Contributions</span>
                        </a>
                        <a href="/Compensation" class="flex items-center gap-3 p-3 rounded-xl border border-gray-100 hover:bg-purple-50 transition-colors group">
                            <div class="w-9 h-9 rounded-xl bg-purple-100 flex items-center justify-center"><svg class="w-4 h-4 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg></div>
                            <span class="text-sm font-semibold text-gray-700 group-hover:text-purple-700">Compensation</span>
                        </a>
                        <a href="/Payslips" class="flex items-center gap-3 p-3 rounded-xl border border-gray-100 hover:bg-indigo-50 transition-colors group">
                            <div class="w-9 h-9 rounded-xl bg-indigo-100 flex items-center justify-center"><svg class="w-4 h-4 text-indigo-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd" /></svg></div>
                            <span class="text-sm font-semibold text-gray-700 group-hover:text-indigo-700">Payslip</span>
                        </a>
                    </div>
                </div>
            }

            <!-- My Workspace Quick Links (Employee, HR, Accountant) -->
            @if (Model.UserRole == "Employee" || Model.UserRole == "HR" || Model.UserRole == "Accountant")
            {
                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                    <div class="px-5 py-4 border-b border-gray-100 flex items-center gap-2">
                        <div class="w-8 h-8 rounded-xl bg-teal-50 flex items-center justify-center">
                            <svg class="w-4 h-4 text-teal-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" /></svg>
                        </div>
                        <h2 class="text-base font-bold text-gray-900">My Workspace</h2>
                    </div>
                    <div class="p-4 space-y-2">
                        <a href="/MyAttendance" class="flex items-center gap-3 p-3 rounded-xl border border-gray-100 hover:bg-teal-50 transition-colors group">
                            <div class="w-9 h-9 rounded-xl bg-teal-100 flex items-center justify-center"><svg class="w-4 h-4 text-teal-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" /></svg></div>
                            <span class="text-sm font-semibold text-gray-700 group-hover:text-teal-700">My Attendance</span>
                        </a>
                        <a href="/EmployeePortal" class="flex items-center gap-3 p-3 rounded-xl border border-gray-100 hover:bg-purple-50 transition-colors group">
                            <div class="w-9 h-9 rounded-xl bg-purple-100 flex items-center justify-center"><svg class="w-4 h-4 text-purple-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" /></svg></div>
                            <span class="text-sm font-semibold text-gray-700 group-hover:text-purple-700">Leave Request</span>
                        </a>
                        <a href="/Payslips" class="flex items-center gap-3 p-3 rounded-xl border border-gray-100 hover:bg-indigo-50 transition-colors group">
                            <div class="w-9 h-9 rounded-xl bg-indigo-100 flex items-center justify-center"><svg class="w-4 h-4 text-indigo-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd" /></svg></div>
                            <span class="text-sm font-semibold text-gray-700 group-hover:text-indigo-700">My Payslips</span>
                        </a>
                        <a href="/Contributions" class="flex items-center gap-3 p-3 rounded-xl border border-gray-100 hover:bg-green-50 transition-colors group">
                            <div class="w-9 h-9 rounded-xl bg-green-100 flex items-center justify-center"><svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path d="M4 4a2 2 0 00-2 2v1h16V6a2 2 0 00-2-2H4z" /><path fill-rule="evenodd" d="M18 9H2v5a2 2 0 002 2h12a2 2 0 002-2V9zM4 13a1 1 0 011-1h1a1 1 0 110 2H5a1 1 0 01-1-1zm5-1a1 1 0 100 2h1a1 1 0 100-2H9z" clip-rule="evenodd" /></svg></div>
                            <span class="text-sm font-semibold text-gray-700 group-hover:text-green-700">My Contributions</span>
                        </a>
                        <a href="/EmployeeQR" class="flex items-center gap-3 p-3 rounded-xl border border-gray-100 hover:bg-gray-50 transition-colors group">
                            <div class="w-9 h-9 rounded-xl bg-gray-200 flex items-center justify-center"><svg class="w-4 h-4 text-gray-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3 4a1 1 0 011-1h3a1 1 0 011 1v3a1 1 0 01-1 1H4a1 1 0 01-1-1V4zm2 2V5h1v1H5zM3 13a1 1 0 011-1h3a1 1 0 011 1v3a1 1 0 01-1 1H4a1 1 0 01-1-1v-3zm2 2v-1h1v1H5zM13 3a1 1 0 00-1 1v3a1 1 0 001 1h3a1 1 0 001-1V4a1 1 0 00-1-1h-3zm1 2v1h1V5h-1z" clip-rule="evenodd" /><path d="M11 4a1 1 0 10-2 0v1a1 1 0 002 0V4zM10 7a1 1 0 011 1v1h2a1 1 0 110 2h-3a1 1 0 01-1-1V8a1 1 0 011-1zM16 9a1 1 0 100 2 1 1 0 000-2zM9 13a1 1 0 011-1h1a1 1 0 110 2v2a1 1 0 11-2 0v-3zM7 11a1 1 0 100-2H4a1 1 0 100 2h3z" /></svg></div>
                            <span class="text-sm font-semibold text-gray-700 group-hover:text-gray-900">My QR Code</span>
                        </a>
                    </div>
                </div>
            }

            <!-- Billing Status (Admin only) -->
            @if (Model.UserRole == "Admin" && Model.Subscription != null)
            {
                var sub = Model.Subscription;
                var subStatusBg = sub.IsExpired ? "bg-red-100 text-red-700" : sub.IsInGracePeriod ? "bg-amber-100 text-amber-700" : sub.IsTrialing ? "bg-purple-100 text-purple-700" : "bg-blue-100 text-blue-700";
                var subStatusText = sub.IsExpired ? "Expired" : sub.IsInGracePeriod ? "Grace Period" : sub.IsTrialing ? "Trial" : "Active";
                var subProgressBar = sub.IsExpired ? "bg-red-400" : sub.IsInGracePeriod ? "bg-amber-400" : "bg-blue-500";
                var subBillingDays = sub.BillingCycle != null && sub.BillingCycle.ToLower().Contains("year") ? 365 : 30;
                var subDaysPercent = sub.IsExpired ? 0 : (int)Math.Min(100.0, Math.Round((double)sub.DaysRemaining / subBillingDays * 100));
                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden" style="min-height:320px">
                    <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
                        <div class="flex items-center gap-2">
                            <div class="w-8 h-8 rounded-xl bg-purple-50 flex items-center justify-center">
                                <svg class="w-4 h-4 text-purple-600" fill="currentColor" viewBox="0 0 20 20">
                                    <path d="M4 4a2 2 0 00-2 2v1h16V6a2 2 0 00-2-2H4z" />
                                    <path fill-rule="evenodd" d="M18 9H2v5a2 2 0 002 2h12a2 2 0 002-2V9zM4 13a1 1 0 011-1h1a1 1 0 110 2H5a1 1 0 01-1-1zm5-1a1 1 0 100 2h1a1 1 0 100-2H9z" clip-rule="evenodd" />
                                </svg>
                            </div>
                            <h2 class="text-base font-bold text-gray-900">Billing Status</h2>
                        </div>
                        <span class="text-xs font-bold px-2.5 py-1 rounded-full @subStatusBg">@subStatusText</span>
                    </div>
                    <div class="p-4 space-y-3">
                        <div class="flex items-center justify-between">
                            <span class="text-sm text-gray-500">Plan</span>
                            <span class="text-sm font-semibold text-gray-900">@sub.PlanName</span>
                        </div>
                        <div class="flex items-center justify-between">
                            <span class="text-sm text-gray-500">Billing</span>
                            <span class="text-sm font-semibold text-gray-900">@sub.BillingCycle</span>
                        </div>
                        <div class="flex items-center justify-between">
                            <span class="text-sm text-gray-500">Renews</span>
                            <span class="text-sm font-semibold text-gray-900">@sub.EndDate.ToString("MMM dd, yyyy")</span>
                        </div>
                        @if (!sub.IsExpired)
                        {
                            <div>
                                <div class="flex items-center justify-between mb-1.5">
                                    <span class="text-xs text-gray-400">Days remaining</span>
                                    <span class="text-xs font-bold text-gray-700">@sub.DaysRemaining days</span>
                                </div>
                                <div class="w-full bg-gray-100 rounded-full h-1.5">
                                    <div class="@subProgressBar h-1.5 rounded-full transition-all" style="width: @subDaysPercent%"></div>
                                </div>
                            </div>
                        }
                        <button type="button" onclick="openRenewalModal()" class="mt-1 flex items-center justify-center gap-2 w-full px-4 py-2.5 rounded-xl text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 transition-colors shadow-sm">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 2a1 1 0 011 1v2.101a7.002 7.002 0 0111.601 2.566 1 1 0 11-1.885.666A5.002 5.002 0 005.999 7H9a1 1 0 010 2H4a1 1 0 01-1-1V3a1 1 0 011-1zm.008 9.057a1 1 0 011.276.61A5.002 5.002 0 0014.001 13H11a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0v-2.101a7.002 7.002 0 01-11.601-2.566 1 1 0 01.61-1.276z" clip-rule="evenodd" /></svg>
                            Renew / Upgrade
                        </button>
                    </div>
                </div>
            }

            <!-- Upcoming Holidays (not for SuperAdmin) -->
            @if (Model.UserRole != "SuperAdmin")
            {
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden flex flex-col" style="height:300px">
                <div class="px-5 py-4 border-b border-gray-100">
                    <div class="flex items-center gap-2">
                        <div class="w-8 h-8 rounded-xl bg-blue-50 flex items-center justify-center">
                            <svg class="w-4 h-4 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
                            </svg>
                        </div>
                        <h2 class="text-base font-bold text-gray-900">Upcoming Holidays</h2>
                    </div>
                </div>
                <div class="p-4 flex-1 overflow-y-auto">
                    @if (!Model.UpcomingHolidays.Any())
                    {
                        <div class="flex flex-col items-center justify-center py-6 text-center">
                            <svg class="w-10 h-10 text-gray-200 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                            <p class="text-sm text-gray-400">No upcoming holidays</p>
                        </div>
                    }
                    <div class="space-y-2">
                        @foreach (var holiday in Model.UpcomingHolidays)
                        {
                            var parsedDate = holiday.Date;
                            var isFixed = holiday.Fixed;
                            var daysUntil = (parsedDate.Date - DateTime.Now.Date).Days;
                            var daysLabel = daysUntil == 0 ? "Today" : daysUntil == 1 ? "Tomorrow" : $"In {daysUntil} days";
                            <div class="flex items-center gap-3 p-2.5 rounded-xl border border-gray-100 hover:border-blue-100 hover:bg-blue-50/40 transition-colors">
                                <div class="flex flex-col items-center justify-center bg-blue-600 text-white rounded-xl w-11 h-11 flex-shrink-0 shadow-sm">
                                    <span class="text-[9px] font-bold uppercase tracking-widest leading-none">@parsedDate.ToString("MMM")</span>
                                    <span class="text-lg font-black leading-tight">@parsedDate.ToString("dd")</span>
                                </div>
                                <div class="min-w-0 flex-1">
                                    <p class="text-sm font-semibold text-gray-900 truncate">@holiday.Name</p>
                                    <div class="flex items-center gap-1.5 mt-0.5">
                                        <span class="inline-block text-[10px] font-semibold px-1.5 py-0.5 rounded-full @(isFixed ? "bg-blue-100 text-blue-700" : "bg-amber-100 text-amber-700")">@(isFixed ? "Regular" : "Special")</span>
                                        <span class="text-[10px] text-gray-400">@daysLabel</span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
            }

        </div><!-- end right sidebar -->
    </div>
</div>

<!-- Payroll Period Detail Modal -->
<div id="periodModal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-hidden="true">
    <div class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm transition-opacity" onclick="closePeriodModal()"></div>
    <div class="flex min-h-full items-center justify-center p-2 sm:p-4">
        <div class="relative bg-white rounded-2xl shadow-xl w-full max-w-md mx-auto">
            <div class="flex items-center justify-between border-b border-gray-200 px-6 py-4">
                <h3 class="text-lg font-bold text-gray-900" id="periodModalTitle">Payroll Period</h3>
                <button type="button" onclick="closePeriodModal()" class="rounded-lg p-1.5 text-gray-400 hover:bg-gray-100">
                    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
                </button>
            </div>
            <div class="px-6 py-5 space-y-4">
                <div class="grid grid-cols-2 gap-4">
                    <div class="bg-gray-50 rounded-xl p-3">
                        <p class="text-xs text-gray-400 font-medium uppercase tracking-wider">Start Date</p>
                        <p class="text-sm font-bold text-gray-900 mt-1" id="periodModalStart">—</p>
                    </div>
                    <div class="bg-gray-50 rounded-xl p-3">
                        <p class="text-xs text-gray-400 font-medium uppercase tracking-wider">End Date</p>
                        <p class="text-sm font-bold text-gray-900 mt-1" id="periodModalEnd">—</p>
                    </div>
                    <div class="bg-gray-50 rounded-xl p-3">
                        <p class="text-xs text-gray-400 font-medium uppercase tracking-wider">Status</p>
                        <p class="text-sm font-bold text-gray-900 mt-1" id="periodModalStatus">—</p>
                    </div>
                    <div class="bg-gray-50 rounded-xl p-3">
                        <p class="text-xs text-gray-400 font-medium uppercase tracking-wider">Employees</p>
                        <p class="text-sm font-bold text-gray-900 mt-1" id="periodModalEmpCount">—</p>
                    </div>
                </div>
                <div class="bg-blue-50 rounded-xl p-4 flex items-center justify-between">
                    <div>
                        <p class="text-xs text-blue-400 font-medium uppercase tracking-wider mb-1">Total Net Pay</p>
                        <p class="text-xl font-bold text-blue-900" id="periodModalNetPay" data-value="" data-hidden="false">—</p>
