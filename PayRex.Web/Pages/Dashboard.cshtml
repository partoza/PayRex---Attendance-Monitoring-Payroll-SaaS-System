                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M3.53 2.47a.75.75 0 0 0-1.06 1.06l18 18a.75.75 0 1 0 1.06-1.06l-18-18ZM22.676 12.553a11.249 11.249 0 0 1-2.631 4.31l-3.099-3.099a5.25 5.25 0 0 0-6.71-6.71L7.759 4.577a11.217 11.217 0 0 1 4.242-.827c4.97 0 9.185 3.223 10.675 7.69.12.362.12.752 0 1.113Z"/><path d="M15.75 12c0 .18-.013.357-.037.53l-4.244-4.243A3.75 3.75 0 0 1 15.75 12ZM12.53 15.713l-4.243-4.244a3.75 3.75 0 0 0 4.244 4.243Z"/><path d="M6.75 12c0-.619.107-1.213.304-1.764l-3.1-3.1a11.25 11.25 0 0 0-2.63 4.31c-.12.362-.12.752 0 1.114 1.489 4.467 5.704 7.69 10.675 7.69 1.5 0 2.933-.294 4.242-.827l-2.477-2.477A5.25 5.25 0 0 1 6.75 12Z"/></svg>
                        </button>
                    </div>
                    <div class="mt-4">
                        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Gov't Contributions</p>
                        <p class="text-2xl font-bold text-gray-900 mt-1" id="finGovt" data-value="₱@Model.Finance.GovernmentTaxes.ToString("N2")" data-hidden="true">₱ ••••••</p>
                    </div>
                    <div class="mt-auto pt-4 border-t border-gray-100">
                        <a href="/Contributions" class="flex items-center gap-1.5 text-sm font-semibold text-yellow-600 hover:text-yellow-800 transition-colors group">View Contributions <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg></a>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Admin Yearly Finance Bar Chart -->
    @if (Model.UserRole == "Admin" || Model.UserRole == "Accountant")
    {
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
            <div class="px-6 py-5 border-b border-gray-50">
                <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4">
                    <div>
                        <h2 class="text-lg font-bold text-gray-900">Yearly Finance Overview</h2>
                        <p class="text-sm text-gray-500 mt-0.5">Monthly breakdown for @DateTime.Now.Year</p>
                    </div>
                    <div class="flex flex-wrap gap-2">
                        <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-blue-50 border border-blue-100">
                            <span class="w-2.5 h-2.5 rounded-full bg-blue-500 flex-shrink-0"></span>
                            <span class="text-xs font-semibold text-blue-700">Income</span>
                            <span class="text-xs font-bold text-blue-900" id="legendYearIncome">&mdash;</span>
                        </div>
                        <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-red-50 border border-red-100">
                            <span class="w-2.5 h-2.5 rounded-full bg-red-500 flex-shrink-0"></span>
                            <span class="text-xs font-semibold text-red-700">Cost</span>
                            <span class="text-xs font-bold text-red-900" id="legendYearCost">&mdash;</span>
                        </div>
                        <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-green-50 border border-green-100">
                            <span class="w-2.5 h-2.5 rounded-full bg-green-500 flex-shrink-0"></span>
                            <span class="text-xs font-semibold text-green-700">Profit</span>
                            <span class="text-xs font-bold text-green-900" id="legendYearProfit">&mdash;</span>
                        </div>
                        <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-amber-50 border border-amber-100">
                            <span class="w-2.5 h-2.5 rounded-full bg-amber-500 flex-shrink-0"></span>
                            <span class="text-xs font-semibold text-amber-700">Gov't</span>
                            <span class="text-xs font-bold text-amber-900" id="legendYearGovt">&mdash;</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="p-6">
                <div class="w-full" style="height:320px">
                    <canvas id="yearlyFinanceChart"></canvas>
                </div>
            </div>
        </div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
        <!-- Main Content: Payroll Status + Recent Activity stacked -->
        <div class="lg:col-span-2 flex flex-col gap-6">
        <!-- Payroll Status / Attendance History / Platform Overview -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden flex flex-col" style="height:320px">
            <div class="px-6 py-5 border-b border-gray-50 bg-white">
                <div class="flex items-center justify-between">
                    <div>
                        @if (Model.UserRole == "SuperAdmin")
                        {
                            <h2 class="text-lg font-bold text-gray-900">Platform Overview</h2>
                            <p class="text-sm text-gray-500 mt-0.5">Key metrics at a glance</p>
                        }
                        else if (Model.UserRole == "Employee")
                        {
                            <h2 class="text-lg font-bold text-gray-900">Attendance History</h2>
                            <p class="text-sm text-gray-500 mt-0.5">Your recent time logs</p>
                        }
                        else
                        {
                            <h2 class="text-lg font-bold text-gray-900">Payroll Status</h2>
                            <p class="text-sm text-gray-500 mt-0.5">Recent payroll processing overview</p>
                        }
                    </div>
                </div>
            </div>
             <div class="p-6 overflow-y-auto flex-1">
                @if (Model.UserRole == "SuperAdmin")
                {
                    <div class="grid grid-cols-2 gap-4">
                        <div class="bg-blue-50 rounded-xl p-4 text-center">
                            <p class="text-2xl font-bold text-blue-700">@Model.SuperAdminKpis.TotalEmployees</p>
                            <p class="text-xs text-blue-600 font-medium mt-1">Total Employees</p>
                        </div>
                        <div class="bg-green-50 rounded-xl p-4 text-center">
                            <p class="text-2xl font-bold text-green-700">@Model.SuperAdminKpis.TotalPlans</p>
                            <p class="text-xs text-green-600 font-medium mt-1">Active Plans</p>
                        </div>
                        <div class="bg-indigo-50 rounded-xl p-4 text-center">
                            <p class="text-2xl font-bold text-indigo-700">@Model.SuperAdminKpis.ActiveCompanies</p>
                            <p class="text-xs text-indigo-600 font-medium mt-1">Active Companies</p>
                        </div>
                        <div class="bg-yellow-50 rounded-xl p-4 text-center">
                            <p class="text-2xl font-bold text-yellow-700">@Model.SuperAdminFinance.EntryCount</p>
                            <p class="text-xs text-yellow-600 font-medium mt-1">Finance Entries</p>
                        </div>
                    </div>
                }
                else if (Model.UserRole == "Employee")
                {
                    <!-- Employee View: Recent Attendance -->
                    <div class="space-y-4">
                        @if (!Model.RecentAttendance.Any())
                        {
                            <p class="text-sm text-gray-500">No recent attendance records found.</p>
                        }
                        @foreach (var record in Model.RecentAttendance)
                        {
                            var isPresent = record.Status == "Present" || record.Status == "Late";
                            <div class="flex justify-between items-center py-2 border-b border-gray-50 last:border-0">
                                <div>
                                    <p class="text-sm font-medium text-gray-900">@record.Date</p>
                                    <p class="text-xs text-gray-500">@(record.TimeIn ?? "--:--") - @(record.TimeOut ?? "--:--")</p>
                                </div>
                                <span class="px-2 py-1 text-xs font-semibold rounded-full 
                                    @(isPresent ? "bg-blue-100 text-blue-800" : "bg-red-100 text-red-800")">
                                    @record.Status
                                </span>
                            </div>
                        }
                    </div>
                }
                else
                {
                     <!-- Admin View: Payroll List -->
                    <div class="space-y-4">
                        @if (!Model.RecentPeriods.Any())
                        {
                            <p class="text-sm text-gray-500">No payroll periods found.</p>
                        }
                        @foreach (var period in Model.RecentPeriods)
                        {
                            var isDraft = period.Status == "Draft";
                            <div class="flex items-center justify-between p-4 bg-gray-50 rounded-xl">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-full flex items-center justify-center font-bold
                                        @(isDraft ? "bg-yellow-100 text-yellow-600" : "bg-blue-100 text-blue-600")">
                                        @System.DateTime.Parse(period.StartDate).ToString("MMM")
                                    </div>
                                    <div>
                                        <p class="text-sm font-bold text-gray-900">@period.PeriodName</p>
                                        <p class="text-xs text-gray-500">@period.EmployeeCount Employees</p>
                                    </div>
                                </div>
                                <div class="flex items-center gap-2">
                                    <span class="px-3 py-1 text-xs font-semibold rounded-full 
                                        @(isDraft ? "bg-yellow-100 text-yellow-800" : "bg-blue-100 text-blue-800")">
                                        @period.Status
                                    </span>
                                    <button type="button"
                                            onclick="openPeriodModal('@period.PeriodName', '@period.StartDate', '@period.EndDate', '@period.Status', @period.EmployeeCount, @period.TotalNetPay)"
                                            class="bg-blue-100 text-blue-600 hover:bg-blue-200 hover:text-blue-800 px-3 py-1.5 rounded-lg text-xs font-medium">
                                        View
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Recent Activity Feed (Admin only) -->
        @if (Model.UserRole == "Admin")
        {
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden flex flex-col" style="height:300px">
            <div class="px-6 py-5 border-b border-gray-50">
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded-xl bg-indigo-50 flex items-center justify-center">
                        <svg class="w-4 h-4 text-indigo-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" /></svg>
                    </div>
                    <h2 class="text-base font-bold text-gray-900">Recent Activity</h2>
                </div>
            </div>
            <div class="p-4 flex-1 overflow-y-auto">
                <div class="space-y-2">
                    @foreach (var activity in Model.RecentActivities)
                    {
                        var actBg = activity.Type == "Success" ? "bg-green-100" : activity.Type == "Warning" ? "bg-amber-100" : activity.Type == "error" ? "bg-red-100" : "bg-blue-100";
                        var actText = activity.Type == "Success" ? "text-green-700" : activity.Type == "Warning" ? "text-amber-700" : activity.Type == "error" ? "text-red-700" : "text-blue-700";
                        var actRing = activity.Type == "Success" ? "ring-green-200" : activity.Type == "Warning" ? "ring-amber-200" : activity.Type == "error" ? "ring-red-200" : "ring-blue-200";
                        var actIcon = activity.Type == "Success"
                            ? "<path fill-rule='evenodd' d='M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z' clip-rule='evenodd' />"
                            : activity.Type == "Warning"
                            ? "<path fill-rule='evenodd' d='M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z' clip-rule='evenodd' />"
                            : activity.Type == "error"
                            ? "<path fill-rule='evenodd' d='M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z' clip-rule='evenodd' />"
                            : "<path fill-rule='evenodd' d='M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z' clip-rule='evenodd' />";
                        <div class="flex items-start gap-3 p-3 rounded-xl border border-gray-100 hover:bg-gray-50 transition-colors">
                            <div class="flex-shrink-0 w-9 h-9 rounded-xl @actBg ring-4 @actRing flex items-center justify-center">
                                <svg class="w-4 h-4 @actText" fill="currentColor" viewBox="0 0 20 20">@Html.Raw(actIcon)</svg>
                            </div>
                            <div class="min-w-0 flex-1">
                                <div class="flex items-start justify-between gap-2">
                                    <p class="text-sm font-semibold text-gray-900 leading-tight">@activity.Title</p>
                                    <span class="text-[10px] text-gray-400 font-medium whitespace-nowrap mt-0.5">@activity.Time</span>
                                </div>
                                <p class="text-xs text-gray-500 mt-0.5">@activity.Description</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
        }

        </div><!-- end lg:col-span-2 -->

        <!-- Right Side Stack -->
        <div class="flex flex-col gap-6">
            <!-- SuperAdmin Quick Links -->
            @if (Model.UserRole == "SuperAdmin")
