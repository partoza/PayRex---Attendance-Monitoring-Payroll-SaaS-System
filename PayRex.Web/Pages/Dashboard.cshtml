                            </div>
                            <span class="text-sm font-semibold text-gray-700 group-hover:text-red-700">Archives</span>
                        </a>
                    </div>
                </div>
            }



            <!-- HR Quick Links -->
            @if (Model.UserRole == "HR")
            {
                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
