@page
@model PayRex.Web.Pages.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="max-w-8xl mx-auto px-4 py-6 sm:px-6 lg:px-8 space-y-6">
    <!-- Header -->
    <div class="bg-gradient-to-r from-blue-50 via-white to-blue-50 rounded-2xl border border-blue-100 shadow-sm overflow-hidden relative group">
        <div class="absolute top-0 right-0 -mt-16 -mr-16 w-64 h-64 bg-yellow-100 rounded-full blur-3xl opacity-20"></div>
        <div class="absolute bottom-0 left-0 -mb-16 -ml-16 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
        
        <div class="px-6 py-8 sm:px-10 sm:py-12 relative z-10">
            <div class="flex flex-col lg:flex-row items-center justify-between gap-8">
                <div class="flex-1 min-w-0 text-center lg:text-left">
                    <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 tracking-tight">
                        Hello, <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-cyan-500">@Model.UserFirstName</span> 👋
                    </h1>
                     @if (Model.UserRole == "Employee")
                    {
                        <p class="text-lg text-gray-600 mt-4 max-w-2xl mx-auto lg:mx-0 leading-relaxed">
                            Welcome to your employee portal. View your payslips, check your attendance, and manage your benefits.
                        </p>
                    }
                    else if (Model.UserRole == "SuperAdmin")
                    {
                        <p class="text-lg text-gray-600 mt-4 max-w-2xl mx-auto lg:mx-0 leading-relaxed">
                            System overview. Manage all companies, users, subscriptions, and platform finances.
                        </p>
                    }
                    else if (Model.UserRole == "HR")
                    {
                        <p class="text-lg text-gray-600 mt-4 max-w-2xl mx-auto lg:mx-0 leading-relaxed">
                            Manage your team, track attendance, and process payroll runs across your organization.
                        </p>
                    }
                    else if (Model.UserRole == "Accountant")
                    {
                        <p class="text-lg text-gray-600 mt-4 max-w-2xl mx-auto lg:mx-0 leading-relaxed">
                            Manage payroll finances, government contributions, and employee compensation packages.
                        </p>
                    }
                    else
                    {
                        <p class="text-lg text-gray-600 mt-4 max-w-2xl mx-auto lg:mx-0 leading-relaxed">
                            Overview of your organization's performance. Manage employees, process payroll, and track attendance.
                        </p>
                    }

                    <div class="mt-8 flex flex-wrap justify-center lg:justify-start gap-4">
                        @if (Model.UserRole == "Employee")
                        {
                            <a href="/Payslips" class="inline-flex items-center px-5 py-2.5 rounded-xl text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 transition-colors shadow-sm hover:shadow-md">
                                View My Payslip
                            </a>
                            <a href="/MyAttendance" class="inline-flex items-center px-5 py-2.5 rounded-xl text-sm font-medium text-blue-700 bg-blue-50 hover:bg-blue-100 transition-colors">
                                Check Attendance
                            </a>
                        }
                        else if (Model.UserRole == "SuperAdmin")
                        {
                            <a href="/Admin/Companies" class="inline-flex items-center px-5 py-2.5 rounded-xl text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 transition-colors shadow-sm hover:shadow-md">
                                Manage Companies
                            </a>
                            <a href="/Admin/Finance" class="inline-flex items-center px-5 py-2.5 rounded-xl text-sm font-medium text-blue-700 bg-blue-50 hover:bg-blue-100 transition-colors">
                                View Finance
                            </a>
                        }
                        else if (Model.UserRole == "HR")
                        {
                            <a href="/Employees" class="inline-flex items-center px-5 py-2.5 rounded-xl text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 transition-colors shadow-sm hover:shadow-md">
                                Employee Management
                            </a>
                            <a href="/Attendance" class="inline-flex items-center px-5 py-2.5 rounded-xl text-sm font-medium text-blue-700 bg-blue-50 hover:bg-blue-100 transition-colors">
                                Attendance Monitoring
                            </a>
                        }
                        else if (Model.UserRole == "Accountant")
                        {
                            <a href="/Salary" class="inline-flex items-center px-5 py-2.5 rounded-xl text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 transition-colors shadow-sm hover:shadow-md">
                                Process Payroll
                            </a>
                            <a href="/Finance" class="inline-flex items-center px-5 py-2.5 rounded-xl text-sm font-medium text-blue-700 bg-blue-50 hover:bg-blue-100 transition-colors">
                                View Finance
                            </a>
                        }
                        else
                        {
                            <a href="/Employees" class="inline-flex items-center px-5 py-2.5 rounded-xl text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 transition-colors shadow-sm hover:shadow-md">
                                Manage Employees
                            </a>
                            <a href="/Salary" class="inline-flex items-center px-5 py-2.5 rounded-xl text-sm font-medium text-blue-700 bg-blue-50 hover:bg-blue-100 transition-colors">
                                Process Payroll
                            </a>
                        }
                    </div>
                </div>
                 <!-- Creative Illustration -->
                <div class="hidden lg:block flex-shrink-0 relative">
                    <div class="absolute inset-0 bg-gradient-to-tr from-blue-100/50 to-yellow-100/50 rounded-full blur-2xl transform scale-90"></div>
                    <!-- Banknote Rafiki Illustration - Larger -->
                    <img src="/images/Banknote-rafiki.png" alt="Dashboard Illustration" class="w-80 h-80 relative z-10 drop-shadow-xl transform group-hover:scale-105 transition-transform duration-500" />
                </div>
            </div>
        </div>
    </div>

    <!-- Subscription Warning Banner -->
    @if (Model.Subscription != null && (Model.Subscription.IsExpired || Model.Subscription.IsInGracePeriod || Model.Subscription.DaysRemaining <= 7))
    {
        var bannerBg = Model.Subscription.IsExpired ? "bg-red-50 border-red-200" : "bg-yellow-50 border-yellow-200";
        var bannerText = Model.Subscription.IsExpired ? "text-red-700" : "text-yellow-700";
        var bannerIcon = Model.Subscription.IsExpired ? "text-red-500" : "text-yellow-500";

        <div class="@bannerBg rounded-2xl border shadow-sm p-4 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
            <div class="flex items-center gap-3">
                <svg class="w-6 h-6 @bannerIcon flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" /></svg>
                <div>
                    @if (Model.Subscription.IsExpired)
                    {
                        <p class="@bannerText font-semibold">Subscription Expired</p>
                        <p class="@bannerText text-sm">Your subscription has expired. Some features may be restricted. Please renew now.</p>
                    }
                    else if (Model.Subscription.IsInGracePeriod)
                    {
                        <p class="@bannerText font-semibold">Subscription Past Due</p>
                        <p class="@bannerText text-sm">Your subscription is in a grace period. Please renew within @Model.Subscription.GracePeriodDays days to avoid service interruption.</p>
                    }
                    else
                    {
                        <p class="@bannerText font-semibold">Subscription Expiring Soon</p>
                        <p class="@bannerText text-sm">Your subscription expires in @Model.Subscription.DaysRemaining days (@Model.Subscription.EndDate.ToString("MMM dd, yyyy")).</p>
                    }
                </div>
            </div>
            <button type="button" onclick="openRenewalModal()" class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-xl hover:bg-blue-700 transition-colors shadow-sm flex-shrink-0">
                <svg class="w-4 h-4 mr-1.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 2a1 1 0 011 1v2.101a7.002 7.002 0 0111.601 2.566 1 1 0 11-1.885.666A5.002 5.002 0 005.999 7H9a1 1 0 010 2H4a1 1 0 01-1-1V3a1 1 0 011-1zm.008 9.057a1 1 0 011.276.61A5.002 5.002 0 0014.001 13H11a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0v-2.101a7.002 7.002 0 01-11.601-2.566 1 1 0 01.61-1.276z" clip-rule="evenodd" /></svg>
                Renew Now
            </button>
        </div>
    }

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        @if (Model.UserRole == "SuperAdmin")
        {
            <!-- Total Companies -->
            <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 hover:shadow-md transition-all duration-300 flex flex-col">
                <div class="w-11 h-11 rounded-2xl bg-blue-50 flex items-center justify-center">
                    <svg class="w-5 h-5 text-blue-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h8a2 2 0 012 2v12a1 1 0 110 2H4a1 1 0 010-2V4zm3 1h2v2H7V5zm2 4H7v2h2V9zm2-4h2v2h-2V5zm2 4h-2v2h2V9z" clip-rule="evenodd" /></svg>
                </div>
                <div class="mt-4">
                    <p class="text-sm font-medium text-gray-500">Total Companies</p>
                    <p class="mt-1 text-3xl font-bold text-gray-900">@Model.SuperAdminKpis.TotalCompanies</p>
                    <span class="mt-2 inline-block text-xs font-semibold bg-blue-50 text-blue-600 px-2.5 py-1 rounded-lg">@Model.SuperAdminKpis.ActiveCompanies Active</span>
                </div>
                <div class="mt-auto pt-4 border-t border-gray-100">
                    <a href="/Admin/Companies" class="flex items-center gap-1.5 text-sm font-semibold text-blue-600 hover:text-blue-800 transition-colors group">
                        Manage Companies
                        <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                    </a>
                </div>
            </div>
            <!-- Total Users -->
            <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 hover:shadow-md transition-all duration-300 flex flex-col">
                <div class="w-11 h-11 rounded-2xl bg-indigo-50 flex items-center justify-center">
                    <svg class="w-5 h-5 text-indigo-600" fill="currentColor" viewBox="0 0 20 20"><path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z" /></svg>
                </div>
                <div class="mt-4">
                    <p class="text-sm font-medium text-gray-500">Total Users</p>
                    <p class="mt-1 text-3xl font-bold text-gray-900">@Model.SuperAdminKpis.TotalUsers</p>
                    <span class="mt-2 inline-block text-xs font-semibold bg-indigo-50 text-indigo-600 px-2.5 py-1 rounded-lg">@Model.SuperAdminKpis.ActiveUsers Active</span>
                </div>
                <div class="mt-auto pt-4 border-t border-gray-100">
                    <a href="/Admin/Users" class="flex items-center gap-1.5 text-sm font-semibold text-indigo-600 hover:text-indigo-800 transition-colors group">
                        Manage Users
                        <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                    </a>
                </div>
            </div>
            <!-- Monthly Revenue -->
            <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 hover:shadow-md transition-all duration-300 flex flex-col">
                <div class="flex items-start justify-between">
                    <div class="w-11 h-11 rounded-2xl bg-green-50 flex items-center justify-center">
                        <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 4a2 2 0 00-2 2v4a2 2 0 002 2V6h10a2 2 0 00-2-2H4zm2 6a2 2 0 012-2h8a2 2 0 012 2v4a2 2 0 01-2 2H8a2 2 0 01-2-2v-4zm6 4a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" /></svg>
                    </div>
                    <button type="button" onclick="toggleVisibility('statMonthlyRev', this)" class="text-gray-400 hover:text-gray-600 transition-colors mt-0.5" title="Toggle visibility">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M3.53 2.47a.75.75 0 0 0-1.06 1.06l18 18a.75.75 0 1 0 1.06-1.06l-18-18ZM22.676 12.553a11.249 11.249 0 0 1-2.631 4.31l-3.099-3.099a5.25 5.25 0 0 0-6.71-6.71L7.759 4.577a11.217 11.217 0 0 1 4.242-.827c4.97 0 9.185 3.223 10.675 7.69.12.362.12.752 0 1.113Z"/><path d="M15.75 12c0 .18-.013.357-.037.53l-4.244-4.243A3.75 3.75 0 0 1 15.75 12ZM12.53 15.713l-4.243-4.244a3.75 3.75 0 0 0 4.244 4.243Z"/><path d="M6.75 12c0-.619.107-1.213.304-1.764l-3.1-3.1a11.25 11.25 0 0 0-2.63 4.31c-.12.362-.12.752 0 1.114 1.489 4.467 5.704 7.69 10.675 7.69 1.5 0 2.933-.294 4.242-.827l-2.477-2.477A5.25 5.25 0 0 1 6.75 12Z"/></svg>
                    </button>
                </div>
                <div class="mt-4">
                    <p class="text-sm font-medium text-gray-500">Monthly Revenue</p>
                    <p class="mt-1 text-3xl font-bold text-gray-900" id="statMonthlyRev" data-value="₱@Model.SuperAdminKpis.MonthlyRevenue.ToString("N2")" data-hidden="true">₱ ••••••</p>
                    <span class="mt-2 inline-block text-xs font-semibold bg-green-50 text-green-600 px-2.5 py-1 rounded-lg">This Month</span>
                </div>
                <div class="mt-auto pt-4 border-t border-gray-100">
                    <a href="/Admin/Finance" class="flex items-center gap-1.5 text-sm font-semibold text-green-600 hover:text-green-800 transition-colors group">
                        View Finance
                        <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                    </a>
                </div>
            </div>
            <!-- Pending Invoices -->
            <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 hover:shadow-md transition-all duration-300 flex flex-col">
                <div class="w-11 h-11 rounded-2xl bg-yellow-50 flex items-center justify-center">
                    <svg class="w-5 h-5 text-yellow-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 2a2 2 0 00-2 2v14l3.5-2 3.5 2 3.5-2 3.5 2V4a2 2 0 00-2-2H5zm4.707 3.707a1 1 0 00-1.414-1.414l-3 3a1 1 0 000 1.414l3 3a1 1 0 001.414-1.414L8.414 9H10a3 3 0 013 3v1a1 1 0 102 0v-1a5 5 0 00-5-5H8.414l1.293-1.293z" clip-rule="evenodd" /></svg>
                </div>
                <div class="mt-4">
                    <p class="text-sm font-medium text-gray-500">Pending Invoices</p>
                    <p class="mt-1 text-3xl font-bold text-gray-900">@Model.SuperAdminKpis.PendingInvoices</p>
                    <span class="mt-2 inline-block text-xs font-semibold bg-yellow-50 text-yellow-600 px-2.5 py-1 rounded-lg">Awaiting Payment</span>
                </div>
                <div class="mt-auto pt-4 border-t border-gray-100">
                    <a href="/Admin/Billing" class="flex items-center gap-1.5 text-sm font-semibold text-yellow-600 hover:text-yellow-800 transition-colors group">
                        View Billing
                        <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                    </a>
                </div>
            </div>
        }
        else if (Model.UserRole == "Employee")
        {
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 hover:shadow-lg transition-all duration-300">
                <p class="text-sm font-medium text-gray-500">Days Present</p>
                <p class="mt-2 text-3xl font-bold text-gray-900">@Model.Stats.PresentDays</p>
                <div class="mt-2 text-xs text-blue-600 font-semibold bg-blue-50 inline-block px-2 py-1 rounded">On Track</div>
            </div>
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 hover:shadow-lg transition-all duration-300">
                <p class="text-sm font-medium text-gray-500">Late Arrivals</p>
                <p class="mt-2 text-3xl font-bold text-gray-900">@Model.Stats.LateDays</p>
                <div class="mt-2 text-xs text-yellow-600 font-semibold bg-yellow-50 inline-block px-2 py-1 rounded">Warning</div>
            </div>
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 hover:shadow-lg transition-all duration-300">
                <p class="text-sm font-medium text-gray-500">Leave Balance</p>
                <p class="mt-2 text-3xl font-bold text-gray-900">@Model.Stats.LeaveBalance</p>
                <div class="mt-2 text-xs text-blue-600 font-semibold bg-blue-50 inline-block px-2 py-1 rounded">Available</div>
            </div>
            <!-- Next Payout — sensitive: eye toggle -->
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 hover:shadow-lg transition-all duration-300">
                <div class="flex items-center justify-between">
                    <p class="text-sm font-medium text-gray-500">Next Payout</p>
                    <button type="button" onclick="toggleVisibility('statEstPay', this)" class="text-gray-400 hover:text-gray-600 transition-colors" title="Toggle visibility">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M3.53 2.47a.75.75 0 0 0-1.06 1.06l18 18a.75.75 0 1 0 1.06-1.06l-18-18ZM22.676 12.553a11.249 11.249 0 0 1-2.631 4.31l-3.099-3.099a5.25 5.25 0 0 0-6.71-6.71L7.759 4.577a11.217 11.217 0 0 1 4.242-.827c4.97 0 9.185 3.223 10.675 7.69.12.362.12.752 0 1.113Z"/><path d="M15.75 12c0 .18-.013.357-.037.53l-4.244-4.243A3.75 3.75 0 0 1 15.75 12ZM12.53 15.713l-4.243-4.244a3.75 3.75 0 0 0 4.244 4.243Z"/><path d="M6.75 12c0-.619.107-1.213.304-1.764l-3.1-3.1a11.25 11.25 0 0 0-2.63 4.31c-.12.362-.12.752 0 1.114 1.489 4.467 5.704 7.69 10.675 7.69 1.5 0 2.933-.294 4.242-.827l-2.477-2.477A5.25 5.25 0 0 1 6.75 12Z"/></svg>
                    </button>
                </div>
                <p class="mt-2 text-3xl font-bold text-gray-900" id="statEstPay" data-value="₱@Model.Stats.EstimatedPay.ToString("N2")" data-hidden="true">₱ ••••••</p>
                <div class="mt-2 text-xs text-blue-600 font-semibold bg-blue-50 inline-block px-2 py-1 rounded">Est. Net Pay</div>
            </div>
        }
        else if (Model.UserRole == "Admin")
        {
            <!-- Total Employees -->
            <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 hover:shadow-md transition-all duration-300 flex flex-col">
                <div class="w-11 h-11 rounded-2xl bg-blue-50 flex items-center justify-center">
                    <svg class="w-5 h-5 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z" />
                    </svg>
                </div>
                <div class="mt-4">
                    <p class="text-sm font-medium text-gray-500">Total Employees</p>
                    <p class="mt-1 text-3xl font-bold text-gray-900">@Model.Stats.TotalEmployees</p>
                    <span class="mt-2 inline-block text-xs font-semibold bg-blue-50 text-blue-600 px-2.5 py-1 rounded-lg">@Model.Stats.NewHires New Hires</span>
                </div>
                <div class="mt-auto pt-4 border-t border-gray-100">
                    <a href="/Employees" class="flex items-center gap-1.5 text-sm font-semibold text-blue-600 hover:text-blue-800 transition-colors group">
                        Employee Management
                        <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                    </a>
                </div>
            </div>
            <!-- Present Today -->
            <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 hover:shadow-md transition-all duration-300 flex flex-col">
                <div class="w-11 h-11 rounded-2xl bg-blue-50 flex items-center justify-center">
                    <svg class="w-5 h-5 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                    </svg>
                </div>
                <div class="mt-4">
                    <p class="text-sm font-medium text-gray-500">Present Today</p>
                    <p class="mt-1 text-3xl font-bold text-gray-900">@Model.Stats.PresentToday</p>
                    <span class="mt-2 inline-block text-xs font-semibold bg-blue-50 text-blue-600 px-2.5 py-1 rounded-lg">@Model.Stats.OnTimePercentage% On Time</span>
                </div>
                <div class="mt-auto pt-4 border-t border-gray-100">
                    <a href="/Attendance" class="flex items-center gap-1.5 text-sm font-semibold text-blue-600 hover:text-blue-800 transition-colors group">
                        Attendance Monitoring
                        <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                    </a>
                </div>
            </div>
            <!-- Pending Payroll -->
            <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 hover:shadow-md transition-all duration-300 flex flex-col">
                <div class="w-11 h-11 rounded-2xl bg-yellow-50 flex items-center justify-center">
                    <svg class="w-5 h-5 text-yellow-600" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
                    </svg>
                </div>
                <div class="mt-4">
                    <p class="text-sm font-medium text-gray-500">Pending Payroll</p>
