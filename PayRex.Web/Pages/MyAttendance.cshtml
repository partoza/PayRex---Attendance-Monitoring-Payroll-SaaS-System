@page
@model PayRex.Web.Pages.MyAttendanceModel
@{
    ViewData["Title"] = "My Attendance";
    var fromVal = Model.FromDate?.ToString("yyyy-MM-dd") ?? DateTime.Today.AddDays(-30).ToString("yyyy-MM-dd");
    var toVal = Model.ToDate?.ToString("yyyy-MM-dd") ?? DateTime.Today.ToString("yyyy-MM-dd");
}

<div class="max-w-8xl mx-auto px-4 sm:px-6 lg:px-8 space-y-4 sm:space-y-6">
    <!-- Header -->
    <div class="bg-gradient-to-r from-blue-50 via-white to-blue-50 rounded-xl sm:rounded-2xl border border-blue-100 shadow-sm relative overflow-hidden">
        <div class="absolute top-0 right-0 -mt-16 -mr-16 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
        <div class="absolute bottom-0 left-0 -mb-16 -ml-16 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
        <div class="px-4 py-5 sm:px-8 sm:py-8 relative z-10">
            <h1 class="text-xl sm:text-2xl lg:text-3xl font-extrabold text-gray-900 tracking-tight">My Attendance</h1>
            <p class="mt-1 sm:mt-2 text-sm sm:text-base text-gray-600">Track your daily time-in and time-out records</p>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
        <div class="bg-white rounded-xl sm:rounded-2xl border border-gray-200 shadow-sm p-4">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg bg-green-100 flex items-center justify-center">
                    <svg class="w-5 h-5 text-green-600" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                    </svg>
                </div>
                <div>
                    <p class="text-xs text-gray-500">Present</p>
                    <p class="text-xl font-bold text-gray-900">@Model.Summary.TotalPresent</p>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-xl sm:rounded-2xl border border-gray-200 shadow-sm p-4">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg bg-yellow-100 flex items-center justify-center">
                    <svg class="w-5 h-5 text-yellow-600" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
                    </svg>
                </div>
                <div>
                    <p class="text-xs text-gray-500">Late</p>
                    <p class="text-xl font-bold text-gray-900">@Model.Summary.TotalLate</p>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-xl sm:rounded-2xl border border-gray-200 shadow-sm p-4">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg bg-red-100 flex items-center justify-center">
                    <svg class="w-5 h-5 text-red-600" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                    </svg>
                </div>
                <div>
                    <p class="text-xs text-gray-500">Absent</p>
                    <p class="text-xl font-bold text-gray-900">@Model.Summary.TotalAbsent</p>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-xl sm:rounded-2xl border border-gray-200 shadow-sm p-4">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center">
                    <svg class="w-5 h-5 text-blue-600" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
                    </svg>
                </div>
                <div>
                    <p class="text-xs text-gray-500">Total Hours</p>
                    <p class="text-xl font-bold text-gray-900">@Model.Summary.TotalHours</p>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-xl sm:rounded-2xl border border-gray-200 shadow-sm p-4">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg bg-purple-100 flex items-center justify-center">
                    <svg class="w-5 h-5 text-purple-600" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                </div>
                <div>
                    <p class="text-xs text-gray-500">Overtime</p>
                    <p class="text-xl font-bold text-gray-900">@Model.Summary.TotalOvertime hrs</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Date Filter -->
    <div class="bg-white rounded-xl sm:rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-4 sm:px-6 py-3 sm:py-4 border-b border-gray-100 bg-gradient-to-r from-gray-50 to-white">
            <h2 class="text-sm sm:text-base font-semibold text-gray-900">Filter by Date</h2>
        </div>
        <div class="px-4 sm:px-6 py-4">
        <form method="get" class="flex flex-col md:flex-row items-end gap-4">
            <div class="flex-1">
                <label for="fromDate" class="block text-sm font-medium text-gray-700 mb-1">From</label>
                <input type="date" id="fromDate" name="fromDate" value="@fromVal"
                       class="w-full rounded-lg border-gray-300 text-sm focus:ring-blue-500 focus:border-blue-500" />
            </div>
            <div class="flex-1">
                <label for="toDate" class="block text-sm font-medium text-gray-700 mb-1">To</label>
                <input type="date" id="toDate" name="toDate" value="@toVal"
                       class="w-full rounded-lg border-gray-300 text-sm focus:ring-blue-500 focus:border-blue-500" />
            </div>
            <button type="submit" class="px-6 py-2.5 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
                Filter
            </button>
        </form>
        </div>
    </div>

    <!-- Attendance Table -->
    <div class="bg-white rounded-xl sm:rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-4 sm:px-6 py-3 sm:py-4 border-b border-gray-100 bg-gradient-to-r from-gray-50 to-white">
            <div class="flex items-center justify-between">
                <h2 class="text-sm sm:text-base font-semibold text-gray-900">Attendance Records</h2>
                <div class="flex items-center gap-2">
                    <select id="pageSizeSelect" onchange="currentPage=1;updateView()"
                            class="px-2.5 py-1.5 border border-gray-300 rounded-lg text-xs bg-white focus:ring-2 focus:ring-blue-500">
                        <option value="10" selected>10 / page</option>
                        <option value="25">25 / page</option>
                        <option value="50">50 / page</option>
                    </select>
                </div>
            </div>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left">
                <thead class="bg-gray-50/80">
                    <tr>
                        <th class="px-4 sm:px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Date</th>
                        <th class="px-4 sm:px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Time In</th>
                        <th class="px-4 sm:px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Time Out</th>
                        <th class="px-4 sm:px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Hours Worked</th>
                        <th class="px-4 sm:px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Overtime</th>
                        <th class="px-4 sm:px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
                        <th class="px-4 sm:px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Remarks</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    @if (Model.Records.Any())
                    {
                        @foreach (var record in Model.Records)
                        {
                            var statusColor = record.Status switch
                            {
                                "Present" => "bg-green-100 text-green-700",
                                "Late" => "bg-yellow-100 text-yellow-700",
                                "Absent" => "bg-red-100 text-red-700",
                                "On Leave" => "bg-blue-100 text-blue-700",
                                _ => "bg-gray-100 text-gray-700"
                            };
                            <tr class="hover:bg-gray-50/50 transition-colors attendance-row">
                                <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap">
                                    <div class="font-medium text-gray-900">
                                        @{
                                            DateTime parsedDate;
                                            var dateDisplay = DateTime.TryParse(record.Date, out parsedDate)
                                                ? parsedDate.ToString("MMMM dd, yyyy")
                                                : record.Date;
                                        }
                                        @dateDisplay
                                    </div>
                                    @if (record.IsHoliday)
                                    {
                                        <span class="text-xs text-orange-600 font-medium">@record.HolidayName</span>
                                    }
                                </td>
                                <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap">
                                    @if (!string.IsNullOrEmpty(record.TimeIn))
                                    {
                                        <span class="text-gray-900 font-medium">@record.TimeIn</span>
                                    }
                                    else
                                    {
                                        <span class="text-gray-400">—</span>
                                    }
                                </td>
                                <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap">
                                    @if (!string.IsNullOrEmpty(record.TimeOut))
                                    {
                                        <span class="text-gray-900 font-medium">@record.TimeOut</span>
                                    }
                                    else
                                    {
                                        <span class="text-gray-400">—</span>
                                    }
                                </td>
                                <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap text-gray-900">@record.TotalHoursWorked hrs</td>
                                <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap">
                                    @if (record.OvertimeHours > 0)
                                    {
                                        <span class="text-purple-600 font-medium">@record.OvertimeHours hrs</span>
                                    }
                                    else
                                    {
                                        <span class="text-gray-400">—</span>
                                    }
                                </td>
                                <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold @statusColor">
                                        @record.Status
                                    </span>
                                </td>
                                <td class="px-4 sm:px-6 py-3 sm:py-4 text-gray-500 text-xs max-w-[200px] truncate">
                                    @(string.IsNullOrWhiteSpace(record.Remarks) ? "None" : record.Remarks)
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="px-6 py-12 text-center">
                                <svg class="mx-auto h-12 w-12 text-gray-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                <p class="mt-2 text-sm text-gray-500">No attendance records found for this period</p>
                                <p class="text-xs text-gray-400 mt-1">Try adjusting the date range</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <!-- Pagination -->
        <div class="px-4 sm:px-6 py-3 sm:py-4 border-t border-gray-100 bg-gray-50/50">
            <div class="flex flex-col sm:flex-row items-center justify-between gap-3">
                <div class="text-xs sm:text-sm text-gray-600" id="myAttendPaginationInfo"></div>
                <nav class="flex items-center gap-1 flex-wrap justify-center" id="myAttendPaginationNav"></nav>
            </div>
        </div>
    </div>
</div>

<script>
    let currentPage = 1;
    let allRows = [];

    function updateView() {
        const pageSize = parseInt(document.getElementById("pageSizeSelect").value) || 10;
        const totalRows = allRows.length;
        const totalPages = Math.max(1, Math.ceil(totalRows / pageSize));
        if (currentPage > totalPages) currentPage = totalPages;
        const start = (currentPage - 1) * pageSize;
        const end = start + pageSize;
        // Show all rows first, then hide non-paginated
        document.querySelectorAll(".attendance-row").forEach(r => r.style.display = "none");
        allRows.forEach((row, i) => { row.style.display = (i >= start && i < end) ? "" : "none"; });
        document.getElementById("myAttendPaginationInfo").textContent =
            totalRows === 0 ? "No records" :
            `Showing ${start + 1}–${Math.min(end, totalRows)} of ${totalRows} records`;
        const nav = document.getElementById("myAttendPaginationNav");
        nav.innerHTML = "";
        const btnClass = (active, disabled) => `px-3 py-1.5 text-sm font-medium border rounded-lg transition-all ${
            active    ? 'bg-blue-600 text-white border-blue-600' :
            disabled  ? 'opacity-40 cursor-not-allowed bg-gray-100 border-gray-200 text-gray-500' :
                        'bg-white text-gray-700 border-gray-200 hover:bg-gray-100'
        }`;
        
        if (totalPages <= 1) return;

        if (currentPage > 1) {
            const b = document.createElement("button"); b.className = btnClass(false, false); b.textContent = "‹";
            b.onclick = () => { currentPage--; updateView(); }; nav.appendChild(b);
        } else {
            const b = document.createElement("button"); b.className = btnClass(false, true); b.textContent = "‹";
            nav.appendChild(b);
        }

        for (let p = Math.max(1, currentPage - 2); p <= Math.min(totalPages, currentPage + 2); p++) {
            const b = document.createElement("button"); b.className = btnClass(p === currentPage, false); b.textContent = p;
            b.onclick = ((page) => () => { currentPage = page; updateView(); })(p); nav.appendChild(b);
        }

        if (currentPage < totalPages) {
            const b = document.createElement("button"); b.className = btnClass(false, false); b.textContent = "›";
            b.onclick = () => { currentPage++; updateView(); }; nav.appendChild(b);
        } else {
            const b = document.createElement("button"); b.className = btnClass(false, true); b.textContent = "›";
            nav.appendChild(b);
        }
    }

    document.addEventListener("DOMContentLoaded", () => {
        allRows = Array.from(document.querySelectorAll(".attendance-row"));
        updateView();
    });
</script>
