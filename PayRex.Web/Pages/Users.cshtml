@page
@model PayRex.Web.Pages.UsersModel
@{
    ViewData["Title"] = "User Management";
    var statusMsg = Model.StatusMessage ?? "";
    var toastType = statusMsg.StartsWith("success:") ? "success" : "error";
    var toastText = statusMsg.Contains(":") ? statusMsg.Substring(statusMsg.IndexOf(':') + 1) : "";
}

@if (!string.IsNullOrEmpty(toastText))
{
    <script>document.addEventListener('DOMContentLoaded',()=>showToast(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(toastText)), '@toastType'));</script>
}

<div class="max-w-8xl mx-auto px-4 sm:px-6 lg:px-8 space-y-5 sm:space-y-6">

    <!-- Header -->
    <div class="bg-gradient-to-r from-blue-50 via-white to-blue-50 rounded-xl sm:rounded-2xl border border-blue-100 shadow-sm overflow-hidden relative">
        <div class="absolute top-0 right-0 -mt-16 -mr-16 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
        <div class="absolute bottom-0 left-0 -mb-16 -ml-16 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
        <div class="px-4 py-5 sm:px-8 sm:py-8 relative z-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
                <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight">User Management</h1>
                <p class="mt-1 text-sm text-gray-600">Manage system users, roles, and access levels.</p>
            </div>
            <div class="flex items-center gap-3">
                <span class="inline-flex items-center px-3 py-1.5 rounded-xl text-sm font-semibold bg-blue-100 text-blue-700">
                    @Model.Users.Count Total Users
                </span>
            </div>
        </div>
    </div>

    <!-- Stats -->
    @{
        var activeCount   = Model.Users.Count(u => u.Status == "Active");
        var inactiveCount = Model.Users.Count(u => u.Status != "Active");
        var adminCount    = Model.Users.Count(u => u.Role == "Admin");
        var hrCount       = Model.Users.Count(u => u.Role == "HR");
    }
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
        <div class="bg-white rounded-xl sm:rounded-2xl border border-gray-200 shadow-sm p-4 flex items-center justify-between">
            <div><p class="text-xs text-gray-500 font-medium">Active</p><p class="text-xl font-bold text-green-600">@activeCount</p></div>
            <div class="p-2.5 bg-green-50 rounded-xl text-green-500"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div>
        </div>
        <div class="bg-white rounded-xl sm:rounded-2xl border border-gray-200 shadow-sm p-4 flex items-center justify-between">
            <div><p class="text-xs text-gray-500 font-medium">Inactive</p><p class="text-xl font-bold text-gray-500">@inactiveCount</p></div>
            <div class="p-2.5 bg-gray-50 rounded-xl text-gray-400"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg></div>
        </div>
        <div class="bg-white rounded-xl sm:rounded-2xl border border-gray-200 shadow-sm p-4 flex items-center justify-between">
            <div><p class="text-xs text-gray-500 font-medium">Admins</p><p class="text-xl font-bold text-purple-600">@adminCount</p></div>
            <div class="p-2.5 bg-purple-50 rounded-xl text-purple-500"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg></div>
        </div>
        <div class="bg-white rounded-xl sm:rounded-2xl border border-gray-200 shadow-sm p-4 flex items-center justify-between">
            <div><p class="text-xs text-gray-500 font-medium">HR Users</p><p class="text-xl font-bold text-blue-600">@hrCount</p></div>
            <div class="p-2.5 bg-blue-50 rounded-xl text-blue-500"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg></div>
        </div>
    </div>

    <!-- Filters + Table Card -->
    <div class="bg-white rounded-xl sm:rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <!-- Card header / filters -->
        <div class="px-4 sm:px-6 py-3 sm:py-4 border-b border-gray-100 bg-gradient-to-r from-gray-50 to-white">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                <h2 class="text-sm sm:text-base font-semibold text-gray-900">All Users</h2>
                <div class="flex flex-wrap items-center gap-2">
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-2.5 flex items-center pointer-events-none">
                            <svg class="w-3.5 h-3.5 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" /></svg>
                        </div>
                        <input type="text" id="searchInput" onkeyup="applyFilters()" placeholder="Search name or email..."
                               class="pl-8 pr-3 py-2 border border-gray-300 rounded-lg text-xs bg-white focus:ring-2 focus:ring-blue-500 w-44 sm:w-52">
                    </div>
                    <select id="roleFilter" onchange="applyFilters()"
                            class="px-3 py-2 border border-gray-300 rounded-lg text-xs bg-white focus:ring-2 focus:ring-blue-500">
                        <option value="">All Roles</option>
                        <option value="Admin">Admin</option>
                        <option value="HR">HR</option>
                        <option value="Accountant">Accountant</option>
                        <option value="Employee">Employee</option>
                    </select>
                    <select id="statusFilter" onchange="applyFilters()"
                            class="px-3 py-2 border border-gray-300 rounded-lg text-xs bg-white focus:ring-2 focus:ring-blue-500">
                        <option value="">All Status</option>
                        <option value="Active">Active</option>
                        <option value="Inactive">Inactive</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Table -->
        <div class="overflow-x-auto">
            <table class="w-full" id="usersTable">
                <thead class="bg-gray-50/80">
                    <tr>
                        <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">User</th>
                        <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Role</th>
                        <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
                        <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Joined</th>
                        <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @if (!Model.Users.Any())
                    {
                        <tr>
                            <td colspan="6" class="px-6 py-12 text-center">
                                <div class="flex flex-col items-center justify-center">
                                    <div class="w-14 h-14 bg-blue-50 rounded-full flex items-center justify-center mb-4">
                                        <svg class="w-7 h-7 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                                    </div>
                                    <p class="text-sm text-gray-400">No users found</p>
                                </div>
                            </td>
                        </tr>
                    }
                    @foreach (var u in Model.Users)
                    {
                        var roleBg = u.Role switch {
                            "Admin"     => "bg-purple-100 text-purple-700",
                            "HR"        => "bg-blue-100 text-blue-700",
                            "Accountant"=> "bg-amber-100 text-amber-700",
                            _           => "bg-gray-100 text-gray-600"
                        };
                        var initial = u.Name.Length > 0 ? u.Name[0].ToString().ToUpper() : "?";
                        <tr class="hover:bg-gray-50/50 transition-colors data-row"
                            data-name="@u.Name.ToUpper()"
                            data-email="@u.Email.ToUpper()"
                            data-role="@u.Role"
                            data-status="@u.Status">
                            <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap">
                                <div class="flex items-center gap-3">
                                    @if (!string.IsNullOrEmpty(u.ProfileImageUrl))
                                    {
                                        <img src="@u.ProfileImageUrl" class="w-9 h-9 rounded-full object-cover shadow-sm flex-shrink-0" />
                                    }
                                    else
                                    {
                                        <div class="w-9 h-9 rounded-full bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center text-white font-bold text-sm shadow-sm flex-shrink-0">@initial</div>
                                    }
                                    <div>
                                    <div class="text-sm font-semibold text-gray-900">@u.Name</div>
                                    <div class="text-xs text-gray-400">@u.Email</div>
                                </div>
                                </div>
                            </td>
                            <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold @roleBg">@u.Role</span>
                            </td>
                            <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap">
                                <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-semibold @(u.Status == "Active" ? "bg-green-100 text-green-700" : "bg-gray-100 text-gray-700")">
                                    <span class="w-1.5 h-1.5 rounded-full @(u.Status == "Active" ? "bg-green-500" : "bg-gray-400")"></span>
                                    @u.Status
                                </span>
                            </td>
                            <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap text-xs text-gray-400">
                                @u.DateJoined.ToString("MMM dd, yyyy")
                            </td>
                            <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap">
                                <form method="post" asp-page-handler="ToggleStatus" class="inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@u.UserId" />
                                    <button type="submit"
                                            class="px-3 py-1.5 text-xs font-semibold rounded-lg border transition-colors @(u.Status == "Active" ? "border-red-200 text-red-600 hover:bg-red-50" : "border-green-200 text-green-600 hover:bg-green-50")">
                                        @(u.Status == "Active" ? "Suspend" : "Activate")
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination info -->
        <div class="px-4 sm:px-6 py-3 border-t border-gray-100 bg-gray-50/50">
            <p class="text-xs text-gray-500" id="filteredCount">Showing @Model.Users.Count of @Model.Users.Count users</p>
        </div>
    </div>
</div>

<script>
    function applyFilters() {
        const search = (document.getElementById('searchInput')?.value || '').toUpperCase();
        const role   = (document.getElementById('roleFilter')?.value  || '').toUpperCase();
        const status = (document.getElementById('statusFilter')?.value || '').toUpperCase();
        let shown = 0;
        document.querySelectorAll('#usersTable tbody tr.data-row').forEach(r => {
            const n = r.dataset.name  || '';
            const e = r.dataset.email || '';
            const rl= (r.dataset.role   || '').toUpperCase();
            const st= (r.dataset.status || '').toUpperCase();
            const ok = (search === '' || n.includes(search) || e.includes(search))
                    && (role   === '' || rl === role)
                    && (status === '' || st === status);
            r.style.display = ok ? '' : 'none';
            if (ok) shown++;
        });
        const total = document.querySelectorAll('#usersTable tbody tr.data-row').length;
        const cnt = document.getElementById('filteredCount');
        if (cnt) cnt.textContent = `Showing ${shown} of ${total} users`;
    }
</script>
