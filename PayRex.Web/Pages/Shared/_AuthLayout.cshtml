@{
 Layout = null;
}
@inject Microsoft.Extensions.Configuration.IConfiguration AppConfig
<!DOCTYPE html>
<html lang="en">
<head>
 <meta charset="utf-8" />
 <title>@ViewData["Title"] - PayRex</title>

 <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />
 <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
 <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
 <link rel="icon" type="image/x-icon" href="~/images/icon/payrexiconofficial.ico" />

 <style>
 body { font-family: 'Inter', sans-serif; background: white; }
 body::before {
 content: ''; 
 position: fixed;
 top:0; left:0; width:100%; height:100%;
 background: url('/images/loginbg.png') center/cover no-repeat;
 opacity:0.2; z-index: -1;
 }

 .brand-panel-bg { background: transparent; }
 </style>
</head>
<body class="min-h-screen flex flex-col lg:grid lg:grid-cols-2">
 @RenderBody()

 <script src="https://cdn.jsdelivr.net/npm/flowbite@2.5.2/dist/flowbite.min.js"></script>
 <script src="https://www.google.com/recaptcha/api.js" async defer></script>
 @RenderSection("Scripts", required: false)
</body>
</html>
