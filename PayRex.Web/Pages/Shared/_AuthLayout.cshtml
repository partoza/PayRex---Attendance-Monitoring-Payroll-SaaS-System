@{
 Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
 <meta charset="utf-8" />
 <title>@ViewData["Title"] - PayRex</title>

 <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />
 <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
 <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
 <link rel="icon" type="image/x-icon" href="~/images/icon/payrexiconofficial.ico" />

 <style>
 body { font-family: 'Inter', sans-serif; background: white; }
 body::before {
 content: ''; 
 position: fixed;
 top:0; left:0; width:100%; height:100%;
 background: url('/images/loginbg.png') center/cover no-repeat;
 opacity:0.2; z-index: -1;
 }

 .brand-panel-bg { background: transparent; }
 .login-panel-bg, .reset-panel-bg { background: transparent; position: relative; }
 .login-panel-bg::before, .reset-panel-bg::before {
 content: '';
 position: absolute; top:50%; left:50%; width:300px; height:300px;
 background: radial-gradient(circle, rgba(59,130,246,0.1), transparent);
 border-radius:50%; transform: translate(-50%, -50%);
 animation: pulseCircle6s ease-in-out infinite; pointer-events: none;
 }

 @@keyframes pulseCircle {
0%,100% { transform: translate(-50%, -50%) scale(0.8); opacity:0.3; }
50% { transform: translate(-50%, -50%) scale(1.1); opacity:0.6; }
 }
 </style>
</head>
<body class="min-h-screen flex flex-col lg:grid lg:grid-cols-2">
 @RenderBody()

 <script src="https://cdn.jsdelivr.net/npm/flowbite@2.5.2/dist/flowbite.min.js"></script>
 @RenderSection("Scripts", required: false)
</body>
</html>
