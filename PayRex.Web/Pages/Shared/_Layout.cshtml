@using PayRex.Web.Configuration
@using PayRexApplication.Models
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@using System.Security.Claims
@using System.IdentityModel.Tokens.Jwt
@{
    var userRole = User.FindFirst(ClaimTypes.Role)?.Value;
    var userEmail = User.FindFirst(ClaimTypes.Email)?.Value ?? User.FindFirst(JwtRegisteredClaimNames.Email)?.Value;
    var userId = User.FindFirst("uid")?.Value;
    var isAuthenticated = Context.Request.Cookies.ContainsKey("PayRex.AuthToken");
    var currentPath = Context.Request.Path.Value ?? "/";

    // Dual-role detection using centralised helper
    var isDualRole = MenuConfiguration.IsDualRole(userRole);
    var isEmployeeViewMode = isDualRole && Context.Request.Cookies["PayRex.ViewMode"] == "employee";

    // Pure Employee role always uses employee menu; dual-role users switch via cookie
    var isEmployeeRole = string.Equals(userRole, "Employee", StringComparison.OrdinalIgnoreCase);

    List<PayRex.Web.Models.MenuItem> menuItems;
    if (!isAuthenticated)
    {
        menuItems = new List<PayRex.Web.Models.MenuItem>();
    }
    else if (isEmployeeRole || isEmployeeViewMode)
    {
        menuItems = MenuConfiguration.GetEmployeeMenuItems(userRole);
    }
    else
    {
        menuItems = MenuConfiguration.GetMenuItemsForRole(userRole);
    }

    // Filter menu items based on RolePermissions (loaded by PermissionPageFilter)
    // When DB permissions exist, they become the SINGLE SOURCE OF TRUTH for sidebar visibility.
    var userPermissions = Context.Items["UserPermissions"] as List<RolePermission>;
    if (userPermissions != null && userPermissions.Count > 0)
    {
        if (isEmployeeRole || isEmployeeViewMode)
        {
            // For employee view, use the full employee menu filtered by DB permissions
            menuItems = MenuConfiguration.GetAllEmployeeMenuItems().Where(item =>
            {
                if (string.Equals(item.Title, "Dashboard", StringComparison.OrdinalIgnoreCase)) return true;
                var perm = userPermissions.FirstOrDefault(p =>
                    string.Equals(p.ModuleName, item.Title, StringComparison.OrdinalIgnoreCase));
                if (perm == null) return false;
                return perm.CanAdd || perm.CanUpdate || perm.CanInactivate;
            }).ToList();
        }
        else
        {
            // For management view, use the full management menu filtered by DB permissions
            menuItems = MenuConfiguration.GetAllManagementMenuItems().Where(item =>
            {
                if (string.Equals(item.Title, "Dashboard", StringComparison.OrdinalIgnoreCase)) return true;
                var perm = userPermissions.FirstOrDefault(p =>
                    string.Equals(p.ModuleName, item.Title, StringComparison.OrdinalIgnoreCase));
                if (perm == null) return false;
                return perm.CanAdd || perm.CanUpdate || perm.CanInactivate;
            }).ToList();
        }
    }

    // Extract user data from JWT token or set defaults
    string firstName = "User";
    string lastName = "";
    string fullName = "User";
    string? profileImageUrl = null;
    string? companyLogoUrl = null;

    if (isAuthenticated && Context.Request.Cookies.TryGetValue("PayRex.AuthToken", out var token))
    {
        try
        {
            var handler = new JwtSecurityTokenHandler();
            var jwtToken = handler.ReadJwtToken(token);
            userEmail = jwtToken.Claims.FirstOrDefault(c => c.Type == JwtRegisteredClaimNames.Email)?.Value ?? userEmail;
            userRole = jwtToken.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role)?.Value ?? userRole;

            // Try to get name from token claims
            var givenName = jwtToken.Claims.FirstOrDefault(c => c.Type == JwtRegisteredClaimNames.GivenName)?.Value;
            var familyName = jwtToken.Claims.FirstOrDefault(c => c.Type == JwtRegisteredClaimNames.FamilyName)?.Value;

            if (!string.IsNullOrEmpty(givenName))
            {
                firstName = givenName;
                lastName = familyName ?? "";
                fullName = !string.IsNullOrEmpty(lastName) ? $"{firstName} {lastName}" : firstName;
            }
            else if (!string.IsNullOrEmpty(userEmail))
            {
                // Fallback: use email prefix as name
                fullName = userEmail.Split('@')[0];
                firstName = fullName;
            }

            // Try to get profile image URL from claim (if added to JWT)
            profileImageUrl = jwtToken.Claims.FirstOrDefault(c => c.Type == "profileImage")?.Value;
            
            // Try to get company logo URL from claim
            companyLogoUrl = jwtToken.Claims.FirstOrDefault(c => c.Type == "companyLogo")?.Value;
        }
        catch { }
    }

    // Subscription status check for layout gating
    var layoutSubscriptionStatus = "";
    if (isAuthenticated && Context.Request.Cookies.TryGetValue("PayRex.AuthToken", out var layoutToken))
    {
        try
        {
            var h = new JwtSecurityTokenHandler();
            var jwt = h.ReadJwtToken(layoutToken);
            layoutSubscriptionStatus = jwt.Claims.FirstOrDefault(c => c.Type == "subscriptionStatus")?.Value ?? "";
        }
        catch { }
    }
    var isSuperAdmin = string.Equals(userRole, "SuperAdmin", StringComparison.OrdinalIgnoreCase);
    var isLayoutSubscriptionExpired = isAuthenticated && !isSuperAdmin &&
        (string.IsNullOrEmpty(layoutSubscriptionStatus) || string.Equals(layoutSubscriptionStatus, "Expired", StringComparison.OrdinalIgnoreCase));

    var roleDisplay = userRole switch
    {
        "SuperAdmin" => "Super Admin",
        "Admin" => "Administrator",
        "HR" => "Human Resource Manager",
        "Hr" => "Human Resource Manager",
        "Accountant" => "Accountant",
        "Employee" => "Employee",
        _ => userRole ?? "User"
    };
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PayRex</title>
    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />
    <!-- CDN fallback will be injected at runtime if local file failed to apply -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="icon" type="image/x-icon" href="~/images/icon/payrexiconofficial.ico" />

    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
    </style>
    @RenderSection("Styles", required: false)
    <script>
        // Expose resolved API base URL to client scripts
        window.ApiBaseUrl = '@(Configuration["ApiBaseUrl"] ?? Configuration.GetSection("ApiSettings:BaseUrls").Get<string[]?>()?[0] ?? "https://localhost:7000")';
    </script>
</head>
<body>

    @if (isAuthenticated)
    {
        <!-- Top Navigation Bar -->
        <nav class="fixed top-0 z-50 w-full bg-white border-b border-gray-200">
            <div class="px-4 py-2 lg:px-6 lg:pl-4">
                <div class="flex items-center justify-between">
                    <div class="flex items-center justify-start rtl:justify-end">
                        <button data-drawer-target="top-bar-sidebar" data-drawer-toggle="top-bar-sidebar" aria-controls="top-bar-sidebar" type="button" class="inline-flex items-center p-2 text-sm text-gray-500 rounded-lg lg:hidden hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-gray-200">
                            <span class="sr-only">Open sidebar</span>
                            <svg class="w-6 h-6 text-gray-800 dark:text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                <path stroke="currentColor" stroke-linecap="round" stroke-width="2" d="M5 7h14M5 12h14M5 17h10" />
                            </svg>

                        </button>
                        <a href="@(userRole == "SuperAdmin" ? "/Admin/Dashboard" : "/Dashboard")" class="flex ms-6 md:me-24">
                            <img id="layout-header-logo" src="@(string.IsNullOrEmpty(companyLogoUrl) ? Url.Content("/images/logo.png") : companyLogoUrl)" class="h-10 lg:h-16 drop-shadow-md" alt="PayRex Logo" />
                        </a>
                    </div>
                    <div class="flex items-center gap-3">
                        <!-- Notification Bell -->
                        <div class="relative">
                            <button type="button" id="notifBellBtn" onclick="toggleNotifDropdown()" class="relative p-2.5 text-gray-500 rounded-xl hover:bg-blue-50 hover:text-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-200 transition-all duration-200">
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zM10 18a3 3 0 01-3-3h6a3 3 0 01-3 3z" /></svg>
                                <span id="notifBadge" class="hidden absolute -top-1 -right-1 min-w-[18px] h-[18px] px-1 bg-gradient-to-r from-red-500 to-rose-500 text-white text-[10px] font-bold rounded-full flex items-center justify-center shadow-sm animate-pulse">0</span>
                            </button>
                            <div id="notifDropdown" class="hidden absolute right-0 mt-2 w-96 bg-white rounded-2xl shadow-2xl border border-gray-100 z-50 overflow-hidden" style="box-shadow: 0 20px 60px -15px rgba(0,0,0,0.15)">
                                <div class="relative px-5 py-4 border-b border-gray-100" style="background: linear-gradient(135deg, #f8fafc 0%, #eef2ff 100%)">
                                    <div class="flex items-center gap-3">
                                        <div id="notifHeaderIcon" class="w-9 h-9 rounded-xl flex items-center justify-center text-white shadow-sm" style="background: linear-gradient(135deg, #3b82f6, #6366f1)"></div>
                                        <div>
                                            <h3 id="notifHeaderTitle" class="text-sm font-bold text-gray-900">Notifications</h3>
                                            <p id="notifHeaderSubtitle" class="text-[11px] text-gray-500 mt-0.5"></p>
                                        </div>
                                    </div>
                                </div>
                                <div id="notifList" class="max-h-80 overflow-y-auto" style="scrollbar-width: thin">
                                    <div class="px-5 py-8 text-center text-sm text-gray-400">Loading...</div>
                                </div>
                            </div>
                        </div>

                        <!-- User Full Name and Role -->
                        <div class="hidden md:flex flex-col items-end">
                            <span class="text-sm font-semibold text-gray-900">@firstName</span>
                            <span class="inline-flex items-center px-2 py-0.5 text-xs font-medium text-gray-600 bg-gray-100 rounded">@roleDisplay</span>
                        </div>

                        <!-- User Avatar with Dropdown -->
                        <div class="flex items-center ms-3">
                            <div>
                                <button type="button" class="flex text-sm rounded-full focus:ring-4 focus:ring-gray-300" aria-expanded="false" data-dropdown-toggle="dropdown-user">
                                    <span class="sr-only">Open user menu</span>
                                    @if (!string.IsNullOrEmpty(profileImageUrl))
                                    {
                                        <img src="@profileImageUrl" alt="Profile" class="layout-profile-img w-10 h-10 rounded-full object-cover border-2 border-gray-200" />
                                    }
                                    else
                                    {
                                        <div class="layout-profile-img default-avatar w-10 h-10 rounded-full bg-blue-600 flex items-center justify-center text-white font-semibold text-lg">
                                            @firstName.Substring(0, 1).ToUpper()
                                        </div>
                                    }
                                </button>
                            </div>
                            <div class="z-50 hidden my-4 text-base list-none bg-white divide-y divide-gray-100 rounded-lg shadow-lg border border-gray-200" id="dropdown-user">
                                <div class="px-4 py-3" role="none">
                                    <div class="flex items-center gap-3">
                                        @if (!string.IsNullOrEmpty(profileImageUrl))
                                        {
                                            <img src="@profileImageUrl" alt="Profile" class="layout-profile-img w-12 h-12 rounded-full object-cover border-2 border-gray-200" />
                                        }
                                        else
                                        {
                                            <div class="layout-profile-img default-avatar w-12 h-12 rounded-full bg-blue-600 flex items-center justify-center text-white font-semibold text-xl">
                                                @firstName.Substring(0, 1).ToUpper()
                                            </div>
                                        }
                                        <div>
                                            <p class="text-sm text-gray-900 font-semibold" role="none">
                                                @fullName
                                            </p>
                                            <p class="text-xs font-medium text-gray-500" role="none">
                                                @roleDisplay
                                            </p>
                                            <p class="text-xs text-gray-400 truncate max-w-[150px]" role="none">
                                                @userEmail
                                            </p>
                                        </div>
                                    </div>
                                </div>
                                <ul class="py-1" role="none">
                                    @if (!isLayoutSubscriptionExpired)
                                    {
                                    <li>
                                        @if (userRole == "SuperAdmin")
                                        {
                                            <a href="/Admin/Dashboard" class="flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" role="menuitem">
                                                <svg class="w-4 h-4 mr-3 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                                                    <path fill-rule="evenodd" d="M9.293 2.293a1 1 0 011.414 0l7 7A1 1 0 0117 11h-1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-3a1 1 0 00-1-1H9a1 1 0 00-1 1v3a1 1 0 01-1 1H5a1 1 0 01-1-1v-6H3a1 1 0 01-.707-1.707l7-7z" clip-rule="evenodd" />
                                                </svg>
                                                Admin Dashboard
                                            </a>
                                        }
                                        else
                                        {
                                            <a href="/Dashboard" class="flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" role="menuitem">
                                                <svg class="w-4 h-4 mr-3 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                                                    <path fill-rule="evenodd" d="M9.293 2.293a1 1 0 011.414 0l7 7A1 1 0 0117 11h-1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-3a1 1 0 00-1-1H9a1 1 0 00-1 1v3a1 1 0 01-1 1H5a1 1 0 01-1-1v-6H3a1 1 0 01-.707-1.707l7-7z" clip-rule="evenodd" />
                                                </svg>
                                                Dashboard
                                            </a>
                                        }
                                    </li>
                                    @if (isDualRole)
                                    {
                                        <li>
                                            @if (isEmployeeViewMode)
                                            {
                                                <a href="#" onclick="switchToManagement()" class="flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" role="menuitem">
                                                    <svg class="w-4 h-4 mr-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 15l-3-3m0 0l3-3m-3 3h8M3 12a9 9 0 1118 0 9 9 0 01-18 0z" />
                                                    </svg>
                                                    Back to Management
                                                </a>
                                            }
                                            else
                                            {
                                                <a href="#" onclick="switchToEmployee()" class="flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" role="menuitem">
                                                    <svg class="w-4 h-4 mr-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                                    </svg>
                                                    Employee View
                                                </a>
                                            }
                                        </li>
                                    }
                                    <li>
                                        <a href="/Profile" class="flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" role="menuitem">
                                            <svg class="w-4 h-4 mr-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                            </svg>
                                            Profile Settings
                                        </a>
                                    </li>
                                    }
                                    <li class="border-t border-gray-100">
                                        <form method="post" asp-page="/Auth/Logout" class="block logout-form">
                                            <button type="submit" class="flex items-center w-full px-4 py-2 text-sm text-red-600 hover:bg-red-50" role="menuitem">
                                                <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                                                </svg>
                                                Sign out
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </nav>

        <!-- Sidebar -->
        <aside id="top-bar-sidebar" class="fixed top-0 left-0 z-40 w-80 h-screen pt-24 transition-transform -translate-x-full bg-white border-r border-gray-200 lg:translate-x-0" aria-label="Sidebar">
            <div class="h-full px-4 pb-4 overflow-y-auto bg-white">
                @if (isLayoutSubscriptionExpired)
                {
                    <!-- Subscription Expired Sidebar -->
                    <div class="mb-4 px-3 py-4 bg-red-50 border border-red-200 rounded-xl">
                        <div class="flex items-center gap-2 mb-2">
                            <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z" />
                            </svg>
                            <span class="text-sm font-bold text-red-800">Subscription Expired</span>
                        </div>
                        <p class="text-xs text-red-600 mb-3">Renew your subscription to access the system.</p>
                        <a href="/Billing" class="block text-center text-sm font-semibold text-white bg-red-600 hover:bg-red-700 rounded-lg py-2 px-4 transition-colors">
                            Renew Now
                        </a>
                    </div>
                    <ul class="space-y-2 font-medium">
                        <li>
                            <a href="/Billing" class="flex items-center p-3 rounded-lg @(currentPath.StartsWith("/Billing", StringComparison.OrdinalIgnoreCase) ? "bg-blue-50 text-blue-600" : "text-gray-700 hover:bg-gray-100") group text-md">
                                <span class="@(currentPath.StartsWith("/Billing", StringComparison.OrdinalIgnoreCase) ? "text-blue-600" : "text-gray-500")">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" /></svg>
                                </span>
                                <span class="ms-3 truncate">Billing & Subscription</span>
                            </a>
                        </li>
                    </ul>
                }
                else
                {
                @if (isEmployeeViewMode)
                {
                    <div class="mb-3 px-3 py-2.5 bg-blue-50 border border-blue-200 rounded-xl flex items-center justify-between">
                        <div class="flex items-center gap-2">
                            <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                            <span class="text-xs font-semibold text-blue-700">Employee View</span>
                        </div>
                        <button onclick="switchToManagement()" class="text-xs font-medium text-blue-600 hover:text-blue-800 hover:underline">Exit</button>
                    </div>
                }
                <ul class="space-y-2 font-medium">
                    @foreach (var item in menuItems)
                    {
                        var isActive = currentPath.StartsWith(item.Url, StringComparison.OrdinalIgnoreCase);
                        var activeClass = isActive ? "bg-blue-50 text-blue-600" : "text-gray-700 hover:bg-gray-100";

                        @if (!string.IsNullOrEmpty(item.SectionHeader))
                        {
                            <li class="pt-4 first:pt-0">
                                <span class="px-3 text-xs font-semibold uppercase tracking-wider text-gray-400">@item.SectionHeader</span>
                            </li>
                        }

                        <li>
                            <a href="@item.Url" class="flex items-center p-3 rounded-lg @activeClass group text-md">
                                <span class="@(isActive ? "text-blue-600" : "text-gray-500")">
                                    @Html.Raw(item.Icon)
                                </span>
                                <span class="ms-3 truncate">@item.Title</span>
                                @if (!string.IsNullOrEmpty(item.Badge))
                                {
                                    <span class="inline-flex items-center justify-center px-2 ms-3 text-sm font-medium @item.BadgeColor">@item.Badge</span>
                                }
                            </a>
                        </li>
                    }
                </ul>
                }
            </div>
        </aside>

        <!-- Main Content with global page skeleton -->
        <div class="p-4 lg:ml-80 mt-20">
            <div class="p-4">
                <div id="page-skeleton" class="space-y-6">
                    <!-- Header skeleton -->
                    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 animate-pulse">
                        <div class="h-5 w-40 bg-gray-200 rounded mb-3"></div>
                        <div class="h-4 w-72 bg-gray-100 rounded"></div>
                    </div>

                    <!-- Cards skeleton -->
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-4 space-y-3 animate-pulse">
                            <div class="h-4 w-20 bg-gray-200 rounded"></div>
                            <div class="h-7 w-16 bg-gray-100 rounded"></div>
                        </div>
                        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-4 space-y-3 animate-pulse">
                            <div class="h-4 w-24 bg-gray-200 rounded"></div>
                            <div class="h-7 w-20 bg-gray-100 rounded"></div>
                        </div>
                        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-4 space-y-3 animate-pulse hidden sm:block">
                            <div class="h-4 w-24 bg-gray-200 rounded"></div>
                            <div class="h-7 w-20 bg-gray-100 rounded"></div>
                        </div>
                        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-4 space-y-3 animate-pulse hidden lg:block">
                            <div class="h-4 w-24 bg-gray-200 rounded"></div>
                            <div class="h-7 w-20 bg-gray-100 rounded"></div>
                        </div>
                    </div>

                    <!-- Table/list skeleton -->
                    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-4 space-y-4 animate-pulse">
                        <div class="h-4 w-32 bg-gray-200 rounded"></div>
                        <div class="space-y-2">
                            <div class="h-10 w-full bg-gray-50 rounded-lg"></div>
                            <div class="h-10 w-full bg-gray-50 rounded-lg"></div>
                            <div class="h-10 w-full bg-gray-50 rounded-lg hidden sm:block"></div>
                        </div>
                    </div>
                </div>

                <div id="page-content" class="opacity-0">
                    @RenderBody()
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Public Layout (No Sidebar) -->
        <div class="min-h-screen">
            @RenderBody()
        </div>
    }

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <script src="https://cdn.jsdelivr.net/npm/flowbite@2.5.2/dist/flowbite.min.js"></script>
    <!-- Global toast container and helpers (centralized) -->
    <div id="toast-container" class="fixed top-4 right-4 z-50 space-y-4 md:top-6 md:right-6 max-w-sm w-full"></div>
    <style>
        @@keyframes slideIn {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
        @@keyframes progress {
            from { width: 100%; }
            to { width: 0%; }
        }
        .animate-slide-in { animation: slideIn 0.3s ease-out forwards; }
        .animate-progress { animation: progress 3s linear forwards; }
    </style>

    <script>
        function showToast(message, type) {
            // remove any loading toast
            const existingLoading = document.getElementById('loading-toast');
            if (existingLoading) existingLoading.remove();

            const container = document.getElementById('toast-container');
            if (!container) return;
            const toast = document.createElement('div');
            toast.className = 'toast-message group relative overflow-hidden bg-white border rounded-2xl shadow-lg p-4 animate-slide-in';
            if (type === 'success') toast.classList.add('border-green-100');
            if (type === 'error') toast.classList.add('border-red-100');
            const barColor = type === 'success' ? 'bg-green-500' : (type === 'error' ? 'bg-red-500' : 'bg-blue-500');
            const iconBg = type === 'success' ? 'bg-green-50' : (type === 'error' ? 'bg-red-50' : 'bg-blue-50');
            const iconColor = type === 'success' ? 'text-green-600' : (type === 'error' ? 'text-red-600' : 'text-blue-600');
            const title = type === 'success' ? 'Success' : (type === 'error' ? 'Error' : 'Notice');

            toast.innerHTML = `<div class="absolute bottom-0 left-0 h-1 ${barColor} transition-all duration-[3000ms] w-full animate-progress"></div>
                <div class="flex items-start gap-4">
                    <div class="p-2 ${iconBg} rounded-xl shrink-0">
                        <svg class="w-6 h-6 ${iconColor}" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
                        </svg>
                    </div>
                    <div class="flex-1 pt-0.5">
                        <h3 class="text-sm font-semibold text-gray-900">${title}</h3>
                        <p class="text-sm text-gray-600 mt-1">${message}</p>
                    </div>
                    <button type="button" onclick="this.closest('.toast-message').remove()" class="text-gray-400 hover:text-gray-600 transition-colors">&times;</button>
                </div>`;

            container.appendChild(toast);
            setTimeout(() => { toast.style.opacity = '0'; toast.style.transform = 'translateY(-10px)'; setTimeout(() => toast.remove(), 300); }, 3000);
        }

        function showLoadingToast(message) {
            const container = document.getElementById('toast-container');
            if (!container) return;
            if (document.getElementById('loading-toast')) return;
            const toast = document.createElement('div');
            toast.id = 'loading-toast';
            toast.className = 'toast-message group relative overflow-hidden bg-white border rounded-2xl shadow-lg p-4 animate-slide-in';
            toast.innerHTML = `<div class="flex items-start gap-4">
                <div class="p-2 bg-blue-50 rounded-xl shrink-0">
                    <svg class="w-6 h-6 text-blue-600 animate-spin" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                    </svg>
                </div>
                <div class="flex-1 pt-0.5">
                    <h3 class="text-sm font-semibold text-gray-900">Uploading</h3>
                    <p class="text-sm text-gray-600 mt-1">${message || 'Uploading...'}</p>
                </div>
            </div>`;
            container.appendChild(toast);
        }

        function showUploadToast() { showLoadingToast('Uploading image...'); }
        function hideUploadToast() { const t = document.getElementById('upload-toast') || document.getElementById('loading-toast'); if (t) { t.style.opacity = '0'; t.style.transform = 'translateY(-10px)'; setTimeout(() => t.remove(), 300); } }

        // Optional helper for server-rendered toasts (keeps backwards compatibility)
        function showToastFromServer() {
            const toasts = document.querySelectorAll('.toast-message');
            toasts.forEach(t => {
                setTimeout(() => { t.style.opacity = '0'; t.style.transform = 'translateY(-10px)'; setTimeout(() => t.remove(), 300); }, 3000);
            });
        }

        document.addEventListener('DOMContentLoaded', showToastFromServer);
    </script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        // Check for locally stored profile image and logo overrides (allows updating without logout)
        (function() {
            try {
                const storedLogo = localStorage.getItem('payrex_company_logo');
                if (storedLogo) {
                    const logoImg = document.getElementById('layout-header-logo');
                    if (logoImg) logoImg.src = storedLogo;
                }
                
                const storedProfile = localStorage.getItem('payrex_profile_image');
                if (storedProfile) {
                    const profileImgs = document.querySelectorAll('.layout-profile-img');
                    profileImgs.forEach(img => img.src = storedProfile);
                }
            } catch (e) { console.error('Error restoring layout images', e); }
        })();

        // Ensure local cached images are cleared before submitting logout forms
        document.addEventListener('DOMContentLoaded', function () {
            try {
                document.querySelectorAll('.logout-form').forEach(function (f) {
                    f.addEventListener('submit', function () {
                        try {
                            // Remove all localStorage
                            localStorage.clear();
                            // Remove all cookies
                            document.cookie.split(';').forEach(function(c) {
                                document.cookie = c.replace(/^ +/, '').replace(/=.*/, '=;expires=' + new Date().toUTCString() + ';path=/');
                            });
                        } catch (e) { }
                        // After logout, let server redirect without forcing a double reload
                    });
                });
            } catch (e) { /* ignore */ }
        });

        // Runtime check: verify Tailwind utilities are applied; if not, inject CDN stylesheet (development fallback)
        (function () {
            try {
                var test = document.createElement('div');
                test.className = 'hidden';
                document.documentElement.appendChild(test);
                var applied = window.getComputedStyle(test).display === 'none';
                document.documentElement.removeChild(test);

                console.log('Tailwind utilities applied:', applied);
                if (!applied) {
                    console.warn('Tailwind appears not to be applied. Injecting CDN fallback stylesheet.');
                    var link = document.createElement('link');
                    link.rel = 'stylesheet';
                    link.href = 'https://cdn.jsdelivr.net/npm/tailwindcss@3.4.19/dist/tailwind.min.css';
                    document.head.appendChild(link);
                }
            } catch (e) {
                console.error('Tailwind detection error', e);
            }
        })();

        // Simple global skeleton controller: fade out skeleton once page is interactive
        document.addEventListener('DOMContentLoaded', function () {
            try {
                const skeleton = document.getElementById('page-skeleton');
                const content = document.getElementById('page-content');
                if (!skeleton || !content) return;

                // Use a small delay so skeleton is visible briefly on fast pages too
                setTimeout(function () {
                    skeleton.classList.add('hidden');
                    content.classList.remove('opacity-0');
                }, 150);
            } catch (e) { /* ignore */ }
        });

        // ── View-mode switching for HR/Accountant dual-role ──
        function switchToEmployee() {
            document.cookie = 'PayRex.ViewMode=employee;path=/;SameSite=Lax';
            window.location.href = '/Dashboard';
        }
        function switchToManagement() {
            document.cookie = 'PayRex.ViewMode=;path=/;expires=Thu, 01 Jan 1970 00:00:00 GMT;SameSite=Lax';
            window.location.href = '/Dashboard';
        }

        // ── Notification Bell ──
        var notifDropdownOpen = false;
        var notifRole = '@(userRole ?? "Employee")';

        // Role-specific configuration
        var notifConfig = {
            SuperAdmin: {
                title: 'System Alerts',
                subtitle: 'Updates, bug fixes & subscriptions',
                gradient: 'linear-gradient(135deg, #7c3aed, #a855f7)',
                icon: '<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>',
                emptyMsg: 'No system alerts at the moment',
                emptyIcon: '⚙️'
            },
            Admin: {
                title: 'Company Updates',
                subtitle: 'Billing, payroll & requests',
                gradient: 'linear-gradient(135deg, #3b82f6, #6366f1)',
                icon: '<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>',
                emptyMsg: 'No company notifications',
                emptyIcon: '🏢'
            },
            HR: {
                title: 'HR Notifications',
                subtitle: 'Leave requests & attendance',
                gradient: 'linear-gradient(135deg, #10b981, #059669)',
                icon: '<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>',
                emptyMsg: 'No pending HR notifications',
                emptyIcon: '👥'
            },
            Accountant: {
                title: 'Announcements',
                subtitle: 'Important company updates',
                gradient: 'linear-gradient(135deg, #f59e0b, #d97706)',
                icon: '<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>',
                emptyMsg: 'No announcements at the moment',
                emptyIcon: '📊'
            },
            Employee: {
                title: 'Announcements',
                subtitle: 'Updates & important notices',
                gradient: 'linear-gradient(135deg, #3b82f6, #2563eb)',
                icon: '<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/></svg>',
                emptyMsg: 'No announcements for you',
                emptyIcon: '📢'
            }
        };

        // Notification type icons
        function getNotifTypeInfo(type) {
            var map = {
                warning: { bg: 'bg-amber-50', border: 'border-amber-200', text: 'text-amber-700', label: 'Warning', icon: '<svg class="w-4 h-4 text-amber-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>' },
                success: { bg: 'bg-emerald-50', border: 'border-emerald-200', text: 'text-emerald-700', label: 'Success', icon: '<svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>' },
                info: { bg: 'bg-blue-50', border: 'border-blue-200', text: 'text-blue-700', label: 'Info', icon: '<svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>' }
            };
            return map[type] || map.info;
        }

        // Time-ago formatter
        function timeAgo(dateStr) {
            var now = new Date();
            var d = new Date(dateStr);
            var diff = Math.floor((now - d) / 1000);
            if (diff < 60) return 'Just now';
            if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
            if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
            if (diff < 172800) return 'Yesterday';
            if (diff < 604800) return Math.floor(diff / 86400) + 'd ago';
            return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
        }

        function toggleNotifDropdown() {
            notifDropdownOpen = !notifDropdownOpen;
            var dd = document.getElementById('notifDropdown');
            if (notifDropdownOpen) {
                dd.classList.remove('hidden');
                initNotifHeader();
                loadNotifications();
            } else {
                dd.classList.add('hidden');
            }
        }
        document.addEventListener('click', function(e) {
            var bell = document.getElementById('notifBellBtn');
            var dd = document.getElementById('notifDropdown');
            if (bell && dd && !bell.contains(e.target) && !dd.contains(e.target)) {
                dd.classList.add('hidden');
                notifDropdownOpen = false;
            }
        });

        function initNotifHeader() {
            var cfg = notifConfig[notifRole] || notifConfig.Employee;
            var hIcon = document.getElementById('notifHeaderIcon');
            var hTitle = document.getElementById('notifHeaderTitle');
            var hSub = document.getElementById('notifHeaderSubtitle');
            if (hIcon) { hIcon.innerHTML = cfg.icon; hIcon.style.background = cfg.gradient; }
            if (hTitle) hTitle.textContent = cfg.title;
            if (hSub) hSub.textContent = cfg.subtitle;
        }

        function loadNotifications() {
            fetch(window.ApiBaseUrl + '/api/superadmin/system-notifications/role/' + encodeURIComponent(notifRole))
                .then(function(r) { return r.ok ? r.json() : []; })
                .then(function(data) {
                    var list = document.getElementById('notifList');
                    var badge = document.getElementById('notifBadge');
                    var cfg = notifConfig[notifRole] || notifConfig.Employee;

                    if (!data || data.length === 0) {
                        list.innerHTML = '<div class="px-5 py-10 text-center">' +
                            '<div class="text-3xl mb-3">' + cfg.emptyIcon + '</div>' +
                            '<p class="text-sm font-medium text-gray-400">' + cfg.emptyMsg + '</p>' +
                            '<p class="text-xs text-gray-300 mt-1">You\'re all caught up!</p>' +
                            '</div>';
                        badge.classList.add('hidden');
                        return;
                    }
                    badge.textContent = data.length > 9 ? '9+' : data.length;
                    badge.classList.remove('hidden');
                    badge.classList.remove('animate-pulse');

                    var html = '';
                    data.forEach(function(n, idx) {
                        var ti = getNotifTypeInfo(n.type);
                        var ago = n.createdAt ? timeAgo(n.createdAt) : '';
                        html += '<div class="px-4 py-3.5 border-b border-gray-50 hover:bg-gray-50/80 transition-colors duration-150 cursor-default">' +
                            '<div class="flex gap-3 items-start">' +
                            '<div class="w-8 h-8 rounded-lg ' + ti.bg + ' ' + ti.border + ' border flex items-center justify-center flex-shrink-0 mt-0.5">' + ti.icon + '</div>' +
                            '<div class="flex-1 min-w-0">' +
                            '<div class="flex items-center justify-between gap-2">' +
                            '<p class="text-[13px] font-semibold text-gray-900 truncate">' + escapeHtml(n.title) + '</p>' +
                            '<span class="text-[10px] text-gray-400 flex-shrink-0 whitespace-nowrap">' + ago + '</span>' +
                            '</div>' +
                            '<p class="text-xs text-gray-500 mt-0.5 line-clamp-2" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">' + escapeHtml(n.message) + '</p>' +
                            '<span class="inline-block mt-1.5 px-2 py-0.5 rounded-full text-[10px] font-medium ' + ti.bg + ' ' + ti.text + '">' + ti.label + '</span>' +
                            '</div></div></div>';
                    });
                    list.innerHTML = html;
                })
                .catch(function() {
                    var cfg = notifConfig[notifRole] || notifConfig.Employee;
                    document.getElementById('notifList').innerHTML = '<div class="px-5 py-10 text-center">' +
                        '<div class="text-3xl mb-3">⚠️</div>' +
                        '<p class="text-sm font-medium text-gray-400">Could not load notifications</p>' +
                        '<p class="text-xs text-gray-300 mt-1">Please try again later</p>' +
                        '</div>';
                });
        }
        function escapeHtml(str) {
            var div = document.createElement('div');
            div.appendChild(document.createTextNode(str));
            return div.innerHTML;
        }
        // Auto-check notification count on page load
        document.addEventListener('DOMContentLoaded', function() {
            initNotifHeader();
            fetch(window.ApiBaseUrl + '/api/superadmin/system-notifications/role/' + encodeURIComponent(notifRole))
                .then(function(r) { return r.ok ? r.json() : []; })
                .then(function(data) {
                    var badge = document.getElementById('notifBadge');
                    if (badge && data && data.length > 0) {
                        badge.textContent = data.length > 9 ? '9+' : data.length;
                        badge.classList.remove('hidden');
                    }
                }).catch(function() {});
        });
    </script>

</body>
</html>