@page
@model IndexModel
@using System.Security.Claims
@using System.IdentityModel.Tokens.Jwt
@using PayRex.Web.Configuration
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
    ViewData["Title"] = "Welcome to PayRex";

    // Authentication Logic & User Data Extraction
    var isAuthenticated = Request.Cookies.ContainsKey("PayRex.AuthToken");
    
    // Default user data
    string firstName = "User";
    string lastName = "";
    string fullName = "User";
    string? userRole = null;
    string userEmail = "";
    string? profileImageUrl = null;
    string? companyLogoUrl = null;

    if (isAuthenticated && Request.Cookies.TryGetValue("PayRex.AuthToken", out var token))
    {
        try
        {
            var handler = new JwtSecurityTokenHandler();
            var jwtToken = handler.ReadJwtToken(token);
            
            userEmail = jwtToken.Claims.FirstOrDefault(c => c.Type == JwtRegisteredClaimNames.Email)?.Value ?? "";
            userRole = jwtToken.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role)?.Value;

            // Try to get name from token claims
            var givenName = jwtToken.Claims.FirstOrDefault(c => c.Type == JwtRegisteredClaimNames.GivenName)?.Value;
            var familyName = jwtToken.Claims.FirstOrDefault(c => c.Type == JwtRegisteredClaimNames.FamilyName)?.Value;

            if (!string.IsNullOrEmpty(givenName))
            {
                firstName = givenName;
                lastName = familyName ?? "";
                fullName = !string.IsNullOrEmpty(lastName) ? $"{firstName} {lastName}" : firstName;
            }
            else if (!string.IsNullOrEmpty(userEmail))
            {
                fullName = userEmail.Split('@')[0];
                firstName = fullName;
            }

            // Get profile image & company logo
            profileImageUrl = jwtToken.Claims.FirstOrDefault(c => c.Type == "profileImage")?.Value;
            companyLogoUrl = jwtToken.Claims.FirstOrDefault(c => c.Type == "companyLogo")?.Value;
        }
        catch { /* Token parsing failed - treat as unauthenticated or handle gracefully */ }
    }
    
    // Role Display Logic (for dropdown)
    var roleDisplay = userRole switch
    {
        "SuperAdmin" => "Super Admin",
        "Admin" => "Administrator",
        "HR" => "Human Resource Manager",
        "Hr" => "Human Resource Manager",
        "Accountant" => "Accountant",
        "Employee" => "Employee",
        _ => userRole ?? "User"
    };

    // Subscription status from JWT claim
    string? subscriptionStatus = null;
    if (isAuthenticated && Request.Cookies.TryGetValue("PayRex.AuthToken", out var tokenForSub))
    {
        try
        {
            var h = new JwtSecurityTokenHandler();
            var jwt = h.ReadJwtToken(tokenForSub);
            subscriptionStatus = jwt.Claims.FirstOrDefault(c => c.Type == "subscriptionStatus")?.Value;
        }
        catch { }
    }

    // Determine if the user is blocked due to expired/no subscription
    var isSuperAdmin = string.Equals(userRole, "SuperAdmin", StringComparison.OrdinalIgnoreCase);
    var isSubscriptionExpired = isAuthenticated && !isSuperAdmin &&
        (string.IsNullOrEmpty(subscriptionStatus) || string.Equals(subscriptionStatus, "Expired", StringComparison.OrdinalIgnoreCase));

    // Dashboard Link Logic
    var dashboardLink = (userRole == "SuperAdmin") ? "/Admin/Dashboard" : "/Dashboard";
    var startBtnLink = isAuthenticated ? dashboardLink : "/Auth/Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Payrex | Attendance & Payroll Management System for Filipino Enterprises</title>

    <!-- Project CSS (existing) -->
    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" type="image/x-icon" href="~/images/icon/payrexiconofficial.ico" />

    <!-- Page-specific fonts / icons -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />

    <!-- Optional: local bundle if you have a compiled dist/styles.css in wwwroot/dist -->
    <link rel="stylesheet" href="~/dist/styles.css" asp-append-version="true" />
    <style>
        /* Ensure the Inter font family is applied when tailwind isn't overriding */
        .font-inter {
            font-family: 'Inter', ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial;
        }
        /* small fallback for full page hero background if needed */
        .bg-page-bg {
            background: radial-gradient(ellipse at 10% 10%, rgba(14,165,233,0.04), transparent), linear-gradient(180deg,#f8fafc,#ffffff);
        }

        @@keyframes carousel {
            0% {
                transform: translateX(0);
            }

            100% {
                transform: translateX(-33.33%); /* For 3 sets */
            }
        }

        .animate-carousel {
            animation: carousel 40s linear infinite;
            will-change: transform;
        }

            .animate-carousel:hover {
                animation-play-state: paused;
            }
    </style>
</head>
