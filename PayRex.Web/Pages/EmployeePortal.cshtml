@page
@model PayRex.Web.Pages.EmployeePortalModel
@{
    ViewData["Title"] = "Employee Portal";
    // Show toast from StatusMessage
    var statusMsg = Model.StatusMessage ?? "";
    var toastType = statusMsg.StartsWith("success:") ? "success" : "error";
    var toastText = statusMsg.Contains(":") ? statusMsg.Substring(statusMsg.IndexOf(':') + 1) : "";
}

@if (!string.IsNullOrEmpty(toastText))
{
    <script>document.addEventListener('DOMContentLoaded',()=>showToast(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(toastText)), '@toastType'));</script>
}

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 space-y-5 sm:space-y-6">
    <!-- Header -->
    <div class="bg-gradient-to-r from-blue-600 to-blue-800 rounded-2xl shadow-lg p-6 sm:p-8 text-white relative overflow-hidden">
        <div class="absolute top-0 right-0 -mt-10 -mr-10 w-64 h-64 bg-white/10 rounded-full blur-3xl"></div>
        <div class="relative z-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
                <h1 class="text-2xl sm:text-3xl font-bold tracking-tight">Employee Portal</h1>
                <p class="mt-1 text-blue-100">Manage your leave requests and view payslips.</p>
            </div>
            <button onclick="openLeaveModal()"
                    class="inline-flex items-center gap-2 px-5 py-2.5 bg-white text-blue-700 font-semibold rounded-xl hover:bg-blue-50 shadow transition-all whitespace-nowrap">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                Request Leave
            </button>
        </div>
    </div>

    <!-- Leave Balance Cards -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 sm:gap-4">
        @{
            var bal = Model.Balance;
            var sickPct  = bal.SickTotal  > 0 ? (bal.SickUsed  * 100.0 / bal.SickTotal)  : 0;
            var vacPct   = bal.VacationTotal > 0 ? (bal.VacationUsed * 100.0 / bal.VacationTotal) : 0;
        }
        <div class="col-span-2 bg-white rounded-2xl border border-gray-100 shadow-sm p-4 sm:p-5">
            <div class="flex items-center justify-between mb-3">
                <div>
                    <p class="text-xs sm:text-sm font-medium text-gray-500">Sick Leave</p>
                    <p class="text-xl sm:text-2xl font-bold text-gray-900">@bal.SickRemaining <span class="text-sm font-normal text-gray-400">/ @bal.SickTotal days</span></p>
                </div>
                <div class="p-2.5 bg-red-50 rounded-xl text-red-500">
                    <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                    </svg>
                </div>
            </div>
            <div class="w-full bg-gray-100 rounded-full h-1.5">
                <div class="bg-red-400 h-1.5 rounded-full" style="width:@sickPct%"></div>
            </div>
            <p class="text-xs text-gray-400 mt-1">@bal.SickUsed used this year</p>
        </div>

        <div class="col-span-2 bg-white rounded-2xl border border-gray-100 shadow-sm p-4 sm:p-5">
            <div class="flex items-center justify-between mb-3">
                <div>
                    <p class="text-xs sm:text-sm font-medium text-gray-500">Vacation Leave</p>
                    <p class="text-xl sm:text-2xl font-bold text-gray-900">@bal.VacationRemaining <span class="text-sm font-normal text-gray-400">/ @bal.VacationTotal days</span></p>
                </div>
                <div class="p-2.5 bg-green-50 rounded-xl text-green-500">
                    <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064" />
                    </svg>
                </div>
            </div>
            <div class="w-full bg-gray-100 rounded-full h-1.5">
                <div class="bg-green-400 h-1.5 rounded-full" style="width:@vacPct%"></div>
            </div>
            <p class="text-xs text-gray-400 mt-1">@bal.VacationUsed used this year</p>
        </div>
    </div>

    <!-- Tabs -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="border-b border-gray-100">
            <nav class="flex gap-0" id="portalTabs">
                <button onclick="showTab('leave')" id="tab-leave"
                        class="portal-tab px-5 py-3.5 text-sm font-semibold text-blue-600 border-b-2 border-blue-600 bg-blue-50/50 transition-all">
                    Leave Requests
                </button>
                <button onclick="showTab('payslips')" id="tab-payslips"
                        class="portal-tab px-5 py-3.5 text-sm font-semibold text-gray-500 border-b-2 border-transparent hover:text-gray-700 transition-all">
                    My Payslips
                </button>
            </nav>
        </div>

        <!-- ── Leave Requests Tab ── -->
        <div id="panel-leave" class="portal-panel">
            <div class="px-4 sm:px-6 py-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 border-b border-gray-50">
                <div>
                    <h2 class="text-sm font-semibold text-gray-900">My Leave Requests</h2>
                    <p class="text-xs text-gray-500 mt-0.5">@Model.LeaveRequests.Count total requests</p>
                </div>
                <div class="flex gap-2">
                    <select id="leaveStatusFilter" onchange="filterLeaveTable()" class="px-3 py-2 text-xs border border-gray-300 rounded-lg bg-white focus:ring-2 focus:ring-blue-500">
                        <option value="">All Status</option>
                        <option value="Pending">Pending</option>
                        <option value="Approved">Approved</option>
                        <option value="Rejected">Rejected</option>
                    </select>
                </div>
            </div>

            @if (!Model.LeaveRequests.Any())
            {
                <div class="flex flex-col items-center justify-center py-12 px-6">
                    <div class="w-14 h-14 bg-blue-50 rounded-full flex items-center justify-center mb-4">
                        <svg class="w-7 h-7 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                    </div>
                    <p class="text-sm font-medium text-gray-500">No leave requests yet</p>
                    <p class="text-xs text-gray-400 mt-1">Click "Request Leave" to submit one</p>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="w-full" id="leaveTable">
                        <thead class="bg-gray-50/80">
                            <tr>
                                <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Type</th>
                                <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Dates</th>
                                <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Days</th>
                                <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
                                <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Reviewer</th>
                                <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Submitted</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            @foreach (var lr in Model.LeaveRequests)
                            {
                                var stClass = lr.Status == "Approved" ? "bg-green-100 text-green-700" :
                                              lr.Status == "Rejected" ? "bg-red-100 text-red-700" :
                                                                        "bg-yellow-100 text-yellow-700";
                                var typeIcon = "";
                                <tr class="hover:bg-gray-50/50 transition-colors leave-data-row" data-status="@lr.Status">
                                    <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap">
                                        <div class="flex items-center gap-2">
                                        <span class="text-xs sm:text-sm font-semibold text-gray-900">@lr.LeaveType</span>
                                        </div>
                                    </td>
                                    <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap text-xs sm:text-sm text-gray-600">
                                        @lr.StartDate → @lr.EndDate
                                    </td>
                                    <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap">
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-bold bg-blue-100 text-blue-700">
                                            @lr.TotalDays day@(lr.TotalDays != 1 ? "s" : "")
                                        </span>
                                    </td>
                                    <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap">
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold @stClass">
                                            @lr.Status
                                        </span>
                                    </td>
                                    <td class="px-4 sm:px-6 py-3 sm:py-4 text-xs sm:text-sm text-gray-500">
                                        @if (!string.IsNullOrEmpty(lr.ReviewerName))
                                        {
                                            <div>@lr.ReviewerName</div>
                                            if (!string.IsNullOrEmpty(lr.ReviewRemarks))
                                            {
                                                <div class="text-xs text-gray-400 italic mt-0.5">"@lr.ReviewRemarks"</div>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-gray-300">—</span>
                                        }
                                    </td>
                                    <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap text-xs text-gray-400">
                                        @lr.CreatedAt.ToString("MMM dd, yyyy")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <!-- ── Payslips Tab ── -->
        <div id="panel-payslips" class="portal-panel hidden">
            @if (!Model.Payslips.Any())
            {
                <div class="flex flex-col items-center justify-center py-12 px-6">
                    <div class="w-14 h-14 bg-blue-50 rounded-full flex items-center justify-center mb-4">
                        <svg class="w-7 h-7 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                    </div>
                    <p class="text-sm font-medium text-gray-500">No payslips available</p>
                    <p class="text-xs text-gray-400 mt-1">Payslips will appear here after payroll is processed</p>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead class="bg-gray-50/80">
                            <tr>
                                <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Period</th>
                                <th class="px-4 sm:px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Gross Pay</th>
                                <th class="px-4 sm:px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Deductions</th>
                                <th class="px-4 sm:px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Net Pay</th>
                                <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            @foreach (var ps in Model.Payslips)
                            {
                                <tr class="hover:bg-gray-50/50 transition-colors">
                                    <td class="px-4 sm:px-6 py-3 sm:py-4">
                                        <div class="text-sm font-semibold text-gray-900">@ps.PeriodName</div>
                                        <div class="text-xs text-gray-400">@ps.GeneratedAt.ToString("MMM dd, yyyy")</div>
                                    </td>
                                    <td class="px-4 sm:px-6 py-3 sm:py-4 text-right text-sm font-medium text-gray-700">₱@ps.GrossPay.ToString("N2")</td>
                                    <td class="px-4 sm:px-6 py-3 sm:py-4 text-right text-sm text-red-600">-₱@ps.TotalDeductions.ToString("N2")</td>
                                    <td class="px-4 sm:px-6 py-3 sm:py-4 text-right text-sm font-bold text-blue-700">₱@ps.NetPay.ToString("N2")</td>
                                    <td class="px-4 sm:px-6 py-3 sm:py-4">
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold @(ps.Released ? "bg-green-100 text-green-700" : "bg-gray-100 text-gray-600")">
                                            @(ps.Released ? "Released" : "Pending")
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- ═══ Request Leave Modal ═══ -->
<div id="leaveModal" class="fixed inset-0 z-50 hidden" role="dialog" aria-modal="true">
    <div class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm" onclick="closeLeaveModal()"></div>
    <div class="flex min-h-full items-center justify-center p-4">
        <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-md overflow-hidden">
            <!-- Header -->
            <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
                <div class="flex items-center gap-3">
                    <div class="p-2 bg-blue-50 rounded-xl text-blue-600">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-base font-bold text-gray-900">Request Leave</h3>
                        <p class="text-xs text-gray-500 mt-0.5">Fill in the details below</p>
                    </div>
                </div>
                <button onclick="closeLeaveModal()" class="rounded-lg p-1.5 text-gray-400 hover:bg-gray-100">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                </button>
            </div>

            <!-- Form -->
            <form method="post" asp-page-handler="SubmitLeave" class="p-6 space-y-4">
                @Html.AntiForgeryToken()

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Leave Type <span class="text-red-500">*</span></label>
                    <select name="leaveType" required
                            class="w-full px-3 py-2.5 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-white">
                        <option value="">Select type...</option>
                        <option value="Vacation">Vacation Leave</option>
                        <option value="Sick">Sick Leave</option>
                        <option value="Emergency">Emergency Leave</option>
                        <option value="Maternity">Maternity Leave</option>
                        <option value="Paternity">Paternity Leave</option>
                    </select>
                </div>

                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1.5">Start Date <span class="text-red-500">*</span></label>
                        <input type="date" name="startDate" id="leaveStartDate" required
                               min="@DateTime.Today.ToString("yyyy-MM-dd")"
                               onchange="calcDays()"
                               class="w-full px-3 py-2.5 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 bg-white">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1.5">End Date <span class="text-red-500">*</span></label>
                        <input type="date" name="endDate" id="leaveEndDate" required
                               min="@DateTime.Today.ToString("yyyy-MM-dd")"
                               onchange="calcDays()"
                               class="w-full px-3 py-2.5 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 bg-white">
                    </div>
                </div>

                <div id="daysPreview" class="hidden bg-blue-50 border border-blue-100 rounded-xl px-4 py-2.5 text-center text-sm font-semibold text-blue-700"></div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Reason</label>
                    <textarea name="reason" rows="3" placeholder="Optional reason for leave..."
                              class="w-full px-3 py-2.5 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 resize-none"></textarea>
                </div>

                <div class="flex gap-3 pt-2">
                    <button type="submit"
                            class="flex-1 py-2.5 text-sm font-bold text-white bg-blue-600 rounded-xl hover:bg-blue-700 shadow-md transition-all">
                        Submit Request
                    </button>
                    <button type="button" onclick="closeLeaveModal()"
                            class="flex-1 py-2.5 text-sm font-semibold text-gray-700 bg-gray-100 rounded-xl hover:bg-gray-200 transition-colors">
                        Cancel
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // ── TABS
    function showTab(name) {
        document.querySelectorAll('.portal-panel').forEach(p => p.classList.add('hidden'));
        document.getElementById('panel-' + name).classList.remove('hidden');
        document.querySelectorAll('.portal-tab').forEach(t => {
            t.classList.remove('text-blue-600', 'border-blue-600', 'bg-blue-50/50');
            t.classList.add('text-gray-500', 'border-transparent');
        });
        const tab = document.getElementById('tab-' + name);
        tab.classList.add('text-blue-600', 'border-blue-600', 'bg-blue-50/50');
        tab.classList.remove('text-gray-500', 'border-transparent');
    }

    // ── LEAVE MODAL
    function openLeaveModal() { document.getElementById('leaveModal').classList.remove('hidden'); }
    function closeLeaveModal() { document.getElementById('leaveModal').classList.add('hidden'); }

    // ── DAYS PREVIEW
    function calcDays() {
        const s = document.getElementById('leaveStartDate').value;
        const e = document.getElementById('leaveEndDate').value;
        const prev = document.getElementById('daysPreview');
        if (!s || !e) { prev.classList.add('hidden'); return; }
        let days = 0;
        let d = new Date(s);
        const end = new Date(e);
        while (d <= end) {
            const dow = d.getDay();
            if (dow !== 0 && dow !== 6) days++;
            d.setDate(d.getDate() + 1);
        }
        prev.classList.remove('hidden');
        prev.textContent = `${days} business day${days !== 1 ? 's' : ''}`;
    }

    // ── LEAVE TABLE FILTER
    function filterLeaveTable() {
        const f = document.getElementById('leaveStatusFilter').value.toUpperCase();
        document.querySelectorAll('.leave-data-row').forEach(r => {
            const s = (r.dataset.status || '').toUpperCase();
            r.style.display = (f === '' || s === f) ? '' : 'none';
        });
    }
</script>
