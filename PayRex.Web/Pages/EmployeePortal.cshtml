@page
@model PayRex.Web.Pages.EmployeePortalModel
@{
    ViewData["Title"] = "Leave Request";
    var statusMsg = Model.StatusMessage ?? "";
    var toastType = statusMsg.StartsWith("success:") ? "success" : "error";
    var toastText = statusMsg.Contains(":") ? statusMsg.Substring(statusMsg.IndexOf(':') + 1) : "";
}

@if (!string.IsNullOrEmpty(toastText))
{
    <script>document.addEventListener('DOMContentLoaded',()=>showToast(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(toastText)), '@toastType'));</script>
}

<div class="max-w-8xl mx-auto px-4 sm:px-6 lg:px-8 space-y-4 sm:space-y-6">
    <!-- Header -->
    <div class="bg-gradient-to-r from-blue-50 via-white to-blue-50 rounded-xl sm:rounded-2xl border border-blue-100 shadow-sm relative overflow-hidden">
        <div class="absolute top-0 right-0 -mt-16 -mr-16 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
        <div class="absolute bottom-0 left-0 -mb-16 -ml-16 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
        <div class="px-4 py-5 sm:px-8 sm:py-8 relative z-10">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <div>
                    <h1 class="text-xl sm:text-2xl lg:text-3xl font-extrabold text-gray-900 tracking-tight">Leave Request</h1>
                    <p class="mt-1 sm:mt-2 text-sm sm:text-base text-gray-600">Submit and track your leave requests.</p>
                </div>
                <button onclick="openLeaveModal()"
                        class="inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold text-white bg-blue-600 rounded-xl hover:bg-blue-700 transition-colors shadow-sm whitespace-nowrap">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                    </svg>
                    Request Leave
                </button>
            </div>
        </div>
    </div>

    <!-- Leave Balance Cards -->
    @{
        var bal = Model.Balance;
        var sickPct  = bal.SickTotal  > 0 ? (bal.SickUsed  * 100.0 / bal.SickTotal)  : 0;
        var vacPct   = bal.VacationTotal > 0 ? (bal.VacationUsed * 100.0 / bal.VacationTotal) : 0;
    }
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
        <div class="bg-white rounded-xl sm:rounded-2xl p-3 sm:p-4 border border-gray-100 shadow-sm">
            <div class="flex items-center justify-between mb-2">
                <div>
                    <p class="text-xs sm:text-sm font-medium text-gray-500">Sick Leave</p>
                    <p class="text-xl sm:text-2xl font-bold text-gray-900">@bal.SickRemaining <span class="text-sm font-normal text-gray-400">/ @bal.SickTotal</span></p>
                </div>
                <div class="p-2 sm:p-3 bg-red-50 rounded-xl text-red-500">
                    <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                    </svg>
                </div>
            </div>
            <div class="w-full bg-gray-100 rounded-full h-1.5">
                <div class="bg-red-400 h-1.5 rounded-full" style="width:@sickPct%"></div>
            </div>
            <p class="text-xs text-gray-400 mt-1">@bal.SickUsed used</p>
        </div>
        <div class="bg-white rounded-xl sm:rounded-2xl p-3 sm:p-4 border border-gray-100 shadow-sm">
            <div class="flex items-center justify-between mb-2">
                <div>
                    <p class="text-xs sm:text-sm font-medium text-gray-500">Vacation Leave</p>
                    <p class="text-xl sm:text-2xl font-bold text-gray-900">@bal.VacationRemaining <span class="text-sm font-normal text-gray-400">/ @bal.VacationTotal</span></p>
                </div>
                <div class="p-2 sm:p-3 bg-green-50 rounded-xl text-green-500">
                    <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064" />
                    </svg>
                </div>
            </div>
            <div class="w-full bg-gray-100 rounded-full h-1.5">
                <div class="bg-green-400 h-1.5 rounded-full" style="width:@vacPct%"></div>
            </div>
            <p class="text-xs text-gray-400 mt-1">@bal.VacationUsed used</p>
        </div>
        <div class="bg-white rounded-xl sm:rounded-2xl p-3 sm:p-4 border border-gray-100 shadow-sm flex items-center justify-between">
            <div>
                <p class="text-xs sm:text-sm font-medium text-gray-500">Pending</p>
                <p class="text-xl sm:text-2xl font-bold text-gray-900">@Model.LeaveRequests.Count(r => r.Status == "Pending")</p>
            </div>
            <div class="p-2 sm:p-3 bg-yellow-50 rounded-xl text-yellow-600">
                <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
        </div>
        <div class="bg-white rounded-xl sm:rounded-2xl p-3 sm:p-4 border border-gray-100 shadow-sm flex items-center justify-between">
            <div>
                <p class="text-xs sm:text-sm font-medium text-gray-500">Approved</p>
                <p class="text-xl sm:text-2xl font-bold text-gray-900">@Model.LeaveRequests.Count(r => r.Status == "Approved")</p>
            </div>
            <div class="p-2 sm:p-3 bg-green-50 rounded-xl text-green-600">
                <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
        </div>
    </div>

    <!-- Leave Requests Table -->
    <div class="bg-white rounded-xl sm:rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-4 sm:px-6 py-3 sm:py-4 border-b border-gray-100 bg-gradient-to-r from-gray-50 to-white">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                <div>
                    <h2 class="text-sm sm:text-base font-semibold text-gray-900">My Leave Requests</h2>
                    <p class="text-xs sm:text-sm text-gray-500 mt-0.5">@Model.LeaveRequests.Count total requests</p>
                </div>
                <div class="flex flex-col sm:flex-row gap-2">
                    <select id="leaveStatusFilter" onchange="filterLeaveTable()" class="px-3 py-2 text-xs sm:text-sm border border-gray-300 rounded-lg bg-white focus:ring-2 focus:ring-blue-500">
                        <option value="">All Status</option>
                        <option value="Pending">Pending</option>
                        <option value="Approved">Approved</option>
                        <option value="Rejected">Rejected</option>
                    </select>
                    <select id="leavePageSizeSelect" onchange="currentLeavePage=1;updateLeavePagination()"
                            class="px-3 py-2 border border-gray-300 rounded-lg text-xs sm:text-sm bg-white focus:ring-2 focus:ring-blue-500">
                        <option value="10" selected>10 per page</option>
                        <option value="25">25 per page</option>
                        <option value="50">50 per page</option>
                    </select>
                </div>
            </div>

            @if (!Model.LeaveRequests.Any())
            {
                <div class="flex flex-col items-center justify-center py-12 px-6">
                    <div class="w-14 h-14 bg-blue-50 rounded-full flex items-center justify-center mb-4">
                        <svg class="w-7 h-7 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                    </div>
                    <p class="text-sm font-medium text-gray-500">No leave requests yet</p>
                    <p class="text-xs text-gray-400 mt-1">Click "Request Leave" to submit one</p>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="w-full" id="leaveTable">
                        <thead class="bg-gray-50/80">
                            <tr>
                                <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Type</th>
                                <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Dates</th>
                                <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Days</th>
                                <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
                                <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Reviewer</th>
                                <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Submitted</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100" id="leaveRequestsBody">
                            @foreach (var lr in Model.LeaveRequests)
                            {
                                var stClass = lr.Status == "Approved" ? "bg-green-100 text-green-700" :
                                              lr.Status == "Rejected" ? "bg-red-100 text-red-700" :
                                                                        "bg-yellow-100 text-yellow-700";
                                var typeIcon = "";
                                <tr class="hover:bg-gray-50/50 transition-colors leave-data-row" data-status="@lr.Status">
                                    <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap">
                                        <div class="flex items-center gap-2">
                                        <span class="text-xs sm:text-sm font-semibold text-gray-900">@lr.LeaveType</span>
                                        </div>
                                    </td>
                                    <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap text-xs sm:text-sm text-gray-600">
                                        @lr.StartDate → @lr.EndDate
                                    </td>
                                    <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap">
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-bold bg-blue-100 text-blue-700">
                                            @lr.TotalDays day@(lr.TotalDays != 1 ? "s" : "")
                                        </span>
                                    </td>
                                    <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap">
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold @stClass">
                                            @lr.Status
                                        </span>
                                    </td>
                                    <td class="px-4 sm:px-6 py-3 sm:py-4 text-xs sm:text-sm text-gray-500">
                                        @if (!string.IsNullOrEmpty(lr.ReviewerName))
                                        {
                                            <div>@lr.ReviewerName</div>
                                            if (!string.IsNullOrEmpty(lr.ReviewRemarks))
                                            {
                                                <div class="text-xs text-gray-400 italic mt-0.5">"@lr.ReviewRemarks"</div>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-gray-300">—</span>
                                        }
                                    </td>
                                    <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap text-xs text-gray-400">
                                        @lr.CreatedAt.ToString("MMM dd, yyyy")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <!-- Pagination -->
                <div class="px-4 sm:px-6 py-3 sm:py-4 border-t border-gray-100 bg-gray-50/50">
                    <div class="flex flex-col sm:flex-row items-center justify-between gap-3">
                        <div class="text-xs sm:text-sm text-gray-600" id="leavePaginationInfo">Showing 0 to 0 of 0 requests</div>
                        <nav class="flex items-center gap-1 flex-wrap justify-center" id="leavePaginationNav"></nav>
                    </div>
                </div>
            }
        </div>

        <!-- ── Payslips Tab removed — use dedicated Payslips page ── -->
    </div>
</div>

<!-- ═══ Request Leave Modal ═══ -->
<div id="leaveModal" class="fixed inset-0 z-[100] hidden overflow-y-auto" aria-modal="true" role="dialog">
    <div class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm transition-opacity" onclick="closeLeaveModal()"></div>
    <div class="flex min-h-full items-center justify-center p-4">
        <div class="relative bg-white rounded-xl shadow-2xl w-full max-w-md mx-auto">
            <!-- Modal header -->
            <div class="flex items-center justify-between border-b border-gray-200 bg-gray-50 px-5 py-3 rounded-t-xl">
                <span class="text-sm font-semibold text-gray-700">Request Leave</span>
                <button onclick="closeLeaveModal()" class="rounded-lg p-1.5 text-gray-400 hover:bg-gray-200 hover:text-gray-600 transition-colors">
                    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
                </button>
            </div>
            <!-- Modal body -->
            <div class="px-5 py-5">
                <form method="post" asp-page-handler="SubmitLeave" class="space-y-4">
                    @Html.AntiForgeryToken()

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1.5">Leave Type <span class="text-red-500">*</span></label>
                        <select name="leaveType" required
                                class="w-full px-3 py-2 border border-gray-300 text-sm rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                            <option value="">Select type...</option>
                            <option value="Vacation">Vacation Leave</option>
                            <option value="Sick">Sick Leave</option>
                            <option value="Emergency">Emergency Leave</option>
                            <option value="Maternity">Maternity Leave</option>
                            <option value="Paternity">Paternity Leave</option>
                        </select>
                    </div>

                    <div class="grid grid-cols-2 gap-3">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1.5">Start Date <span class="text-red-500">*</span></label>
                            <input type="date" name="startDate" id="leaveStartDate" required
                                   min="@DateTime.Today.ToString("yyyy-MM-dd")"
                                   onchange="calcDays()"
                                   class="w-full px-3 py-2 border border-gray-300 text-sm rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1.5">End Date <span class="text-red-500">*</span></label>
                            <input type="date" name="endDate" id="leaveEndDate" required
                                   min="@DateTime.Today.ToString("yyyy-MM-dd")"
                                   onchange="calcDays()"
                                   class="w-full px-3 py-2 border border-gray-300 text-sm rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                        </div>
                    </div>

                    <div id="daysPreview" class="hidden bg-blue-50 border border-blue-100 rounded-lg p-2.5 text-center text-sm font-semibold text-blue-700"></div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1.5">Reason</label>
                        <textarea name="reason" rows="3" placeholder="Optional reason for leave..."
                                  class="w-full px-3 py-2 border border-gray-300 text-sm rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 resize-none"></textarea>
                    </div>

                    <div class="flex justify-end gap-3 pt-2 border-t border-gray-200">
                        <button type="button" onclick="closeLeaveModal()" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-100 transition-colors">Cancel</button>
                        <button type="submit" class="px-5 py-2 text-sm font-semibold text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors">Submit Request</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    // ── LEAVE MODAL
    function openLeaveModal() { document.getElementById('leaveModal').classList.remove('hidden'); }
    function closeLeaveModal() { document.getElementById('leaveModal').classList.add('hidden'); }

    // ── DAYS PREVIEW
    function calcDays() {
        const s = document.getElementById('leaveStartDate').value;
        const e = document.getElementById('leaveEndDate').value;
        const prev = document.getElementById('daysPreview');
        if (!s || !e) { prev.classList.add('hidden'); return; }
        let days = 0;
        let d = new Date(s);
        const end = new Date(e);
        while (d <= end) {
            const dow = d.getDay();
            if (dow !== 0 && dow !== 6) days++;
            d.setDate(d.getDate() + 1);
        }
        prev.classList.remove('hidden');
        prev.textContent = `${days} business day${days !== 1 ? 's' : ''}`;
    }

    // ── LEAVE TABLE FILTER & PAGINATION
    let currentLeavePage = 1;

    function filterLeaveTable() {
        const filter = document.getElementById('leaveStatusFilter').value.toUpperCase();
        const rows = document.querySelectorAll('.leave-data-row');
        let matched = [];
        rows.forEach(r => {
            const s = (r.dataset.status || '').toUpperCase();
            if (filter === '' || s === filter) {
                r.style.display = '';
                matched.push(r);
            } else {
                r.style.display = 'none';
            }
        });
        currentLeavePage = 1;
        updateLeavePagination(matched);
    }

    function updateLeavePagination(matchedRows) {
        const tableBody = document.getElementById("leaveRequestsBody");
        if (!tableBody) return;

        const leavePageSize = parseInt(document.getElementById('leavePageSizeSelect')?.value) || 10;

        let allMatched;
        if (matchedRows) {
            allMatched = matchedRows;
        } else {
            const filter = document.getElementById('leaveStatusFilter').value.toUpperCase();
            allMatched = Array.from(document.querySelectorAll('.leave-data-row')).filter(r => {
                const s = (r.dataset.status || '').toUpperCase();
                return filter === '' || s === filter;
            });
        }

        const totalRows = allMatched.length;
        const totalPages = Math.max(1, Math.ceil(totalRows / leavePageSize));
        if (currentLeavePage > totalPages) currentLeavePage = totalPages;

        const start = (currentLeavePage - 1) * leavePageSize;
        const end = start + leavePageSize;

        allMatched.forEach((r, i) => {
            if (i >= start && i < end) r.style.display = '';
            else r.style.display = 'none';
        });

        const info = document.getElementById("leavePaginationInfo");
        if (info) {
            info.textContent = totalRows === 0 ? "No requests found" : `Showing ${start + 1}–${Math.min(end, totalRows)} of ${totalRows} requests`;
        }

        const nav = document.getElementById("leavePaginationNav");
        if (!nav) return;
        nav.innerHTML = "";

        const btnClass = (active, disabled) => `px-3 py-1.5 text-sm font-medium border rounded-lg transition-all ${
            active    ? 'bg-blue-600 text-white border-blue-600' :
            disabled  ? 'opacity-40 cursor-not-allowed bg-gray-100 border-gray-200 text-gray-500' :
                        'bg-white text-gray-700 border-gray-200 hover:bg-gray-100'
        }`;

        if (totalPages <= 1) return;

        const prevBtn = document.createElement("button");
        prevBtn.className = btnClass(false, currentLeavePage === 1);
        prevBtn.textContent = "‹";
        if (currentLeavePage > 1) prevBtn.onclick = () => { currentLeavePage--; updateLeavePagination(); };
        nav.appendChild(prevBtn);

        for (let p = Math.max(1, currentLeavePage - 2); p <= Math.min(totalPages, currentLeavePage + 2); p++) {
            const b = document.createElement("button");
            b.className = btnClass(p === currentLeavePage, false);
            b.textContent = p;
            b.onclick = () => { currentLeavePage = p; updateLeavePagination(); };
            nav.appendChild(b);
        }

        const nextBtn = document.createElement("button");
        nextBtn.className = btnClass(false, currentLeavePage === totalPages);
        nextBtn.textContent = "›";
        if (currentLeavePage < totalPages) nextBtn.onclick = () => { currentLeavePage++; updateLeavePagination(); };
        nav.appendChild(nextBtn);
    }

    document.addEventListener("DOMContentLoaded", () => {
        updateLeavePagination();
    });
</script>
