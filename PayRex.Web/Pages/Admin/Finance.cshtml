@page
@model PayRex.Web.Pages.Admin.FinanceModel
@{
    ViewData["Title"] = "Finance";
    var fromVal = Model.FromDate ?? "";
    var toVal   = Model.ToDate ?? "";
    var hasFilter = !string.IsNullOrEmpty(fromVal) || !string.IsNullOrEmpty(toVal);
}

<div class="max-w-8xl mx-auto px-4 py-6 sm:px-6 lg:px-8 space-y-6">
    <!-- Welcome Header -->
    <div class="bg-gradient-to-r from-blue-50 via-white to-blue-50 rounded-2xl border border-blue-100 shadow-sm overflow-hidden relative">
        <div class="absolute top-0 right-0 -mt-16 -mr-16 w-64 h-64 bg-green-100 rounded-full blur-3xl opacity-20"></div>
        <div class="absolute bottom-0 left-0 -mb-16 -ml-16 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
        <div class="px-6 py-8 sm:px-10 relative z-10">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                <div>
                    <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight">Finance</h1>
                    <p class="mt-1 text-gray-600">Track income, cost, and profit overview</p>
                </div>
                <button type="button" onclick="openAddEntryModal()" class="inline-flex items-center px-5 py-2.5 rounded-xl text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 transition-colors shadow-sm self-start sm:self-auto">
                    <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" /></svg>
                    Add Entry
                </button>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <script>document.addEventListener('DOMContentLoaded',()=>showToast(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.StatusMessage)), '@(Model.StatusMessage!.StartsWith("Failed") ? "error" : "success")'));</script>
    }

    <!-- KPI Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
         <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-gray-500">Total Income</p>
                    <p class="mt-1 text-2xl font-bold text-green-700">&#8369;@Model.Summary.TotalIncome.ToString("N2")</p>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-gray-500">Total Cost</p>
                    <p class="mt-1 text-2xl font-bold text-red-700">&#8369;@Model.Summary.TotalDeductions.ToString("N2")</p>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-gray-500">Tax (VAT)</p>
                    <p class="mt-1 text-2xl font-bold text-yellow-700">&#8369;@Model.Summary.TotalVat.ToString("N2")</p>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-gray-500">Net Profit</p>
                    <p class="mt-1 text-2xl font-bold @(Model.Summary.NetProfit >= 0 ? "text-blue-700" : "text-red-700")">&#8369;@Model.Summary.NetProfit.ToString("N2")</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Entries Table -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-4 sm:px-6 py-4 border-b border-gray-100 bg-gradient-to-r from-gray-50 to-white">
            <div class="flex flex-col gap-3">
                <!-- Title row -->
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
                    <div>
                        <h2 class="text-base font-semibold text-gray-900">Finance Entries</h2>
                        <p class="text-sm text-gray-500 mt-0.5" id="tableInfo">Showing @Model.Entries.Count entries@(hasFilter ? " (filtered)" : "")</p>
                    </div>
                    <div>
                        <form method="post" asp-page-handler="ExportPdf" id="reportForm" class="hidden">
                            <input type="hidden" name="FromDate" value="@Model.FromDate" />
                            <input type="hidden" name="ToDate" value="@Model.ToDate" />
                        </form>
                        <button type="button" onclick="document.getElementById('reportForm').submit()"
                                class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-semibold text-gray-700 bg-white border border-gray-200 rounded-xl hover:bg-gray-50 shadow-sm transition-colors self-start sm:self-auto">
                            <svg class="w-4 h-4 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                            Generate Report
                        </button>
                    </div>
                </div>
                <!-- Filter row -->
                <form method="get" class="flex flex-wrap items-end gap-2 pt-2 border-t border-gray-100">
                    <div class="flex flex-col gap-1">
                        <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide">From</label>
                        <input type="date" name="fromDate" value="@fromVal"
                               class="px-3 py-1.5 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-white" />
                    </div>
                    <div class="flex flex-col gap-1">
                        <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide">To</label>
                        <input type="date" name="toDate" value="@toVal"
                               class="px-3 py-1.5 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-white" />
                    </div>
                    <div class="flex flex-col gap-1">
                        <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Type</label>
                        <select id="typeFilter" class="px-3 py-1.5 border border-gray-300 rounded-lg text-sm bg-white focus:ring-2 focus:ring-blue-500">
                            <option value="">All Types</option>
                            <option value="Income">Income</option>
                            <option value="Deduction">Cost</option>
                        </select>
                    </div>
                    <div class="flex items-end gap-2">
                        <button type="submit"
                                class="inline-flex items-center gap-1.5 px-4 py-1.5 text-sm font-semibold text-white bg-blue-600 rounded-lg hover:bg-blue-700 shadow-sm transition-colors">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-.293.707L13 13.414V19a1 1 0 01-.553.894l-4 2A1 1 0 017 21v-7.586L3.293 6.707A1 1 0 013 6V4z" /></svg>
                            Filter
                        </button>
                        @if (hasFilter)
                        {
                            <a href="/Admin/Finance"
                               class="inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium text-gray-600 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
                                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
                                Reset
                            </a>
                        }
                    </div>
                </form>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-gray-50/80">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Date</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Type</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Description</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Category</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Amount</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">VAT</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider text-right">Actions</th>
                    </tr></thead>
                <tbody class="divide-y divide-gray-100" id="entriesBody">
                    @if (Model.Entries.Count == 0)
                    {
                        <tr id="emptyRow">
                            <td colspan="7" class="px-6 py-12 text-center">
                                <div class="flex flex-col items-center justify-center">
                                    <div class="w-16 h-16 bg-blue-50 rounded-full flex items-center justify-center mb-4">
                                        <svg class="w-8 h-8 text-blue-400" fill="currentColor" viewBox="0 0 20 20"><path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z" /><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.22-.071-.412-.164-.567-.267C8.07 12.34 8 12.114 8 12a1 1 0 10-2 0c0 1.414.935 2.846 2.5 3.502V17a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 15.766 14 14.991 14 14c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 11.092V9.151c.22.071.412.164.567.267.364.243.433.468.433.582a1 1 0 102 0c0-1.414-.935-2.846-2.5-3.502V4z" clip-rule="evenodd" /></svg>
                                    </div>
                                    <p class="text-gray-500 font-medium">No finance entries yet</p>
                                    <p class="text-sm text-gray-400 mt-1">Click "Add Entry" to create your first entry</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var entry in Model.Entries)
                        {
                            var typeColor = entry.Type == "Income" ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700";
                            <tr class="hover:bg-gray-50/50 transition-colors data-row" data-type="@entry.Type">
                                <td class="px-6 py-4 text-sm text-gray-500 whitespace-nowrap">@entry.CreatedAt.ToString("MMM dd, yyyy hh:mm tt")</td>
                                <td class="px-6 py-4">
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-semibold @typeColor">@(entry.Type == "Deduction" ? "Cost" : entry.Type)</span>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-900 font-medium max-w-[250px] truncate">@entry.Description</td>
                                <td class="px-6 py-4 text-sm text-gray-600">@(entry.Category ?? "—")</td>
                                <td class="px-6 py-4 text-sm font-semibold @(entry.Type == "Income" ? "text-green-700" : "text-red-700")">
                                    &#8369;@entry.Amount.ToString("N2")
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-500">&#8369;@entry.VatAmount.ToString("N2")</td>
                                <td class="px-6 py-4 text-sm text-gray-500 text-right">
                                    <button type="button" onclick="openViewEntryModal('@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(entry.Description))', '@entry.Type', '@entry.Amount.ToString("N2")', '@(entry.Category ?? "N/A")', '@(entry.Reference ?? "N/A")', '@(entry.IsAutoGenerated ? "Auto" : "Manual")', '@entry.CreatedAt.ToString("MMM dd, yyyy hh:mm tt")', '&#8369;@entry.VatAmount.ToString("N2")')" 
                                            class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-blue-600 bg-blue-50 rounded-lg hover:bg-blue-100 transition-colors">
                                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                                        View
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Add Finance Entry Modal -->
<div id="addEntryModal" class="fixed inset-0 z-[60] hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="fixed inset-0 bg-gray-900/60 backdrop-blur-sm transition-opacity" onclick="closeAddEntryModal()"></div>
    <div class="flex min-h-full items-center justify-center p-4 text-center">
        <div class="relative transform overflow-hidden rounded-2xl bg-white text-left shadow-2xl transition-all w-full max-w-lg">
            <div class="absolute top-0 right-0 pt-4 pr-4">
                <button type="button" onclick="closeAddEntryModal()" class="rounded-lg bg-white p-2 text-gray-400 hover:text-gray-500 focus:outline-none hover:bg-gray-100">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
            </div>
            
            <form id="addEntryForm" onsubmit="submitAddEntry(event)">
                <div class="px-6 pt-6 pb-4 border-b border-gray-50">
                    <h3 class="text-xl font-bold text-gray-900" id="modal-title">New Finance Entry</h3>
                    <p class="text-sm text-gray-500 mt-1">Record a manual income or expense entry.</p>
                </div>

                <div class="px-6 py-6 space-y-5">
                    <div class="grid grid-cols-2 gap-4">
                        <div class="space-y-1.5">
                            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Entry Type</label>
                            <div class="relative">
                                <select name="type" required class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all appearance-none cursor-pointer">
                                    <option value="Income">Income</option>
                                    <option value="Deduction">Expense</option>
                                </select>
                            </div>
                        </div>
                        <div class="space-y-1.5">
                            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Category</label>
                            <select name="category" class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all appearance-none cursor-pointer">
                                <option value="">Select Category</option>
                                <option value="Subscription">Subscription</option>
                                <option value="Hosting">Hosting Feed</option>
                                <option value="Marketing">Marketing</option>
                                <option value="Salary">Salaries</option>
                                <option value="Office">Office Rent</option>
                                <option value="Utilities">Utilities</option>
                                <option value="Refund">Refunds</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                    </div>

                    <div class="space-y-1.5">
                        <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Amount (₱)</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                <span class="text-gray-400 font-medium">&#8369;</span>
                            </div>
                            <input type="number" name="amount" required min="0.01" step="0.01" placeholder="0.00" 
                                   class="w-full pl-9 pr-4 py-2.5 bg-gray-50 border border-gray-200 rounded-xl text-sm font-semibold text-gray-900 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all">
                        </div>
                    </div>

                    <div class="space-y-1.5">
                        <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Description</label>
                        <textarea name="description" required rows="2" placeholder="Describe this financial movement..." 
                                  class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all resize-none"></textarea>
                    </div>

                    <div class="space-y-1.5">
                        <label class="text-xs font-bold text-gray-500 uppercase tracking-wider">Reference Code (Optional)</label>
                        <input type="text" name="reference" placeholder="e.g. INV-2024-001" 
                               class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all">
                    </div>
                </div>

                <div class="px-6 py-4 bg-gray-50/80 border-t border-gray-100 flex items-center justify-end gap-3">
                    <button type="button" onclick="closeAddEntryModal()" 
                            class="px-4 py-2.5 text-sm font-semibold text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded-xl transition-all">
                        Cancel
                    </button>
                    <button type="submit" id="addEntrySubmitBtn"
                            class="px-6 py-2.5 text-sm font-bold text-white bg-blue-600 hover:bg-blue-700 rounded-xl shadow-lg shadow-blue-200 transition-all active:scale-95 flex items-center gap-2">
                        <span>Save Entry</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- View Detail Modal -->
<div id="viewEntryModal" class="fixed inset-0 z-[60] hidden overflow-y-auto" aria-labelledby="view-modal-title" role="dialog" aria-modal="true">
    <div class="fixed inset-0 bg-gray-900/60 backdrop-blur-sm transition-opacity" onclick="closeViewEntryModal()"></div>
    <div class="flex min-h-full items-center justify-center p-4 text-center">
        <div class="relative transform overflow-hidden rounded-2xl bg-white text-left shadow-2xl transition-all w-full max-w-md">
            <div class="px-6 pt-6 pb-4 border-b border-gray-50">
                <div class="flex items-center justify-between">
                    <div id="viewTypePill" class="px-3 py-1 rounded-full text-xs font-bold tracking-wider uppercase">Income</div>
                    <button type="button" onclick="closeViewEntryModal()" class="rounded-lg p-2 text-gray-400 hover:text-gray-500 hover:bg-gray-100">
                        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                    </button>
                </div>
                <h3 class="text-2xl font-black text-gray-900 mt-4 leading-tight" id="viewDescription">Description here</h3>
                <p class="text-sm text-gray-500 font-medium mt-1" id="viewTimestamp">Timestamp</p>
            </div>

            <div class="p-6 space-y-6">
                <div class="flex items-center justify-between p-4 bg-gray-50 rounded-2xl border border-gray-100">
                    <span class="text-sm font-bold text-gray-500 uppercase tracking-wider">Amount</span>
                    <span class="text-2xl font-black" id="viewAmount">&#8369;0.00</span>
                </div>

                <div class="grid grid-cols-2 gap-6">
                    <div>
                        <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1.5">Category</p>
                        <p class="text-sm font-bold text-gray-800" id="viewCategory">Technology</p>
                    </div>
                    <div>
                        <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1.5">Tax (VAT)</p>
                        <p class="text-sm font-bold text-gray-800" id="viewVat">&#8369;0.00</p>
                    </div>
                    <div>
                        <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1.5">Reference</p>
                        <p class="text-sm font-bold text-gray-800" id="viewReference">REF-000</p>
                    </div>
                    <div>
                        <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1.5">Source</p>
                        <p class="text-sm font-bold text-gray-800" id="viewSource">Manual</p>
                    </div>
                </div>
            </div>

            <div class="px-6 py-6 bg-gray-50/80 border-t border-gray-100">
                <button type="button" onclick="closeViewEntryModal()" 
                        class="w-full py-3 text-sm font-bold text-gray-700 bg-white border border-gray-200 rounded-xl hover:bg-gray-50 transition-all active:scale-95 shadow-sm">
                    Close Details
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function openAddEntryModal() {
        document.getElementById('addEntryModal').classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }
    function closeAddEntryModal() {
        document.getElementById('addEntryModal').classList.add('hidden');
        document.body.style.overflow = 'auto';
        document.getElementById('addEntryForm').reset();
    }

    function openViewEntryModal(desc, type, amount, cat, ref, src, time, vat) {
        document.getElementById('viewDescription').textContent = desc;
        document.getElementById('viewTimestamp').textContent = time;
        document.getElementById('viewAmount').textContent = amount;
        document.getElementById('viewCategory').textContent = cat;
        document.getElementById('viewReference').textContent = ref;
        document.getElementById('viewSource').textContent = src;
        document.getElementById('viewVat').textContent = vat;

        const pill = document.getElementById('viewTypePill');
        const amountEl = document.getElementById('viewAmount');
        if (type === 'Income') {
            pill.className = 'px-3 py-1 rounded-full text-xs font-bold tracking-wider uppercase bg-green-100 text-green-700';
            pill.textContent = 'Income';
            amountEl.className = 'text-2xl font-black text-green-700';
            amountEl.textContent = amount;
        } else {
            pill.className = 'px-3 py-1 rounded-full text-xs font-bold tracking-wider uppercase bg-red-100 text-red-700';
            pill.textContent = 'Expense';
            amountEl.className = 'text-2xl font-black text-red-700';
            amountEl.textContent = amount;
        }

        document.getElementById('viewEntryModal').classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }

    function closeViewEntryModal() {
        document.getElementById('viewEntryModal').classList.add('hidden');
        document.body.style.overflow = 'auto';
    }

    // Client-side type filter
    document.addEventListener('DOMContentLoaded', function () {
        const filter = document.getElementById('typeFilter');
        if (filter) {
            filter.addEventListener('change', function () {
                const type = this.value;
                document.querySelectorAll('.data-row').forEach(row => {
                    row.style.display = (!type || row.dataset.type === type) ? '' : 'none';
                });
            });
        }
    });

    async function submitAddEntry(e) {
        e.preventDefault();
        const form = document.getElementById('addEntryForm');
        const btn  = document.getElementById('addEntrySubmitBtn');
        const originalText = btn.innerHTML;
        
        btn.disabled = true;
        btn.innerHTML = `
            <svg class="animate-spin h-4 w-4 text-white" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
            <span>Saving...</span>
        `;

        try {
            const resp = await fetch('/Admin/Finance?handler=AddEntry', {
                method: 'POST',
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                body: new FormData(form)
            });
            const data = await resp.json().catch(() => null);
            if (resp.ok && data?.success) {
                closeAddEntryModal();
                showToast('Finance entry added successfully.', 'success');
                setTimeout(() => location.reload(), 1000);
            } else {
                showToast(data?.message || 'Failed to add finance entry.', 'error');
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        } catch (err) {
            console.error(err);
            showToast('An error occurred. Please check your connection.', 'error');
            btn.disabled = false;
            btn.innerHTML = originalText;
        }
    }
</script>
}
