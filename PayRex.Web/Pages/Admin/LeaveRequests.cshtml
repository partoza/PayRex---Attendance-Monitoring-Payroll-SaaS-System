@page
@model PayRex.Web.Pages.Admin.LeaveRequestsModel
@{
    ViewData["Title"] = "Leave Management";
    var statusMsg = Model.StatusMessage ?? "";
    var toastType = statusMsg.StartsWith("success:") ? "success" : "error";
    var toastText = statusMsg.Contains(":") ? statusMsg.Substring(statusMsg.IndexOf(':') + 1) : "";
}

@if (!string.IsNullOrEmpty(toastText))
{
    <script>document.addEventListener('DOMContentLoaded',()=>showToast(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(toastText)), '@toastType'));</script>
}

<div class="max-w-8xl mx-auto px-4 sm:px-6 lg:px-8 space-y-5 sm:space-y-6">
    <!-- Header -->
    <div class="bg-gradient-to-r from-blue-50 via-white to-blue-50 rounded-2xl border border-blue-100 shadow-sm overflow-hidden relative">
        <div class="absolute top-0 right-0 -mt-16 -mr-16 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
        <div class="px-6 sm:px-8 py-6 sm:py-8 relative z-10">
            <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight">Leave Management</h1>
            <p class="mt-1 sm:mt-2 text-sm sm:text-base text-gray-600">Review and approve employee leave requests.</p>
        </div>
    </div>

    <!-- Stats row -->
    @{
        var all = Model.AllRequests.Count;
        var pending  = Model.AllRequests.Count(r => r.Status == "Pending");
        var approved = Model.AllRequests.Count(r => r.Status == "Approved");
        var rejected = Model.AllRequests.Count(r => r.Status == "Rejected");
    }
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
        <!-- All Requests -->
        <div class="bg-white rounded-xl sm:rounded-2xl p-3 sm:p-4 border border-gray-100 shadow-sm flex items-center justify-between">
            <div>
                <p class="text-xs sm:text-sm font-medium text-gray-500">All Requests</p>
                <p class="text-xl sm:text-2xl font-bold text-gray-900">@all</p>
            </div>
            <div class="p-2 sm:p-3 bg-blue-50 rounded-xl text-blue-600">
                <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                </svg>
            </div>
        </div>
        <!-- Pending -->
        <div class="bg-white rounded-xl sm:rounded-2xl p-3 sm:p-4 border border-gray-100 shadow-sm flex items-center justify-between">
            <div>
                <p class="text-xs sm:text-sm font-medium text-gray-500">Pending</p>
                <p class="text-xl sm:text-2xl font-bold text-gray-900">@pending</p>
            </div>
            <div class="p-2 sm:p-3 bg-yellow-50 rounded-xl text-yellow-600">
                <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
        </div>
        <!-- Approved -->
        <div class="bg-white rounded-xl sm:rounded-2xl p-3 sm:p-4 border border-gray-100 shadow-sm flex items-center justify-between">
            <div>
                <p class="text-xs sm:text-sm font-medium text-gray-500">Approved</p>
                <p class="text-xl sm:text-2xl font-bold text-gray-900">@approved</p>
            </div>
            <div class="p-2 sm:p-3 bg-green-50 rounded-xl text-green-600">
                <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
        </div>
        <!-- Rejected -->
        <div class="bg-white rounded-xl sm:rounded-2xl p-3 sm:p-4 border border-gray-100 shadow-sm flex items-center justify-between">
            <div>
                <p class="text-xs sm:text-sm font-medium text-gray-500">Rejected</p>
                <p class="text-xl sm:text-2xl font-bold text-gray-900">@rejected</p>
            </div>
            <div class="p-2 sm:p-3 bg-red-50 rounded-xl text-red-600">
                <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
        </div>
    </div>

    <!-- Navigation Tabs -->
    <div class="border-b border-gray-200">
        <nav class="-mb-px flex space-x-6 overflow-x-auto" aria-label="Tabs">
            <a href="?status=All" class="@(Model.ActiveStatus == "All" ? "border-blue-500 text-blue-600" : "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300") whitespace-nowrap py-3 px-1 border-b-2 font-medium text-sm transition-colors">
                All
            </a>
            <a href="?status=Pending" class="@(Model.ActiveStatus == "Pending" ? "border-blue-500 text-blue-600" : "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300") whitespace-nowrap py-3 px-1 border-b-2 font-medium text-sm transition-colors">
                Pending
            </a>
            <a href="?status=Approved" class="@(Model.ActiveStatus == "Approved" ? "border-blue-500 text-blue-600" : "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300") whitespace-nowrap py-3 px-1 border-b-2 font-medium text-sm transition-colors">
                Approved
            </a>
            <a href="?status=Rejected" class="@(Model.ActiveStatus == "Rejected" ? "border-blue-500 text-blue-600" : "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300") whitespace-nowrap py-3 px-1 border-b-2 font-medium text-sm transition-colors">
                Rejected
            </a>
        </nav>
    </div>

    <!-- Filters Card -->
    <div class="bg-white rounded-xl sm:rounded-2xl border border-gray-200 shadow-sm overflow-hidden mb-4">
        <div class="px-4 sm:px-6 py-3 sm:py-4 border-b border-gray-100 bg-gradient-to-r from-gray-50 to-white">
            <h2 class="text-sm sm:text-base font-semibold text-gray-900 flex items-center">
                <svg class="w-4 h-4 sm:w-5 sm:h-5 mr-1.5 sm:mr-2 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M3 3a1 1 0 011-1h12a1 1 0 011 1v3a1 1 0 01-.293.707L12 11.414V15a1 1 0 01-.293.707l-2 2A1 1 0 018 17v-5.586L3.293 6.707A1 1 0 013 6V3z" clip-rule="evenodd" />
                </svg>
                Filters & Search
            </h2>
        </div>
        <div class="p-4 sm:p-5 lg:p-6">
            <div class="flex flex-col space-y-3 sm:space-y-4 md:space-y-0 md:flex-row md:items-end md:gap-3">
                <div class="w-full lg:flex-1">
                    <label class="block text-xs sm:text-sm font-medium text-gray-700 mb-1">Search</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-2.5 sm:pl-3 flex items-center pointer-events-none">
                            <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
                            </svg>
                        </div>
                        <input type="text" id="searchInput" onkeyup="filterTable()"
                               class="w-full pl-8 sm:pl-10 pr-3 sm:pr-4 py-2 sm:py-2.5 border border-gray-300 rounded-lg sm:rounded-xl text-xs sm:text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all"
                               placeholder="Search employee...">
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Table Card -->
    <div class="bg-white rounded-xl sm:rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-4 sm:px-6 py-3 sm:py-4 border-b border-gray-100 bg-gradient-to-r from-gray-50 to-white flex items-center justify-between">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 w-full">
                <div>
                    <h2 class="text-sm sm:text-base font-semibold text-gray-900">@Model.ActiveStatus Leave Requests</h2>
                    <p class="text-xs sm:text-sm text-gray-500 mt-0.5">@Model.Requests.Count records</p>
                </div>
                <div class="w-full md:w-auto md:ml-auto">
                    <select id="pageSizeSelect" class="w-full md:w-auto px-3 py-2 border border-gray-300 rounded-lg text-xs sm:text-sm bg-white focus:ring-2 focus:ring-blue-500">
                        <option value="5">5 per page</option>
                        <option value="10" selected>10 per page</option>
                        <option value="25">25 per page</option>
                        <option value="50">50 per page</option>
                        <option value="100">100 per page</option>
                    </select>
                </div>
            </div>
        </div>

        @if (!Model.Requests.Any())
        {
            <div class="flex flex-col items-center justify-center py-12 px-6">
                <div class="w-14 h-14 bg-gray-50 rounded-full flex items-center justify-center mb-4">
                    <svg class="w-7 h-7 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
                </div>
                <p class="text-sm font-medium text-gray-400">No @Model.ActiveStatus.ToLower() leave requests</p>
            </div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full" id="leaveTable">
                    <thead class="bg-gray-50/80">
                        <tr>
                            <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Employee</th>
                            <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Type</th>
                            <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">From</th>
                            <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">To</th>
                            <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Duration</th>
                            <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Reason</th>
                            <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
                                <th class="px-4 sm:px-6 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
                            }
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        @foreach (var lr in Model.Requests)
                        {
                            var stClass = lr.Status == "Approved" ? "bg-green-100 text-green-700" :
                                          lr.Status == "Rejected" ? "bg-red-100 text-red-700" :
                                                                    "bg-yellow-100 text-yellow-700";
                            <tr class="hover:bg-gray-50/50 transition-colors data-row">
                                <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap">
                                    <div class="flex items-center gap-2.5">
                                        <div class="w-8 h-8 rounded-full bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center flex-shrink-0 shadow-sm">
                                            <span class="text-xs font-bold text-white">@((lr.EmployeeName ?? "?").FirstOrDefault())</span>
                                        </div>
                                        <div>
                                            <div class="text-sm font-semibold text-gray-900 search-name">@lr.EmployeeName</div>
                                            <div class="text-xs text-gray-400">@lr.EmployeeCode</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap text-sm font-medium text-gray-800">
                                    @lr.LeaveType
                                </td>
                                <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap text-sm text-gray-700">
                                    @lr.StartDate
                                </td>
                                <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap text-sm text-gray-700">
                                    @lr.EndDate
                                </td>
                                <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap">
                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-bold bg-blue-100 text-blue-700">@Model.FormatDuration(Convert.ToInt32(lr.TotalDays))</span>
                                </td>
                                <td class="px-4 sm:px-6 py-3 sm:py-4 text-xs text-gray-500 max-w-xs">
                                    <div class="truncate">@(lr.Reason ?? "—")</div>
                                    @if (!string.IsNullOrEmpty(lr.ReviewRemarks))
                                    {
                                        <div class="text-xs text-gray-400 italic mt-0.5">"@lr.ReviewRemarks"</div>
                                    }
                                </td>
                                <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold @stClass">@lr.Status</span>
                                </td>
                                @if (Model.ActiveStatus == "Pending")
                                {
                                    <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap text-center">
                                        <div class="flex items-center justify-center gap-2">
                                            <button onclick="openReview(@lr.LeaveRequestId, '@lr.EmployeeName')"
                                                    class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-green-700 bg-green-50 rounded-lg hover:bg-green-100 transition-colors">
                                                <svg class="w-3.5 h-3.5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                                                Approve
                                            </button>
                                            <button onclick="openReject(@lr.LeaveRequestId, '@lr.EmployeeName')"
                                                    class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-red-700 bg-red-50 rounded-lg hover:bg-red-100 transition-colors">
                                                <svg class="w-3.5 h-3.5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" /></svg>
                                                Reject
                                            </button>
                                        </div>
                                    </td>
                                }

                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <!-- Pagination Footer -->
            <div class="px-4 sm:px-6 py-3 sm:py-4 border-t border-gray-100 bg-gray-50/50" id="paginationContainer">
                <div class="flex flex-col sm:flex-row items-center justify-between gap-3">
                    <div class="text-xs sm:text-sm text-gray-600" id="paginationInfo">Showing 0 to 0 of 0 requests</div>
                    <nav class="flex items-center gap-1 flex-wrap justify-center" id="paginationNav"></nav>
                </div>
            </div>
        }
    </div>
</div>

<!-- ═══ Archive Modal ═══ -->
<div id="archiveModal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-hidden="true">
    <div class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm transition-opacity" onclick="closeArchiveModal()"></div>
    <div class="flex min-h-full items-center justify-center p-2 sm:p-4 text-center">
        <div class="relative transform overflow-hidden rounded-lg bg-white text-left shadow-xl transition-all w-full sm:w-[90%] md:w-[60%] lg:w-[40%] max-w-md mx-auto">
            <div class="h-1.5 w-full bg-gray-500"></div>
            <div class="flex items-center justify-between border-b border-gray-200 bg-white px-4 py-3 sm:px-6 sm:py-4">
                <h3 class="text-base sm:text-lg font-semibold text-gray-900">Archive Leave Request</h3>
                <button type="button" onclick="closeArchiveModal()" class="rounded-lg p-1.5 text-gray-400 hover:bg-gray-100 hover:text-gray-500">
                    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
                </button>
            </div>
            <div class="px-4 py-6 sm:px-6">
                <form method="post" asp-page-handler="Archive" id="formArchive">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="archiveId" />
                    <input type="hidden" name="ActiveStatus" value="@Model.ActiveStatus" />
                    <div class="text-center">
                        <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-gray-100 mb-4">
                            <svg class="h-6 w-6 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
                            </svg>
                        </div>
                        <h4 class="text-lg font-bold text-gray-900 mb-2">Confirm Archiving</h4>
                        <p class="text-sm text-gray-500" id="archiveQuestion">Are you sure you want to archive this leave request?</p>
                        <p class="mt-2 text-xs text-gray-400 italic font-medium">Archived requests are moved to the Archives section.</p>
                        
                        <div class="mt-6 flex justify-center gap-3">
                            <button type="button" onclick="closeArchiveModal()" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500">
                                Cancel
                            </button>
                            <button type="submit" class="inline-flex items-center justify-center px-4 py-2 text-sm font-medium text-white bg-gray-600 rounded-lg hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-gray-500 shadow-sm transition-colors">
                                Archive Request
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    let currentPage = 1;
    let pageSize = 10;

    document.addEventListener('DOMContentLoaded', function() {
        const ps = document.getElementById('pageSizeSelect');
        if (ps) {
            pageSize = parseInt(ps.value) || 10;
            ps.addEventListener('change', function() {
                pageSize = parseInt(this.value) || 10;
                currentPage = 1;
                filterTable();
            });
        }
        filterTable();
    });

    function filterTable() {
        const input = document.getElementById('searchInput');
        const f = input ? input.value.toUpperCase() : '';
        const table = document.getElementById('leaveTable');
        
        if (table) {
            const trs = table.getElementsByTagName('tr');
            for (let i = 1; i < trs.length; i++) {
                const row = trs[i];
                if (row.querySelector('td[colspan]')) continue;
                
                const nameTd = row.querySelector('.search-name');
                const nameText = nameTd ? nameTd.textContent.toUpperCase() : '';
                
                if (f === '' || nameText.indexOf(f) > -1) {
                    row.dataset.match = '1';
                } else {
                    row.dataset.match = '0';
                    row.style.display = 'none';
                }
            }
        }
        
        applyPagination();
    }

    function applyPagination() {
        const table = document.getElementById('leaveTable');
        if (!table) return;

        const rows = Array.from(table.querySelectorAll('tbody tr.data-row'))
                          .filter(tr => !tr.querySelector('td[colspan]') && tr.dataset.match === '1');
        
        const start = (currentPage - 1) * pageSize;
        const end = start + pageSize;

        rows.forEach(row => row.style.display = 'none');

        for (let i = start; i < end && i < rows.length; i++) {
            rows[i].style.display = '';
        }

        updatePaginationUI(rows.length, start, end);
    }

    function updatePaginationUI(totalItems, start, end) {
        const info = document.getElementById('paginationInfo');
        const nav = document.getElementById('paginationNav');
        if (!info || !nav) return;

        if (totalItems === 0) {
            info.textContent = 'Showing 0 to 0 of 0 requests';
            nav.innerHTML = '';
            return;
        }

        const actualEnd = Math.min(end, totalItems);
        info.textContent = `Showing ${start + 1} to ${actualEnd} of ${totalItems} requests`;

        const totalPages = Math.ceil(totalItems / pageSize);
        nav.innerHTML = '';

        const btn = (label, page, active = false, disabled = false) => {
            const b = document.createElement('button');
            b.innerHTML = label;
            b.className = `px-3 py-1.5 text-sm font-medium border rounded-lg transition-all ${
                active    ? 'bg-blue-600 text-white border-blue-600' :
                disabled  ? 'opacity-40 cursor-not-allowed bg-gray-100 border-gray-200' :
                            'bg-white text-gray-700 border-gray-200 hover:bg-gray-100'
            }`;
            if (!disabled && !active) b.onclick = () => { currentPage = page; applyPagination(); };
            return b;
        };

        nav.appendChild(btn('‹', currentPage - 1, false, currentPage === 1));

        const getPages = (c, t) => {
            if (t <= 5) return Array.from({length: t}, (_,i) => i+1);
            if (c <= 3) return [1,2,3,4,'...',t];
            if (c >= t - 2) return [1,'...',t-3,t-2,t-1,t];
            return [1,'...',c-1,c,c+1,'...',t];
        };

        getPages(currentPage, totalPages).forEach(p => {
            if (p === '...') {
                const d = document.createElement('span');
                d.className = 'px-2 py-1.5 text-gray-400 text-sm';
                d.textContent = '…';
                nav.appendChild(d);
            } else {
                nav.appendChild(btn(p, p, p === currentPage));
            }
        });

        nav.appendChild(btn('›', currentPage + 1, false, currentPage === totalPages));
    }

    function openArchive(id, name) {
        document.getElementById('archiveId').value = id;
        document.getElementById('archiveQuestion').innerHTML = 'Are you sure you want to archive the leave request for <span class="font-semibold">' + name + '</span>?';
        document.getElementById('archiveModal').classList.remove('hidden');
    }

    function closeArchiveModal() {
        document.getElementById('archiveModal').classList.add('hidden');
    }

    function openReview(id, name) {
        document.getElementById('reviewId').value = id;
        document.getElementById('reviewApproved').value = 'true';
        document.getElementById('reviewTitle').textContent = 'Confirm Approval';
        document.getElementById('reviewQuestion').innerHTML = 'Are you sure you want to approve the leave request for <span class="font-semibold">' + name + '</span>?';
        
        const btn = document.getElementById('reviewSubmitBtn');
        btn.className = 'inline-flex items-center justify-center px-4 py-2 text-sm font-medium text-white bg-green-600 rounded-lg hover:bg-green-700 focus:ring-2 focus:ring-green-300 transition-colors shadow-sm focus:outline-none';
        
        document.getElementById('reviewModal').classList.remove('hidden');
    }

    function openReject(id, name) {
        document.getElementById('reviewId').value = id;
        document.getElementById('reviewApproved').value = 'false';
        document.getElementById('reviewTitle').textContent = 'Confirm Rejection';
        document.getElementById('reviewQuestion').innerHTML = 'Are you sure you want to reject the leave request for <span class="font-semibold">' + name + '</span>?';
        
        const btn = document.getElementById('reviewSubmitBtn');
        btn.className = 'inline-flex items-center justify-center px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700 focus:ring-2 focus:ring-red-300 transition-colors shadow-sm focus:outline-none';
        
        document.getElementById('reviewModal').classList.remove('hidden');
    }

    function closeReviewModal() { document.getElementById('reviewModal').classList.add('hidden'); }
</script>
