@section Scripts {
<script>
    let currentPage = 1;
    let pageSize = 10;
    let allRows = [];
    let filteredRows = [];

    document.addEventListener('DOMContentLoaded', function () {
        allRows = Array.from(document.querySelectorAll('.data-row'));
        filteredRows = [...allRows];
        renderPage();

        document.getElementById('searchInput').addEventListener('input', applyFilters);
        document.getElementById('invoiceStatusFilter').addEventListener('change', applyFilters);
        document.getElementById('dateFrom').addEventListener('change', applyFilters);
        document.getElementById('dateTo').addEventListener('change', applyFilters);
        document.getElementById('pageSizeSelect').addEventListener('change', function () {
            pageSize = parseInt(this.value);
            currentPage = 1;
            renderPage();
        });
    });

    function applyFilters() {
        const search = document.getElementById('searchInput').value.toLowerCase();
        const status = document.getElementById('invoiceStatusFilter').value;
        const from = document.getElementById('dateFrom').value;
        const to = document.getElementById('dateTo').value;

        filteredRows = allRows.filter(row => {
            const s = (row.dataset.search || '').toLowerCase();
            const st = row.dataset.status || '';
            const due = row.dataset.due || '';

            if (search && !s.includes(search)) return false;
            if (status && st !== status) return false;
            if (from && due < from) return false;
            if (to && due > to) return false;
            return true;
        });
        currentPage = 1;
        renderPage();
    }

    function clearInvoiceFilters() {
        document.getElementById('searchInput').value = '';
        document.getElementById('invoiceStatusFilter').value = '';
        document.getElementById('dateFrom').value = '';
        document.getElementById('dateTo').value = '';
        filteredRows = [...allRows];
        currentPage = 1;
        renderPage();
    }

    function renderPage() {
        const total = filteredRows.length;
        const totalPages = Math.max(1, Math.ceil(total / pageSize));
        if (currentPage > totalPages) currentPage = totalPages;
        const start = (currentPage - 1) * pageSize;
        const end = Math.min(start + pageSize, total);

        allRows.forEach(row => row.style.display = 'none');
        for (let i = start; i < end; i++) filteredRows[i].style.display = '';

        document.getElementById('showStart').textContent = total === 0 ? 0 : start + 1;
        document.getElementById('showEnd').textContent = end;
        document.getElementById('showTotal').textContent = total;

        const nav = document.getElementById('paginationNav');
        nav.innerHTML = '';
        if (totalPages <= 1) return;

        nav.appendChild(createPageBtn('‹', currentPage > 1, () => { currentPage--; renderPage(); }));
        getPageNumbers(currentPage, totalPages).forEach(p => {
            if (p === '...') {
                const d = document.createElement('span');
                d.className = 'px-3 py-1.5 text-gray-400 text-sm';
                d.textContent = '...';
                nav.appendChild(d);
            } else {
                const btn = createPageBtn(p, true, () => { currentPage = p; renderPage(); });
                if (p === currentPage) btn.className = 'px-3 py-1.5 text-sm font-semibold bg-blue-600 text-white rounded-lg shadow-sm';
                nav.appendChild(btn);
            }
        });
        nav.appendChild(createPageBtn('›', currentPage < totalPages, () => { currentPage++; renderPage(); }));
    }

    function createPageBtn(label, enabled, onClick) {
        const btn = document.createElement('button');
        btn.textContent = label;
        btn.className = 'px-3 py-1.5 text-sm font-medium text-gray-700 hover:bg-gray-100 rounded-lg border border-gray-200 transition-all';
        if (!enabled) { btn.disabled = true; btn.className += ' opacity-40 cursor-not-allowed'; }
        else btn.addEventListener('click', onClick);
        return btn;
    }

    function getPageNumbers(current, total) {
        if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
        if (current <= 4) { const p = []; for (let i = 1; i <= 5; i++) p.push(i); p.push('...', total); return p; }
        if (current >= total - 3) { const p = [1, '...']; for (let i = total - 4; i <= total; i++) p.push(i); return p; }
        return [1, '...', current - 1, current, current + 1, '...', total];
    }

    function exportInvoicesPdf() {
        document.getElementById('exportSearch').value = document.getElementById('searchInput').value || '';
        document.getElementById('exportStatus').value = document.getElementById('invoiceStatusFilter').value || '';
        document.getElementById('exportDateFrom').value = document.getElementById('dateFrom').value || '';
        document.getElementById('exportDateTo').value = document.getElementById('dateTo').value || '';
        document.getElementById('exportInvoicesForm').submit();
    }

    function viewInvoice(btn) {
        const row = btn.closest('tr');
        const invoiceNum    = row.dataset.invoiceNumber;
        const company       = row.dataset.company;
        const amount        = row.dataset.amount;
        const vat           = row.dataset.vat;
        const status        = row.dataset.status;
        const created       = row.dataset.created;
        const start         = row.dataset.start;
        const due           = row.dataset.dueDisplay || row.dataset.periodEnd;

        document.getElementById('invModalNumber').textContent       = invoiceNum;
        document.getElementById('invModalCompany').textContent      = company;
        document.getElementById('invModalCompanyLine').textContent  = company;
        document.getElementById('invModalSubtotal').textContent     = amount;
        document.getElementById('invModalSubtotalAlt').textContent  = amount;
        document.getElementById('invModalVat').textContent          = vat;
        document.getElementById('invModalVatAlt').textContent       = vat;
        document.getElementById('invModalCreated').textContent      = created;
        document.getElementById('invModalStart').textContent        = start;
        document.getElementById('invModalDue').textContent          = due;

        const amtNum = parseFloat(amount.replace('₱', '').replace(/,/g, '')) || 0;
        const vatNum = parseFloat(vat.replace('₱', '').replace(/,/g, '')) || 0;
        const totalStr = '₱' + (amtNum + vatNum).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        document.getElementById('invModalTotal').textContent = totalStr;

        // Status badge coloring
        const badge = document.getElementById('invModalStatusBadge');
        badge.textContent = status;
        badge.className = 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold ' +
            (status === 'Paid' ? 'bg-green-100 text-green-700' :
             status === 'Pending' ? 'bg-yellow-100 text-yellow-700' :
             status === 'Overdue' ? 'bg-red-100 text-red-700' : 'bg-gray-100 text-gray-700');

        document.getElementById('invoiceViewModal').classList.remove('hidden');
    }

    function closeInvoiceViewModal() {
        document.getElementById('invoiceViewModal').classList.add('hidden');
    }

    function printInvoice() {
        const content = document.getElementById('invoicePrintBody').innerHTML;
        const invNum = document.getElementById('invModalNumber').textContent;
        const win = window.open('', '_blank', 'width=800,height=900');
        
        // Use safe tag construction to prevent script leak
        const _html = '<' + 'html>';
        const _hd = '<' + 'head>';
        const _hdc = '<' + '/head>';
        const _bd = '<' + 'body>';
        const _bdc = '<' + '/body>';
        const _htmlc = '<' + '/html>';

        win.document.write(`
            ${_html}
            ${_hd}
                <meta charset="UTF-8">
                <title>Invoice — ${invNum}</title>
                <style>
                    * { box-sizing: border-box; margin: 0; padding: 0; }
                    body { font-family: 'Segoe UI', Arial, sans-serif; color: #111; font-size: 13px; padding: 32px 40px; background: #fff; }
                    .flex { display: flex; } .flex-col { flex-direction: column; }
                    .items-start { align-items: flex-start; } .justify-between { justify-content: space-between; }
                    .gap-4 { gap: 16px; } .gap-2 { gap: 8px; } .gap-6 { gap: 24px; }
                    .mb-8 { margin-bottom: 32px; } .mb-6 { margin-bottom: 24px; } .mb-2 { margin-bottom: 8px; } .mb-1 { margin-bottom: 4px; } .mt-0\\.5 { margin-top: 2px; }
                    .pt-4 { padding-top: 16px; }
                    .text-xs { font-size: 11px; } .text-sm { font-size: 12.5px; } .text-base { font-size: 14px; } .text-2xl { font-size: 22px; } .text-xl { font-size: 19px; } .text-lg { font-size: 16px; }
                    .font-bold { font-weight: 700; } .font-extrabold { font-weight: 800; } .font-semibold { font-weight: 600; } .font-medium { font-weight: 500; }
                    .text-blue-700 { color: #1d4ed8; } .text-blue-600 { color: #2563eb; } .text-gray-900 { color: #111827; } .text-gray-800 { color: #1f2937; }
                    .text-gray-600 { color: #4b5563; } .text-gray-500 { color: #6b7280; } .text-gray-400 { color: #9ca3af; } .text-white { color: #fff; }
                    .tracking-tight { letter-spacing: -0.025em; } .tracking-widest { letter-spacing: 0.1em; } .tracking-wider { letter-spacing: 0.075em; }
                    .uppercase { text-transform: uppercase; } .text-center { text-align: center; } .text-right { text-align: right; }
                    .font-mono { font-family: monospace; }
                    .grid { display: grid; } .grid-cols-2 { grid-template-columns: 1fr 1fr; }
                    .border-t-2 { border-top: 2px solid; } .border-blue-600 { border-color: #2563eb; } .border-t { border-top: 1px solid #e5e7eb; } .border-gray-200 { border-color: #e5e7eb; } .border-gray-100 { border-color: #f3f4f6; } .border-b { border-bottom: 1px solid #e5e7eb; }
                    .border { border: 1px solid #e5e7eb; } .rounded-xl { border-radius: 12px; } .rounded-tl-lg { border-top-left-radius: 8px; } .rounded-tr-lg { border-top-right-radius: 8px; } .overflow-hidden { overflow: hidden; }
                    .w-full { width: 100%; } .w-7 { width: 28px; } .h-7 { height: 28px; } .w-64 { width: 256px; }
                    table { width: 100%; border-collapse: collapse; font-size: 12.5px; }
                    th { background: #2563eb; color: #fff; text-align: left; padding: 10px 14px; font-weight: 600; font-size: 11px; }
                    td { padding: 10px 14px; border-bottom: 1px solid #e5e7eb; }
                    .bg-gray-50 { background: #f9fafb; } .bg-blue-600 { background: #2563eb; }
                    .px-4 { padding-left: 16px; padding-right: 16px; } .py-2\\.5 { padding-top: 10px; padding-bottom: 10px; }
                    .px-5 { padding-left: 20px; padding-right: 20px; } .py-3 { padding-top: 12px; padding-bottom: 12px; } .py-4 { padding-top: 16px; padding-bottom: 16px; }
                    .space-y-1 > * + * { margin-top: 4px; }
                    .inline-flex { display: inline-flex; } .items-center { align-items: center; } .px-2\\.5 { padding-left: 10px; padding-right: 10px; } .py-0\\.5 { padding-top: 2px; padding-bottom: 2px; } .rounded-full { border-radius: 9999px; }
                    .bg-green-100 { background: #dcfce7; } .text-green-700 { color: #15803d; }
                    .bg-yellow-100 { background: #fef9c3; } .text-yellow-700 { color: #a16207; }
                    .bg-red-100 { background: #fee2e2; } .text-red-700 { color: #b91c1c; }
                    .bg-gray-100 { background: #f3f4f6; } .text-gray-700 { color: #374151; }
                    .print-hide { display: none !important; }
                    .sm\:flex-row { flex-direction: row; } .sm\:text-right { text-align: right; } .sm\:items-start { align-items: flex-start; } .sm\:justify-end { justify-content: flex-end; }
                    .sm\:w-64 { width: 256px; } .sm\:grid-cols-2 { grid-template-columns: 1fr 1fr; }
                    @@media print { body { padding: 0 !important; } .print-hide { display: none !important; } }
                </style>
            ${_hdc}
            ${_bd} 
                ${content} 
            ${_bdc}
            ${_htmlc}
        `);
        win.document.close();
        win.focus();
        win.onload = function () { win.print(); };
    }

    let _archiveInvoiceId = null;
    function archiveInvoice(btn) {
        const row = btn.closest('tr');
        _archiveInvoiceId = row.dataset.id;
        document.querySelector('.archive-inv-number').textContent = row.dataset.invoiceNumber;
        document.getElementById('invoiceArchiveModal').classList.remove('hidden');
    }

    function hideArchiveModal() {
        document.getElementById('invoiceArchiveModal').classList.add('hidden');
        _archiveInvoiceId = null;
    }

    function confirmArchive() {
        if (!_archiveInvoiceId) return;
        const token = document.cookie.split(';').map(c => c.trim()).find(c => c.startsWith('PayRex.AuthToken='))?.split('=').slice(1).join('=');
        fetch(`/api/superadmin/billing/${_archiveInvoiceId}/archive`, {
            method: 'POST',
            headers: { 'Authorization': `Bearer ${token}` }
        }).then(r => {
            if (r.ok) {
                const row = document.querySelector(`tr[data-id="${_archiveInvoiceId}"]`);
                if (row) {
                    allRows = allRows.filter(r => r !== row);
                    filteredRows = filteredRows.filter(r => r !== row);
                    row.remove();
                    renderPage();
                }
                hideArchiveModal();
                showToast('Invoice archived successfully', 'success');
            } else {
                hideArchiveModal();
                showToast('Failed to archive invoice', 'error');
            }
        }).catch(() => { hideArchiveModal(); showToast('Failed to archive invoice', 'error'); });
    }
    // ── Checkout Functions ──
    function getAuthToken() {
        return document.cookie.split(';').map(c => c.trim()).find(c => c.startsWith('PayRex.AuthToken='))?.split('=').slice(1).join('=');
    }

    // ── Renewal/Upgrade Modal ──
    function openBillingRenewalModal() {
        var modal = document.getElementById('billingRenewalModal');
        if (modal) modal.classList.remove('hidden');
    }
    function closeBillingRenewalModal() {
        var modal = document.getElementById('billingRenewalModal');
        if (modal) modal.classList.add('hidden');
    }
</script>

<!-- ═══════════════════════════ RENEWAL PLAN MODAL ═══════════════════════════ -->
<div id="billingRenewalModal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm hidden" onclick="if(event.target===this)closeBillingRenewalModal()">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-2xl mx-4 overflow-hidden">
        <!-- Header -->
        <div class="px-6 py-5 border-b border-gray-100" style="background: linear-gradient(135deg, #eff6ff 0%, #f0f9ff 100%)">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-blue-600 flex items-center justify-center text-white">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
                    </div>
                    <div>
                        <h2 class="text-lg font-bold text-gray-900">Renew or Upgrade Plan</h2>
                        <p class="text-sm text-gray-500">Choose a plan to continue using PayRex</p>
                    </div>
                </div>
                <button onclick="closeBillingRenewalModal()" class="text-gray-400 hover:text-gray-600 transition-colors">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                </button>
            </div>
        </div>

        <!-- Plan Cards -->
        <div class="p-6 space-y-4 max-h-[60vh] overflow-y-auto">
            @foreach (var plan in Model.Plans.Where(p => p.Price > 0))
            {
            <div class="bg-white rounded-xl border border-gray-200 hover:border-blue-300 hover:shadow-md transition-all p-5">
                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                    <div>
                        <h3 class="text-lg font-bold text-gray-900 mb-1">@plan.Name</h3>
                        <p class="text-sm text-gray-500 mb-2">@(plan.Description ?? "PayRex Subscription Plan")</p>
                        <div class="flex flex-wrap gap-3 text-xs text-gray-500">
                            <span class="flex items-center gap-1">
                                <svg class="w-3.5 h-3.5 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
                                @plan.MaxEmployees employees
                            </span>
                            @if (plan.PlanUserLimit.HasValue)
                            {
                            <span class="flex items-center gap-1">
                                <svg class="w-3.5 h-3.5 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
                                @plan.PlanUserLimit users
                            </span>
                            }
                        </div>
                    </div>
                    <div class="flex flex-col items-end gap-2 flex-shrink-0">
                        <div class="text-right">
                            <span class="text-2xl font-extrabold text-gray-900">₱@plan.Price.ToString("N2")</span>
                            <span class="text-xs text-gray-400">/mo</span>
                        </div>
                        <a href="/Checkout?planId=@plan.PlanId" class="inline-flex items-center px-5 py-2.5 text-sm font-semibold text-white bg-blue-600 rounded-xl hover:bg-blue-700 transition-colors shadow-sm">
                            Select Plan
                            <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                        </a>
                    </div>
                </div>
            </div>
            }
        </div>

        <!-- Footer -->
        <div class="px-6 py-4 border-t border-gray-100 bg-gray-50 flex items-center justify-between">
            <p class="text-xs text-gray-400 flex items-center gap-1">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                Secure payment via PayMongo
            </p>
            <button onclick="closeBillingRenewalModal()" class="text-sm text-gray-500 hover:text-gray-700 transition-colors">Cancel</button>
        </div>
    </div>
</div>

<!-- Hidden Invoice Export Form -->
<form id="exportInvoicesForm" method="post" asp-page-handler="ExportInvoicesPdf" style="display:none">
    @Html.AntiForgeryToken()
    <input type="hidden" name="exportSearch" id="exportSearch">
    <input type="hidden" name="exportStatus" id="exportStatus">
    <input type="hidden" name="exportDateFrom" id="exportDateFrom">
    <input type="hidden" name="exportDateTo" id="exportDateTo">
</form>

<!-- Print Styles -->
<style>
    @@media print {
        nav, header, aside, .print\:hidden { display: none !important; }
        .rounded-2xl { border-radius: 0 !important; }
        .shadow-sm { box-shadow: none !important; }
        body { background: white !important; }
        table { font-size: 11px !important; }
        .print-hide { display: none !important; }
    }
</style>
}
