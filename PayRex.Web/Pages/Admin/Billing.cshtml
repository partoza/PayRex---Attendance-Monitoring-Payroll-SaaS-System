@page
@model PayRex.Web.Pages.Admin.BillingModel
@{
    ViewData["Title"] = "Admin Billing";
}

<div class="max-w-8xl mx-auto px-4 py-6 sm:px-6 lg:px-8 space-y-6" id="billingContent">
    <!-- Welcome Header -->
    <div class="bg-gradient-to-r from-blue-50 via-white to-blue-50 rounded-2xl border border-blue-100 shadow-sm overflow-hidden relative">
        <div class="absolute top-0 right-0 -mt-16 -mr-16 w-64 h-64 bg-yellow-100 rounded-full blur-3xl opacity-20"></div>
        <div class="absolute bottom-0 left-0 -mb-16 -ml-16 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
        <div class="px-6 py-8 sm:px-10 relative z-10">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <div>
                    <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight">Admin Billing</h1>
                    <p class="mt-2 text-gray-600">Manage subscription plans and view invoice history</p>
                </div>
                <div class="flex items-center gap-3">
                    <button onclick="window.print()" class="inline-flex items-center px-5 py-2.5 rounded-xl text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 transition-colors shadow-sm hover:shadow-md print:hidden">
                        <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 4v3H4a2 2 0 00-2 2v3a2 2 0 002 2h1v2a2 2 0 002 2h6a2 2 0 002-2v-2h1a2 2 0 002-2V9a2 2 0 00-2-2h-1V4a2 2 0 00-2-2H7a2 2 0 00-2 2zm8 0H7v3h6V4zm0 8H7v4h6v-4z" clip-rule="evenodd" /></svg>
                        Print / Download
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- KPI Summary Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        @{
            var totalRevenue = Model.Invoices.Where(i => i.Status == "Paid").Sum(i => i.Amount);
            var pendingAmount = Model.Invoices.Where(i => i.Status == "Pending").Sum(i => i.Amount);
            var overdueCount = Model.Invoices.Count(i => i.Status == "Overdue");
        }
        <!-- Total Revenue -->
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-gray-500">Total Revenue</p>
                    <p class="mt-1 text-2xl font-bold text-gray-900">₱@totalRevenue.ToString("N2")</p>
                </div>
                <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center">
                    <svg class="w-6 h-6 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path d="M4 4a2 2 0 00-2 2v4a2 2 0 002 2V6h10a2 2 0 00-2-2H4zm2 6a2 2 0 012-2h8a2 2 0 012 2v4a2 2 0 01-2 2H8a2 2 0 01-2-2v-4zm6 1a1 1 0 100 2 1 1 0 000-2z" /></svg>
                </div>
            </div>
            <span class="inline-flex items-center mt-3 px-2.5 py-1 rounded-lg text-xs font-semibold bg-green-100 text-green-700">
                <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
                Paid invoices
            </span>
        </div>
        <!-- Pending -->
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-gray-500">Pending Amount</p>
                    <p class="mt-1 text-2xl font-bold text-gray-900">₱@pendingAmount.ToString("N2")</p>
                </div>
                <div class="w-12 h-12 bg-yellow-100 rounded-xl flex items-center justify-center">
                    <svg class="w-6 h-6 text-yellow-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" /></svg>
                </div>
            </div>
            <span class="inline-flex items-center mt-3 px-2.5 py-1 rounded-lg text-xs font-semibold bg-yellow-100 text-yellow-700">Awaiting payment</span>
        </div>
        <!-- Overdue -->
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-gray-500">Overdue Invoices</p>
                    <p class="mt-1 text-2xl font-bold text-gray-900">@overdueCount</p>
                </div>
                <div class="w-12 h-12 bg-red-100 rounded-xl flex items-center justify-center">
                    <svg class="w-6 h-6 text-red-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" /></svg>
                </div>
            </div>
            <span class="inline-flex items-center mt-3 px-2.5 py-1 rounded-lg text-xs font-semibold bg-red-100 text-red-700">Needs attention</span>
        </div>
    </div>

    <!-- Subscription Plans -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 bg-gradient-to-r from-gray-50 to-white">
            <h2 class="text-base font-semibold text-gray-900 flex items-center">
                <svg class="w-5 h-5 mr-2 text-blue-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 2a2 2 0 00-2 2v14l3.5-2 3.5 2 3.5-2 3.5 2V4a2 2 0 00-2-2H5zm4.707 3.707a1 1 0 00-1.414-1.414l-3 3a1 1 0 000 1.414l3 3a1 1 0 001.414-1.414L8.414 9H10a3 3 0 110 6 1 1 0 100 2 5 5 0 000-10h-1.586l1.293-1.293z" clip-rule="evenodd" /></svg>
                Subscription Plans
            </h2>
        </div>
        <div class="p-6">
            @if (Model.Plans.Count == 0)
            {
                <p class="text-gray-400 text-sm text-center py-6">No subscription plans configured</p>
            }
            else
            {
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    @foreach (var plan in Model.Plans)
                    {
                        var isPopular = plan.Name?.ToLower() == "professional" || plan.Name?.ToLower() == "pro";
                        <div class="relative rounded-2xl border @(isPopular ? "border-blue-300 ring-2 ring-blue-100" : "border-gray-200") p-6 hover:shadow-md transition-all">
                            @if (isPopular)
                            {
                                <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                                    <span class="px-3 py-1 rounded-full text-xs font-bold bg-blue-600 text-white shadow-md">POPULAR</span>
                                </div>
                            }
                            <h3 class="text-lg font-bold text-gray-900">@plan.Name</h3>
                            <p class="text-sm text-gray-500 mt-1">@(plan.Description ?? "Standard plan")</p>
                            <div class="mt-4">
                                <span class="text-3xl font-extrabold text-gray-900">₱@plan.Price.ToString("N0")</span>
                                <span class="text-sm text-gray-500">/@plan.BillingCycle</span>
                            </div>
                            <ul class="mt-4 space-y-2 text-sm text-gray-600">
                                <li class="flex items-center"><svg class="w-4 h-4 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>Up to @plan.MaxEmployees employees</li>
                                @if (plan.PlanUserLimit.HasValue)
                                {
                                    <li class="flex items-center"><svg class="w-4 h-4 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>@plan.PlanUserLimit users</li>
                                }
                                <li class="flex items-center"><svg class="w-4 h-4 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>@plan.Status</li>
                            </ul>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Invoices Section -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 bg-gradient-to-r from-gray-50 to-white">
            <h2 class="text-base font-semibold text-gray-900 flex items-center">
                <svg class="w-5 h-5 mr-2 text-yellow-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd" /></svg>
                Invoices
            </h2>
        </div>
        <!-- Filters -->
        <div class="p-4 sm:p-6 border-b border-gray-100">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Search</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <svg class="w-4 h-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" /></svg>
                        </div>
                        <input type="text" placeholder="Invoice # or company..." class="w-full pl-10 pr-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all" id="searchInput">
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Status</label>
                    <select id="invoiceStatusFilter" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all bg-white">
                        <option value="">All Status</option>
                        <option value="Paid">Paid</option>
                        <option value="Pending">Pending</option>
                        <option value="Overdue">Overdue</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">From Date</label>
                    <input type="date" id="dateFrom" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">To Date</label>
                    <input type="date" id="dateTo" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all">
                </div>
            </div>
            <div class="flex items-center gap-3 mt-4">
                <button onclick="clearInvoiceFilters()" class="inline-flex items-center px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-xl hover:bg-gray-200 transition-colors border border-gray-200">
                    <svg class="w-4 h-4 mr-1.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                    Clear
                </button>
                <div class="ml-auto flex items-center gap-3 print:hidden">
                    <select id="pageSizeSelect" class="px-3 py-1.5 border border-gray-300 rounded-lg text-sm bg-white focus:ring-2 focus:ring-blue-500">
                        <option value="10">10 per page</option>
                        <option value="25">25 per page</option>
                        <option value="50">50 per page</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Invoice Table -->
        <div class="overflow-x-auto">
            <table class="w-full" id="invoicesTable">
                <thead class="bg-gray-50/80">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Invoice #</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Company</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Amount</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Due Date</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Created</th>
                    </tr>
                </thead>
                @{
                    var demoInvoices = new[] {
                        new { Num = "INV-2026-001", Company = "TechVision Corp", Amount = 4999.00m, Status = "Paid", Due = "Jan 15, 2026", Created = "Jan 01, 2026", DueRaw = "2026-01-15" },
                        new { Num = "INV-2026-002", Company = "CloudSync Inc", Amount = 2499.00m, Status = "Paid", Due = "Jan 20, 2026", Created = "Jan 05, 2026", DueRaw = "2026-01-20" },
                        new { Num = "INV-2026-003", Company = "DataFlow Systems", Amount = 9999.00m, Status = "Pending", Due = "Feb 15, 2026", Created = "Feb 01, 2026", DueRaw = "2026-02-15" },
                        new { Num = "INV-2026-004", Company = "NexGen Solutions", Amount = 4999.00m, Status = "Paid", Due = "Feb 10, 2026", Created = "Jan 25, 2026", DueRaw = "2026-02-10" },
                        new { Num = "INV-2026-005", Company = "SmartPay Inc", Amount = 2499.00m, Status = "Overdue", Due = "Jan 05, 2026", Created = "Dec 20, 2025", DueRaw = "2026-01-05" },
                        new { Num = "INV-2026-006", Company = "PayWell Group", Amount = 9999.00m, Status = "Paid", Due = "Jan 30, 2026", Created = "Jan 15, 2026", DueRaw = "2026-01-30" },
                        new { Num = "INV-2026-007", Company = "HR Direct", Amount = 4999.00m, Status = "Pending", Due = "Feb 20, 2026", Created = "Feb 05, 2026", DueRaw = "2026-02-20" },
                        new { Num = "INV-2026-008", Company = "WorkForce PH", Amount = 2499.00m, Status = "Paid", Due = "Jan 25, 2026", Created = "Jan 10, 2026", DueRaw = "2026-01-25" },
                        new { Num = "INV-2026-009", Company = "EasyPay Corp", Amount = 9999.00m, Status = "Overdue", Due = "Jan 10, 2026", Created = "Dec 25, 2025", DueRaw = "2026-01-10" },
                        new { Num = "INV-2026-010", Company = "TechVision Corp", Amount = 4999.00m, Status = "Pending", Due = "Feb 28, 2026", Created = "Feb 10, 2026", DueRaw = "2026-02-28" },
                        new { Num = "INV-2026-011", Company = "CloudSync Inc", Amount = 2499.00m, Status = "Paid", Due = "Feb 05, 2026", Created = "Jan 20, 2026", DueRaw = "2026-02-05" },
                        new { Num = "INV-2026-012", Company = "DataFlow Systems", Amount = 9999.00m, Status = "Paid", Due = "Jan 18, 2026", Created = "Jan 03, 2026", DueRaw = "2026-01-18" },
                    };
                }
                <tbody class="divide-y divide-gray-100" id="invoicesBody">
                    @if (Model.Invoices.Count == 0)
                    {
                        @foreach (var inv in demoInvoices)
                        {
                            var statusColor = inv.Status switch {
                                "Paid" => "bg-green-100 text-green-700",
                                "Pending" => "bg-yellow-100 text-yellow-700",
                                "Overdue" => "bg-red-100 text-red-700",
                                _ => "bg-gray-100 text-gray-700"
                            };
                            var dotColor = inv.Status switch {
                                "Paid" => "bg-green-500",
                                "Pending" => "bg-yellow-500",
                                "Overdue" => "bg-red-500",
                                _ => "bg-gray-500"
                            };
                            <tr class="hover:bg-gray-50/50 transition-colors data-row"
                                data-search="@inv.Num @inv.Company"
                                data-status="@inv.Status"
                                data-due="@inv.DueRaw">
                                <td class="px-6 py-4 text-sm font-mono font-semibold text-blue-600">@inv.Num</td>
                                <td class="px-6 py-4 text-sm font-medium text-gray-900">@inv.Company</td>
                                <td class="px-6 py-4 text-sm font-semibold text-gray-900">₱@inv.Amount.ToString("N2")</td>
                                <td class="px-6 py-4"><span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-semibold @statusColor"><span class="w-1.5 h-1.5 rounded-full @dotColor mr-1.5"></span>@inv.Status</span></td>
                                <td class="px-6 py-4 text-sm text-gray-500">@inv.Due</td>
                                <td class="px-6 py-4 text-sm text-gray-500">@inv.Created</td>
                            </tr>
                        }
                    }
                    else
                    {
                        @foreach (var inv in Model.Invoices)
                        {
                            var statusColor = inv.Status switch {
                                "Paid" => "bg-green-100 text-green-700",
                                "Pending" => "bg-yellow-100 text-yellow-700",
                                "Overdue" => "bg-red-100 text-red-700",
                                _ => "bg-gray-100 text-gray-700"
                            };
                            var dotColor = inv.Status switch {
                                "Paid" => "bg-green-500",
                                "Pending" => "bg-yellow-500",
                                "Overdue" => "bg-red-500",
                                _ => "bg-gray-500"
                            };
                            <tr class="hover:bg-gray-50/50 transition-colors data-row"
                                data-search="@inv.InvoiceNumber @inv.CompanyName"
                                data-status="@inv.Status"
                                data-due="@inv.DueDate.ToString("yyyy-MM-dd")">
                                <td class="px-6 py-4 text-sm font-mono font-semibold text-blue-600">@inv.InvoiceNumber</td>
                                <td class="px-6 py-4 text-sm font-medium text-gray-900">@inv.CompanyName</td>
                                <td class="px-6 py-4 text-sm font-semibold text-gray-900">₱@inv.Amount.ToString("N2")</td>
                                <td class="px-6 py-4"><span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-semibold @statusColor"><span class="w-1.5 h-1.5 rounded-full @dotColor mr-1.5"></span>@inv.Status</span></td>
                                <td class="px-6 py-4 text-sm text-gray-500">@inv.DueDate.ToString("MMM dd, yyyy")</td>
                                <td class="px-6 py-4 text-sm text-gray-500">@inv.CreatedAt.ToString("MMM dd, yyyy")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="px-6 py-4 border-t border-gray-100 bg-gray-50/50 print:hidden">
            <div class="flex flex-col sm:flex-row items-center justify-between gap-3">
                <div class="text-sm text-gray-600">
                    Showing <span class="font-semibold" id="showStart">1</span> to <span class="font-semibold" id="showEnd">10</span> of <span class="font-semibold" id="showTotal">0</span> invoices
                </div>
                <nav class="flex items-center gap-1" id="paginationNav"></nav>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let currentPage = 1;
    let pageSize = 10;
    let allRows = [];
    let filteredRows = [];

    document.addEventListener('DOMContentLoaded', function () {
        allRows = Array.from(document.querySelectorAll('.data-row'));
        filteredRows = [...allRows];
        renderPage();

        document.getElementById('searchInput').addEventListener('input', applyFilters);
        document.getElementById('invoiceStatusFilter').addEventListener('change', applyFilters);
        document.getElementById('dateFrom').addEventListener('change', applyFilters);
        document.getElementById('dateTo').addEventListener('change', applyFilters);
        document.getElementById('pageSizeSelect').addEventListener('change', function () {
            pageSize = parseInt(this.value);
            currentPage = 1;
            renderPage();
        });
    });

    function applyFilters() {
        const search = document.getElementById('searchInput').value.toLowerCase();
        const status = document.getElementById('invoiceStatusFilter').value;
        const from = document.getElementById('dateFrom').value;
        const to = document.getElementById('dateTo').value;

        filteredRows = allRows.filter(row => {
            const s = (row.dataset.search || '').toLowerCase();
            const st = row.dataset.status || '';
            const due = row.dataset.due || '';

            if (search && !s.includes(search)) return false;
            if (status && st !== status) return false;
            if (from && due < from) return false;
            if (to && due > to) return false;
            return true;
        });
        currentPage = 1;
        renderPage();
    }

    function clearInvoiceFilters() {
        document.getElementById('searchInput').value = '';
        document.getElementById('invoiceStatusFilter').value = '';
        document.getElementById('dateFrom').value = '';
        document.getElementById('dateTo').value = '';
        filteredRows = [...allRows];
        currentPage = 1;
        renderPage();
    }

    function renderPage() {
        const total = filteredRows.length;
        const totalPages = Math.max(1, Math.ceil(total / pageSize));
        if (currentPage > totalPages) currentPage = totalPages;
        const start = (currentPage - 1) * pageSize;
        const end = Math.min(start + pageSize, total);

        allRows.forEach(row => row.style.display = 'none');
        for (let i = start; i < end; i++) filteredRows[i].style.display = '';

        document.getElementById('showStart').textContent = total === 0 ? 0 : start + 1;
        document.getElementById('showEnd').textContent = end;
        document.getElementById('showTotal').textContent = total;

        const nav = document.getElementById('paginationNav');
        nav.innerHTML = '';
        if (totalPages <= 1) return;

        nav.appendChild(createPageBtn('‹', currentPage > 1, () => { currentPage--; renderPage(); }));
        getPageNumbers(currentPage, totalPages).forEach(p => {
            if (p === '...') {
                const d = document.createElement('span');
                d.className = 'px-3 py-1.5 text-gray-400 text-sm';
                d.textContent = '...';
                nav.appendChild(d);
            } else {
                const btn = createPageBtn(p, true, () => { currentPage = p; renderPage(); });
                if (p === currentPage) btn.className = 'px-3 py-1.5 text-sm font-semibold bg-blue-600 text-white rounded-lg shadow-sm';
                nav.appendChild(btn);
            }
        });
        nav.appendChild(createPageBtn('›', currentPage < totalPages, () => { currentPage++; renderPage(); }));
    }

    function createPageBtn(label, enabled, onClick) {
        const btn = document.createElement('button');
        btn.textContent = label;
        btn.className = 'px-3 py-1.5 text-sm font-medium text-gray-700 hover:bg-gray-100 rounded-lg border border-gray-200 transition-all';
        if (!enabled) { btn.disabled = true; btn.className += ' opacity-40 cursor-not-allowed'; }
        else btn.addEventListener('click', onClick);
        return btn;
    }

    function getPageNumbers(current, total) {
        if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
        if (current <= 4) { const p = []; for (let i = 1; i <= 5; i++) p.push(i); p.push('...', total); return p; }
        if (current >= total - 3) { const p = [1, '...']; for (let i = total - 4; i <= total; i++) p.push(i); return p; }
        return [1, '...', current - 1, current, current + 1, '...', total];
    }
</script>

