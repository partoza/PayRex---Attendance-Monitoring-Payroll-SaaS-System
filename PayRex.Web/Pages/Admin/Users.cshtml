@page
@model PayRex.Web.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "Manage Users";
}

<div class="max-w-8xl mx-auto px-4 py-6 sm:px-6 lg:px-8 space-y-6">

<!-- Confirm Deactivate Modal -->
<div id="popup-modal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-hidden="true">
    <div class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm transition-opacity" aria-hidden="true" onclick="hideConfirmModal()"></div>
    <div class="flex min-h-full items-center justify-center p-2 sm:p-4 text-center">
        <div class="relative transform overflow-hidden rounded-lg bg-white text-left shadow-xl transition-all w-full sm:w-[90%] md:w-[60%] lg:w-[50%] max-w-md mx-auto">
            <div class="flex items-center justify-between border-b border-gray-200 bg-white px-4 py-3 sm:px-6 sm:py-4 md:px-6 md:py-4">
                <h3 class="text-base sm:text-lg font-semibold text-gray-900">Confirm Inactivate</h3>
                <button type="button" onclick="hideConfirmModal()" class="rounded-lg p-1.5 text-gray-400 hover:bg-gray-100 hover:text-gray-500">
                    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
                </button>
            </div>
            <div class="px-4 py-4 sm:px-6 sm:py-5 md:px-6 md:py-6">
                <div class="text-center">
                    <p class="mb-4 text-sm text-gray-700">
                        Are you sure you want to inactivate
                        <span class="font-semibold confirm-user-name">this user</span>?
                    </p>
                    <div class="flex justify-center gap-3">
                        <button type="button" onclick="hideConfirmModal()" class="inline-flex items-center justify-center px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-lg hover:bg-gray-200 focus:ring-2 focus:ring-gray-300">No, Cancel</button>
                        <button id="confirmDeactivateBtn" type="button" onclick="confirmDeactivateUser()" class="inline-flex items-center justify-center px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700 focus:ring-2 focus:ring-red-300">Yes, I'm sure</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Hidden deactivate form (submitted by JS confirm) -->
<form id="deactivateUserForm" method="post" asp-page-handler="ToggleStatus" class="hidden">
    <input type="hidden" name="userId" id="deactivateUserId" />
    <input type="hidden" name="currentStatus" value="Active" />
</form>

    <!-- Welcome Header (Dashboard Style) -->
    <div class="bg-gradient-to-r from-blue-50 via-white to-blue-50 rounded-2xl border border-blue-100 shadow-sm overflow-hidden relative">
        <div class="absolute top-0 right-0 -mt-16 -mr-16 w-64 h-64 bg-yellow-100 rounded-full blur-3xl opacity-20"></div>
        <div class="absolute bottom-0 left-0 -mb-16 -ml-16 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
        <div class="px-6 py-8 sm:px-10 relative z-10">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <div>
                    <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight">Manage Users</h1>
                    <p class="mt-2 text-gray-600">View and manage all platform users and role permissions</p>
                </div>
                <div class="flex items-center gap-3">
                    <span class="inline-flex items-center px-4 py-2 rounded-xl text-sm font-semibold bg-blue-100 text-blue-700">
                        <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20"><path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z" /></svg>
                        @Model.Users.Count Total Users
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabs -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="border-b border-gray-200 px-6">
            <nav class="-mb-px flex space-x-8" id="tabNav">
                <button type="button" onclick="switchTab('users')" id="tab-users"
                    class="tab-btn py-4 px-1 border-b-2 border-blue-500 text-blue-600 font-semibold text-sm whitespace-nowrap transition-all">
                    <svg class="w-4 h-4 inline mr-1.5 -mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z" /></svg>
                    Users
                </button>
                <button type="button" onclick="switchTab('permissions')" id="tab-permissions"
                    class="tab-btn py-4 px-1 border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 font-medium text-sm whitespace-nowrap transition-all">
                    <svg class="w-4 h-4 inline mr-1.5 -mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
                    Role Permissions
                </button>
            </nav>
        </div>
    </div>

    <!-- Tab: Users (existing content) -->
    <div id="panel-users">

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <script>document.addEventListener('DOMContentLoaded',()=>showToast(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.StatusMessage)), '@(Model.StatusMessage!.StartsWith("Failed") ? "error" : "success")'));</script>
    }

    <!-- Filters Card -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 bg-gradient-to-r from-gray-50 to-white">
            <h2 class="text-base font-semibold text-gray-900 flex items-center">
                <svg class="w-5 h-5 mr-2 text-blue-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3 3a1 1 0 011-1h12a1 1 0 011 1v3a1 1 0 01-.293.707L12 11.414V15a1 1 0 01-.293.707l-2 2A1 1 0 018 17v-5.586L3.293 6.707A1 1 0 013 6V3z" clip-rule="evenodd" /></svg>
                Filters & Search
            </h2>
        </div>
        <div class="p-4 sm:p-6">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                <!-- Search -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Search</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <svg class="w-4 h-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" /></svg>
                        </div>
                        <input type="text" placeholder="Name or email..." class="w-full pl-10 pr-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all" id="searchInput">
                    </div>
                </div>
                <!-- Role Filter -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Role</label>
                    <select id="roleFilter" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all bg-white">
                        <option value="">All Roles</option>
                        <option value="Admin">Administration</option>
                        <option value="HR">Human Resource Manager</option>
                        <option value="Accountant">Accountant</option>
                        <option value="Employee">Employee</option>
                    </select>
                </div>
                <!-- Status Filter -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Status</label>
                    <select id="statusFilter" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all bg-white">
                        <option value="">All Status</option>
                        <option value="Active">Active</option>
                    </select>
                </div>
                <!-- Company Filter -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Company</label>
                    <select id="companyFilter" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all bg-white">
                        <option value="">All Companies</option>
                        @foreach (var companyName in Model.Users.Select(u => u.CompanyName).Where(c => !string.IsNullOrEmpty(c)).Distinct().OrderBy(c => c))
                        {
                            <option value="@companyName">@companyName</option>
                        }
                    </select>
                </div>
            </div>
            <div class="flex items-center gap-3 mt-4">
                <button onclick="clearFilters()" class="inline-flex items-center px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-xl hover:bg-gray-200 transition-colors border border-gray-200">
                    <svg class="w-4 h-4 mr-1.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                    Clear Filters
                </button>
            </div>
        </div>
    </div>

    <!-- Users Table Card -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 bg-gradient-to-r from-gray-50 to-white">
            <div class="flex items-center justify-between">
                <div>
                    <h2 class="text-base font-semibold text-gray-900">All Users</h2>
                    <p class="text-sm text-gray-500 mt-0.5" id="tableInfo">Showing @Model.Users.Count users</p>
                </div>
                <div class="flex items-center gap-3">
                    <select id="pageSizeSelect" class="px-3 py-1.5 border border-gray-300 rounded-lg text-sm bg-white focus:ring-2 focus:ring-blue-500">
                        <option value="10">10 per page</option>
                        <option value="25">25 per page</option>
                        <option value="50">50 per page</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full" id="usersTable">
                <thead class="bg-gray-50/80">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">User</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Role</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Company</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Created</th>
                        <th class="px-6 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100" id="usersBody">
                    @if (Model.Users.Count == 0)
                    {
                        <tr id="emptyRow">
                            <td colspan="6" class="px-6 py-12 text-center">
                                <div class="flex flex-col items-center justify-center">
                                    <div class="w-16 h-16 bg-blue-50 rounded-full flex items-center justify-center mb-4">
                                        <svg class="w-8 h-8 text-blue-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" /></svg>
                                    </div>
                                    <p class="text-gray-500 font-medium">No users found</p>
                                    <p class="text-sm text-gray-400 mt-1">Try adjusting your filters</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var user in Model.Users)
                        {
                            var roleDisplay = user.Role switch {
                                "Admin" => "Administration",
                                "HR" => "Human Resource Manager",
                                "Hr" => "Human Resource Manager",
                                "Accountant" => "Accountant",
                                "Employee" => "Employee",
                                "SuperAdmin" => "Super Admin",
                                _ => user.Role
                            };
                            var roleColor = user.Role switch {
                                "Admin" => "bg-blue-100 text-blue-700",
                                "HR" or "Hr" => "bg-yellow-100 text-yellow-700",
                                "Accountant" => "bg-purple-100 text-purple-700",
                                "Employee" => "bg-green-100 text-green-700",
                                "SuperAdmin" => "bg-red-100 text-red-700",
                                _ => "bg-gray-100 text-gray-700"
                            };

                            <tr class="hover:bg-gray-50/50 transition-colors data-row"
                                data-name="@user.FirstName @user.LastName"
                                data-email="@user.Email"
                                data-role="@user.Role"
                                data-status="@user.Status"
                                data-company="@user.CompanyName"
                                data-profile-image="@(user.ProfileImageUrl ?? "")">
                                <!-- User Info -->
                                <td class="px-6 py-4">
                                    <div class="flex items-center">
                                        <div class="w-9 h-9 rounded-full overflow-hidden flex items-center justify-center mr-3 shadow-sm flex-shrink-0">
                                            @if (!string.IsNullOrEmpty(user.ProfileImageUrl))
                                            {
                                                <img src="@user.ProfileImageUrl" alt="Profile" class="w-9 h-9 object-cover rounded-full" />
                                            }
                                            else
                                            {
                                                <div class="w-full h-full bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center">
                                                    <span class="text-xs font-bold text-white">
                                                        @user.FirstName?.Substring(0, 1).ToUpper()@user.LastName?.Substring(0, 1).ToUpper()
                                                    </span>
                                                </div>
                                            }
                                        </div>
                                        <div>
                                            <p class="text-sm font-semibold text-gray-900">@user.FirstName @user.LastName</p>
                                            <p class="text-xs text-gray-500 truncate max-w-[200px]">@user.Email</p>
                                        </div>
                                    </div>
                                </td>
                                <!-- Role -->
                                <td class="px-6 py-4">
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-semibold @roleColor">
                                        @roleDisplay
                                    </span>
                                </td>
                                <!-- Company -->
                                <td class="px-6 py-4">
                                    <div class="flex items-center">
                                        <svg class="w-4 h-4 text-gray-400 mr-1.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h8a2 2 0 012 2v12a1 1 0 110 2h-3a1 1 0 01-1-1v-2a1 1 0 00-1-1H9a1 1 0 00-1 1v2a1 1 0 01-1 1H4a1 1 0 110-2V4zm3 1h2v2H7V5zm2 4H7v2h2V9zm2-4h2v2h-2V5zm2 4h-2v2h2V9z" clip-rule="evenodd" /></svg>
                                        <span class="text-sm text-gray-600 truncate max-w-[130px]">@(user.CompanyName ?? "—")</span>
                                    </div>
                                </td>
                                <!-- Status -->
                                <td class="px-6 py-4">
                                    <span class="text-xs sm:text-sm font-semibold @(user.Status == "Active" ? "text-green-700" : "text-red-700")">
                                        @user.Status
                                    </span>
                                </td>
                                <!-- Created -->
                                <td class="px-6 py-4 text-sm text-gray-500 whitespace-nowrap">
                                    @user.CreatedAt.ToString("MMM dd, yyyy")
                                </td>
                                <!-- Actions -->
                                <td class="px-6 py-4">
                                    <div class="flex items-center justify-center gap-2">
                                        <button type="button"
                                                onclick="openUserModal('@user.UserId', '@user.FirstName', '@user.LastName', '@user.Email', '@roleDisplay', '@user.Status', '@(user.CompanyName ?? "")', '@user.CreatedAt.ToString("MMM dd, yyyy")', '@(user.ProfileImageUrl ?? "")')"
                                                class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-blue-700 bg-blue-50 rounded-lg hover:bg-blue-100 transition-colors">
                                            <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                                            View
                                        </button>
                                        @if (user.Status == "Active")
                                        {
                                            <button type="button"
                                                    data-name="@user.FirstName @user.LastName"
                                                    onclick="deactivateUser(this, '@user.UserId')"
                                                    class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-red-600 bg-red-50 rounded-lg hover:bg-red-100 transition-colors">
                                                <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" /></svg>
                                                Inactive
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-gray-400 bg-gray-100 rounded-lg cursor-not-allowed">Inactive</span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="px-4 sm:px-6 py-3 sm:py-4 border-t border-gray-100 bg-gray-50/50" id="paginationContainer">
            <div class="flex flex-col sm:flex-row items-center justify-between gap-3">
                <div class="text-xs sm:text-sm text-gray-600" id="paginationInfo">
                    Showing <span class="font-semibold" id="showStart">1</span> to <span class="font-semibold" id="showEnd">10</span> of <span class="font-semibold" id="showTotal">0</span> users
                </div>
                <nav class="flex items-center gap-1 flex-wrap justify-center" id="paginationNav"></nav>
            </div>
        </div>
    </div>
    </div> <!-- /panel-users -->

    <!-- Tab: Role Permissions -->
    <div id="panel-permissions" class="hidden space-y-6">
        <!-- Permissions Header -->
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100 bg-gradient-to-r from-gray-50 to-white">
                <div class="flex items-center justify-between">
                    <div>
                        <h2 class="text-base font-semibold text-gray-900 flex items-center">
                            <svg class="w-5 h-5 mr-2 text-blue-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
                            Role Permission Matrix
                        </h2>
                        <p class="text-sm text-gray-500 mt-1">Configure what each role can do in every module</p>
                    </div>
                    <div class="flex items-center gap-2">
                        <button onclick="cancelEditMode()" id="cancelPermBtn"
                            class="hidden inline-flex items-center px-5 py-2.5 text-sm font-semibold text-gray-700 bg-white border border-gray-300 rounded-xl hover:bg-gray-50 shadow-sm transition-all">
                            <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                            Cancel
                        </button>
                        <button onclick="toggleEditMode()" id="savePermBtn"
                            class="inline-flex items-center px-5 py-2.5 text-sm font-semibold text-white bg-blue-600 rounded-xl hover:bg-blue-700 shadow-sm transition-all disabled:opacity-50 disabled:cursor-not-allowed">
                            <svg id="permBtnIcon" class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" /></svg>
                            <span id="permBtnLabel">Edit Permission</span>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Matrix Grid -->
            <div class="overflow-x-auto">
                <table class="w-full" id="permissionsTable">
                    <thead class="bg-gray-50/80">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider sticky left-0 bg-gray-50 z-10 min-w-[220px]">Module</th>
                            <th class="px-4 py-3 text-center text-xs font-semibold text-blue-600 uppercase tracking-wider border-l border-gray-200 min-w-[100px]">Admin</th>
                            <th class="px-4 py-3 text-center text-xs font-semibold text-yellow-600 uppercase tracking-wider border-l border-gray-200 min-w-[100px]">HR</th>
                            <th class="px-4 py-3 text-center text-xs font-semibold text-purple-600 uppercase tracking-wider border-l border-gray-200 min-w-[100px]">Accountant</th>
                            <th class="px-4 py-3 text-center text-xs font-semibold text-green-600 uppercase tracking-wider border-l border-gray-200 min-w-[100px]">Employee</th>
                        </tr>
                    </thead>
                    <tbody id="permissionsBody" class="divide-y divide-gray-100">
                        <!-- Populated by JS -->
                        <tr><td colspan="5" class="px-6 py-12 text-center text-gray-400">Loading permissions...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
<!-- View User Modal -->
<div id="userModal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-labelledby="user-modal-title" role="dialog" aria-modal="true">
    <!-- Backdrop -->
    <div class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm transition-opacity" aria-hidden="true" onclick="closeUserModal()"></div>

    <!-- Modal container -->
    <div class="fixed inset-0 z-50 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-2 sm:p-4 text-center">
            <div class="relative transform overflow-hidden rounded-lg bg-white text-left shadow-xl transition-all w-full sm:w-[90%] md:w-[75%] lg:w-[60%] xl:w-[50%] max-w-2xl mx-auto">

                <!-- Header -->
                <div class="flex items-center justify-between border-b border-gray-200 bg-white px-4 py-3 sm:px-6 sm:py-4 md:px-8 md:py-5">
                    <h3 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900" id="user-modal-title">
                        User Details
                    </h3>
                    <button onclick="closeUserModal()" class="rounded-lg p-1.5 sm:p-2 text-gray-400 hover:bg-gray-100 hover:text-gray-500 transition-colors">
                        <svg class="h-5 w-5 sm:h-6 sm:w-6" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                        </svg>
                    </button>
                </div>

                <!-- Body -->
                <div class="px-4 py-4 sm:px-6 sm:py-5 md:px-8 md:py-6 max-h-[70vh] overflow-y-auto">
                    <div class="space-y-5 sm:space-y-6">

                        <!-- User header (avatar + name) -->
                        <div class="flex flex-col sm:flex-row items-center sm:items-start gap-4 sm:gap-6 border-b border-gray-100 pb-4 sm:pb-6">
                            <div class="relative flex-shrink-0">
                                <div class="h-16 w-16 sm:h-20 sm:w-20 md:h-24 md:w-24 overflow-hidden rounded-full shadow-lg ring-4 ring-white">
                                    <img id="modalUserProfileImg" class="h-full w-full object-cover hidden" alt="Profile" />
                                    <div id="modalUserInitialsWrapper" class="w-full h-full bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center">
                                        <span class="text-xl sm:text-2xl font-bold text-white" id="modalUserInitials">JD</span>
                                    </div>
                                </div>
                            </div>
                            <div class="text-center sm:text-left flex-1">
                                <h4 class="text-xl sm:text-2xl md:text-3xl font-bold text-gray-900" id="modalUserName">John Doe</h4>
                                <p class="mt-1 text-sm text-gray-500" id="modalUserEmail">john@example.com</p>
                                <div class="mt-2 flex flex-wrap justify-center sm:justify-start items-center gap-2">
                                    <span class="rounded-full bg-blue-100 px-2 sm:px-3 py-1 text-xs sm:text-sm font-medium text-blue-800" id="modalUserRoleBadge">Role</span>
                                    <span class="rounded-full px-2 sm:px-3 py-1 text-xs sm:text-sm font-medium" id="modalUserStatusBadge">Active</span>
                                </div>
                            </div>
                        </div>

                        <!-- User Details -->
                        <div>
                            <h5 class="mb-3 text-xs sm:text-sm font-medium uppercase tracking-wider text-gray-500">Account Information</h5>
                            <div class="grid grid-cols-2 sm:grid-cols-2 gap-3 sm:gap-4">
                                <div class="bg-gray-50 p-2 sm:p-3 rounded-lg col-span-2">
                                    <p class="text-xs text-gray-500 mb-1">Email</p>
                                    <p class="text-xs sm:text-sm font-medium text-gray-900 break-all" id="modalUserEmailDetail">—</p>
                                </div>
                                <div class="bg-gray-50 p-2 sm:p-3 rounded-lg">
                                    <p class="text-xs text-gray-500 mb-1">Role</p>
                                    <p class="text-xs sm:text-sm font-semibold text-gray-900" id="modalUserRoleDetail">—</p>
                                </div>
                                <div class="bg-gray-50 p-2 sm:p-3 rounded-lg">
                                    <p class="text-xs text-gray-500 mb-1">Company</p>
                                    <p class="text-xs sm:text-sm font-semibold text-gray-900" id="modalUserCompany">—</p>
                                </div>
                                <div class="bg-gray-50 p-2 sm:p-3 rounded-lg">
                                    <p class="text-xs text-gray-500 mb-1">Member Since</p>
                                    <p class="text-xs sm:text-sm font-semibold text-gray-900" id="modalUserCreated">—</p>
                                </div>
                                <div class="bg-gray-50 p-2 sm:p-3 rounded-lg">
                                    <p class="text-xs text-gray-500 mb-1">User ID</p>
                                    <p class="text-xs font-mono text-gray-600" id="modalUserId">—</p>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Footer -->
                <div class="border-t border-gray-200 bg-gray-50 px-4 py-3 sm:px-6 sm:py-4">
                    <div class="flex justify-end">
                        <button type="button" class="inline-flex justify-center rounded-lg bg-blue-600 px-4 py-2 sm:px-5 sm:py-2.5 text-xs sm:text-sm font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-4 focus:ring-blue-300 transition-colors w-full sm:w-auto" onclick="closeUserModal()">
                            Close
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // ===== Pagination & Filter State =====
    let currentPage = 1;
    let pageSize = 10;
    let allRows = [];
    let filteredRows = [];

    document.addEventListener('DOMContentLoaded', function () {
        allRows = Array.from(document.querySelectorAll('.data-row'));
        filteredRows = [...allRows];
        renderPage();

        // Live search
        document.getElementById('searchInput').addEventListener('input', applyFilters);
        document.getElementById('roleFilter').addEventListener('change', applyFilters);
        document.getElementById('statusFilter').addEventListener('change', applyFilters);
        document.getElementById('companyFilter').addEventListener('change', applyFilters);
        document.getElementById('pageSizeSelect').addEventListener('change', function () {
            pageSize = parseInt(this.value);
            currentPage = 1;
            renderPage();
        });
    });

    function applyFilters() {
        const search = document.getElementById('searchInput').value.toLowerCase();
        const role = document.getElementById('roleFilter').value;
        const status = document.getElementById('statusFilter').value;
        const company = document.getElementById('companyFilter').value;

        filteredRows = allRows.filter(row => {
            const name = (row.dataset.name || '').toLowerCase();
            const email = (row.dataset.email || '').toLowerCase();
            const r = row.dataset.role || '';
            const s = row.dataset.status || '';
            const c = row.dataset.company || '';

            if (search && !name.includes(search) && !email.includes(search)) return false;
            if (role && r !== role) return false;
            if (status && s !== status) return false;
            if (company && c !== company) return false;
            return true;
        });

        currentPage = 1;
        renderPage();
    }

    function clearFilters() {
        document.getElementById('searchInput').value = '';
        document.getElementById('roleFilter').value = '';
        document.getElementById('statusFilter').value = '';
        document.getElementById('companyFilter').value = '';
        filteredRows = [...allRows];
        currentPage = 1;
        renderPage();
    }

    function renderPage() {
        const total = filteredRows.length;
        const totalPages = Math.max(1, Math.ceil(total / pageSize));
        if (currentPage > totalPages) currentPage = totalPages;

        const start = (currentPage - 1) * pageSize;
        const end = Math.min(start + pageSize, total);

        // Hide all rows, show only current page
        allRows.forEach(row => row.style.display = 'none');
        for (let i = start; i < end; i++) {
            filteredRows[i].style.display = '';
        }

        // Update info
        document.getElementById('showStart').textContent = total === 0 ? 0 : start + 1;
        document.getElementById('showEnd').textContent = end;
        document.getElementById('showTotal').textContent = total;
        document.getElementById('tableInfo').textContent = `Showing ${total} users`;

        // Build pagination nav
        const nav = document.getElementById('paginationNav');
        nav.innerHTML = '';

        if (totalPages <= 1) return;

        // Prev button
        const prevBtn = createPageBtn('‹', currentPage > 1, () => { currentPage--; renderPage(); });
        prevBtn.className += ' rounded-l-lg';
        nav.appendChild(prevBtn);

        // Page buttons
        const pages = getPageNumbers(currentPage, totalPages);
        pages.forEach(p => {
            if (p === '...') {
                const dots = document.createElement('span');
                dots.className = 'px-3 py-1.5 text-gray-400 text-sm';
                dots.textContent = '...';
                nav.appendChild(dots);
            } else {
                const btn = createPageBtn(p, true, () => { currentPage = p; renderPage(); });
                if (p === currentPage) {
                    btn.className = 'px-3 py-1.5 text-sm font-semibold bg-blue-600 text-white rounded-lg shadow-sm';
                }
                nav.appendChild(btn);
            }
        });

        // Next button
        const nextBtn = createPageBtn('›', currentPage < totalPages, () => { currentPage++; renderPage(); });
        nextBtn.className += ' rounded-r-lg';
        nav.appendChild(nextBtn);
    }

    function createPageBtn(label, enabled, onClick) {
        const btn = document.createElement('button');
        btn.textContent = label;
        btn.className = 'px-3 py-1.5 text-sm font-medium text-gray-700 hover:bg-gray-100 rounded-lg border border-gray-200 transition-all';
        if (!enabled) {
            btn.disabled = true;
            btn.className += ' opacity-40 cursor-not-allowed';
        } else {
            btn.addEventListener('click', onClick);
        }
        return btn;
    }

    function getPageNumbers(current, total) {
        if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
        const pages = [];
        if (current <= 4) {
            for (let i = 1; i <= 5; i++) pages.push(i);
            pages.push('...', total);
        } else if (current >= total - 3) {
            pages.push(1, '...');
            for (let i = total - 4; i <= total; i++) pages.push(i);
        } else {
            pages.push(1, '...', current - 1, current, current + 1, '...', total);
        }
        return pages;
    }

    // ===== Deactivate User Confirm =====
    let pendingDeactivateUserId = null;

    function deactivateUser(btn, userId) {
        pendingDeactivateUserId = userId;
        const name = btn && btn.dataset && btn.dataset.name ? btn.dataset.name : 'this user';
        document.querySelectorAll('.confirm-user-name').forEach(el => { el.textContent = name; });
        document.getElementById('popup-modal').classList.remove('hidden');
    }

    function hideConfirmModal() {
        document.getElementById('popup-modal').classList.add('hidden');
    }

    function confirmDeactivateUser() {
        if (!pendingDeactivateUserId) return;
        const confirmBtn = document.getElementById('confirmDeactivateBtn');
        if (confirmBtn) { confirmBtn.disabled = true; confirmBtn.textContent = 'Processing...'; }
        document.getElementById('deactivateUserId').value = pendingDeactivateUserId;
        document.getElementById('deactivateUserForm').submit();
    }

    // ===== Modal =====
    function closeUserModal() {
        document.getElementById('userModal').classList.add('hidden');
    }

    function openUserModal(userId, firstName, lastName, email, role, status, company, created, profileImageUrl) {
        const initials = (firstName?.charAt(0) || '') + (lastName?.charAt(0) || '');
        document.getElementById('modalUserInitials').textContent = initials.toUpperCase();
        document.getElementById('modalUserName').textContent = `${firstName} ${lastName}`;
        document.getElementById('modalUserEmail').textContent = email;
        document.getElementById('modalUserEmailDetail').textContent = email;
        document.getElementById('modalUserRoleDetail').textContent = role;
        document.getElementById('modalUserRoleBadge').textContent = role;
        document.getElementById('modalUserCompany').textContent = company || 'No Company';
        document.getElementById('modalUserCreated').textContent = created;
        document.getElementById('modalUserId').textContent = userId;

        // Profile image
        const imgEl = document.getElementById('modalUserProfileImg');
        const initialsWrapper = document.getElementById('modalUserInitialsWrapper');
        if (profileImageUrl && profileImageUrl.trim() !== '') {
            imgEl.src = profileImageUrl;
            imgEl.classList.remove('hidden');
            initialsWrapper.classList.add('hidden');
        } else {
            imgEl.src = '';
            imgEl.classList.add('hidden');
            initialsWrapper.classList.remove('hidden');
        }

        // Status badge
        const statusBadge = document.getElementById('modalUserStatusBadge');
        if (status === 'Active') {
            statusBadge.className = 'rounded-full bg-green-100 px-2 sm:px-3 py-1 text-xs sm:text-sm font-medium text-green-800';
        } else {
            statusBadge.className = 'rounded-full bg-red-100 px-2 sm:px-3 py-1 text-xs sm:text-sm font-medium text-red-800';
        }
        statusBadge.textContent = status;

        document.getElementById('userModal').classList.remove('hidden');
    }

    // ===== Tab Switching =====
    let permissionsLoaded = false;
    let permissionsData = [];

    function switchTab(tab) {
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.className = 'tab-btn py-4 px-1 border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 font-medium text-sm whitespace-nowrap transition-all';
        });
        const activeBtn = document.getElementById('tab-' + tab);
        if (activeBtn) activeBtn.className = 'tab-btn py-4 px-1 border-b-2 border-blue-500 text-blue-600 font-semibold text-sm whitespace-nowrap transition-all';

        document.getElementById('panel-users').classList.toggle('hidden', tab !== 'users');
        document.getElementById('panel-permissions').classList.toggle('hidden', tab !== 'permissions');

        if (tab === 'permissions' && !permissionsLoaded) loadPermissions();
    }

    async function loadPermissions() {
        try {
            const res = await fetch(window.ApiBaseUrl + '/api/superadmin/permissions', {
                credentials: 'include',
                headers: { 'Authorization': 'Bearer ' + getCookie('PayRex.AuthToken') }
            });
            if (!res.ok) throw new Error('Failed');
            permissionsData = await res.json();
            permissionsLoaded = true;
            renderPermissions();
        } catch (e) {
            document.getElementById('permissionsBody').innerHTML = '<tr><td colspan="5" class="px-6 py-12 text-center text-red-500">Failed to load permissions.</td></tr>';
        }
    }

    // Sidebar modules to display in permissions matrix
    const sidebarModules = [
        { name: 'Dashboard', section: 'General' },
        { name: 'Employee Management', section: 'Organization' },
        { name: 'Attendance Monitoring', section: 'Payroll & Attendance' },
        { name: 'Leave Management', section: '' },
        { name: 'Salary Computation', section: '' },
        { name: 'Tax & Contributions', section: 'Compensation' },
        { name: 'Finance', section: '' },
        { name: 'Compensation', section: '' },
        { name: 'Payslip', section: '' },
        { name: 'Billing', section: 'Administration' },
        { name: 'Audit Logs', section: '' },
        { name: 'Company Settings', section: '' },
        { name: 'Archives', section: '' },
        { name: 'My Attendance', section: 'Employee Pages' },
        { name: 'Leave Request', section: '' },
        { name: 'My Payslips', section: '' },
        { name: 'My Contributions', section: '' },
        { name: 'My QR Code', section: '' },
    ];

    function renderPermissions() {
        const roles = ['Admin', 'HR', 'Accountant', 'Employee'];
        const tbody = document.getElementById('permissionsBody');
        tbody.innerHTML = '';

        let lastSection = '';
        sidebarModules.forEach((mod, idx) => {
            // Section header row
            if (mod.section && mod.section !== lastSection) {
                lastSection = mod.section;
                const sectionRow = document.createElement('tr');
                sectionRow.className = 'bg-blue-50/50';
                sectionRow.innerHTML = `<td colspan="5" class="px-6 py-2 text-xs font-bold text-blue-600 uppercase tracking-wider">${mod.section}</td>`;
                tbody.appendChild(sectionRow);
            }

            const row = document.createElement('tr');
            row.className = idx % 2 === 0 ? 'bg-white hover:bg-gray-50/50' : 'bg-gray-50/30 hover:bg-gray-50/80';

            let cells = `<td class="px-6 py-3.5 text-sm font-medium text-gray-900 sticky left-0 ${idx%2===0?'bg-white':'bg-gray-50/30'} z-10">${mod.name}</td>`;

            roles.forEach(role => {
                const perm = permissionsData.find(p => p.roleName === role && p.moduleName === mod.name);
                const isChecked = perm ? (perm.canAdd || perm.canUpdate || perm.canInactivate) : false;
                const permId = perm ? perm.permissionId : 0;
                cells += `<td class="px-4 py-3 text-center border-l border-gray-100">
                    <input type="checkbox" data-role="${role}" data-module="${mod.name}" data-id="${permId}" ${isChecked ? 'checked' : ''}
                        class="perm-cb w-4 h-4 text-blue-600 rounded border-gray-300 focus:ring-blue-500" disabled>
                </td>`;
            });

            row.innerHTML = cells;
            tbody.appendChild(row);
        });
    }

    let isPermEditMode = false;
    let permOriginalState = {};

    function toggleEditMode() {
        if (!isPermEditMode) {
            // Snapshot current checkbox states for cancel
            permOriginalState = {};
            document.querySelectorAll('.perm-cb').forEach(cb => {
                permOriginalState[cb.dataset.role + '|' + cb.dataset.module] = cb.checked;
            });
            // Enter edit mode
            isPermEditMode = true;
            document.querySelectorAll('.perm-cb').forEach(cb => { cb.disabled = false; cb.classList.add('cursor-pointer'); });
            document.getElementById('permBtnIcon').innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />';
            document.getElementById('permBtnLabel').textContent = 'Save Changes';
            document.getElementById('cancelPermBtn').classList.remove('hidden');
        } else {
            savePermissions();
        }
    }

    function cancelEditMode() {
        // Revert checkboxes to original state
        document.querySelectorAll('.perm-cb').forEach(cb => {
            const key = cb.dataset.role + '|' + cb.dataset.module;
            if (key in permOriginalState) cb.checked = permOriginalState[key];
            cb.disabled = true;
            cb.classList.remove('cursor-pointer');
        });
        isPermEditMode = false;
        permOriginalState = {};
        document.getElementById('permBtnIcon').innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />';
        document.getElementById('permBtnLabel').textContent = 'Edit Permission';
        document.getElementById('cancelPermBtn').classList.add('hidden');
    }

    async function savePermissions() {
        const btn = document.getElementById('savePermBtn');
        btn.disabled = true;
        btn.innerHTML = '<svg class="w-4 h-4 mr-1.5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg> Saving...';

        const updates = [];
        document.querySelectorAll('.perm-cb').forEach(cb => {
            const permId = parseInt(cb.dataset.id);
            const isChecked = cb.checked;
            const roleName = cb.dataset.role;
            const moduleName = cb.dataset.module;

            if (permId > 0) {
                // Update existing
                const existing = permissionsData.find(p => p.permissionId === permId);
                if (existing) {
                    updates.push({
                        permissionId: permId,
                        roleName: existing.roleName,
                        moduleName: existing.moduleName,
                        canAdd: isChecked,
                        canUpdate: isChecked,
                        canInactivate: isChecked
                    });
                }
            } else {
                // New permission record
                updates.push({
                    permissionId: 0,
                    roleName: roleName,
                    moduleName: moduleName,
                    canAdd: isChecked,
                    canUpdate: isChecked,
                    canInactivate: isChecked
                });
            }
        });

        try {
            const res = await fetch(window.ApiBaseUrl + '/api/superadmin/permissions', {
                method: 'POST', credentials: 'include',
                headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + getCookie('PayRex.AuthToken') },
                body: JSON.stringify(updates)
            });
            if (!res.ok) throw new Error('Save failed');
            if (typeof showToast === 'function') showToast('Permissions saved successfully!', 'success');
            permissionsLoaded = false;
            loadPermissions();
        } catch (e) {
            if (typeof showToast === 'function') showToast('Failed to save permissions.', 'error');
        } finally {
            btn.disabled = false;
            // Exit edit mode
            isPermEditMode = false;
            permOriginalState = {};
            document.querySelectorAll('.perm-cb').forEach(cb => { cb.disabled = true; cb.classList.remove('cursor-pointer'); });
            btn.innerHTML = '<svg class="w-4 h-4 mr-1.5" id="permBtnIcon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" /></svg><span id="permBtnLabel">Edit Permission</span>';
            document.getElementById('cancelPermBtn').classList.add('hidden');
        }
    }

    function getCookie(name) {
        const val = `; ${document.cookie}`;
        const parts = val.split(`; ${name}=`);
        if (parts.length === 2) return parts.pop().split(';').shift();
        return '';
    }

</script>
}