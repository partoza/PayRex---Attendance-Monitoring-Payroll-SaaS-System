@page
@model PayRex.Web.Pages.Admin.SettingsModel
@{
    ViewData["Title"] = "System Settings";
}

<div class="max-w-8xl mx-auto px-4 py-6 sm:px-6 lg:px-8 space-y-6">
    <!-- Welcome Header -->
    <div class="bg-gradient-to-r from-blue-50 via-white to-blue-50 rounded-2xl border border-blue-100 shadow-sm overflow-hidden relative">
        <div class="absolute top-0 right-0 -mt-16 -mr-16 w-64 h-64 bg-yellow-100 rounded-full blur-3xl opacity-20"></div>
        <div class="absolute bottom-0 left-0 -mb-16 -ml-16 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
        <div class="px-6 py-8 sm:px-10 relative z-10">
            <div>
                <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight">System Settings</h1>
                <p class="mt-2 text-gray-600">Manage platform configuration, tax rates, subscription plans, and notifications</p>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <script>document.addEventListener('DOMContentLoaded',()=>showToast(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.StatusMessage)), '@(Model.StatusMessage!.StartsWith("Failed") ? "error" : "success")'));</script>
    }

    <!-- Section 1: Tax & Government Contributions (Read-Only) -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 bg-gradient-to-r from-blue-50 to-white">
            <div class="flex items-center justify-between">
                <h2 class="text-base font-semibold text-gray-900 flex items-center">
                    <svg class="w-5 h-5 mr-2 text-blue-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1.323l3.954 1.582 1.599-.8a1 1 0 01.894 1.79l-1.233.616 1.738 5.42a1 1 0 01-.285 1.05A3.989 3.989 0 0115 15a3.989 3.989 0 01-2.667-1.019 1 1 0 01-.285-1.05l1.715-5.349L11 6.477V16h2a1 1 0 110 2H7a1 1 0 110-2h2V6.477L6.237 7.582l1.715 5.349a1 1 0 01-.285 1.05A3.989 3.989 0 015 15a3.989 3.989 0 01-2.667-1.019 1 1 0 01-.285-1.05l1.738-5.42-1.233-.617a1 1 0 01.894-1.788l1.599.799L9 4.323V3a1 1 0 011-1zm-5 8.274l-.818 2.552c.25.112.526.174.818.174.292 0 .569-.062.818-.174L5 10.274zm10 0l-.818 2.552c.25.112.526.174.818.174.292 0 .569-.062.818-.174L15 10.274z" clip-rule="evenodd" /></svg>
                    Tax & Government Contributions
                </h2>
                <span class="inline-flex items-center px-3 py-1 rounded-lg text-xs font-semibold bg-blue-100 text-blue-700">
                    <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" /></svg>
                    Read Only
                </span>
            </div>
        </div>
        <div class="p-6">
            <div class="bg-blue-50 border border-blue-200 rounded-xl p-4 mb-6">
                <div class="flex items-start">
                    <svg class="w-5 h-5 text-blue-600 mt-0.5 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" /></svg>
                    <div>
                        <p class="text-sm font-medium text-blue-800">Government-Mandated Rates</p>
                        <p class="text-xs text-blue-600 mt-1">These rates are set by Philippine law and cannot be modified in the system. Updates will be applied automatically when legislation changes.</p>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <!-- SSS -->
                <div class="bg-gray-50 rounded-xl p-5 border border-gray-100">
                    <div class="flex items-center mb-3">
                        <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center mr-3">
                            <span class="text-sm font-bold text-blue-700">SSS</span>
                        </div>
                        <div>
                            <h3 class="text-sm font-bold text-gray-900">Social Security System</h3>
                            <p class="text-xs text-gray-500">Republic Act No. 11199</p>
                        </div>
                    </div>
                    <div class="grid grid-cols-2 gap-3 mt-3">
                        <div class="bg-white rounded-lg p-3 border border-gray-200">
                            <p class="text-xs text-gray-500">Employee Share</p>
                            <p class="text-lg font-bold text-gray-900">4.5%</p>
                        </div>
                        <div class="bg-white rounded-lg p-3 border border-gray-200">
                            <p class="text-xs text-gray-500">Employer Share</p>
                            <p class="text-lg font-bold text-gray-900">9.5%</p>
                        </div>
                    </div>
                </div>

                <!-- Pag-IBIG -->
                <div class="bg-gray-50 rounded-xl p-5 border border-gray-100">
                    <div class="flex items-center mb-3">
                        <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center mr-3">
                            <span class="text-xs font-bold text-green-700">HDMF</span>
                        </div>
                        <div>
                            <h3 class="text-sm font-bold text-gray-900">Pag-IBIG Fund (HDMF)</h3>
                            <p class="text-xs text-gray-500">Republic Act No. 9679</p>
                        </div>
                    </div>
                    <div class="grid grid-cols-2 gap-3 mt-3">
                        <div class="bg-white rounded-lg p-3 border border-gray-200">
                            <p class="text-xs text-gray-500">Employee Share</p>
                            <p class="text-lg font-bold text-gray-900">1–2%</p>
                        </div>
                        <div class="bg-white rounded-lg p-3 border border-gray-200">
                            <p class="text-xs text-gray-500">Employer Share</p>
                            <p class="text-lg font-bold text-gray-900">2%</p>
                        </div>
                    </div>
                </div>

                <!-- PhilHealth -->
                <div class="bg-gray-50 rounded-xl p-5 border border-gray-100">
                    <div class="flex items-center mb-3">
                        <div class="w-10 h-10 bg-yellow-100 rounded-lg flex items-center justify-center mr-3">
                            <span class="text-xs font-bold text-yellow-700">PH</span>
                        </div>
                        <div>
                            <h3 class="text-sm font-bold text-gray-900">PhilHealth</h3>
                            <p class="text-xs text-gray-500">Republic Act No. 11223</p>
                        </div>
                    </div>
                    <div class="grid grid-cols-2 gap-3 mt-3">
                        <div class="bg-white rounded-lg p-3 border border-gray-200">
                            <p class="text-xs text-gray-500">Employee Share</p>
                            <p class="text-lg font-bold text-gray-900">2.25%</p>
                        </div>
                        <div class="bg-white rounded-lg p-3 border border-gray-200">
                            <p class="text-xs text-gray-500">Employer Share</p>
                            <p class="text-lg font-bold text-gray-900">2.25%</p>
                        </div>
                    </div>
                </div>

                <!-- Withholding Tax -->
                <div class="bg-gray-50 rounded-xl p-5 border border-gray-100">
                    <div class="flex items-center mb-3">
                        <div class="w-10 h-10 bg-red-100 rounded-lg flex items-center justify-center mr-3">
                            <span class="text-xs font-bold text-red-700">TAX</span>
                        </div>
                        <div>
                            <h3 class="text-sm font-bold text-gray-900">Withholding Tax</h3>
                            <p class="text-xs text-gray-500">TRAIN Law (RA 10963)</p>
                        </div>
                    </div>
                    <div class="bg-white rounded-lg p-3 border border-gray-200 mt-3">
                        <p class="text-xs text-gray-500">Tax Schedule</p>
                        <p class="text-sm font-medium text-gray-700 mt-1">Progressive rates from 0% to 35% based on taxable income brackets. First ₱250,000 is tax-exempt.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Section 2: Subscription Plans (Editable) -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 bg-gradient-to-r from-green-50 to-white">
            <div class="flex items-center justify-between">
                <h2 class="text-base font-semibold text-gray-900 flex items-center">
                    <svg class="w-5 h-5 mr-2 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 2a2 2 0 00-2 2v14l3.5-2 3.5 2 3.5-2 3.5 2V4a2 2 0 00-2-2H5z" clip-rule="evenodd" /></svg>
                    Subscription Plans
                </h2>
                <span class="inline-flex items-center px-3 py-1 rounded-lg text-xs font-semibold bg-green-100 text-green-700">
                    <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20"><path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" /></svg>
                    Editable
                </span>
            </div>
        </div>
        <div class="p-6">
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-gray-50/80">
                        <tr>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Plan Name</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Price</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Billing</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Max Employees</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">User Limit</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Status</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        @if (Model.Plans.Count == 0)
                        {
                            <tr>
                                <td colspan="7" class="px-4 py-8 text-center text-gray-400">No subscription plans found</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var plan in Model.Plans)
                            {
                                <tr class="hover:bg-gray-50/50 transition-colors">
                                    <td class="px-4 py-3">
                                        <span class="text-sm font-semibold text-gray-900">@plan.Name</span>
                                    </td>
                                    <td class="px-4 py-3 text-sm font-semibold text-gray-900">₱@plan.Price.ToString("N0")</td>
                                    <td class="px-4 py-3 text-sm text-gray-600 capitalize">@plan.BillingCycle</td>
                                    <td class="px-4 py-3 text-sm text-gray-600">@plan.MaxEmployees</td>
                                    <td class="px-4 py-3 text-sm text-gray-600">@(plan.PlanUserLimit?.ToString() ?? "Unlimited")</td>
                                    <td class="px-4 py-3">
                                        <span class="text-xs font-semibold @(plan.Status == "Active" ? "text-green-700" : "text-gray-500")">@plan.Status</span>
                                    </td>
                                    <td class="px-4 py-3">
                                        <button type="button" onclick="openEditPlanModal(@plan.PlanId, '@Html.Raw(plan.Name.Replace("'", "\\'"))', @plan.Price, @plan.MaxEmployees, '@Html.Raw(plan.Description?.Replace("'", "\\'") ?? "")')" class="inline-flex items-center px-3 py-1 text-xs font-medium text-blue-700 bg-blue-50 rounded-lg hover:bg-blue-100">
                                            Edit
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>


    <!-- Section 3: System Notifications -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 bg-gradient-to-r from-yellow-50 to-white">
            <div class="flex items-center justify-between">
                <h2 class="text-base font-semibold text-gray-900 flex items-center">
                    <svg class="w-5 h-5 mr-2 text-yellow-500" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zM10 18a3 3 0 01-3-3h6a3 3 0 01-3 3z" /></svg>
                    System Notifications
                </h2>
                <button type="button" onclick="openAddNotifModal()" class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-yellow-700 bg-yellow-100 rounded-lg hover:bg-yellow-200">
                    <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 5a1 1 0 011 1v3h3a1 1 0 110 2h-3v3a1 1 0 11-2 0v-3H6a1 1 0 110-2h3V6a1 1 0 011-1z" clip-rule="evenodd" /></svg>
                    Add Notification
                </button>
            </div>
        </div>
        <div class="p-6">
            <div class="space-y-4">
                @if (Model.SystemNotifications.Count == 0)
                {
                    <div class="text-center py-8">
                        <p class="text-gray-400">No system notifications. Click "Add Notification" to create one.</p>
                    </div>
                }
                else
                {
                    @foreach (var notif in Model.SystemNotifications)
                    {
                        var borderColor = notif.Type == "warning" ? "border-l-yellow-400" : notif.Type == "success" ? "border-l-green-400" : "border-l-blue-400";
                        <div class="border border-gray-200 rounded-xl overflow-hidden @(notif.IsActive ? "" : "opacity-50")">
                            <div class="flex items-center justify-between px-5 py-4 border-l-4 @borderColor">
                                <div class="flex-1 min-w-0">
                                    <div class="flex items-center gap-2">
                                        <h3 class="text-sm font-semibold text-gray-900">@notif.Title</h3>
                                        @if (notif.IsActive)
                                        {
                                            <span class="px-2 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-700">Active</span>
                                        }
                                        else
                                        {
                                            <span class="px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-500">Inactive</span>
                                        }
                                        @if (!string.IsNullOrEmpty(notif.TargetRoles))
                                        {
                                            <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-600">@notif.TargetRoles</span>
                                        }
                                        else
                                        {
                                            <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-gray-50 text-gray-500">All Roles</span>
                                        }
                                    </div>
                                    <p class="text-sm text-gray-600 mt-1 truncate">@notif.Message</p>
                                    <p class="text-xs text-gray-400 mt-1">@notif.CreatedAt.ToString("MMM dd, yyyy hh:mm tt")</p>
                                </div>
                                <div class="flex items-center gap-2 ml-4">
                                    <form method="post" asp-page-handler="ToggleNotification" class="inline">
                                        <input type="hidden" name="notificationId" value="@notif.NotificationId" />
                                        <input type="hidden" name="isActive" value="@(!notif.IsActive)" />
                                        <button type="submit" class="p-1.5 rounded-lg @(notif.IsActive ? "text-green-600 hover:bg-green-50" : "text-gray-400 hover:bg-gray-50")">
                                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                                @if (notif.IsActive)
                                                {
                                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                                                }
                                                else
                                                {
                                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                                                }
                                            </svg>
                                        </button>
                                    </form>
                                    <form method="post" asp-page-handler="DeleteNotification" class="inline" onsubmit="return confirm('Delete this notification?')">
                                        <input type="hidden" name="notificationId" value="@notif.NotificationId" />
                                        <button type="submit" class="p-1.5 rounded-lg text-red-400 hover:bg-red-50 hover:text-red-600">
                                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" /></svg>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

</div>

<!-- Edit Plan Modal -->
<div id="editPlanModal" class="fixed inset-0 z-50 hidden overflow-y-auto">
    <div class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm" onclick="closeEditPlanModal()"></div>
    <div class="flex min-h-full items-center justify-center p-4">
        <div class="relative bg-white rounded-lg shadow-xl w-full max-w-md">
            <form method="post" asp-page-handler="UpdatePlan">
                <input type="hidden" name="planId" id="editPlanId" />
                <div class="flex items-center justify-between border-b px-6 py-4">
                    <h3 class="text-lg font-semibold text-gray-900">Edit Plan</h3>
                    <button type="button" onclick="closeEditPlanModal()" class="p-1.5 text-gray-400 hover:bg-gray-100 rounded-lg"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" /></svg></button>
                </div>
                <div class="px-6 py-5 space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Plan Name</label>
                        <input type="text" name="name" id="editPlanName" required class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Price (₱)</label>
                        <input type="number" name="price" id="editPlanPrice" required min="0" step="0.01" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Max Employees</label>
                        <input type="number" name="maxEmployees" id="editPlanMaxEmp" required min="1" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
                        <textarea name="description" id="editPlanDesc" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500" rows="2"></textarea>
                    </div>
                </div>
                <div class="border-t bg-gray-50 px-6 py-4 flex justify-end gap-3">
                    <button type="button" onclick="closeEditPlanModal()" class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-lg hover:bg-gray-200">Cancel</button>
                    <button type="submit" class="px-5 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Add Notification Modal -->
<div id="addNotifModal" class="fixed inset-0 z-50 hidden overflow-y-auto">
    <div class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm" onclick="closeAddNotifModal()"></div>
    <div class="flex min-h-full items-center justify-center p-4">
        <div class="relative bg-white rounded-lg shadow-xl w-full max-w-md">
            <form method="post" asp-page-handler="AddNotification">
                <div class="flex items-center justify-between border-b px-6 py-4">
                    <h3 class="text-lg font-semibold text-gray-900">Add System Notification</h3>
                    <button type="button" onclick="closeAddNotifModal()" class="p-1.5 text-gray-400 hover:bg-gray-100 rounded-lg"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" /></svg></button>
                </div>
                <div class="px-6 py-5 space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Title</label>
                        <input type="text" name="title" required class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500" placeholder="e.g., System Maintenance" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Message</label>
                        <textarea name="message" required rows="3" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500" placeholder="Notification message..."></textarea>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Type</label>
                        <select name="type" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 bg-white">
                            <option value="info">Info</option>
                            <option value="warning">Warning</option>
                            <option value="success">Success</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Target Roles</label>
                        <select name="targetRoles" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 bg-white">
                            <option value="">All Roles</option>
                            <option value="Admin">Admin Only</option>
                            <option value="HR">HR Only</option>
                            <option value="Accountant">Accountant Only</option>
                            <option value="Employee">Employee Only</option>
                            <option value="Admin,HR">Admin & HR</option>
                            <option value="Admin,HR,Accountant">Admin, HR & Accountant</option>
                        </select>
                    </div>
                </div>
                <div class="border-t bg-gray-50 px-6 py-4 flex justify-end gap-3">
                    <button type="button" onclick="closeAddNotifModal()" class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-lg hover:bg-gray-200">Cancel</button>
                    <button type="submit" class="px-5 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700">Create Notification</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function openEditPlanModal(id, name, price, maxEmp, desc) {
        document.getElementById('editPlanId').value = id;
        document.getElementById('editPlanName').value = name;
        document.getElementById('editPlanPrice').value = price;
        document.getElementById('editPlanMaxEmp').value = maxEmp;
        document.getElementById('editPlanDesc').value = desc;
        document.getElementById('editPlanModal').classList.remove('hidden');
    }
    function closeEditPlanModal() { document.getElementById('editPlanModal').classList.add('hidden'); }
    function openAddNotifModal() { document.getElementById('addNotifModal').classList.remove('hidden'); }
    function closeAddNotifModal() { document.getElementById('addNotifModal').classList.add('hidden'); }
</script>
}
