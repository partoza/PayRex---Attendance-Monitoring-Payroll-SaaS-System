@page
@model PayRex.Web.Pages.Admin.SettingsModel
@{
    ViewData["Title"] = "System Settings";
}

<div class="max-w-8xl mx-auto px-4 py-6 sm:px-6 lg:px-8 space-y-6">
    <!-- Welcome Header -->
    <div class="bg-gradient-to-r from-blue-50 via-white to-blue-50 rounded-2xl border border-blue-100 shadow-sm overflow-hidden relative">
        <div class="absolute top-0 right-0 -mt-16 -mr-16 w-64 h-64 bg-yellow-100 rounded-full blur-3xl opacity-20"></div>
        <div class="absolute bottom-0 left-0 -mb-16 -ml-16 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
        <div class="px-6 py-8 sm:px-10 relative z-10">
            <div>
                <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight">System Settings</h1>
                <p class="mt-2 text-gray-600">Manage platform configuration, tax rates, subscription plans, and notifications</p>
            </div>
        </div>
    </div>

    <!-- Status Message -->
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="flex items-center p-4 rounded-xl bg-green-50 border border-green-200 text-green-800 shadow-sm" id="statusAlert">
            <svg class="w-5 h-5 mr-3 text-green-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm font-medium flex-1">@Model.StatusMessage</span>
            <button onclick="document.getElementById('statusAlert').remove()" class="ml-3 text-green-600 hover:text-green-800">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
            </button>
        </div>
    }

    <!-- Section 1: Tax & Government Contributions (Read-Only) -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 bg-gradient-to-r from-blue-50 to-white">
            <div class="flex items-center justify-between">
                <h2 class="text-base font-semibold text-gray-900 flex items-center">
                    <svg class="w-5 h-5 mr-2 text-blue-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1.323l3.954 1.582 1.599-.8a1 1 0 01.894 1.79l-1.233.616 1.738 5.42a1 1 0 01-.285 1.05A3.989 3.989 0 0115 15a3.989 3.989 0 01-2.667-1.019 1 1 0 01-.285-1.05l1.715-5.349L11 6.477V16h2a1 1 0 110 2H7a1 1 0 110-2h2V6.477L6.237 7.582l1.715 5.349a1 1 0 01-.285 1.05A3.989 3.989 0 015 15a3.989 3.989 0 01-2.667-1.019 1 1 0 01-.285-1.05l1.738-5.42-1.233-.617a1 1 0 01.894-1.788l1.599.799L9 4.323V3a1 1 0 011-1zm-5 8.274l-.818 2.552c.25.112.526.174.818.174.292 0 .569-.062.818-.174L5 10.274zm10 0l-.818 2.552c.25.112.526.174.818.174.292 0 .569-.062.818-.174L15 10.274z" clip-rule="evenodd" /></svg>
                    Tax & Government Contributions
                </h2>
                <span class="inline-flex items-center px-3 py-1 rounded-lg text-xs font-semibold bg-blue-100 text-blue-700">
                    <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" /></svg>
                    Read Only
                </span>
            </div>
        </div>
        <div class="p-6">
            <div class="bg-blue-50 border border-blue-200 rounded-xl p-4 mb-6">
                <div class="flex items-start">
                    <svg class="w-5 h-5 text-blue-600 mt-0.5 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" /></svg>
                    <div>
                        <p class="text-sm font-medium text-blue-800">Government-Mandated Rates</p>
                        <p class="text-xs text-blue-600 mt-1">These rates are set by Philippine law and cannot be modified in the system. Updates will be applied automatically when legislation changes.</p>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <!-- SSS -->
                <div class="bg-gray-50 rounded-xl p-5 border border-gray-100">
                    <div class="flex items-center mb-3">
                        <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center mr-3">
                            <span class="text-sm font-bold text-blue-700">SSS</span>
                        </div>
                        <div>
                            <h3 class="text-sm font-bold text-gray-900">Social Security System</h3>
                            <p class="text-xs text-gray-500">Republic Act No. 11199</p>
                        </div>
                    </div>
                    <div class="grid grid-cols-2 gap-3 mt-3">
                        <div class="bg-white rounded-lg p-3 border border-gray-200">
                            <p class="text-xs text-gray-500">Employee Share</p>
                            <p class="text-lg font-bold text-gray-900">4.5%</p>
                        </div>
                        <div class="bg-white rounded-lg p-3 border border-gray-200">
                            <p class="text-xs text-gray-500">Employer Share</p>
                            <p class="text-lg font-bold text-gray-900">9.5%</p>
                        </div>
                    </div>
                </div>

                <!-- Pag-IBIG -->
                <div class="bg-gray-50 rounded-xl p-5 border border-gray-100">
                    <div class="flex items-center mb-3">
                        <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center mr-3">
                            <span class="text-xs font-bold text-green-700">HDMF</span>
                        </div>
                        <div>
                            <h3 class="text-sm font-bold text-gray-900">Pag-IBIG Fund (HDMF)</h3>
                            <p class="text-xs text-gray-500">Republic Act No. 9679</p>
                        </div>
                    </div>
                    <div class="grid grid-cols-2 gap-3 mt-3">
                        <div class="bg-white rounded-lg p-3 border border-gray-200">
                            <p class="text-xs text-gray-500">Employee Share</p>
                            <p class="text-lg font-bold text-gray-900">1–2%</p>
                        </div>
                        <div class="bg-white rounded-lg p-3 border border-gray-200">
                            <p class="text-xs text-gray-500">Employer Share</p>
                            <p class="text-lg font-bold text-gray-900">2%</p>
                        </div>
                    </div>
                </div>

                <!-- PhilHealth -->
                <div class="bg-gray-50 rounded-xl p-5 border border-gray-100">
                    <div class="flex items-center mb-3">
                        <div class="w-10 h-10 bg-yellow-100 rounded-lg flex items-center justify-center mr-3">
                            <span class="text-xs font-bold text-yellow-700">PH</span>
                        </div>
                        <div>
                            <h3 class="text-sm font-bold text-gray-900">PhilHealth</h3>
                            <p class="text-xs text-gray-500">Republic Act No. 11223</p>
                        </div>
                    </div>
                    <div class="grid grid-cols-2 gap-3 mt-3">
                        <div class="bg-white rounded-lg p-3 border border-gray-200">
                            <p class="text-xs text-gray-500">Employee Share</p>
                            <p class="text-lg font-bold text-gray-900">2.25%</p>
                        </div>
                        <div class="bg-white rounded-lg p-3 border border-gray-200">
                            <p class="text-xs text-gray-500">Employer Share</p>
                            <p class="text-lg font-bold text-gray-900">2.25%</p>
                        </div>
                    </div>
                </div>

                <!-- Withholding Tax -->
                <div class="bg-gray-50 rounded-xl p-5 border border-gray-100">
                    <div class="flex items-center mb-3">
                        <div class="w-10 h-10 bg-red-100 rounded-lg flex items-center justify-center mr-3">
                            <span class="text-xs font-bold text-red-700">TAX</span>
                        </div>
                        <div>
                            <h3 class="text-sm font-bold text-gray-900">Withholding Tax</h3>
                            <p class="text-xs text-gray-500">TRAIN Law (RA 10963)</p>
                        </div>
                    </div>
                    <div class="bg-white rounded-lg p-3 border border-gray-200 mt-3">
                        <p class="text-xs text-gray-500">Tax Schedule</p>
                        <p class="text-sm font-medium text-gray-700 mt-1">Progressive rates from 0% to 35% based on taxable income brackets. First ₱250,000 is tax-exempt.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Section 2: Subscription Plans (Editable) -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 bg-gradient-to-r from-green-50 to-white">
            <div class="flex items-center justify-between">
                <h2 class="text-base font-semibold text-gray-900 flex items-center">
                    <svg class="w-5 h-5 mr-2 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 2a2 2 0 00-2 2v14l3.5-2 3.5 2 3.5-2 3.5 2V4a2 2 0 00-2-2H5z" clip-rule="evenodd" /></svg>
                    Subscription Plans
                </h2>
                <span class="inline-flex items-center px-3 py-1 rounded-lg text-xs font-semibold bg-green-100 text-green-700">
                    <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20"><path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" /></svg>
                    Editable
                </span>
            </div>
        </div>
        <div class="p-6">
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-gray-50/80">
                        <tr>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Plan Name</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Price</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Billing</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Max Employees</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">User Limit</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Status</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        @{
                            // Static demo plans (used if backend returns empty)
                            var plansToShow = new List<(string Name, decimal Price, string Cycle, int MaxEmp, int? UserLimit, string Status)>();
                            if (true)  // always show — real plans will replace these when API is ready
                            {
                                plansToShow.Add(("Starter", 2499, "month", 25, 3, "Active"));
                                plansToShow.Add(("Professional", 4999, "month", 100, 10, "Active"));
                                plansToShow.Add(("Enterprise", 9999, "month", 500, null, "Active"));
                            }
                        }
                        @foreach (var plan in plansToShow)
                        {
                            <tr class="hover:bg-gray-50/50 transition-colors">
                                <td class="px-4 py-3">
                                    <span class="text-sm font-semibold text-gray-900">@plan.Name</span>
                                </td>
                                <td class="px-4 py-3 text-sm font-semibold text-gray-900">₱@plan.Price.ToString("N0")</td>
                                <td class="px-4 py-3 text-sm text-gray-600 capitalize">@plan.Cycle</td>
                                <td class="px-4 py-3 text-sm text-gray-600">@plan.MaxEmp</td>
                                <td class="px-4 py-3 text-sm text-gray-600">@(plan.UserLimit?.ToString() ?? "Unlimited")</td>
                                <td class="px-4 py-3">
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-semibold bg-green-100 text-green-700">
                                        <span class="w-1.5 h-1.5 rounded-full bg-green-500 mr-1.5"></span>@plan.Status
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Section 3: System Notifications -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 bg-gradient-to-r from-yellow-50 to-white">
            <div class="flex items-center justify-between">
                <h2 class="text-base font-semibold text-gray-900 flex items-center">
                    <svg class="w-5 h-5 mr-2 text-yellow-500" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zM10 18a3 3 0 01-3-3h6a3 3 0 01-3 3z" /></svg>
                    System Notifications
                </h2>
                <span class="inline-flex items-center px-3 py-1 rounded-lg text-xs font-semibold bg-yellow-100 text-yellow-700">
                    <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20"><path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" /></svg>
                    Configurable
                </span>
            </div>
        </div>
        <div class="p-6">
            <div class="space-y-4">
                @{
                    var notifications = new[] {
                        new { Title = "System Maintenance", Message = "PayRex will undergo scheduled maintenance on March 1, 2026 from 12:00 AM - 4:00 AM PHT.", Type = "warning", Active = true },
                        new { Title = "New Feature: Payroll Export", Message = "You can now export payroll data to CSV and PDF formats. Check it out in the Reports section.", Type = "info", Active = true },
                        new { Title = "Holiday Notice", Message = "The office will be closed on February 25, 2026 for EDSA Anniversary.", Type = "info", Active = false },
                    };
                }
                @foreach (var notif in notifications)
                {
                    var borderColor = notif.Type == "warning" ? "border-l-yellow-400" : "border-l-blue-400";
                    <div class="border border-gray-200 rounded-xl overflow-hidden @(notif.Active ? "" : "opacity-50")">
                        <div class="flex items-center justify-between px-5 py-4 border-l-4 @borderColor">
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center gap-2">
                                    <h3 class="text-sm font-semibold text-gray-900">@notif.Title</h3>
                                    @if (notif.Active)
                                    {
                                        <span class="px-2 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-700">Active</span>
                                    }
                                    else
                                    {
                                        <span class="px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-500">Inactive</span>
                                    }
                                </div>
                                <p class="text-sm text-gray-600 mt-1 truncate">@notif.Message</p>
                            </div>
                            <div class="flex items-center gap-2 ml-4">
                                <label class="relative inline-flex items-center cursor-pointer">
                                    <input type="checkbox" class="sr-only peer" @(notif.Active ? "checked" : "")>
                                    <div class="w-9 h-5 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-blue-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-blue-600"></div>
                                </label>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="mt-6 bg-gray-50 rounded-xl p-5 border border-gray-200 border-dashed">
                <div class="text-center">
                    <svg class="w-8 h-8 text-gray-300 mx-auto mb-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 5a1 1 0 011 1v3h3a1 1 0 110 2h-3v3a1 1 0 11-2 0v-3H6a1 1 0 110-2h3V6a1 1 0 011-1z" clip-rule="evenodd" /></svg>
                    <p class="text-sm text-gray-400">Add new notification messages that will be broadcast to all users</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Section 4: Current API Settings Info -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 bg-gradient-to-r from-gray-50 to-white">
            <h2 class="text-base font-semibold text-gray-900 flex items-center">
                <svg class="w-5 h-5 mr-2 text-gray-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M11.49 3.17c-.38-1.56-2.6-1.56-2.98 0a1.532 1.532 0 01-2.286.948c-1.372-.836-2.942.734-2.106 2.106.54.886.061 2.042-.947 2.287-1.561.379-1.561 2.6 0 2.978a1.532 1.532 0 01.947 2.287c-.836 1.372.734 2.942 2.106 2.106a1.532 1.532 0 012.287.947c.379 1.561 2.6 1.561 2.978 0a1.533 1.533 0 012.287-.947c1.372.836 2.942-.734 2.106-2.106a1.533 1.533 0 01.947-2.287c1.561-.379 1.561-2.6 0-2.978a1.532 1.532 0 01-.947-2.287c.836-1.372-.734-2.942-2.106-2.106a1.532 1.532 0 01-2.287-.947zM10 13a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd" /></svg>
                Platform Settings
            </h2>
        </div>
        <div class="p-6">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
                    <p class="text-xs text-gray-500 mb-1">SSS Rate (from API)</p>
                    <p class="text-lg font-bold text-gray-900">@Model.SssPercentage%</p>
                </div>
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
                    <p class="text-xs text-gray-500 mb-1">Pag-IBIG Rate (from API)</p>
                    <p class="text-lg font-bold text-gray-900">@Model.PagIbigPercentage%</p>
                </div>
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
                    <p class="text-xs text-gray-500 mb-1">PhilHealth Rate (from API)</p>
                    <p class="text-lg font-bold text-gray-900">@Model.PhilHealthPercentage%</p>
                </div>
            </div>
            @if (Model.LoadSuccess)
            {
                <div class="mt-4 bg-gray-50 rounded-xl p-4 border border-gray-100">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <p class="text-xs text-gray-500 mb-1">Effective Date</p>
                            <p class="text-sm font-semibold text-gray-900">@Model.EffectiveDate.ToString("MMMM dd, yyyy")</p>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.Note))
                        {
                            <div>
                                <p class="text-xs text-gray-500 mb-1">Note</p>
                                <p class="text-sm text-gray-700">@Model.Note</p>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>
