@page
@model PayRex.Web.Pages.Admin.CompaniesModel
@{
    ViewData["Title"] = "Manage Companies";
}

<div class="max-w-8xl mx-auto px-4 py-6 sm:px-6 lg:px-8 space-y-6">

<!-- Confirm Deactivate Modal -->
<div id="popup-modal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-hidden="true">
    <div class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm transition-opacity" aria-hidden="true" onclick="hideConfirmModal()"></div>
    <div class="flex min-h-full items-center justify-center p-2 sm:p-4 text-center">
        <div class="relative transform overflow-hidden rounded-lg bg-white text-left shadow-xl transition-all w-full sm:w-[90%] md:w-[60%] lg:w-[50%] max-w-md mx-auto">
            <div class="flex items-center justify-between border-b border-gray-200 bg-white px-4 py-3 sm:px-6 sm:py-4 md:px-6 md:py-4">
                <h3 class="text-base sm:text-lg font-semibold text-gray-900">Confirm Inactivate</h3>
                <button type="button" onclick="hideConfirmModal()" class="rounded-lg p-1.5 text-gray-400 hover:bg-gray-100 hover:text-gray-500">
                    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
                </button>
            </div>
            <div class="px-4 py-4 sm:px-6 sm:py-5 md:px-6 md:py-6">
                <div class="text-center">
                    <p class="mb-4 text-sm text-gray-700">
                        Are you sure you want to inactivate
                        <span class="font-semibold confirm-company-name">Company Name</span>?
                    </p>
                    <div class="flex justify-center gap-3">
                        <button type="button" onclick="hideConfirmModal()" class="inline-flex items-center justify-center px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-lg hover:bg-gray-200 focus:ring-2 focus:ring-gray-300">No, Cancel</button>
                        <button id="confirmDeactivateBtn" type="button" onclick="confirmDeactivateCompany()" class="inline-flex items-center justify-center px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700 focus:ring-2 focus:ring-red-300">Yes, I'm sure</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Hidden deactivate form (submitted by JS confirm) -->
<form id="deactivateCompanyForm" method="post" asp-page-handler="ToggleActive" class="hidden">
    <input type="hidden" name="companyId" id="deactivateCompanyId" />
    <input type="hidden" name="isActive" value="true" />
</form>
    <!-- Welcome Header (Dashboard Style) -->
    <div class="bg-gradient-to-r from-blue-50 via-white to-blue-50 rounded-2xl border border-blue-100 shadow-sm overflow-hidden relative">
        <div class="absolute top-0 right-0 -mt-16 -mr-16 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
        <div class="absolute bottom-0 left-0 -mb-16 -ml-16 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
        <div class="px-6 py-8 sm:px-10 relative z-10">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <div>
                    <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight">Manage Companies</h1>
                    <p class="mt-2 text-gray-600">View and manage all registered companies on the platform</p>
                </div>
                <div class="flex items-center gap-3">
                    <span class="inline-flex items-center px-4 py-2 rounded-xl text-sm font-semibold bg-blue-100 text-blue-700">
                        <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h8a2 2 0 012 2v12a1 1 0 110 2h-3a1 1 0 01-1-1v-2a1 1 0 00-1-1H9a1 1 0 00-1 1v2a1 1 0 01-1 1H4a1 1 0 110-2V4zm3 1h2v2H7V5zm2 4H7v2h2V9zm2-4h2v2h-2V5zm2 4h-2v2h2V9z" clip-rule="evenodd" /></svg>
                        @Model.Companies.Count Total Companies
                    </span>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <script>document.addEventListener('DOMContentLoaded',()=>showToast(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.StatusMessage)), '@(Model.StatusMessage!.StartsWith("Failed") ? "error" : "success")'));</script>
    }

    <!-- Filters Card -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 bg-gradient-to-r from-gray-50 to-white">
            <h2 class="text-base font-semibold text-gray-900 flex items-center">
                <svg class="w-5 h-5 mr-2 text-blue-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3 3a1 1 0 011-1h12a1 1 0 011 1v3a1 1 0 01-.293.707L12 11.414V15a1 1 0 01-.293.707l-2 2A1 1 0 018 17v-5.586L3.293 6.707A1 1 0 013 6V3z" clip-rule="evenodd" /></svg>
                Filters & Search
            </h2>
        </div>
        <div class="p-4 sm:p-6">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <!-- Search -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Search</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <svg class="w-4 h-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" /></svg>
                        </div>
                        <input type="text" placeholder="Company name..." class="w-full pl-10 pr-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all" id="searchInput">
                    </div>
                </div>
                <!-- Plan Filter -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Plan</label>
                    <select id="planFilter" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all bg-white">
                        <option value="">All Plans</option>
                        @foreach (var plan in Model.Companies.Select(c => c.PlanName).Where(p => !string.IsNullOrEmpty(p)).Distinct().OrderBy(p => p))
                        {
                            <option value="@plan">@plan</option>
                        }
                    </select>
                </div>
                <!-- Status Filter -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Status</label>
                    <select id="statusFilter" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all bg-white">
                        <option value="">All Status</option>
                        <option value="Active">Active</option>
                    </select>
                </div>
            </div>
            <div class="flex items-center gap-3 mt-4">
                <button onclick="clearFilters()" class="inline-flex items-center px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-xl hover:bg-gray-200 transition-colors border border-gray-200">
                    <svg class="w-4 h-4 mr-1.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                    Clear Filters
                </button>
            </div>
        </div>
    </div>

    <!-- Companies Table Card -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 bg-gradient-to-r from-gray-50 to-white">
            <div class="flex items-center justify-between">
                <div>
                    <h2 class="text-base font-semibold text-gray-900">All Companies</h2>
                    <p class="text-sm text-gray-500 mt-0.5" id="tableInfo">Showing @Model.Companies.Count companies</p>
                </div>
                <div class="flex items-center gap-3">
                    <button type="button" onclick="executeExport()" class="px-3 sm:px-4 py-2 text-xs sm:text-sm font-medium text-gray-700 bg-gray-100 rounded-lg sm:rounded-xl hover:bg-gray-200 transition-colors border border-gray-200 flex items-center shadow-sm">
                        <svg class="w-4 h-4 mr-1.5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                        Export <span class="hidden sm:inline ml-1">PDF</span>
                    </button>
                    <select id="pageSizeSelect" class="px-3 py-1.5 border border-gray-300 rounded-lg text-sm bg-white focus:ring-2 focus:ring-blue-500">
                        <option value="10">10 per page</option>
                        <option value="25">25 per page</option>
                        <option value="50">50 per page</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full" id="companiesTable">
                <thead class="bg-gray-50/80">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Company</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Plan</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Users</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Employees</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Created</th>
                        <th class="px-6 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100" id="companiesBody">
                    @if (Model.Companies.Count == 0)
                    {
                        <tr id="emptyRow">
                            <td colspan="7" class="px-6 py-12 text-center">
                                <div class="flex flex-col items-center justify-center">
                                    <div class="w-16 h-16 bg-blue-50 rounded-full flex items-center justify-center mb-4">
                                        <svg class="w-8 h-8 text-blue-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h8a2 2 0 012 2v12a1 1 0 110 2h-3a1 1 0 01-1-1v-2a1 1 0 00-1-1H9a1 1 0 00-1 1v2a1 1 0 01-1 1H4a1 1 0 110-2V4z" clip-rule="evenodd" /></svg>
                                    </div>
                                    <p class="text-gray-500 font-medium">No companies found</p>
                                    <p class="text-sm text-gray-400 mt-1">Try adjusting your filters</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var company in Model.Companies)
                        {
                            var statusActive = company.IsActive || company.Status == "Active";
                            var planColor = company.PlanName?.ToLower() switch {
                                "starter" => "bg-green-100 text-green-700",
                                "professional" or "pro" => "bg-blue-100 text-blue-700",
                                "enterprise" => "bg-yellow-100 text-yellow-700",
                                _ => "bg-gray-100 text-gray-700"
                            };

                            <tr class="hover:bg-gray-50/50 transition-colors data-row"
                                data-name="@company.CompanyName"
                                data-plan="@company.PlanName"
                                data-status="@(statusActive ? "Active" : "Inactive")">
                                <!-- Company -->
                                <td class="px-6 py-4">
                                    <div class="flex items-center">
                                        <div class="w-9 h-9 rounded-xl overflow-hidden flex items-center justify-center mr-3 shadow-sm flex-shrink-0">
                                            @if (!string.IsNullOrEmpty(company.LogoUrl))
                                            {
                                                <img src="@company.LogoUrl" alt="Logo" class="w-9 h-9 object-contain" />
                                            }
                                            else
                                            {
                                                <div class="w-full h-full bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center">
                                                    <span class="text-xs font-bold text-white">@company.CompanyName?.Substring(0, Math.Min(2, company.CompanyName?.Length ?? 0)).ToUpper()</span>
                                                </div>
                                            }
                                        </div>
                                        <div>
                                            <p class="text-sm font-semibold text-gray-900">@company.CompanyName</p>
                                            <p class="text-xs text-gray-500">ID: @company.CompanyCode</p>
                                        </div>
                                    </div>
                                </td>
                                <!-- Plan -->
                                <td class="px-6 py-4">
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-semibold @planColor">
                                        @company.PlanName
                                    </span>
                                </td>
                                <!-- Users -->
                                <td class="px-6 py-4">
                                    <div class="flex items-center">
                                        <svg class="w-4 h-4 text-blue-400 mr-1.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z" /></svg>
                                        <span class="text-sm font-semibold text-gray-900">@company.UserCount</span>
                                    </div>
                                </td>
                                <!-- Employees -->
                                <td class="px-6 py-4">
                                    <div class="flex items-center">
                                        <svg class="w-4 h-4 text-blue-400 mr-1.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" /></svg>
                                        <span class="text-sm font-semibold text-gray-900">@company.EmployeeCount</span>
                                    </div>
                                </td>
                                <!-- Status -->
                                <td class="px-6 py-4">
                                    @{
                                        var statusClass = statusActive ? "text-blue-700" : "text-red-700";
                                    }
                                    <span class="text-xs sm:text-sm font-semibold @statusClass">
                                        @(statusActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <!-- Created -->
                                <td class="px-6 py-4 text-sm text-gray-500 whitespace-nowrap">
                                    @company.CreatedAt.ToString("MMM dd, yyyy")
                                </td>
                                <!-- Actions -->
                                <td class="px-6 py-4">
                                    <div class="flex items-center justify-center gap-2">
                                        <button type="button"
                                                onclick="openCompanyModal('@company.CompanyId', '@company.CompanyCode', '@company.CompanyName', '@company.PlanName', '@company.UserCount', '@company.EmployeeCount', '@(statusActive ? "Active" : "Inactive")', '@company.CreatedAt.ToString("MMM dd, yyyy")', '@(company.LogoUrl ?? "")')"
                                                class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-blue-700 bg-blue-50 rounded-lg hover:bg-blue-100 transition-colors">
                                            <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                                            View
                                        </button>
                                        @if (statusActive)
                                        {
                                            <button type="button"
                                                    data-name="@company.CompanyName"
                                                    onclick="deactivateCompany(this, '@company.CompanyId')"
                                                    class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-red-600 bg-red-50 rounded-lg hover:bg-red-100 transition-colors">
                                                <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" /></svg>
                                                Inactive
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-gray-400 bg-gray-100 rounded-lg cursor-not-allowed">Inactive</span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="px-4 sm:px-6 py-3 sm:py-4 border-t border-gray-100 bg-gray-50/50" id="paginationContainer">
            <div class="flex flex-col sm:flex-row items-center justify-between gap-3">
                <div class="text-xs sm:text-sm text-gray-600" id="paginationInfo">
                    Showing <span class="font-semibold" id="showStart">1</span> to <span class="font-semibold" id="showEnd">10</span> of <span class="font-semibold" id="showTotal">0</span> companies
                </div>
                <nav class="flex items-center gap-1 flex-wrap justify-center" id="paginationNav"></nav>
            </div>
        </div>
    </div>
</div>

<!-- View Company Modal -->
<div id="companyModal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <!-- Backdrop with blur -->
    <div class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm transition-opacity" aria-hidden="true" onclick="closeCompanyModal()"></div>

    <!-- Modal container -->
    <div class="fixed inset-0 z-50 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-2 sm:p-4 text-center">
            <div class="relative transform overflow-hidden rounded-lg bg-white text-left shadow-xl transition-all w-full sm:w-[90%] md:w-[75%] lg:w-[60%] xl:w-[50%] max-w-2xl mx-auto">

                <!-- Header -->
                <div class="flex items-center justify-between border-b border-gray-200 bg-white px-4 py-3 sm:px-6 sm:py-4 md:px-8 md:py-5">
                    <h3 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900" id="modal-title">
                        Company Details
                    </h3>
                    <button onclick="closeCompanyModal()" class="rounded-lg p-1.5 sm:p-2 text-gray-400 hover:bg-gray-100 hover:text-gray-500 transition-colors">
                        <svg class="h-5 w-5 sm:h-6 sm:w-6" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                        </svg>
                    </button>
                </div>

                <!-- Body -->
                <div class="px-4 py-4 sm:px-6 sm:py-5 md:px-8 md:py-6 max-h-[70vh] overflow-y-auto">
                    <div class="space-y-5 sm:space-y-6">

                        <!-- Company header (logo + name) -->
                        <div class="flex flex-col sm:flex-row items-center sm:items-start gap-4 sm:gap-6 border-b border-gray-100 pb-4 sm:pb-6">
                            <div class="relative flex-shrink-0">
                                <div id="modalLogoWrapper" class="h-16 w-16 sm:h-20 sm:w-20 md:h-24 md:w-24 overflow-hidden rounded-xl shadow-lg ring-4 ring-white flex items-center justify-center">
                                    <img id="modalCompanyLogo" class="h-full w-full object-contain hidden" alt="Company Logo" />
                                    <div id="modalCompanyInitials" class="w-full h-full bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center">
                                        <span class="text-xl sm:text-2xl font-bold text-white" id="modalInitialsText">TC</span>
                                    </div>
                                </div>
                            </div>
                            <div class="text-center sm:text-left flex-1">
                                <h4 class="text-xl sm:text-2xl md:text-3xl font-bold text-gray-900" id="modalCompanyName">Company Name</h4>
                                <p class="mt-1 text-sm text-gray-500" id="modalCompanyId">—</p>
                            </div>
                        </div>

                        <!-- Company Details -->
                        <div>
                            <h5 class="mb-3 text-xs sm:text-sm font-medium uppercase tracking-wider text-gray-500">Company Information</h5>
                            <div class="grid grid-cols-2 sm:grid-cols-2 gap-3 sm:gap-4">
                                <div class="bg-gray-50 p-2 sm:p-3 rounded-lg">
                                    <p class="text-xs text-gray-500 mb-1">Plan</p>
                                    <p class="text-xs sm:text-sm font-semibold text-gray-900" id="modalCompanyPlan">—</p>
                                </div>
                                <div class="bg-gray-50 p-2 sm:p-3 rounded-lg">
                                    <p class="text-xs text-gray-500 mb-1">Status</p>
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium" id="modalCompanyStatus">
                                        <span class="w-1.5 h-1.5 rounded-full mr-1.5" id="modalStatusDot"></span>
                                        <span id="modalStatusText">Active</span>
                                    </span>
                                </div>
                                <div class="bg-gray-50 p-2 sm:p-3 rounded-lg">
                                    <p class="text-xs text-gray-500 mb-1">Users</p>
                                    <p class="text-xs sm:text-sm font-semibold text-gray-900" id="modalCompanyUsers">0</p>
                                </div>
                                <div class="bg-gray-50 p-2 sm:p-3 rounded-lg">
                                    <p class="text-xs text-gray-500 mb-1">Employees</p>
                                    <p class="text-xs sm:text-sm font-semibold text-gray-900" id="modalCompanyEmployees">0</p>
                                </div>
                                <div class="bg-gray-50 p-2 sm:p-3 rounded-lg col-span-2">
                                    <p class="text-xs text-gray-500 mb-1">Registered On</p>
                                    <p class="text-xs sm:text-sm font-semibold text-gray-900" id="modalCompanyCreated">—</p>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Footer -->
                <div class="border-t border-gray-200 bg-gray-50 px-4 py-3 sm:px-6 sm:py-4">
                    <div class="flex justify-end">
                        <button type="button" class="inline-flex justify-center rounded-lg bg-blue-600 px-4 py-2 sm:px-5 sm:py-2.5 text-xs sm:text-sm font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-4 focus:ring-blue-300 transition-colors w-full sm:w-auto" onclick="closeCompanyModal()">
                            Close
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let currentPage = 1;
    let pageSize = 10;
    let allRows = [];
    let filteredRows = [];

    document.addEventListener('DOMContentLoaded', function () {
        allRows = Array.from(document.querySelectorAll('.data-row'));
        filteredRows = [...allRows];
        renderPage();

        document.getElementById('searchInput').addEventListener('input', applyFilters);
        document.getElementById('planFilter').addEventListener('change', applyFilters);
        document.getElementById('statusFilter').addEventListener('change', applyFilters);
        document.getElementById('pageSizeSelect').addEventListener('change', function () {
            pageSize = parseInt(this.value);
            currentPage = 1;
            renderPage();
        });
    });

    function applyFilters() {
        const search = document.getElementById('searchInput').value.toLowerCase();
        const plan = document.getElementById('planFilter').value;
        const status = document.getElementById('statusFilter').value;

        filteredRows = allRows.filter(row => {
            const name = (row.dataset.name || '').toLowerCase();
            const p = row.dataset.plan || '';
            const s = row.dataset.status || '';

            if (search && !name.includes(search)) return false;
            if (plan && p !== plan) return false;
            if (status && s !== status) return false;
            return true;
        });

        currentPage = 1;
        renderPage();
    }

    function clearFilters() {
        document.getElementById('searchInput').value = '';
        document.getElementById('planFilter').value = '';
        document.getElementById('statusFilter').value = '';
        filteredRows = [...allRows];
        currentPage = 1;
        renderPage();
    }

    function renderPage() {
        const total = filteredRows.length;
        const totalPages = Math.max(1, Math.ceil(total / pageSize));
        if (currentPage > totalPages) currentPage = totalPages;

        const start = (currentPage - 1) * pageSize;
        const end = Math.min(start + pageSize, total);

        allRows.forEach(row => row.style.display = 'none');
        for (let i = start; i < end; i++) {
            filteredRows[i].style.display = '';
        }

        document.getElementById('showStart').textContent = total === 0 ? 0 : start + 1;
        document.getElementById('showEnd').textContent = end;
        document.getElementById('showTotal').textContent = total;
        document.getElementById('tableInfo').textContent = `Showing ${total} companies`;

        const nav = document.getElementById('paginationNav');
        nav.innerHTML = '';
        if (totalPages <= 1) return;

        const prevBtn = createPageBtn('‹', currentPage > 1, () => { currentPage--; renderPage(); });
        nav.appendChild(prevBtn);

        const pages = getPageNumbers(currentPage, totalPages);
        pages.forEach(p => {
            if (p === '...') {
                const dots = document.createElement('span');
                dots.className = 'px-3 py-1.5 text-gray-400 text-sm';
                dots.textContent = '...';
                nav.appendChild(dots);
            } else {
                const btn = createPageBtn(p, true, () => { currentPage = p; renderPage(); });
                if (p === currentPage) btn.className = 'px-3 py-1.5 text-sm font-semibold bg-blue-600 text-white rounded-lg shadow-sm';
                nav.appendChild(btn);
            }
        });

        const nextBtn = createPageBtn('›', currentPage < totalPages, () => { currentPage++; renderPage(); });
        nav.appendChild(nextBtn);
    }

    function createPageBtn(label, enabled, onClick) {
        const btn = document.createElement('button');
        btn.textContent = label;
        btn.className = 'px-3 py-1.5 text-sm font-medium text-gray-700 hover:bg-gray-100 rounded-lg border border-gray-200 transition-all';
        if (!enabled) { btn.disabled = true; btn.className += ' opacity-40 cursor-not-allowed'; }
        else btn.addEventListener('click', onClick);
        return btn;
    }

    function getPageNumbers(current, total) {
        if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
        const pages = [];
        if (current <= 4) { for (let i = 1; i <= 5; i++) pages.push(i); pages.push('...', total); }
        else if (current >= total - 3) { pages.push(1, '...'); for (let i = total - 4; i <= total; i++) pages.push(i); }
        else pages.push(1, '...', current - 1, current, current + 1, '...', total);
        return pages;
    }

    function closeCompanyModal() {
        document.getElementById('companyModal').classList.add('hidden');
    }

    let pendingDeactivateCompanyId = null;

    function deactivateCompany(btn, companyId) {
        pendingDeactivateCompanyId = companyId;
        const name = btn && btn.dataset && btn.dataset.name ? btn.dataset.name : 'this company';
        document.querySelectorAll('.confirm-company-name').forEach(el => {
            el.textContent = name;
        });
        document.getElementById('popup-modal').classList.remove('hidden');
    }

    function hideConfirmModal() {
        document.getElementById('popup-modal').classList.add('hidden');
    }

    function confirmDeactivateCompany() {
        if (!pendingDeactivateCompanyId) return;
        const confirmBtn = document.getElementById('confirmDeactivateBtn');
        if (confirmBtn) { confirmBtn.disabled = true; confirmBtn.textContent = 'Processing...'; }
        document.getElementById('deactivateCompanyId').value = pendingDeactivateCompanyId;
        document.getElementById('deactivateCompanyForm').submit();
    }

    // ─── EXPORT PDF ───────────────────────────────────────────────────────────
    function executeExport() {
        document.getElementById('exportSearch').value = document.getElementById('searchInput')?.value || '';
        document.getElementById('exportPlan').value = document.getElementById('planFilter')?.value || '';
        document.getElementById('exportStatus').value = document.getElementById('statusFilter')?.value || '';
        if (typeof showToast === 'function') showToast('Generating PDF, please wait...', 'info');
        document.getElementById('exportForm').submit();
    }

    function openCompanyModal(id, code, name, plan, users, employees, status, created, logoUrl) {
        document.getElementById('modalCompanyName').textContent = name;
        document.getElementById('modalCompanyId').textContent = 'ID: ' + code;
        document.getElementById('modalCompanyPlan').textContent = plan || 'No Plan';
        document.getElementById('modalCompanyUsers').textContent = users;
        document.getElementById('modalCompanyEmployees').textContent = employees;
        document.getElementById('modalCompanyCreated').textContent = created;
        document.getElementById('modalInitialsText').textContent = (name || '').substring(0, 2).toUpperCase();

        const logoEl = document.getElementById('modalCompanyLogo');
        const initialsEl = document.getElementById('modalCompanyInitials');
        if (logoUrl && logoUrl.trim() !== '') {
            logoEl.src = logoUrl;
            logoEl.classList.remove('hidden');
            initialsEl.classList.add('hidden');
        } else {
            logoEl.src = '';
            logoEl.classList.add('hidden');
            initialsEl.classList.remove('hidden');
        }

        const statusEl = document.getElementById('modalCompanyStatus');
        const dot = document.getElementById('modalStatusDot');
        const statusText = document.getElementById('modalStatusText');
        if (status === 'Active') {
            statusEl.className = 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800';
            dot.className = 'w-1.5 h-1.5 rounded-full bg-blue-400 mr-1.5';
        } else {
            statusEl.className = 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800';
            dot.className = 'w-1.5 h-1.5 rounded-full bg-red-400 mr-1.5';
        }
        statusText.textContent = status;

        document.getElementById('companyModal').classList.remove('hidden');
    }
</script>
}

<form id="exportForm" method="post" asp-page-handler="ExportPdf" class="hidden">
    <input type="hidden" name="search" id="exportSearch" />
    <input type="hidden" name="plan" id="exportPlan" />
    <input type="hidden" name="status" id="exportStatus" />
</form>