@page
@model PayRex.Web.Pages.FinanceModel
@{
    ViewData["Title"] = "Finance";
}

<div class="max-w-8xl mx-auto px-4 py-6 sm:px-6 lg:px-8 space-y-6">
    <div class="bg-gradient-to-r from-blue-50 via-white to-blue-50 rounded-2xl border border-blue-100 shadow-sm relative overflow-hidden">
        <div class="absolute top-0 right-0 -mt-16 -mr-16 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
        <div class="px-6 py-8 sm:px-10 relative z-10">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <div>
                    <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight">Finance</h1>
                    <p class="mt-2 text-gray-600">Track Income and Expenses</p>
                </div>
                <div class="flex items-center gap-3">
                    <span class="inline-flex items-center px-4 py-2 rounded-xl text-sm font-semibold bg-blue-100 text-blue-700">
                        <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M3 3h14v2H3V3zm0 4h14v10H3V7z" />
                        </svg>
                        @Model.TotalItems total
                    </span>
                </div>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
        <div class="border-b border-gray-100 px-6">
            <nav class="-mb-px flex space-x-8" aria-label="Tabs">
                <button onclick="switchTab('income')" id="tab-income-btn" class="border-blue-500 text-blue-600 whitespace-nowrap py-4 px-1 border-b-2 font-bold text-sm transition-all">Income</button>
                <button onclick="switchTab('expenses')" id="tab-expenses-btn" class="border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition-all">Expenses</button>
            </nav>
        </div>

        <div id="income-content" class="p-6 space-y-6">
            <div class="flex flex-col sm:flex-row justify-between gap-4">
                <div class="relative w-full sm:w-64">
                    <input type="text" id="incomeSearch" placeholder="Search income..." class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-xl focus:ring-blue-500 focus:border-blue-500 sm:text-sm" onkeyup="filterIncome()">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <svg class="h-4 w-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" /></svg>
                    </div>
                </div>
                <button onclick="openAddIncomeModal()" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-xl text-white bg-blue-600 hover:bg-blue-700 shadow-sm transition-colors">Add Income</button>
            </div>

            <div class="overflow-x-auto rounded-xl border border-gray-100">
                <table class="min-w-full divide-y divide-gray-200" id="incomeTable">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Source</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Category</th>
                            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Note</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        @if (!Model.Income.Any())
                        {
                            <tr><td colspan="5" class="px-6 py-12 text-center text-gray-500">No income records</td></tr>
                        }
                        else
                        {
                            @foreach(var i in Model.Income)
                            {
                                <tr class="hover:bg-gray-50 transition-colors">
                                    <td class="px-6 py-4 text-sm text-gray-900">@i.Date.ToShortDateString()</td>
                                    <td class="px-6 py-4 text-sm text-gray-900">@i.Source</td>
                                    <td class="px-6 py-4 text-sm text-gray-500">@i.Category</td>
                                    <td class="px-6 py-4 text-sm text-right font-semibold text-green-600">₱@i.Amount.ToString("N2")</td>
                                    <td class="px-6 py-4 text-sm text-gray-500">@i.Note</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div id="expenses-content" class="hidden p-6 space-y-6">
            <div class="flex flex-col sm:flex-row justify-between gap-4">
                <div class="relative w-full sm:w-64">
                    <input type="text" id="expenseSearch" placeholder="Search expenses..." class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-xl focus:ring-blue-500 focus:border-blue-500 sm:text-sm" onkeyup="filterExpenses()">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <svg class="h-4 w-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" /></svg>
                    </div>
                </div>
                <button onclick="openAddExpenseModal()" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-xl text-white bg-blue-600 hover:bg-blue-700 shadow-sm transition-colors">Add Expense</button>
            </div>

            <div class="overflow-x-auto rounded-xl border border-gray-100">
                <table class="min-w-full divide-y divide-gray-200" id="expenseTable">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Payee</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Category</th>
                            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Note</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        @if (!Model.Expenses.Any())
                        {
                            <tr><td colspan="5" class="px-6 py-12 text-center text-gray-500">No expense records</td></tr>
                        }
                        else
                        {
                            @foreach(var e in Model.Expenses)
                            {
                                <tr class="hover:bg-gray-50 transition-colors">
                                    <td class="px-6 py-4 text-sm text-gray-900">@e.Date.ToShortDateString()</td>
                                    <td class="px-6 py-4 text-sm text-gray-900">@e.Payee</td>
                                    <td class="px-6 py-4 text-sm text-gray-500">@e.Category</td>
                                    <td class="px-6 py-4 text-sm text-right font-semibold text-red-600">₱@e.Amount.ToString("N2")</td>
                                    <td class="px-6 py-4 text-sm text-gray-500">@e.Note</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    function switchTab(tab) {
        const income = document.getElementById('income-content');
        const expenses = document.getElementById('expenses-content');
        const iBtn = document.getElementById('tab-income-btn');
        const eBtn = document.getElementById('tab-expenses-btn');

        if (tab === 'income') {
            income.classList.remove('hidden'); expenses.classList.add('hidden');
            iBtn.className = "border-blue-500 text-blue-600 whitespace-nowrap py-4 px-1 border-b-2 font-bold text-sm transition-all";
            eBtn.className = "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition-all";
        } else {
            income.classList.add('hidden'); expenses.classList.remove('hidden');
            iBtn.className = "border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition-all";
            eBtn.className = "border-blue-500 text-blue-600 whitespace-nowrap py-4 px-1 border-b-2 font-bold text-sm transition-all";
        }
    }

    function filterIncome() {
        const input = document.getElementById('incomeSearch');
        const filter = input ? input.value.toUpperCase() : '';
        const table = document.getElementById('incomeTable');
        if (!table) return;
        const tr = table.getElementsByTagName('tr');
        for (let i = 1; i < tr.length; i++) {
            const txt = (tr[i].textContent || tr[i].innerText || '').toUpperCase();
            tr[i].style.display = txt.indexOf(filter) > -1 ? '' : 'none';
        }
    }

    function filterExpenses() {
        const input = document.getElementById('expenseSearch');
        const filter = input ? input.value.toUpperCase() : '';
        const table = document.getElementById('expenseTable');
        if (!table) return;
        const tr = table.getElementsByTagName('tr');
        for (let i = 1; i < tr.length; i++) {
            const txt = (tr[i].textContent || tr[i].innerText || '').toUpperCase();
            tr[i].style.display = txt.indexOf(filter) > -1 ? '' : 'none';
        }
    }

    document.addEventListener('DOMContentLoaded', () => switchTab('income'));

    function openAddIncomeModal() { document.getElementById('addIncomeModal').classList.remove('hidden'); }
    function closeAddIncomeModal() { document.getElementById('addIncomeModal').classList.add('hidden'); }
    function openAddExpenseModal() { document.getElementById('addExpenseModal').classList.remove('hidden'); }
    function closeAddExpenseModal() { document.getElementById('addExpenseModal').classList.add('hidden'); }

    async function submitIncome(e) {
        e.preventDefault();
        const form = e.target;
        const data = { date: form.date.value, source: form.source.value, category: form.category.value, amount: parseFloat(form.amount.value), note: form.note.value };
        const resp = await fetch('/Finance?handler=AddIncome', { method: 'POST', headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || '' }, body: JSON.stringify(data) });
        if (resp.ok) location.reload(); else alert('Failed to add income');
    }

    async function submitExpense(e) {
        e.preventDefault();
        const form = e.target;
        const data = { date: form.date.value, payee: form.payee.value, category: form.category.value, amount: parseFloat(form.amount.value), note: form.note.value };
        const resp = await fetch('/Finance?handler=AddExpense', { method: 'POST', headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || '' }, body: JSON.stringify(data) });
        if (resp.ok) location.reload(); else alert('Failed to add expense');
    }
</script>

<!-- Add Income Modal -->
<div id="addIncomeModal" class="fixed inset-0 z-50 hidden overflow-y-auto">
    <div class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm" onclick="closeAddIncomeModal()"></div>
    <div class="flex min-h-full items-center justify-center p-4">
        <div class="relative bg-white rounded-2xl shadow-xl w-full max-w-md">
            <form onsubmit="submitIncome(event)">
                <div class="flex items-center justify-between border-b px-6 py-4">
                    <h3 class="text-lg font-semibold text-gray-900">Add Income</h3>
                    <button type="button" onclick="closeAddIncomeModal()" class="p-1.5 text-gray-400 hover:bg-gray-100 rounded-lg"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" /></svg></button>
                </div>
                <div class="px-6 py-5 space-y-4">
                    <div><label class="block text-sm font-medium text-gray-700 mb-1">Date</label><input type="date" name="date" required class="w-full px-4 py-2 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500" /></div>
                    <div><label class="block text-sm font-medium text-gray-700 mb-1">Source</label><input type="text" name="source" required class="w-full px-4 py-2 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500" placeholder="e.g., Sales Revenue" /></div>
                    <div><label class="block text-sm font-medium text-gray-700 mb-1">Category</label><input type="text" name="category" required class="w-full px-4 py-2 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500" placeholder="e.g., Revenue, Service" /></div>
                    <div><label class="block text-sm font-medium text-gray-700 mb-1">Amount (₱)</label><input type="number" name="amount" required min="0" step="0.01" class="w-full px-4 py-2 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500" /></div>
                    <div><label class="block text-sm font-medium text-gray-700 mb-1">Note</label><textarea name="note" rows="2" class="w-full px-4 py-2 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500"></textarea></div>
                </div>
                <div class="border-t bg-gray-50 px-6 py-4 flex justify-end gap-3">
                    <button type="button" onclick="closeAddIncomeModal()" class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-lg hover:bg-gray-200">Cancel</button>
                    <button type="submit" class="px-5 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700">Add Income</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Add Expense Modal -->
<div id="addExpenseModal" class="fixed inset-0 z-50 hidden overflow-y-auto">
    <div class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm" onclick="closeAddExpenseModal()"></div>
    <div class="flex min-h-full items-center justify-center p-4">
        <div class="relative bg-white rounded-2xl shadow-xl w-full max-w-md">
            <form onsubmit="submitExpense(event)">
                <div class="flex items-center justify-between border-b px-6 py-4">
                    <h3 class="text-lg font-semibold text-gray-900">Add Expense</h3>
                    <button type="button" onclick="closeAddExpenseModal()" class="p-1.5 text-gray-400 hover:bg-gray-100 rounded-lg"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" /></svg></button>
                </div>
                <div class="px-6 py-5 space-y-4">
                    <div><label class="block text-sm font-medium text-gray-700 mb-1">Date</label><input type="date" name="date" required class="w-full px-4 py-2 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500" /></div>
                    <div><label class="block text-sm font-medium text-gray-700 mb-1">Payee</label><input type="text" name="payee" required class="w-full px-4 py-2 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500" placeholder="e.g., Electric Company" /></div>
                    <div><label class="block text-sm font-medium text-gray-700 mb-1">Category</label><input type="text" name="category" required class="w-full px-4 py-2 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500" placeholder="e.g., Utilities, Supplies" /></div>
                    <div><label class="block text-sm font-medium text-gray-700 mb-1">Amount (₱)</label><input type="number" name="amount" required min="0" step="0.01" class="w-full px-4 py-2 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500" /></div>
                    <div><label class="block text-sm font-medium text-gray-700 mb-1">Note</label><textarea name="note" rows="2" class="w-full px-4 py-2 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500"></textarea></div>
                </div>
                <div class="border-t bg-gray-50 px-6 py-4 flex justify-end gap-3">
                    <button type="button" onclick="closeAddExpenseModal()" class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-lg hover:bg-gray-200">Cancel</button>
                    <button type="submit" class="px-5 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700">Add Expense</button>
                </div>
            </form>
        </div>
    </div>
</div>