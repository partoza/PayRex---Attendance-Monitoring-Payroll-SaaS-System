@page
@model PayRex.Web.Pages.FinanceModel
@{
    ViewData["Title"] = "Finance";
    var netPositive = Model.NetBalance >= 0;
    var fromVal = Model.FromDate?.ToString("yyyy-MM-dd") ?? "";
    var toVal   = Model.ToDate?.ToString("yyyy-MM-dd") ?? "";
}

<div class="max-w-8xl mx-auto px-4 py-6 sm:px-6 lg:px-8 space-y-6">

    <!-- â”€â”€ Header â”€â”€ -->
    <div class="bg-gradient-to-r from-blue-50 via-white to-blue-50 rounded-2xl border border-blue-100 shadow-sm relative overflow-hidden">
        <div class="absolute top-0 right-0 -mt-16 -mr-16 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
        <div class="px-6 py-7 sm:px-10 relative z-10">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <div>
                    <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight">Finance Overview</h1>
                    <p class="mt-1 text-gray-500 text-sm sm:text-base">Track income, payroll expenses, and government contributions</p>
                </div>
                <!-- Date filter -->
                <form method="get" class="flex flex-wrap items-end gap-2">
                    <div class="flex flex-col">
                        <label class="text-xs font-semibold text-gray-500 uppercase mb-1">From</label>
                        <input type="date" name="fromDate" value="@fromVal"
                               class="px-3 py-2 text-sm border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-white" />
                    </div>
                    <div class="flex flex-col">
                        <label class="text-xs font-semibold text-gray-500 uppercase mb-1">To</label>
                        <input type="date" name="toDate" value="@toVal"
                               class="px-3 py-2 text-sm border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-white" />
                    </div>
                    <button type="submit"
                            class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-semibold text-white bg-blue-600 rounded-xl hover:bg-blue-700 shadow-sm transition-colors">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-.293.707L13 13.414V19a1 1 0 01-.553.894l-4 2A1 1 0 017 21v-7.586L3.293 6.707A1 1 0 013 6V4z" /></svg>
                        Filter
                    </button>
                    <a href="/Finance" class="inline-flex items-center gap-1 px-3 py-2 text-sm font-medium text-gray-600 bg-white border border-gray-300 rounded-xl hover:bg-gray-50 transition-colors">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
                        Reset
                    </a>
                </form>
            </div>
        </div>
    </div>

    <!-- â”€â”€ KPI Cards â”€â”€ -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <!-- Total Income -->
        <div class="bg-white rounded-xl sm:rounded-2xl border border-gray-200 shadow-sm p-5 flex flex-col gap-3">
            <div class="flex items-center justify-between">
                <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Total Income</span>
                <div class="w-9 h-9 rounded-xl bg-green-50 flex items-center justify-center">
                    <svg class="w-5 h-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11l5-5m0 0l5 5m-5-5v12" /></svg>
                </div>
            </div>
            <div>
                <p class="text-xl sm:text-2xl font-extrabold text-gray-900">â‚±@Model.TotalIncome.ToString("N2")</p>
                <p class="text-xs text-gray-400 mt-0.5">@Model.Income.Count records</p>
            </div>
        </div>
        <!-- Total Expenses -->
        <div class="bg-white rounded-xl sm:rounded-2xl border border-gray-200 shadow-sm p-5 flex flex-col gap-3">
            <div class="flex items-center justify-between">
                <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Total Expenses</span>
                <div class="w-9 h-9 rounded-xl bg-red-50 flex items-center justify-center">
                    <svg class="w-5 h-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 13l-5 5m0 0l-5-5m5 5V6" /></svg>
                </div>
            </div>
            <div>
                <p class="text-xl sm:text-2xl font-extrabold text-gray-900">â‚±@Model.TotalExpenses.ToString("N2")</p>
                <p class="text-xs text-gray-400 mt-0.5">@Model.Expenses.Count records</p>
            </div>
        </div>
        <!-- Net Balance -->
        <div class="bg-white rounded-xl sm:rounded-2xl border @(netPositive ? "border-green-100" : "border-red-100") shadow-sm p-5 flex flex-col gap-3">
            <div class="flex items-center justify-between">
                <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Net Balance</span>
                <div class="w-9 h-9 rounded-xl @(netPositive ? "bg-green-50" : "bg-red-50") flex items-center justify-center">
                    <svg class="w-5 h-5 @(netPositive ? "text-green-600" : "text-red-500")" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" /></svg>
                </div>
            </div>
            <div>
                <p class="text-xl sm:text-2xl font-extrabold @(netPositive ? "text-green-600" : "text-red-600")">@(netPositive ? "+" : "")â‚±@Model.NetBalance.ToString("N2")</p>
                <p class="text-xs @(netPositive ? "text-green-400" : "text-red-400") mt-0.5">@(netPositive ? "Surplus" : "Deficit")</p>
            </div>
        </div>
        <!-- Gov. Contributions -->
        <div class="bg-white rounded-xl sm:rounded-2xl border border-gray-200 shadow-sm p-5 flex flex-col gap-3">
            <div class="flex items-center justify-between">
                <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Gov. Contributions</span>
                <div class="w-9 h-9 rounded-xl bg-blue-50 flex items-center justify-center">
                    <svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
                </div>
            </div>
            <div>
                <p class="text-xl sm:text-2xl font-extrabold text-gray-900">â‚±@Model.TotalContributions.ToString("N2")</p>
                <p class="text-xs text-gray-400 mt-0.5">@Model.Contributions.Count entries</p>
            </div>
        </div>
    </div>

    <!-- Tabbed Content -->
    <div class="bg-white rounded-xl sm:rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <!-- Tabs -->
        <div class="border-b border-gray-100 px-6 flex items-center justify-between">
            <nav class="-mb-px flex space-x-6" aria-label="Tabs">
                <button onclick="switchTab('income')" id="tab-income-btn"
                        class="tab-btn active-tab whitespace-nowrap py-4 px-1 border-b-2 font-semibold text-sm transition-all">
                    <span class="flex items-center gap-1.5">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11l5-5m0 0l5 5m-5-5v12" /></svg>
                        Income
                        <span class="ml-1 bg-green-100 text-green-700 text-xs font-bold px-2 py-0.5 rounded-full">@Model.Income.Count</span>
                    </span>
                </button>
                <button onclick="switchTab('expenses')" id="tab-expenses-btn"
                        class="tab-btn inactive-tab whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition-all">
                    <span class="flex items-center gap-1.5">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 13l-5 5m0 0l-5-5m5 5V6" /></svg>
                        Expenses
                        <span class="ml-1 bg-red-100 text-red-600 text-xs font-bold px-2 py-0.5 rounded-full">@Model.Expenses.Count</span>
                    </span>
                </button>
                <button onclick="switchTab('contributions')" id="tab-contributions-btn"
                        class="tab-btn inactive-tab whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition-all">
                    <span class="flex items-center gap-1.5">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16" /></svg>
                        Gov. Contributions
                        <span class="ml-1 bg-blue-100 text-blue-700 text-xs font-bold px-2 py-0.5 rounded-full">@Model.Contributions.Count</span>
                    </span>
                </button>
            </nav>
        </div>

        <!-- â”€â”€ Income Tab â”€â”€ -->
        <div id="income-content" class="p-6 space-y-4">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                <div class="relative w-full sm:w-64">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <svg class="h-4 w-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" /></svg>
                    </div>
                    <input type="text" id="incomeSearch" placeholder="Search income..." onkeyup="filterTable('incomeTable','incomeSearch')"
                           class="w-full pl-9 pr-4 py-2 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm" />
                </div>
                <button onclick="openAddIncomeModal()"
                        class="inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold text-white bg-blue-600 rounded-xl hover:bg-blue-700 shadow-sm transition-colors ring-1 ring-blue-500/30">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                    Add Income
                </button>
            </div>

            <div class="overflow-x-auto rounded-xl border border-gray-200">
                <table class="min-w-full divide-y divide-gray-100" id="incomeTable">
                    <thead class="bg-gray-50/80">
                        <tr>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Date</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Source</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Category</th>
                            <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Amount</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Note</th>
                            <th class="px-4 py-3 w-10"></th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-50">
                        @if (!Model.Income.Any())
                        {
                            <tr><td colspan="6" class="px-6 py-14 text-center text-gray-400 text-sm">No income records for this period</td></tr>
                        }
                        else
                        {
                            @foreach (var i in Model.Income)
                            {
                                <tr class="hover:bg-gray-50/50 transition-colors">
                                    <td class="px-4 py-3 text-sm text-gray-600 whitespace-nowrap">@i.Date.ToString("MMM dd, yyyy")</td>
                                    <td class="px-4 py-3 text-sm font-medium text-gray-900">@i.Source</td>
                                    <td class="px-4 py-3"><span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-700">@i.Category</span></td>
                                    <td class="px-4 py-3 text-sm text-right font-bold text-green-600 whitespace-nowrap">â‚±@i.Amount.ToString("N2")</td>
                                    <td class="px-4 py-3 text-sm text-gray-400 max-w-xs truncate">@(string.IsNullOrEmpty(i.Note) ? "â€”" : i.Note)</td>
                                    <td class="px-4 py-3 text-right">
                                        <button onclick="deleteIncome(@i.Id, this)"
                                                class="p-1.5 text-gray-300 hover:text-red-500 hover:bg-red-50 rounded-lg transition-colors" title="Delete">
                                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                    @if (Model.Income.Any())
                    {
                        <tfoot class="bg-gray-50 border-t-2 border-gray-200">
                            <tr>
                                <td colspan="3" class="px-4 py-3 text-sm font-bold text-gray-700 uppercase tracking-wide">Total Income</td>
                                <td class="px-4 py-3 text-right text-sm font-extrabold text-green-600">â‚±@Model.TotalIncome.ToString("N2")</td>
                                <td colspan="2"></td>
                            </tr>
                        </tfoot>
                    }
                </table>
            </div>
        </div>

        <!-- â”€â”€ Expenses Tab â”€â”€ -->
        <div id="expenses-content" class="hidden p-6 space-y-4">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                <div class="flex items-center gap-3 flex-wrap">
                    <div class="relative w-full sm:w-64">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <svg class="h-4 w-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" /></svg>
                        </div>
                        <input type="text" id="expenseSearch" placeholder="Search expenses..." onkeyup="filterTable('expenseTable','expenseSearch')"
                               class="w-full pl-9 pr-4 py-2 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm" />
                    </div>
                    <div class="flex items-center gap-2 text-xs text-gray-500 flex-wrap">
                        <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-md bg-blue-50 text-blue-700 font-medium">
                            <span class="w-2 h-2 rounded-full bg-blue-500 inline-block"></span>
                            Payroll: â‚±@Model.Expenses.Where(e => e.Type == "Payroll").Sum(e => e.Amount).ToString("N2")
                        </span>
                        <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-md bg-orange-50 text-orange-700 font-medium">
                            <span class="w-2 h-2 rounded-full bg-orange-500 inline-block"></span>
                            Other: â‚±@Model.Expenses.Where(e => e.Type == "Manual").Sum(e => e.Amount).ToString("N2")
                        </span>
                    </div>
                </div>
                <button onclick="openAddExpenseModal()"
                        class="inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold text-white bg-red-600 rounded-xl hover:bg-red-700 shadow-sm transition-colors ring-1 ring-red-500/30">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                    Add Expense
                </button>
            </div>

            <div class="overflow-x-auto rounded-xl border border-gray-200">
                <table class="min-w-full divide-y divide-gray-100" id="expenseTable">
                    <thead class="bg-gray-50/80">
                        <tr>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Date</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Description</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Category / Type</th>
                            <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Amount</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Note</th>
                            <th class="px-4 py-3 w-10"></th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-50">
                        @if (!Model.Expenses.Any())
                        {
                            <tr><td colspan="6" class="px-6 py-14 text-center text-gray-400 text-sm">No expense records for this period</td></tr>
                        }
                        else
                        {
                            @foreach (var e in Model.Expenses)
                            {
                                var isPayroll = e.Type == "Payroll";
                                <tr class="hover:bg-gray-50/50 transition-colors">
                                    <td class="px-4 py-3 text-sm text-gray-600 whitespace-nowrap">@e.Date.ToString("MMM dd, yyyy")</td>
                                    <td class="px-4 py-3 text-sm font-medium text-gray-900">@e.Description</td>
                                    <td class="px-4 py-3">
                                        <div class="flex flex-wrap gap-1">
                                            @if (isPayroll)
                                            {
                                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-semibold bg-blue-100 text-blue-700">
                                                    <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20"><path d="M4 4a2 2 0 00-2 2v4a2 2 0 002 2V6h10a2 2 0 00-2-2H4zm2 6a2 2 0 012-2h8a2 2 0 012 2v4a2 2 0 01-2 2H8a2 2 0 01-2-2v-4zm6 4a2 2 0 100-4 2 2 0 000 4z" /></svg>
                                                    Payroll
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-orange-100 text-orange-700">@e.Category</span>
                                            }
                                        </div>
                                    </td>
                                    <td class="px-4 py-3 text-sm text-right font-bold text-red-600 whitespace-nowrap">â‚±@e.Amount.ToString("N2")</td>
                                    <td class="px-4 py-3 text-sm text-gray-400 max-w-xs truncate">@(string.IsNullOrEmpty(e.Note) ? "â€”" : e.Note)</td>
                                    <td class="px-4 py-3 text-right">
                                        @if (!isPayroll)
                                        {
                                            <button onclick="deleteExpense(@e.Id, this)"
                                                    class="p-1.5 text-gray-300 hover:text-red-500 hover:bg-red-50 rounded-lg transition-colors" title="Delete">
                                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="p-1.5 text-gray-200 cursor-not-allowed" title="Payroll expenses cannot be deleted here">
                                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                    @if (Model.Expenses.Any())
                    {
                        <tfoot class="bg-gray-50 border-t-2 border-gray-200">
                            <tr>
                                <td colspan="3" class="px-4 py-3 text-sm font-bold text-gray-700 uppercase tracking-wide">Total Expenses</td>
                                <td class="px-4 py-3 text-right text-sm font-extrabold text-red-600">â‚±@Model.TotalExpenses.ToString("N2")</td>
                                <td colspan="2"></td>
                            </tr>
                        </tfoot>
                    }
                </table>
            </div>
        </div>

        <!-- â”€â”€ Government Contributions Tab â”€â”€ -->
        <div id="contributions-content" class="hidden p-6 space-y-4">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                <!-- Contribution summary mini-cards -->
                <div class="flex flex-wrap gap-2">
                    @{
                        var sssTotal    = Model.Contributions.Where(c => c.Type == "SSS").Sum(c => c.EmployeeShare + c.EmployerShare);
                        var phTotal     = Model.Contributions.Where(c => c.Type == "PhilHealth").Sum(c => c.EmployeeShare + c.EmployerShare);
                        var pagTotal    = Model.Contributions.Where(c => c.Type == "PagIig").Sum(c => c.EmployeeShare + c.EmployerShare);
                    }
                    <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-blue-50 border border-blue-100 text-xs font-semibold text-blue-700">
                        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><circle cx="10" cy="10" r="8" /></svg>
                        SSS â‚±@sssTotal.ToString("N2")
                    </span>
                    <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-green-50 border border-green-100 text-xs font-semibold text-green-700">
                        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><circle cx="10" cy="10" r="8" /></svg>
                        PhilHealth â‚±@phTotal.ToString("N2")
                    </span>
                    <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-orange-50 border border-orange-100 text-xs font-semibold text-orange-700">
                        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><circle cx="10" cy="10" r="8" /></svg>
                        Pag-IBIG â‚±@pagTotal.ToString("N2")
                    </span>
                </div>
                <div class="text-sm text-gray-500">
                    Total employer + employee: <span class="font-bold text-gray-800">â‚±@Model.TotalContributions.ToString("N2")</span>
                </div>
            </div>

            <div class="overflow-x-auto rounded-xl border border-gray-200">
                <table class="min-w-full divide-y divide-gray-100">
                    <thead class="bg-gray-50/80">
                        <tr>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Period</th>
                            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Type</th>
                            <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">Employees</th>
                            <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Employee Share</th>
                            <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Employer Share</th>
                            <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Total</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-50">
                        @if (!Model.Contributions.Any())
                        {
                            <tr><td colspan="6" class="px-6 py-14 text-center text-gray-400 text-sm">No contribution records for this period</td></tr>
                        }
                        else
                        {
                            @foreach (var c in Model.Contributions)
                            {
                                var (typeBg, typeColor) = c.Type switch {
                                    "SSS"        => ("bg-blue-50",   "text-blue-700"),
                                    "PhilHealth" => ("bg-green-50",  "text-green-700"),
                                    "PagIig"     => ("bg-orange-50", "text-orange-700"),
                                    _            => ("bg-gray-50",   "text-gray-700")
                                };
                                var typeLabel = c.Type == "PagIig" ? "Pag-IBIG" : c.Type;
                                <tr class="hover:bg-gray-50/50 transition-colors">
                                    <td class="px-4 py-3 text-sm font-medium text-gray-900 whitespace-nowrap">@c.PeriodName</td>
                                    <td class="px-4 py-3">
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold @typeBg @typeColor">@typeLabel</span>
                                    </td>
                                    <td class="px-4 py-3 text-sm text-gray-600 text-center">@c.Count</td>
                                    <td class="px-4 py-3 text-sm text-right font-semibold text-gray-800 whitespace-nowrap">â‚±@c.EmployeeShare.ToString("N2")</td>
                                    <td class="px-4 py-3 text-sm text-right font-semibold text-gray-800 whitespace-nowrap">â‚±@c.EmployerShare.ToString("N2")</td>
                                    <td class="px-4 py-3 text-sm text-right font-bold text-blue-700 whitespace-nowrap">â‚±@((c.EmployeeShare + c.EmployerShare).ToString("N2"))</td>
                                </tr>
                            }
                        }
                    </tbody>
                    @if (Model.Contributions.Any())
                    {
                        <tfoot class="bg-gray-50 border-t-2 border-gray-200">
                            <tr>
                                <td colspan="3" class="px-4 py-3 text-sm font-bold text-gray-700 uppercase tracking-wide">Total</td>
                                <td class="px-4 py-3 text-right text-sm font-extrabold text-gray-800">â‚±@Model.Contributions.Sum(c => c.EmployeeShare).ToString("N2")</td>
                                <td class="px-4 py-3 text-right text-sm font-extrabold text-gray-800">â‚±@Model.Contributions.Sum(c => c.EmployerShare).ToString("N2")</td>
                                <td class="px-4 py-3 text-right text-sm font-extrabold text-blue-700">â‚±@Model.TotalContributions.ToString("N2")</td>
                            </tr>
                        </tfoot>
                    }
                </table>
            </div>
        </div>
    </div>
</div>

