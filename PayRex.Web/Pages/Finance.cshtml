<style>
    .active-tab   { border-color: #3b82f6; color: #2563eb; }
    .inactive-tab { border-color: transparent; color: #6b7280; }
    .inactive-tab:hover { color: #374151; border-color: #d1d5db; }
</style>

<script>
    const TOKEN = document.cookie.split('; ').find(r => r.startsWith('PayRex.AuthToken='))?.split('=')[1] || '';

    function switchTab(tab) {
        const tabs = ['income', 'expenses', 'contributions'];
        tabs.forEach(t => {
            const content = document.getElementById(t + '-content');
            const btn = document.getElementById('tab-' + t + '-btn');
            if (content) content.classList.toggle('hidden', t !== tab);
            if (btn) {
                btn.classList.toggle('active-tab', t === tab);
                btn.classList.toggle('inactive-tab', t !== tab);
            }
        });
    }

    function filterTable(tableId, inputId) {
        const filter = (document.getElementById(inputId)?.value || '').toUpperCase();
        const rows = document.querySelectorAll(`#${tableId} tbody tr`);
        rows.forEach(r => {
            r.style.display = (r.textContent || '').toUpperCase().includes(filter) ? '' : 'none';
        });
    }

    const openAddIncomeModal  = () => document.getElementById('addIncomeModal').classList.remove('hidden');
    const closeAddIncomeModal = () => document.getElementById('addIncomeModal').classList.add('hidden');
    const openAddExpenseModal  = () => document.getElementById('addExpenseModal').classList.remove('hidden');
    const closeAddExpenseModal = () => document.getElementById('addExpenseModal').classList.add('hidden');

    async function submitIncome(e) {
        e.preventDefault();
        const form = e.target;
        const btn = form.querySelector('button[type="submit"]');
        btn.disabled = true; btn.textContent = 'Saving...';
        const data = { date: form.date.value, source: form.source.value, category: form.category.value, amount: parseFloat(form.amount.value), note: form.note.value };
        try {
            const resp = await fetch('/Finance?handler=AddIncome', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
            if (resp.ok) { showToast('Income added successfully.', 'success'); closeAddIncomeModal(); setTimeout(() => location.reload(), 800); }
            else showToast('Failed to add income.', 'error');
        } catch { showToast('Network error.', 'error'); }
        finally { btn.disabled = false; btn.textContent = 'Save Income'; }
    }

    async function submitExpense(e) {
        e.preventDefault();
        const form = e.target;
        const btn = form.querySelector('button[type="submit"]');
        btn.disabled = true; btn.textContent = 'Saving...';
        const data = { date: form.date.value, payee: form.payee.value, category: form.category.value, amount: parseFloat(form.amount.value), note: form.note.value };
        try {
            const resp = await fetch('/Finance?handler=AddExpense', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
            if (resp.ok) { showToast('Expense added successfully.', 'success'); closeAddExpenseModal(); setTimeout(() => location.reload(), 800); }
            else showToast('Failed to add expense.', 'error');
        } catch { showToast('Network error.', 'error'); }
        finally { btn.disabled = false; btn.textContent = 'Save Expense'; }
    }

    async function deleteIncome(id, btn) {
        if (!confirm('Delete this income record?')) return;
        const row = btn.closest('tr');
        try {
            const resp = await fetch(`${window.ApiBaseUrl}/api/admin/finance/income/${id}`, {
                method: 'DELETE', headers: { 'Authorization': 'Bearer ' + TOKEN }
            });
            if (resp.ok) { row.style.transition = 'opacity 0.3s'; row.style.opacity = '0'; setTimeout(() => { row.remove(); showToast('Income deleted.', 'success'); }, 300); }
            else showToast('Failed to delete income.', 'error');
        } catch { showToast('Network error.', 'error'); }
    }

    async function deleteExpense(id, btn) {
        if (!confirm('Delete this expense record?')) return;
        const row = btn.closest('tr');
        try {
            const resp = await fetch(`${window.ApiBaseUrl}/api/admin/finance/expense/${id}`, {
                method: 'DELETE', headers: { 'Authorization': 'Bearer ' + TOKEN }
            });
            if (resp.ok) { row.style.transition = 'opacity 0.3s'; row.style.opacity = '0'; setTimeout(() => { row.remove(); showToast('Expense deleted.', 'success'); }, 300); }
            else showToast('Failed to delete expense.', 'error');
        } catch { showToast('Network error.', 'error'); }
    }

    document.addEventListener('DOMContentLoaded', () => switchTab('income'));
</script>

