@page
@model PayRex.Web.Pages.SettingsModel
@using System.Text.Json
@{
    ViewData["Title"] = "Company Settings";
}

<div class="max-w-8xl mx-auto px-4 py-6 sm:px-6 lg:px-8 space-y-6">
    <div id="toast-container" class="fixed top-4 right-4 z-50 space-y-4 md:top-6 md:right-6 max-w-sm w-full">
        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="toast-message group relative overflow-hidden bg-white border border-green-100 rounded-2xl shadow-lg shadow-green-100/50 p-4 animate-slide-in" role="alert">
                 <div class="absolute bottom-0 left-0 h-1 bg-green-500 transition-all duration-[3000ms] w-full animate-progress"></div>
                <div class="flex items-start gap-4">
                    <div class="p-2 bg-green-50 rounded-xl shrink-0">
                        <svg class="w-6 h-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                    <div class="flex-1 pt-0.5">
                        <h3 class="text-sm font-semibold text-gray-900">Success</h3>
                        <p class="text-sm text-gray-600 mt-1">@Model.SuccessMessage</p>
                    </div>
                    <button type="button" onclick="this.closest('.toast-message').remove()" class="text-gray-400 hover:text-gray-600 transition-colors">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>
            </div>
        }
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="toast-message group relative overflow-hidden bg-white border border-red-100 rounded-2xl shadow-lg shadow-red-100/50 p-4 animate-slide-in" role="alert">
                 <div class="absolute bottom-0 left-0 h-1 bg-red-500 transition-all duration-[3000ms] w-full animate-progress"></div>
                <div class="flex items-start gap-4">
                    <div class="p-2 bg-red-50 rounded-xl shrink-0">
                        <svg class="w-6 h-6 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                    <div class="flex-1 pt-0.5">
                        <h3 class="text-sm font-semibold text-gray-900">Error</h3>
                        <p class="text-sm text-gray-600 mt-1">@Model.ErrorMessage</p>
                    </div>
                    <button type="button" onclick="this.closest('.toast-message').remove()" class="text-gray-400 hover:text-gray-600 transition-colors">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>
            </div>
        }
    </div>
    <!-- Header -->
    <div class="bg-gradient-to-r from-blue-50 via-white to-blue-50 rounded-2xl border border-blue-100 shadow-sm relative overflow-hidden">
        <div class="absolute top-0 right-0 -mt-16 -mr-16 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
        <div class="px-8 py-10 relative z-10 text-gray-900">
            <h1 class="text-3xl font-extrabold tracking-tight">Company Settings</h1>
            <p class="mt-2 text-gray-600 text-lg">Manage detailed company profile, logo, and salary configurations.</p>
        </div>
    </div>

    <form method="post" asp-page-handler="SaveCompany" class="space-y-6">
        @Html.AntiForgeryToken()

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Company Profile & Logo -->
            <div class="lg:col-span-1 space-y-6">
                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
                    <div class="flex justify-between items-start mb-4">
                        <h2 class="text-lg font-bold text-gray-900 mb-6 flex items-center">Company Profile</h2>
                    </div>

                    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
    <!-- Header -->
    <div class="flex items-center justify-between mb-5">
        <div>
            <h3 class="text-sm font-semibold text-gray-900">Company Logo</h3>
            <p class="text-xs text-gray-500 mt-0.5">PNG, JPG up to 2MB</p>
        </div>
        
        @if (Model.IsEditMode)
        {
            <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-blue-50 text-blue-700 border border-blue-200">
                Edit Mode
            </span>
        }
    </div>

    <!-- Logo Display -->
    @{ var logoSrc = Model.Profile.UrlImage ?? Model.Profile.LogoUrl ?? "/images/logo.png"; var isFallback = string.IsNullOrEmpty(Model.Profile.UrlImage) && string.IsNullOrEmpty(Model.Profile.LogoUrl); }
    <div class="flex flex-col items-center py-4">
        <div class="relative w-32 h-32 mb-3">
            <div class="w-full h-full rounded-xl bg-gradient-to-br from-gray-50 to-gray-100 p-3 border border-gray-200 shadow-sm">
                <img id="companyLogo" 
                     src="@logoSrc" 
                     alt="Company Logo" 
                     class="w-full h-full object-contain rounded-lg @(isFallback ? "filter grayscale opacity-50" : "")"
                     onerror="this.src='/images/logo.png'" />
            </div>
            
            @if (Model.IsEditMode && (!string.IsNullOrEmpty(Model.Profile.UrlImage) || !string.IsNullOrEmpty(Model.Profile.LogoUrl)))
            {
                <button type="button" 
                        onclick="document.getElementById('removeLogoBtn').click()"
                        class="absolute -top-2 -right-2 w-6 h-6 bg-red-500 hover:bg-red-600 text-white rounded-full shadow-md flex items-center justify-center transition-colors">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            }
        </div>

        @if (!string.IsNullOrEmpty(Model.Profile.UrlImage) || !string.IsNullOrEmpty(Model.Profile.LogoUrl))
        {
            <div class="flex items-center gap-1.5 text-xs text-gray-500">
                <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Logo uploaded</span>
            </div>
        }
    </div>

    <!-- Upload Controls -->
    @if (Model.IsEditMode)
    {
        <div class="mt-4 pt-4 border-t border-gray-100">
            <form method="post" asp-page-handler="UploadCompanyLogo" enctype="multipart/form-data" id="logoForm">
                @Html.AntiForgeryToken()
                
                <!-- Hidden remove button -->
                <button type="submit" 
                        id="removeLogoBtn"
                        formaction="?handler=RemoveCompanyLogo" 
                        formmethod="post"
                        class="hidden"></button>

                <!-- Upload Area -->
                <div class="relative">
                    <input type="file" 
                           name="CompanyLogoFile" 
                           accept="image/*" 
                           id="fileInput"
                           onchange="this.form.submit()"
                           class="hidden" />
                    
                    <label for="fileInput" class="w-full inline-flex items-center justify-center px-4 py-3 bg-blue-50 hover:bg-blue-100 text-blue-700 text-sm font-medium rounded-xl border-2 border-blue-200 border-dashed transition-all cursor-pointer">
                        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                        </svg>
                        Choose New Logo
                    </label>
                </div>
            </form>
        </div>
    }
</div>


                    <div class="space-y-6">
                        <!-- Company Name - Featured -->
                        <div class="bg-blue-50/30 p-4 rounded-xl border border-blue-100">
                            <label class="text-xs font-semibold text-blue-600 uppercase tracking-wider">Company Name</label>
                            <div class="mt-1 text-lg font-bold text-gray-900">
                                @if (Model.IsEditMode)
                                {
                                    <input name="CompanyName" value="@Model.Profile.CompanyName" type="text"
                                           class="mt-1 block w-full border-gray-300 rounded-xl shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm"
                                           placeholder="Enter company name" />
                                }
                                else
                                {
                                    <span id="companyNameDisplay" class="block py-2 px-3 bg-gray-50 rounded-xl border border-gray-200">
                                        @(string.IsNullOrEmpty(Model.Profile.CompanyName) ? "—" : Model.Profile.CompanyName)
                                    </span>
                                }
                            </div>
                        </div>

                        <!-- Grid for other fields -->
                        <div class="gap-4">
                            <!-- TIN -->
                            <div class="bg-white p-4 rounded-xl border border-gray-100 hover:border-gray-200 transition-colors">
                                <label class="flex items-center text-xs font-medium text-gray-500 uppercase tracking-wider">
                                    <svg class="w-4 h-4 mr-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2" />
                                    </svg>
                                    TIN
                                </label>
                                <div class="mt-1">
                                    @if (Model.IsEditMode)
                                    {
                                        <input name="Tin" value="@(Model.Profile.Tin ?? "")" type="text"
                                               class="mt-1 block w-full border-gray-300 rounded-xl shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm"
                                               placeholder="Enter TIN" />
                                    }
                                    else
                                    {
                                        <span id="tinDisplay" class="block text-gray-900 font-medium">
                                                @(string.IsNullOrEmpty(@Model.Profile.Tin) ? "No TIN specified" : @Model.Profile.Tin)
                                            </span>
                                    }
                                </div>
                            </div>

                            <!-- Contact Phone -->
                            <div class="bg-white p-4 rounded-xl border border-gray-100 hover:border-gray-200 transition-colors">
                                <label class="flex items-center text-xs font-medium text-gray-500 uppercase tracking-wider">
                                    <svg class="w-4 h-4 mr-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                                    </svg>
                                    Contact
                                </label>
                                <div class="mt-1">
                                    @if (Model.IsEditMode)
                                    {
                                        <input name="ContactPhone" value="@(Model.Profile.ContactPhone ?? "")" type="text"
                                               class="mt-1 block w-full border-gray-300 rounded-xl shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm"
                                               placeholder="Enter contact number" />
                                    }
                                    else
                                    {
                                        <span id="contactDisplay" class="block text-gray-900 font-medium">
                                                @(string.IsNullOrEmpty(@Model.Profile.ContactPhone) ? "No contact specified"  : @Model.Profile.ContactPhone)
                                            </span>
                                    }
                                </div>
                            </div>

                            <!-- Address - Full width -->
                            <div class="md:col-span-2 bg-white p-4 rounded-xl border border-gray-100 hover:border-gray-200 transition-colors">
                                <label class="flex items-center text-xs font-medium text-gray-500 uppercase tracking-wider">
                                    <svg class="w-4 h-4 mr-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                                    </svg>
                                    Address
                                </label>
                                <div class="mt-1">
                                    @if (Model.IsEditMode)
                                    {
                                        <textarea name="Address" rows="2"
                                              class="mt-1 block w-full border-gray-300 rounded-xl shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm"
                                              placeholder="Enter complete address">@(Model.Profile.Address ?? "")</textarea>
                                    }
                                    else
                                    {
                                        <span id="addressDisplay" class="block text-gray-900">
                                                @(string.IsNullOrEmpty(Model.Profile.Address) ? "No address specified" : Model.Profile.Address)
                                            </span>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Optional: Display metadata or helper text -->
                        @if (!Model.IsEditMode)
                        {
                            <div class="flex items-center justify-end text-xs text-gray-400 border-t border-gray-100 pt-3 mt-2">
                                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                Click "Edit Profile" to update company information
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Role Configuration + Payroll -->
            <div class="lg:col-span-2 space-y-6">
                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
                    <div class="flex justify-between items-center mb-4">
                        <div>
                            <h2 class="text-lg font-bold text-gray-900 flex items-center">Employee Roles & Salary Rates</h2>
                        </div>
                        <div class="flex items-center space-x-2">
                            @if (!Model.IsEditMode)
                            {
                                <a href="/Settings?edit=true"
                                   class="inline-flex items-center justify-center px-6 py-3 rounded-xl text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 transition-all shadow-sm hover:shadow-md hover:-translate-y-0.5">
                                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                                    </svg>
                                    Edit Profile
                                </a>
                            }
                            else
                            {
                                <a href="/Settings"
                                   class="inline-flex items-center justify-center px-6 py-3 rounded-xl text-sm font-medium text-gray-700 bg-white border border-gray-200 hover:bg-gray-50 transition-all shadow-sm hover:shadow-md">
                                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                    </svg>
                                    Cancel Editing
                                </a>
                            }
                        </div>
                    </div>

                    <div class="overflow-x-auto">
                        <div class="max-h-64 overflow-y-auto border border-gray-200 rounded-xl">
                            <table class="min-w-full divide-y divide-gray-200">
                                <thead class="bg-gray-50 sticky top-0">
                                    <tr>
                                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Role</th>
                                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Default Rate</th>
                                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Rate Type</th>
                                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                                        <th class="px-6 py-3 relative"></th>
                                    </tr>
                                </thead>
                                <tbody class="bg-white divide-y divide-gray-200" id="rolesList">
                                    @* JS renders rows *@
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="mt-4">
                        <button id="btnAddRole" type="button" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-xl text-blue-700 bg-blue-50 hover:bg-blue-100 transition-colors @(Model.IsEditMode ? "" : "hidden")">Add New Role</button>
                    </div>
                </div>

                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
                    <h2 class="text-lg font-bold text-gray-900 mb-4">Payroll Configuration</h2>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-medium text-gray-700">Payroll Frequency</label>
                            <select name="PayrollCycle" class="mt-1 block w-full border-gray-300 rounded-xl shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm" @(Model.IsEditMode ? "" : "disabled")>
                                <option value="0" selected>Semi-Monthly (15th & 30th)</option>
                                <option value="1">Monthly (30th)</option>
                                <option value="2">Weekly (Friday)</option>
                            </select>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700">Work Hours per Day</label>
                            <input name="WorkHoursPerDay" type="number" step="0.25" value="@(Model.Profile.WorkHoursPerDay ?? 8)" @(Model.IsEditMode ? "" : "disabled") class="mt-1 block w-full border-gray-300 rounded-xl shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm" />
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700">Overtime Rate</label>
                            <input name="OvertimeRate" type="number" step="0.01" value="@(Model.Profile.OvertimeRate ?? 1.25m)" @(Model.IsEditMode ? "" : "disabled") class="mt-1 block w-full border-gray-300 rounded-xl shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm" />
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700">Late Grace Minutes</label>
                            <input name="LateGraceMinutes" type="number" value="@(Model.Profile.LateGraceMinutes ?? 15)" @(Model.IsEditMode ? "" : "disabled") class="mt-1 block w-full border-gray-300 rounded-xl shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm" />
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700">Holiday Rate</label>
                            <input name="HolidayRate" type="number" step="0.01" value="@(Model.Profile.HolidayRate ?? 2.00m)" @(Model.IsEditMode ? "" : "disabled") class="mt-1 block w-full border-gray-300 rounded-xl shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm" />
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700">Absent Rate</label>
                            <input name="AbsentRate" type="number" step="0.01" value="@(Model.Profile.AbsentRate ?? 0.00m)" @(Model.IsEditMode ? "" : "disabled") class="mt-1 block w-full border-gray-300 rounded-xl shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm" />
                        </div>
                    </div>
                </div>

                <!-- Page level Save button -->
                <div class="flex justify-end">
                    @if (Model.IsEditMode)
                    {
                        <button type="submit" class="px-6 py-2 rounded-xl bg-blue-600 text-white hover:bg-blue-700 transition-all shadow-sm hover:shadow-md">Save Changes</button>
                    }
                </div>
            </div>
        </div>
    </form>

    <!-- Flowbite-style Modal -->
    <div id="roleModal" tabindex="-1" aria-hidden="true" class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full md:inset-0 h-[calc(100%-1rem)] max-h-full bg-black/50 backdrop-blur-sm">
        <div class="relative p-4 w-full max-w-md max-h-full">
            <!-- Modal content -->
            <div class="relative bg-white border border-gray-200 rounded-2xl shadow-lg p-4 md:p-6">
                <!-- Modal header -->
                <div class="flex items-center justify-between border-b border-gray-200 pb-4 md:pb-5">
                    <h3 id="roleModalTitle" class="text-lg font-bold text-gray-900">Add Role</h3>
                    <button type="button" class="text-gray-400 bg-transparent hover:bg-gray-100 hover:text-gray-900 rounded-lg text-sm w-9 h-9 ms-auto inline-flex justify-center items-center" onclick="closeModal()">
                        <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L17.94 6M18 18L6.06 6" />
                        </svg>
                        <span class="sr-only">Close modal</span>
                    </button>
                </div>
                <!-- Modal body -->
                <input type="hidden" id="editingRoleId" />
                <div class="grid gap-4 grid-cols-2 py-4 md:py-6">
                    <div class="col-span-2">
                        <label for="roleName" class="block mb-2.5 text-sm font-medium text-gray-900">Role Name</label>
                        <input type="text" id="roleName" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-xl focus:ring-blue-500 focus:border-blue-500 block w-full px-3 py-2.5" placeholder="Enter role name" required>
                    </div>
                    <div class="col-span-2 sm:col-span-1">
                        <label for="basicRate" class="block mb-2.5 text-sm font-medium text-gray-900">Basic Rate</label>
                        <input type="number" step="0.01" id="basicRate" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-xl focus:ring-blue-500 focus:border-blue-500 block w-full px-3 py-2.5" placeholder="0.00" required>
                    </div>
                    <div class="col-span-2 sm:col-span-1">
                        <label for="rateType" class="block mb-2.5 text-sm font-medium text-gray-900">Rate Type</label>
                        <select id="rateType" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-xl focus:ring-blue-500 focus:border-blue-500 block w-full px-3 py-2.5">
                            <option value="Semi-Monthly">Semi-Monthly</option>
                            <option value="Monthly">Monthly</option>
                            <option value="Daily">Daily</option>
                        </select>
                    </div>
                    <div class="col-span-2">
                        <label for="roleDesc" class="block mb-2.5 text-sm font-medium text-gray-900">Description</label>
                        <textarea id="roleDesc" rows="4" class="block bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-xl focus:ring-blue-500 focus:border-blue-500 w-full p-3.5" placeholder="Write role description here"></textarea>
                    </div>
                    <div class="col-span-2">
                        <div class="flex items-center space-x-2">
                            <input type="checkbox" id="roleActive" checked class="w-4 h-4 text-blue-600 bg-gray-100 border-gray-300 rounded focus:ring-blue-500">
                            <label for="roleActive" class="text-sm font-medium text-gray-900">Active</label>
                        </div>
                    </div>
                </div>
                <div class="flex items-center space-x-4 border-t border-gray-200 pt-4 md:pt-6">
                    <button id="saveRole" type="button" class="inline-flex items-center text-white bg-blue-600 hover:bg-blue-700 focus:ring-4 focus:ring-blue-300 font-medium leading-5 rounded-xl text-sm px-4 py-2.5 focus:outline-none transition-all shadow-sm">
                        <svg class="w-4 h-4 me-1.5 -ms-0.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14m-7 7V5" />
                        </svg>
                        Save Role
                    </button>
                    <button id="cancelRole" type="button" class="text-gray-500 bg-gray-100 border border-gray-200 hover:bg-gray-200 hover:text-gray-900 focus:ring-4 focus:ring-gray-300 font-medium leading-5 rounded-xl text-sm px-4 py-2.5 focus:outline-none transition-all">Cancel</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Toast helper (auto-dismiss) - client-side usable
    function showToastFromServer() {
        const toasts = document.querySelectorAll('.toast-message');
        toasts.forEach(t => {
            setTimeout(() => {
                t.style.opacity = '0';
                t.style.transform = 'translateY(-10px)';
                setTimeout(() => t.remove(), 300);
            }, 3000);
        });
    }

    function showToast(message, type) {
        const container = document.getElementById('toast-container');
        if (!container) return;
        const toast = document.createElement('div');
        toast.className = 'toast-message group relative overflow-hidden bg-white border rounded-2xl shadow-lg p-4 animate-slide-in';
        if (type === 'success') toast.classList.add('border-green-100');
        if (type === 'error') toast.classList.add('border-red-100');
        toast.innerHTML = `<div class="absolute bottom-0 left-0 h-1 ${type==='success'? 'bg-green-500':'bg-red-500'} transition-all duration-[3000ms] w-full animate-progress"></div>
            <div class="flex items-start gap-4">
                <div class="p-2 ${type==='success'? 'bg-green-50':'bg-red-50'} rounded-xl shrink-0">
                    <svg class="w-6 h-6 ${type==='success'? 'text-green-600':'text-red-600'}" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                <div class="flex-1 pt-0.5">
                    <h3 class="text-sm font-semibold text-gray-900">${type==='success' ? 'Success' : 'Notice'}</h3>
                    <p class="text-sm text-gray-600 mt-1">${message}</p>
                </div>
                <button type="button" onclick="this.closest('.toast-message').remove()" class="text-gray-400 hover:text-gray-600 transition-colors">&times;</button>
            </div>`;
        container.appendChild(toast);
        setTimeout(() => { toast.style.opacity = '0'; toast.style.transform = 'translateY(-10px)'; setTimeout(() => toast.remove(),300); },3000);
    }

    // Run on load to auto-dismiss any server-rendered toasts
    document.addEventListener('DOMContentLoaded', showToastFromServer);

    // Load roles from model

    document.getElementById('fileInput')?.addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (file) {
            // Auto-submit the logo upload form (same behavior as Profile page)
            try { this.form.submit(); } catch (err) { console.error('Failed to submit logo form', err); }
        }
    });


    let roles = @Html.Raw(JsonSerializer.Serialize(Model.Roles));
    // Normalize role objects so rendering works whether API returns camelCase or PascalCase
    function normalizeRole(r) {
        if (!r) return { RoleId: 0, RoleName: '', BasicRate: 0, RateType: '', Description: '', IsActive: true };
        return {
            RoleId: r.RoleId ?? r.roleId ?? 0,
            RoleName: r.RoleName ?? r.roleName ?? r.name ?? '',
            BasicRate: (typeof r.BasicRate !== 'undefined') ? r.BasicRate : (typeof r.basicRate !== 'undefined' ? r.basicRate : 0),
            RateType: r.RateType ?? r.rateType ?? '',
            Description: r.Description ?? r.description ?? '',
            IsActive: (typeof r.IsActive !== 'undefined') ? r.IsActive : (typeof r.isActive !== 'undefined' ? r.isActive : true)
        };
    }

    if (Array.isArray(roles) && roles.length > 0) {
        roles = roles.map(normalizeRole);
    }

    function renderRoles() {
        const tbody = document.getElementById('rolesList');
        tbody.innerHTML = '';

        if (!roles || roles.length === 0) {
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td colspan="5" class="px-6 py-8 text-center text-gray-500">
                    <div class="flex flex-col items-center justify-center">
                        <svg class="w-12 h-12 text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                        </svg>
                        <p class="text-sm">No Roles Configured</p>
                        <p class="text-xs text-gray-400 mt-1">Click "Add New Role" to create one</p>
                    </div>
                </td>
            `;
            tbody.appendChild(tr);
            return;
        }

        roles.forEach(raw => {
            const r = normalizeRole(raw);
            const tr = document.createElement('tr');
            tr.className = 'hover:bg-gray-50/50 transition-colors';
            const statusBadge = r.IsActive ?
                '<span class="px-2 py-0.5 rounded-full text-[10px] font-bold uppercase bg-green-100 text-green-800">Active</span>' :
                '<span class="px-2 py-0.5 rounded-full text-[10px] font-bold uppercase bg-gray-100 text-gray-600">Inactive</span>';

            const editLink = @Model.IsEditMode.ToString().ToLower() ?
                `<a href="#" class="text-blue-600 hover:text-blue-800" onclick="openModal('edit', ${r.RoleId})">Edit</a>` :
                `<span class="text-gray-400">Edit</span>`;

            tr.innerHTML = `
                <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-gray-900">${r.RoleName}</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">₱${(r.BasicRate || 0).toFixed(2)}</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">${r.RateType || ''}</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm">${statusBadge}</td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">${editLink}</td>
            `;
            tbody.appendChild(tr);
        });
    }

    function openModal(mode, id) {
        const modal = document.getElementById('roleModal');
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        document.getElementById('roleModalTitle').innerText = mode === 'add' ? 'Add Role' : 'Edit Role';

        if (mode === 'edit') {
            const numericId = Number(id);
            const r = roles.find(x => Number(x.RoleId) === numericId);
            if (!r) return;
            document.getElementById('editingRoleId').value = r.RoleId;
            document.getElementById('roleName').value = r.RoleName || '';
            document.getElementById('basicRate').value = r.BasicRate || '';
            document.getElementById('rateType').value = r.RateType || 'Semi-Monthly';
            document.getElementById('roleDesc').value = r.Description || '';
            document.getElementById('roleActive').checked = r.IsActive;
        } else {
            document.getElementById('editingRoleId').value = '';
            document.getElementById('roleName').value = '';
            document.getElementById('basicRate').value = '';
            document.getElementById('rateType').value = 'Semi-Monthly';
            document.getElementById('roleDesc').value = '';
            document.getElementById('roleActive').checked = true;
        }
    }

    function closeModal() {
        const modal = document.getElementById('roleModal');
        modal.classList.add('hidden');
        modal.classList.remove('flex');
    }

    // Initialize immediately (script is placed at the end of the page)
    (function initRoles() {
        const btnAddRole = document.getElementById('btnAddRole');
        if (btnAddRole) {
            btnAddRole.addEventListener('click', () => openModal('add'));
        }

        const cancelBtn = document.getElementById('cancelRole');
        if (cancelBtn) cancelBtn.addEventListener('click', closeModal);

        const saveBtn = document.getElementById('saveRole');
        if (saveBtn) {
            saveBtn.addEventListener('click', async () => {
                const id = parseInt(document.getElementById('editingRoleId').value || '0');
                const name = document.getElementById('roleName').value.trim();
                const basicRate = parseFloat(document.getElementById('basicRate').value || '0');
                const rateType = document.getElementById('rateType').value;
                const desc = document.getElementById('roleDesc').value.trim();
                const isActive = document.getElementById('roleActive').checked;

                if (!name) {
                    alert('Role name required');
                    return;
                }

                if (id > 0) {
                    const numericId = Number(id);
                    const r = roles.find(x => Number(x.RoleId) === numericId);
                    if (r) {
                        r.RoleName = name;
                        r.BasicRate = basicRate;
                        r.RateType = rateType;
                        r.Description = desc;
                        r.IsActive = isActive;
                        // show update toast
                        showToast(`${name} Role Updated`, 'success');
                    }
                } else {
                    roles.push({
                        RoleId: 0,
                        RoleName: name,
                        BasicRate: basicRate,
                        RateType: rateType,
                        Description: desc,
                        IsActive: isActive
                    });
                    // show added toast
                    showToast(`${name} Role Added`, 'success');
                }

                closeModal();
                renderRoles();

                // Submit roles to page handler using fetch with antiforgery token (form-encoded)
                try {
                    const antiTokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
                    const token = antiTokenInput ? antiTokenInput.value : '';
                    const payload = `__RequestVerificationToken=${encodeURIComponent(token)}&RolesJson=${encodeURIComponent(JSON.stringify(roles))}`;
                    const url = window.location.pathname + '?handler=SaveCompanyRoles';
                    saveBtn.setAttribute('disabled', 'disabled');
                    const res = await fetch(url, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                        body: payload
                    });

                    // If server redirected (Razor Pages redirect), follow it; otherwise reload
                    if (res.redirected) {
                        window.location.href = res.url;
                    } else {
                        window.location.reload();
                    }
                } catch (err) {
                    console.error('Failed to save roles', err);
                    alert('Failed to save roles. Check console for details.');
                    saveBtn.removeAttribute('disabled');
                }
            });
        }

        // Fetch latest profile and roles without blocking initial render
        async function loadRemoteData() {
            try {
                // fetch company profile
                const profileRes = await fetch(window.location.pathname + '?handler=CompanyProfileJson');
                if (profileRes.ok) {
                    const profile = await profileRes.json();
                    // update logo (prefer UrlImage over LogoUrl); apply gray fallback when missing
                    const logo = document.getElementById('companyLogo');
                    if (logo) {
                        const src = (profile?.urlImage) ? profile.urlImage : (profile?.logoUrl ? profile.logoUrl : '/images/logo.png');
                        logo.src = src;
                        if (!profile?.urlImage && !profile?.logoUrl) {
                            logo.classList.add('filter','grayscale','opacity-50');
                        } else {
                            logo.classList.remove('filter','grayscale','opacity-50');
                        }
                    }
                    // populate inputs if in edit mode
                    const setIf = (name, val) => { const el = document.getElementsByName(name)[0]; if (el) el.value = val ?? ''; };
                    setIf('CompanyName', profile.companyName ?? '');
                    setIf('Address', profile.address ?? '');
                    setIf('ContactEmail', profile.contactEmail ?? '');
                    setIf('ContactPhone', profile.contactPhone ?? '');
                    setIf('Tin', profile.tin ?? '');
                    setIf('PayrollCycle', profile.payrollCycle ?? 0);
                    setIf('WorkHoursPerDay', profile.workHoursPerDay ?? 8);
                    setIf('OvertimeRate', profile.overtimeRate ?? 1.25);
                    setIf('LateGraceMinutes', profile.lateGraceMinutes ?? 15);
                    setIf('HolidayRate', profile.holidayRate ?? 2.0);
                    setIf('AbsentRate', profile.absentRate ?? 0.0);

                    // update non-edit display fields
                    const setDisplay = (id, val, empty) => { const el = document.getElementById(id); if (!el) return; el.textContent = (val && val !== '') ? val : empty; };
                    setDisplay('companyNameDisplay', profile.companyName, '—');
                    setDisplay('tinDisplay', profile.tin, 'No TIN specified');
                    // prefer phone then email for contact display
                    setDisplay('contactDisplay', profile.contactPhone ?? profile.contactEmail, 'No contact specified');
                    setDisplay('addressDisplay', profile.address, 'No address specified');
                }

                // fetch roles
                    const rolesRes = await fetch(window.location.pathname + '?handler=EmployeeRolesJson');
                if (rolesRes.ok) {
                    const remoteRoles = await rolesRes.json();
                    if (Array.isArray(remoteRoles)) {
                        roles = remoteRoles.map(normalizeRole);
                        renderRoles();
                    }
                } else {
                    const txt = await rolesRes.text();
                    console.error('Failed to fetch roles:', rolesRes.status, txt);
                }
            } catch (err) {
                console.debug('Error loading profile/roles', err);
            }
        }

        loadRemoteData();
    })();

    // wire delete to set inactive (no physical delete)
    async function setRoleInactive(id) {
        const r = roles.find(x => x.RoleId === id);
        if (!r) return;
        r.IsActive = false;
        renderRoles();
        document.getElementById('RolesJson').value = JSON.stringify(roles);
        document.getElementById('rolesSyncForm')?.submit();
    }
</script>

<form id="rolesSyncForm" method="post" asp-page-handler="SaveCompanyRoles" class="hidden">
    @Html.AntiForgeryToken()
    <input type="hidden" id="RolesJson" name="RolesJson" />
</form>