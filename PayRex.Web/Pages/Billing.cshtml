@page
@model PayRex.Web.Pages.BillingModel
@{
    ViewData["Title"] = "Billing & Subscription";

    string statusColor(string status) => status switch {
        "Active" or "Trialing" => "bg-green-100 text-green-700",
        "PastDue" or "GracePeriod" => "bg-yellow-100 text-yellow-700",
        "Expired" or "Cancelled" => "bg-red-100 text-red-700",
        _ => "bg-gray-100 text-gray-700"
    };

    string invoiceStatusColor(string status) => status switch {
        "Paid" => "bg-green-100 text-green-700",
        "Pending" or "Unpaid" => "bg-yellow-100 text-yellow-700",
        "Overdue" => "bg-red-100 text-red-700",
        "Archived" => "bg-gray-100 text-gray-500",
        _ => "bg-gray-100 text-gray-700"
    };
}

<div class="max-w-8xl mx-auto px-4 py-6 sm:px-6 lg:px-8 space-y-6">
    <!-- Header -->
    <div class="bg-gradient-to-r from-blue-50 via-white to-blue-50 rounded-2xl border border-blue-100 shadow-sm overflow-hidden relative">
        <div class="absolute top-0 right-0 -mt-16 -mr-16 w-64 h-64 bg-yellow-100 rounded-full blur-3xl opacity-20"></div>
        <div class="absolute bottom-0 left-0 -mb-16 -ml-16 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
        <div class="px-6 py-8 sm:px-10 relative z-10">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <div>
                    <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight">Billing & Subscription</h1>
                    <p class="mt-2 text-gray-600">Manage your subscription, view invoices, and make payments</p>
                </div>
                <span class="inline-flex items-center px-4 py-2 rounded-xl text-sm font-semibold bg-blue-100 text-blue-700">
                    <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20"><path d="M4 4a2 2 0 00-2 2v1h16V6a2 2 0 00-2-2H4z" /><path fill-rule="evenodd" d="M18 9H2v5a2 2 0 002 2h12a2 2 0 002-2V9zM4 13a1 1 0 011-1h1a1 1 0 110 2H5a1 1 0 01-1-1zm5-1a1 1 0 100 2h1a1 1 0 100-2H9z" clip-rule="evenodd" /></svg>
                    Billing
                </span>
            </div>
        </div>
    </div>

    <!-- Subscription Status -->
    @if (Model.Subscription != null)
    {
        var sub = Model.Subscription;
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100 bg-gradient-to-r from-gray-50 to-white">
                <h2 class="text-base font-semibold text-gray-900 flex items-center">
                    <svg class="w-5 h-5 mr-2 text-blue-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
                    Current Subscription
                </h2>
            </div>
            <div class="p-6">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                    <div>
                        <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Plan</p>
                        <p class="text-lg font-bold text-gray-900">@sub.PlanName</p>
                        <p class="text-sm text-gray-500">@sub.BillingCycle · Up to @sub.MaxEmployees employees</p>
                    </div>
                    <div>
                        <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Status</p>
                        <span class="inline-flex items-center px-3 py-1 rounded-lg text-sm font-semibold @statusColor(sub.Status)">@sub.Status</span>
                        @if (sub.IsTrialing)
                        {
                            <p class="text-xs text-blue-600 mt-1">Free trial period</p>
                        }
                    </div>
                    <div>
                        <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Period</p>
                        <p class="text-sm font-medium text-gray-900">@sub.StartDate.ToString("MMM dd, yyyy") — @sub.EndDate.ToString("MMM dd, yyyy")</p>
                        @if (sub.DaysRemaining > 0 && !sub.IsExpired)
                        {
                            <p class="text-xs text-gray-500 mt-1">@sub.DaysRemaining days remaining</p>
                        }
                    </div>
                    <div>
                        <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Price</p>
                        <p class="text-lg font-bold text-gray-900">₱@sub.PlanPrice.ToString("N2")</p>
                        <p class="text-xs text-gray-500">per @sub.BillingCycle.ToLower()</p>
                    </div>
                </div>

                @if (sub.IsExpired || sub.IsInGracePeriod || sub.DaysRemaining <= 7)
                {
                    <div class="mt-6 pt-6 border-t border-gray-100 flex flex-col sm:flex-row items-start sm:items-center gap-4">
                        @if (sub.IsExpired)
                        {
                            <div class="flex items-center gap-2 text-red-600">
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd" /></svg>
                                <span class="text-sm font-medium">Your subscription has expired. Renew to continue using all features.</span>
                            </div>
                        }
                        else if (sub.IsInGracePeriod)
                        {
                            <div class="flex items-center gap-2 text-yellow-600">
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" /></svg>
                                <span class="text-sm font-medium">Grace period active. Please renew within @sub.GracePeriodDays days.</span>
                            </div>
                        }
                        else
                        {
                            <div class="flex items-center gap-2 text-yellow-600">
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" /></svg>
                                <span class="text-sm font-medium">Subscription expires in @sub.DaysRemaining days.</span>
                            </div>
                        }
                        <form method="post" asp-page-handler="Renew" class="flex-shrink-0">
                            <button type="submit" class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-white bg-blue-600 rounded-xl hover:bg-blue-700 transition-colors shadow-sm">
                                <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 2a1 1 0 011 1v2.101a7.002 7.002 0 0111.601 2.566 1 1 0 11-1.885.666A5.002 5.002 0 005.999 7H9a1 1 0 010 2H4a1 1 0 01-1-1V3a1 1 0 011-1zm.008 9.057a1 1 0 011.276.61A5.002 5.002 0 0014.001 13H11a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0v-2.101a7.002 7.002 0 01-11.601-2.566 1 1 0 01.61-1.276z" clip-rule="evenodd" /></svg>
                                Renew Subscription
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8 text-center">
            <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" /></svg>
            <p class="text-gray-500 font-medium">No active subscription found</p>
            <p class="text-gray-400 text-sm mt-1">Contact your system administrator to set up a subscription.</p>
        </div>
    }

    <!-- Invoice History -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 bg-gradient-to-r from-gray-50 to-white">
            <h2 class="text-base font-semibold text-gray-900 flex items-center">
                <svg class="w-5 h-5 mr-2 text-blue-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd" /></svg>
                Invoice History
            </h2>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-gray-50/80">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Invoice #</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Description</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Amount</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Due Date</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @if (Model.Invoices.Any())
                    {
                        @foreach (var inv in Model.Invoices)
                        {
                            <tr class="hover:bg-gray-50/50 transition-colors">
                                <td class="px-6 py-3 text-sm font-mono text-gray-900">@inv.InvoiceNumber</td>
                                <td class="px-6 py-3 text-sm text-gray-600">@(inv.Description ?? "Subscription")</td>
                                <td class="px-6 py-3 text-sm font-semibold text-gray-900">₱@inv.Amount.ToString("N2")</td>
                                <td class="px-6 py-3 text-sm text-gray-500">@inv.DueDate.ToString("MMM dd, yyyy")</td>
                                <td class="px-6 py-3">
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-semibold @invoiceStatusColor(inv.Status)">@inv.Status</span>
                                </td>
                                <td class="px-6 py-3">
                                    <div class="flex items-center gap-2">
                                        <button type="button" onclick="openInvoiceModal(@inv.InvoiceId, '@inv.InvoiceNumber', '@inv.Amount.ToString("N2")', '@(inv.Description ?? "Subscription")', '@inv.DueDate.ToString("MMM dd, yyyy")', '@inv.Status', '@(inv.PaidAt?.ToString("MMM dd, yyyy") ?? "")')" class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-blue-700 bg-blue-50 rounded-lg hover:bg-blue-100 transition-colors">
                                            <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                                            View
                                        </button>
                                        @if (inv.Status == "Unpaid")
                                        {
                                            <form method="post" asp-page-handler="PayInvoice" class="inline">
                                                <input type="hidden" name="invoiceId" value="@inv.InvoiceId" />
                                                <button type="submit" class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors">
                                                    <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" /></svg>
                                                    Pay Now
                                                </button>
                                            </form>
                                            <form method="post" asp-page-handler="DeleteInvoice" class="inline" onsubmit="return confirm('Permanently delete this unpaid invoice? This cannot be undone.')">
                                                <input type="hidden" name="invoiceId" value="@inv.InvoiceId" />
                                                <button type="submit" class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-red-700 bg-red-50 rounded-lg hover:bg-red-100 transition-colors">
                                                    <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                                                    Delete
                                                </button>
                                            </form>
                                        }
                                        @if (inv.Status == "Paid" || inv.Status == "Voided")
                                        {
                                            <form method="post" asp-page-handler="ArchiveInvoice" class="inline" onsubmit="return confirm('Archive this invoice?')">
                                                <input type="hidden" name="invoiceId" value="@inv.InvoiceId" />
                                                <button type="submit" class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-gray-600 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors">
                                                    <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" /></svg>
                                                    Archive
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="px-6 py-12 text-center">
                                <svg class="w-12 h-12 text-gray-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                                <p class="text-gray-500 font-medium">No invoices yet</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Invoice View Modal -->
<div id="invoiceModal" class="fixed inset-0 z-50 hidden overflow-y-auto">
    <div class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm" onclick="closeInvoiceModal()"></div>
    <div class="flex min-h-full items-center justify-center p-4">
        <div class="relative bg-white rounded-2xl shadow-xl w-full max-w-md">
            <div class="flex items-center justify-between border-b px-6 py-4">
                <h3 class="text-lg font-semibold text-gray-900">Invoice Details</h3>
                <button type="button" onclick="closeInvoiceModal()" class="p-1.5 text-gray-400 hover:bg-gray-100 rounded-lg">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                </button>
            </div>
            <div class="px-6 py-5 space-y-3">
                <div class="flex justify-between"><span class="text-sm text-gray-500">Invoice #</span><span id="modal-inv-number" class="text-sm font-semibold text-gray-900"></span></div>
                <div class="flex justify-between"><span class="text-sm text-gray-500">Description</span><span id="modal-inv-desc" class="text-sm text-gray-700"></span></div>
                <div class="flex justify-between"><span class="text-sm text-gray-500">Amount</span><span id="modal-inv-amount" class="text-sm font-semibold text-gray-900"></span></div>
                <div class="flex justify-between"><span class="text-sm text-gray-500">Due Date</span><span id="modal-inv-due" class="text-sm text-gray-700"></span></div>
                <div class="flex justify-between"><span class="text-sm text-gray-500">Status</span><span id="modal-inv-status" class="text-sm font-semibold"></span></div>
                <div id="modal-inv-paid-row" class="flex justify-between hidden"><span class="text-sm text-gray-500">Paid On</span><span id="modal-inv-paid" class="text-sm text-green-600 font-medium"></span></div>
            </div>
            <div class="border-t bg-gray-50 px-6 py-4 flex justify-end">
                <button type="button" onclick="closeInvoiceModal()" class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-lg hover:bg-gray-200">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Show server-side toasts on page load
    document.addEventListener('DOMContentLoaded', function() {
        const successMsg = @Json.Serialize(Model.SuccessMessage);
        const errorMsg = @Json.Serialize(Model.ErrorMessage ?? Model.BillingTempError);
        if (successMsg) showToast(successMsg, 'success');
        if (errorMsg) showToast(errorMsg, 'error');
    });

    // Show loading toast on invoice action form submit
    document.querySelectorAll('form[asp-page-handler]').forEach(function(form) {
        form.addEventListener('submit', function() {
            showLoadingToast('Processing...');
        });
    });

    function openInvoiceModal(id, number, amount, desc, due, status, paid) {
        document.getElementById('modal-inv-number').textContent = number;
        document.getElementById('modal-inv-desc').textContent = desc;
        document.getElementById('modal-inv-amount').textContent = '₱' + amount;
        document.getElementById('modal-inv-due').textContent = due;
        var statusEl = document.getElementById('modal-inv-status');
        statusEl.textContent = status;
        statusEl.className = 'text-sm font-semibold ' + (status === 'Paid' ? 'text-green-600' : status === 'Unpaid' ? 'text-red-600' : 'text-gray-600');
        var paidRow = document.getElementById('modal-inv-paid-row');
        if (paid) { paidRow.classList.remove('hidden'); document.getElementById('modal-inv-paid').textContent = paid; }
        else { paidRow.classList.add('hidden'); }
        document.getElementById('invoiceModal').classList.remove('hidden');
    }
    function closeInvoiceModal() { document.getElementById('invoiceModal').classList.add('hidden'); }
</script>
}
