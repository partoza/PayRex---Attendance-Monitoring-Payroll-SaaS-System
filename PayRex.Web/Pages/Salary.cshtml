@page
@model PayRex.Web.Pages.SalaryModel
@{
    ViewData["Title"] = "Salary Computation";
}

<div class="max-w-8xl mx-auto px-4 py-6 sm:px-6 lg:px-8 space-y-6">
    <!-- Header -->
    <div class="bg-gradient-to-r from-blue-600 to-blue-800 rounded-2xl shadow-lg p-8 text-white relative overflow-hidden">
        <div class="absolute top-0 right-0 -mt-10 -mr-10 w-64 h-64 bg-white/10 rounded-full blur-3xl"></div>
        <div class="relative z-10 flex flex-col md:flex-row justify-between items-center gap-6">
            <div>
                <h1 class="text-3xl font-bold tracking-tight">Salary Computation</h1>
                <p class="mt-2 text-blue-100 text-lg">Payroll Period: <span class="font-semibold text-white">@Model.CurrentPeriod</span></p>
            </div>
            <div class="bg-white/10 backdrop-blur-md rounded-2xl px-6 py-4 border border-white/20">
                <p class="text-blue-100 text-sm font-medium uppercase tracking-wider">Total Payroll Cost</p>
                <p class="text-3xl font-extrabold mt-1">₱@Model.TotalPayrollCost.ToString("N2")</p>
            </div>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="flex flex-col sm:flex-row justify-between gap-4 bg-white p-4 rounded-2xl border border-gray-100 shadow-sm">
        <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
            <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <svg class="h-5 w-5 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
                    </svg>
                </div>
                <input type="text" id="searchInput" 
                       class="pl-10 block w-full sm:w-64 rounded-xl border-gray-300 shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm" 
                       placeholder="Search employees..." onkeyup="filterTable()">
            </div>
        </div>
        
        <div class="flex gap-3">
             <button class="inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-xl text-gray-700 bg-white hover:bg-gray-50 transition-colors">
                <i class="bi bi-download mr-2"></i> Export
            </button>
            <button class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-xl text-white bg-blue-600 hover:bg-blue-700 shadow-sm transition-colors">
                Generate All
            </button>
        </div>
    </div>

    <!-- Payroll Table -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200" id="payrollTable">
                <thead class="bg-gray-50">
                    <tr>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Employee</th>
                        <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Basic Pay</th>
                        <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Deductions</th>
                        <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Net Pay</th>
                        <th scope="col" class="relative px-6 py-3"><span class="sr-only">Actions</span></th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    @foreach (var payroll in Model.Payrolls)
                    {
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center">
                                    <div class="h-8 w-8 rounded-full bg-blue-100 flex items-center justify-center text-blue-700 font-bold text-xs">
                                        @payroll.EmployeeName.Substring(0, 1)
                                    </div>
                                    <div class="ml-3">
                                        <div class="text-sm font-medium text-gray-900 search-name">@payroll.EmployeeName</div>
                                        <div class="text-xs text-gray-500">@payroll.Role</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm text-gray-900 font-medium">
                                ₱@payroll.BasicPay.ToString("N2")
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm text-red-600">
                                -₱@payroll.TotalDeductions.ToString("N2")
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-bold text-blue-700">
                                ₱@payroll.NetPay.ToString("N2")
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                <button onclick="openModal(@System.Text.Json.JsonSerializer.Serialize(payroll))" class="text-blue-600 hover:text-blue-900">View Breakdown</button>
                            </td>
                        </tr>
                    }
                </tbody>
                 <tfoot class="bg-gray-50 font-bold text-gray-900">
                    <tr>
                        <td class="px-6 py-3">TOTAL</td>
                        <td class="px-6 py-3 text-right">₱@Model.Payrolls.Sum(x => x.BasicPay).ToString("N2")</td>
                        <td class="px-6 py-3 text-right text-red-600">-₱@Model.Payrolls.Sum(x => x.TotalDeductions).ToString("N2")</td>
                        <td class="px-6 py-3 text-right text-blue-700">₱@Model.Payrolls.Sum(x => x.NetPay).ToString("N2")</td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

<!-- Breakdown Modal -->
<div id="breakdownModal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
  <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
    <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" aria-hidden="true" onclick="closeModal()"></div>
    <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
    <div class="inline-block align-bottom bg-white rounded-2xl text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full">
      <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
        <div class="sm:flex sm:items-start">
          <div class="mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full bg-blue-100 sm:mx-0 sm:h-10 sm:w-10">
            <svg class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left w-full">
            <h3 class="text-lg leading-6 font-medium text-gray-900" id="modal-title">Payroll Breakdown</h3>
            <div class="mt-4 space-y-4">
               <div>
                   <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide">Employee Information</label>
                   <div class="mt-2 bg-gray-50 rounded-lg p-3">
                       <p class="text-sm font-bold text-gray-900" id="modalName">Name</p>
                       <p class="text-sm text-gray-500" id="modalBasic">Basic Pay: ₱0.00</p>
                   </div>
               </div>
               
               <div>
                   <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide">Deductions</label>
                   <div class="mt-2 space-y-2">
                       <div class="flex justify-between text-sm">
                           <span class="text-gray-600">SSS Contribution</span>
                           <span class="font-medium text-red-600" id="modalSSS">-₱0.00</span>
                       </div>
                       <div class="flex justify-between text-sm">
                           <span class="text-gray-600">PhilHealth</span>
                           <span class="font-medium text-red-600" id="modalPhilHealth">-₱0.00</span>
                       </div>
                       <div class="flex justify-between text-sm">
                           <span class="text-gray-600">Pag-IBIG</span>
                           <span class="font-medium text-red-600" id="modalPagIBIG">-₱0.00</span>
                       </div>
                       <div class="flex justify-between text-sm">
                           <span class="text-gray-600">Income Tax (WHT)</span>
                           <span class="font-medium text-red-600" id="modalTax">-₱0.00</span>
                       </div>
                       <div class="flex justify-between text-sm">
                           <span class="text-gray-600">Late / Undertime</span>
                           <span class="font-medium text-red-600" id="modalLate">-₱0.00</span>
                       </div>
                   </div>
               </div>

               <div class="pt-4 border-t border-gray-100 flex justify-between items-center text-lg font-bold">
                   <span class="text-gray-900">NET PAY</span>
                   <span class="text-blue-700" id="modalNet">₱0.00</span>
               </div>
            </div>
          </div>
        </div>
      </div>
      <div class="bg-gray-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse">
        <button type="button" class="w-full inline-flex justify-center rounded-xl border border-transparent shadow-sm px-4 py-2 bg-blue-600 text-base font-medium text-white hover:bg-blue-700 focus:outline-none sm:ml-3 sm:w-auto sm:text-sm" onclick="closeModal()">
          Close
        </button>
      </div>
    </div>
  </div>
</div>

<script>
    function filterTable() {
        var input = document.getElementById("searchInput");
        var filter = input.value.toUpperCase();
        var table = document.getElementById("payrollTable");
        var tr = table.getElementsByTagName("tr");

        for (var i = 1; i < tr.length - 1; i++) { // Skip header and footer
            var nameTd = tr[i].querySelector(".search-name");
            if (nameTd) {
                var nameText = nameTd.textContent || nameTd.innerText;
                if (nameText.toUpperCase().indexOf(filter) > -1) {
                    tr[i].style.display = "";
                } else {
                    tr[i].style.display = "none";
                }
            }
        }
    }

    function openModal(payroll) {
        document.getElementById('modalName').textContent = payroll.EmployeeName;
        document.getElementById('modalBasic').textContent = "Basic Pay: ₱" + payroll.BasicPay.toLocaleString('en-US', {minimumFractionDigits: 2});
        
        document.getElementById('modalSSS').textContent = "-₱" + payroll.SSS.toLocaleString('en-US', {minimumFractionDigits: 2});
        document.getElementById('modalPhilHealth').textContent = "-₱" + payroll.PhilHealth.toLocaleString('en-US', {minimumFractionDigits: 2});
        document.getElementById('modalPagIBIG').textContent = "-₱" + payroll.PagIBIG.toLocaleString('en-US', {minimumFractionDigits: 2});
        document.getElementById('modalTax').textContent = "-₱" + payroll.Tax.toLocaleString('en-US', {minimumFractionDigits: 2});
        document.getElementById('modalLate').textContent = "-₱" + payroll.LateDeduction.toLocaleString('en-US', {minimumFractionDigits: 2});
        
        document.getElementById('modalNet').textContent = "₱" + payroll.NetPay.toLocaleString('en-US', {minimumFractionDigits: 2});

        document.getElementById('breakdownModal').classList.remove('hidden');
    }

    function closeModal() {
        document.getElementById('breakdownModal').classList.add('hidden');
    }
</script>
