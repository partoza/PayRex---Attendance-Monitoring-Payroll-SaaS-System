        <div class="flex min-h-full items-center justify-center p-2 sm:p-4 text-center">
            <div class="relative transform overflow-hidden rounded-lg bg-white text-left shadow-xl transition-all w-full sm:w-[90%] md:w-[55%] lg:w-[40%] max-w-lg mx-auto">
                <div class="flex items-center justify-between border-b border-gray-200 bg-white px-4 py-3 sm:px-6 sm:py-4">
                    <h3 class="text-base sm:text-lg font-semibold text-gray-900">Release Payroll</h3>
                    <button type="button" onclick="closeReleaseModal()" class="rounded-lg p-1.5 text-gray-400 hover:bg-gray-100 hover:text-gray-500">
                        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
                    </button>
                </div>
                <div class="px-4 py-4 sm:px-6 sm:py-5">
                    <div class="flex items-start gap-3">
                        <div class="w-10 h-10 rounded-full bg-emerald-100 flex items-center justify-center flex-shrink-0">
                            <svg class="w-5 h-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" /></svg>
                        </div>
                        <div>
                            <p class="text-sm font-semibold text-gray-900 mb-1">Confirm Payroll Release</p>
                            <p class="text-sm text-gray-600">This will mark the period as <strong>Released</strong> and make all payslips visible to employees. This action cannot be undone.</p>
                        </div>
                    </div>
                </div>
                <div class="border-t border-gray-200 bg-gray-50 px-4 py-3 sm:px-6 flex justify-end gap-3">
                    <button type="button" onclick="closeReleaseModal()" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50">Cancel</button>
                    <button type="button" onclick="confirmRelease()" id="btnConfirmRelease" class="px-4 py-2 text-sm font-medium text-white bg-emerald-600 rounded-lg hover:bg-emerald-700">
                        Yes, Release Payroll
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const TOKEN = document.getElementById('authToken')?.value || '';
    const SELECTED_PERIOD = @(Model.SelectedPeriodId?.ToString() ?? "null");
    const SELECTED_STATUS = '@Model.SelectedPeriodStatus';
    
    let currentPage = 1;

    function changePeriod(val) {
        if (val) window.location.href = '/Salary?periodId=' + val;
    }

    // Modal helpers
    const openCreatePeriod = () => document.getElementById('createPeriodModal')?.classList.remove('hidden');
    const closePeriodModal = () => document.getElementById('createPeriodModal')?.classList.add('hidden');
    const closeBreakdown = () => document.getElementById('breakdownModal')?.classList.add('hidden');

    async function submitCreatePeriod() {
        const start = document.getElementById('newPeriodStart').value;
        const end   = document.getElementById('newPeriodEnd').value;
        const name  = document.getElementById('newPeriodName').value;
        if (!start || !end) { showToast('Please fill in start and end dates.', 'error'); return; }
        
        const btn = document.getElementById('createPeriodBtn');
        const originalText = btn.textContent;
        btn.disabled = true; 
        btn.innerHTML = '<svg class="animate-spin w-4 h-4 mr-2 inline" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"></path></svg> Thinking...';
        
        try {
            const res = await fetch(`${window.ApiBaseUrl}/api/payroll/periods`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + TOKEN },
                body: JSON.stringify({ startDate: start, endDate: end, periodName: name || null })
            });
            const data = await res.json().catch(() => ({}));
            
            if (res.ok) {
                showToast('New payroll period established successfully.', 'success');
                closePeriodModal();
                setTimeout(() => window.location.reload(), 1200);
            } else {
                showToast(data.message || 'The system encountered an error creating the period.', 'error');
            }
        } catch (e) {
            showToast('Network error while creating period.', 'error');
        } finally {
            btn.disabled = false; btn.textContent = originalText;
        }
    }

    async function runPayroll() {
        if (!SELECTED_PERIOD) { showToast('Please select a period first.', 'error'); return; }
        const btn = document.getElementById('btnRunPayroll');
        const originalHtml = btn.innerHTML;
        
        btn.disabled = true;
        showLoadingToast('Running payroll computation...');
        btn.innerHTML = '<svg class="animate-spin w-4 h-4 inline mr-2" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path></svg> Processing...';

        try {
            const computeRes = await fetch(`${window.ApiBaseUrl}/api/payroll/compute/${SELECTED_PERIOD}`, {
                method: 'POST',
                headers: { 'Authorization': 'Bearer ' + TOKEN }
            });
            const computeData = await computeRes.json().catch(() => ({}));
            hideUploadToast();

            if (!computeRes.ok) {
                showToast(computeData.message || 'Failed to submit payroll for review.', 'error');
                return;
            }

            showToast(computeData.message || `Payroll submitted for review. ${computeData.employeeCount || 0} employees pending.`, 'success');
            setTimeout(() => window.location.reload(), 1500);
        } catch (e) {
            hideUploadToast();
            showToast('A network error occurred. Please try again.', 'error');
        } finally {
            btn.disabled = false;
            btn.innerHTML = originalHtml;
        }
    }

    // Pagination & Search Logic
    function updateView() {
        const search = (document.getElementById('searchInput')?.value || '').toUpperCase();
        const pageSize = parseInt(document.getElementById('pageSizeSelect')?.value || '25');
        const rows = Array.from(document.querySelectorAll('.payroll-row'));
        
        // Filter
        const filtered = rows.filter(r => {
            const name = (r.querySelector('.search-name')?.textContent || '').toUpperCase();
            return search === '' || name.includes(search);
        });

        // Toggle visibility
        const start = (currentPage - 1) * pageSize;
        const end = start + pageSize;
        
        rows.forEach(r => r.classList.add('hidden'));
        filtered.slice(start, end).forEach(r => r.classList.remove('hidden'));

        // Update Info
        const info = document.getElementById('payrollPaginationInfo');
        if (info) {
            if (filtered.length === 0) info.textContent = "No matching records";
            else info.textContent = `Showing ${start + 1} to ${Math.min(end, filtered.length)} of ${filtered.length} records`;
        }

        const countLabel = document.getElementById('payrollSummaryCount');
        if (countLabel) countLabel.textContent = `${filtered.length} employees found`;

        renderPaginationButtons(Math.ceil(filtered.length / pageSize));
    }

    function renderPaginationButtons(totalPages) {
        const nav = document.getElementById('payrollPaginationNav');
        if (!nav) return;
        nav.innerHTML = '';
        if (totalPages <= 1) return;

        const btn = (label, page, active = false, disabled = false) => {
            const b = document.createElement('button');
            b.innerHTML = label;
            b.className = `px-3 py-1.5 text-sm font-medium border rounded-lg transition-all ${
                active    ? 'bg-blue-600 text-white border-blue-600' :
                disabled  ? 'opacity-40 cursor-not-allowed bg-gray-100 border-gray-200' :
                            'bg-white text-gray-700 border-gray-200 hover:bg-gray-100'
            }`;
            if (!disabled && !active) b.onclick = () => { currentPage = page; updateView(); };
            return b;
        };

        nav.appendChild(btn('‹', currentPage - 1, false, currentPage === 1));
        
        const getPages = (c, t) => {
            if (t <= 5) return Array.from({length: t}, (_,i) => i+1);
            if (c <= 3) return [1,2,3,4,'...',t];
            if (c >= t - 2) return [1,'...',t-3,t-2,t-1,t];
            return [1,'...',c-1,c,c+1,'...',t];
        };

        getPages(currentPage, totalPages).forEach(p => {
            if (p === '...') {
                const s = document.createElement('span');
                s.className = 'px-2 py-1.5 text-gray-400 text-sm'; s.textContent = '\u2026';
                nav.appendChild(s);
            } else {
                nav.appendChild(btn(p, p, p === currentPage));
            }
        });

        nav.appendChild(btn('›', currentPage + 1, false, currentPage === totalPages));
    }

    function openBreakdown(p) {
        document.getElementById('bdAvatar').textContent = (p.EmployeeName || '?').charAt(0).toUpperCase();
        document.getElementById('bdName').textContent = p.EmployeeName;
        document.getElementById('bdCode').textContent = p.EmployeeCode || 'EMP-XXXX';
        
        const fmt = v => '₱' + (v || 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        
        document.getElementById('bdBasic').textContent = fmt(p.BasicPay);
        document.getElementById('bdOT').textContent = fmt(p.OvertimePay);
        document.getElementById('bdHoliday').textContent = fmt(p.HolidayPay);
        document.getElementById('bdAllowances').textContent = fmt(p.Allowances);
        document.getElementById('bdGross').textContent = fmt(p.GrossPay);
        document.getElementById('bdDeductions').textContent = '-' + fmt(p.TotalDeductions);
        document.getElementById('bdNet').textContent = fmt(p.NetPay);
        
        document.getElementById('breakdownModal').classList.remove('hidden');
    }

    function downloadBreakdownPdf() {
        const name = document.getElementById('bdName')?.textContent || 'Payroll';
        const element = document.getElementById('breakdownContent');
        if (!element) return;
        if (typeof showLoadingToast === 'function') showLoadingToast('Generating PDF...');
        if (typeof html2pdf !== 'undefined') {
            const opt = {
                margin: [0.5, 0.5, 0.5, 0.5],
                filename: `Payroll_${name.replace(/\s+/g, '_')}.pdf`,
                image: { type: 'jpeg', quality: 0.98 },
                html2canvas: { scale: 2, useCORS: true },
                jsPDF: { unit: 'in', format: 'letter', orientation: 'portrait' }
            };
            html2pdf().set(opt).from(element).save().then(() => {
                if (typeof hideUploadToast === 'function') hideUploadToast();
                showToast('PDF downloaded successfully!', 'success');
            });
        } else {
            if (typeof hideUploadToast === 'function') hideUploadToast();
            showToast('PDF library not loaded. Please try again.', 'error');
        }
    }

    // Init
    document.addEventListener('DOMContentLoaded', () => {
        updateView();
    });

    async function approvePeriod() {
        if (!SELECTED_PERIOD) { showToast('Please select a period first.', 'error'); return; }
        const btn = document.getElementById('btnApprove');
        const orig = btn?.innerHTML;
        if (btn) { btn.disabled = true; btn.innerHTML = '<svg class="animate-spin w-4 h-4 inline mr-1" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"></path></svg> Approving...'; }
        showLoadingToast('Approving payroll period...');
        try {
            const res = await fetch(`${window.ApiBaseUrl}/api/payroll/periods/${SELECTED_PERIOD}/approve`, {
                method: 'POST',
                headers: { 'Authorization': 'Bearer ' + TOKEN }
            });
            const data = await res.json().catch(() => ({}));
            hideUploadToast();
            if (res.ok) {
                showToast(data.message || 'Payroll period approved.', 'success');
                setTimeout(() => window.location.reload(), 1200);
            } else {
                showToast(data.message || 'Failed to approve period.', 'error');
            }
        } catch (e) {
            hideUploadToast();
            showToast('Network error during approval.', 'error');
        } finally {
            if (btn) { btn.disabled = false; btn.innerHTML = orig; }
        }
    }

    const openRejectModal  = () => document.getElementById('rejectPeriodModal')?.classList.remove('hidden');
    const closeRejectModal = () => { document.getElementById('rejectPeriodModal')?.classList.add('hidden'); document.getElementById('rejectRemarks').value = ''; };

    async function submitReject() {
        const remarks = document.getElementById('rejectRemarks')?.value?.trim();
        if (!remarks) { showToast('Please provide remarks for rejection.', 'error'); return; }
        if (!SELECTED_PERIOD) return;
        const btn = document.getElementById('btnConfirmReject');
        const orig = btn?.innerHTML;
        if (btn) { btn.disabled = true; btn.innerHTML = '<svg class="animate-spin w-4 h-4 inline mr-1" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"></path></svg> Rejecting...'; }
        showLoadingToast('Rejecting payroll period...');
        try {
            const res = await fetch(`${window.ApiBaseUrl}/api/payroll/periods/${SELECTED_PERIOD}/reject`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + TOKEN },
                body: JSON.stringify({ remarks })
            });
            const data = await res.json().catch(() => ({}));
            hideUploadToast();
            if (res.ok) {
                closeRejectModal();
                showToast(data.message || 'Period returned to Draft.', 'success');
                setTimeout(() => window.location.reload(), 1200);
            } else {
                showToast(data.message || 'Failed to reject period.', 'error');
            }
        } catch (e) {
            hideUploadToast();
            showToast('Network error during rejection.', 'error');
        } finally {
            if (btn) { btn.disabled = false; btn.innerHTML = orig; }
        }
    }

    const openReleaseModal  = () => document.getElementById('releasePeriodModal')?.classList.remove('hidden');
    const closeReleaseModal = () => document.getElementById('releasePeriodModal')?.classList.add('hidden');

    async function confirmRelease() {
        if (!SELECTED_PERIOD) return;
        const btn = document.getElementById('btnConfirmRelease');
        const orig = btn?.innerHTML;
        if (btn) { btn.disabled = true; btn.innerHTML = '<svg class="animate-spin w-4 h-4 inline mr-1" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"></path></svg> Releasing...'; }
        showLoadingToast('Releasing payroll to employees...');
        try {
            const res = await fetch(`${window.ApiBaseUrl}/api/payroll/periods/${SELECTED_PERIOD}/release`, {
                method: 'POST',
                headers: { 'Authorization': 'Bearer ' + TOKEN }
            });
            const data = await res.json().catch(() => ({}));
            hideUploadToast();
            if (res.ok) {
                closeReleaseModal();
                showToast(data.message || 'Payroll released successfully.', 'success');
                setTimeout(() => window.location.reload(), 1200);
            } else {
                showToast(data.message || 'Failed to release payroll.', 'error');
            }
        } catch (e) {
            hideUploadToast();
            showToast('Network error during release.', 'error');
        } finally {
            if (btn) { btn.disabled = false; btn.innerHTML = orig; }
        }
    }
</script>
