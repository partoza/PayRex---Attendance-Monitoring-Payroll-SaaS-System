                                <input type="date" id="newPeriodStart" class="w-full px-3 sm:px-4 py-2 sm:py-2.5 border border-gray-300 rounded-lg sm:rounded-xl text-xs sm:text-sm bg-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all text-gray-700">
