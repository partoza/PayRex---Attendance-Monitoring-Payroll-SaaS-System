@page
@model PayRex.Web.Pages.SalaryModel
@{
    ViewData["Title"] = "Salary Computation";
    var hasPeriod = Model.SelectedPeriodId.HasValue;
    var periodStatus = Model.SelectedPeriodStatus;
    var authCookie = HttpContext.Request.Cookies["PayRex.AuthToken"] ?? "";
    var (badgeBg, badgeLabel) = periodStatus switch {
        "Draft"    => ("bg-gray-100 text-gray-600 border-gray-200",     "Draft"),
        "Computed" => ("bg-yellow-100 text-yellow-700 border-yellow-200", "Pending Review"),
        "Approved" => ("bg-green-100 text-green-700 border-green-200",   "Approved"),
        "Released" => ("bg-blue-100 text-blue-700 border-blue-200",     "Released"),
        _          => ("bg-gray-100 text-gray-500 border-gray-200",      "Unknown")
    };
}

<input type="hidden" id="authToken" value="@authCookie" />
<div class="max-w-8xl mx-auto px-4 sm:px-6 lg:px-8 space-y-5 sm:space-y-6">
    <!-- Header -->
    <div class="bg-gradient-to-r from-blue-50 via-white to-blue-50 rounded-xl sm:rounded-2xl border border-blue-100 shadow-sm overflow-hidden relative">
        <div class="absolute top-0 right-0 -mt-16 -mr-16 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
        <div class="absolute bottom-0 left-0 -mb-16 -ml-16 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
        <div class="px-4 py-5 sm:px-8 sm:py-8 relative z-10">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 sm:gap-4">
                <div>
                    <h1 class="text-xl sm:text-2xl lg:text-3xl font-extrabold text-gray-900 tracking-tight">Salary Computation</h1>
                    <p class="mt-1 sm:mt-2 text-sm sm:text-base text-gray-600">Manage and compute payroll for current periods</p>
                </div>
                <div class="flex items-center gap-2 sm:gap-3">
                    <span class="inline-flex items-center px-3 sm:px-4 py-1.5 sm:py-2 rounded-lg sm:rounded-xl text-xs sm:text-sm font-semibold bg-blue-100 text-blue-700">
                        <svg class="w-3 h-3 sm:w-4 sm:h-4 mr-1.5 sm:mr-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 4a2 2 0 00-2 2v4a2 2 0 002 2V6h10a2 2 0 00-2-2H4zm2 6a2 2 0 012-2h8a2 2 0 012 2v4a2 2 0 01-2 2H8a2 2 0 01-2-2v-4zm6 4a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" /></svg>
                        <span class="hidden sm:inline">Total: </span>₱@Model.TotalPayrollCost.ToString("N2")
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Payroll Flow Guide -->
    <div class="bg-white rounded-xl border border-blue-100 shadow-sm overflow-hidden">
        <div class="px-4 py-3 sm:px-6 sm:py-4 border-b border-gray-100 flex items-center justify-between">
            <h2 class="text-sm font-semibold text-gray-700 flex items-center gap-2">
                <svg class="w-4 h-4 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                Payroll Approval Workflow
            </h2>
            <button onclick="document.getElementById('workflowGuide').classList.toggle('hidden')" class="text-xs text-blue-600 font-medium hover:underline">Toggle guide</button>
        </div>
        <div id="workflowGuide" class="px-4 py-4 sm:px-6">
            <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3 sm:gap-0">
                <!-- Step 1 -->
                <div class="flex-1 flex flex-col items-center text-center px-2">
                    <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center mb-2">
                        <span class="text-sm font-bold text-blue-700">1</span>
                    </div>
                    <span class="text-xs font-semibold text-gray-800 mb-1">HR / Admin / Accountant</span>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700 mb-1">Draft</span>
                    <svg class="w-4 h-4 text-gray-400 my-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                    <span class="text-xs text-gray-600">Run Payroll</span>
                    <svg class="w-4 h-4 text-gray-400 my-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-700">Computed</span>
                </div>
                <!-- Divider -->
                <div class="hidden sm:block w-6 text-gray-300 text-2xl font-thin text-center mt-3">&rsaquo;</div>
                <!-- Step 2 -->
                <div class="flex-1 flex flex-col items-center text-center px-2">
                    <div class="w-10 h-10 rounded-full bg-orange-100 flex items-center justify-center mb-2">
                        <span class="text-sm font-bold text-orange-700">2</span>
                    </div>
                    <span class="text-xs font-semibold text-gray-800 mb-1">Accountant / Admin</span>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-700 mb-1">Computed</span>
                    <svg class="w-4 h-4 text-gray-400 my-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                    <span class="text-xs text-gray-600">Approve or Reject</span>
                    <svg class="w-4 h-4 text-gray-400 my-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">Approved</span>
                </div>
                <!-- Divider -->
                <div class="hidden sm:block w-6 text-gray-300 text-2xl font-thin text-center mt-3">&rsaquo;</div>
                <!-- Step 3 -->
                <div class="flex-1 flex flex-col items-center text-center px-2">
                    <div class="w-10 h-10 rounded-full bg-emerald-100 flex items-center justify-center mb-2">
                        <span class="text-sm font-bold text-emerald-700">3</span>
                    </div>
                    <span class="text-xs font-semibold text-gray-800 mb-1">Admin Only</span>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700 mb-1">Approved</span>
                    <svg class="w-4 h-4 text-gray-400 my-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                    <span class="text-xs text-gray-600">Release Payroll</span>
                    <svg class="w-4 h-4 text-gray-400 my-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-700">Released</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Period Selector + Action Buttons -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-50 bg-gray-50/30 flex items-center justify-between">
            <h2 class="text-sm font-bold text-gray-900 flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-blue-500"></div>
                Payroll Period Selection
            </h2>
            <span class="text-xs font-semibold px-2.5 py-1 rounded-lg bg-blue-50 text-blue-600 border border-blue-100">
                Current: @Model.CurrentPeriod
            </span>
        </div>
        <div class="px-6 py-5">
            <div class="flex flex-col md:flex-row items-end gap-4">
                <!-- Period selector -->
                <div class="w-full md:flex-1">
                    <label class="block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2">Select Payroll Batch</label>
                    <div class="relative">
                        <select id="periodSelect" onchange="changePeriod(this.value)"
                                class="w-full pl-4 pr-10 py-3 border border-gray-200 rounded-xl text-sm bg-white focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 transition-all appearance-none cursor-pointer font-medium text-gray-700">
                            <option value="">— Select a payroll period —</option>
                            @foreach (var p in Model.Periods)
                            {
                                var isSelected = p.PayrollPeriodId == Model.SelectedPeriodId ? "selected" : null;
                                <option value="@p.PayrollPeriodId" selected="@isSelected">
                                    @p.PeriodName — @(p.Status) (@p.EmployeeCount emp, ₱@p.TotalNetPay.ToString("N2"))
                                </option>
                            }
                        </select>
                        <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none text-gray-400">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                        </div>
                    </div>
                </div>

                <div class="flex flex-wrap items-center gap-2 sm:gap-3 w-full md:w-auto">
                    @if (hasPeriod)
                    {
                        @* Draft: HR/Admin/Accountant can run payroll *@
                        @if (periodStatus == "Draft" && (User.IsInRole("Admin") || User.IsInRole("Accountant") || User.IsInRole("HR")))
                        {
                            <button id="btnRunPayroll" onclick="runPayroll()"
                                    class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-blue-700 bg-blue-50 rounded-lg hover:bg-blue-100 transition-colors">
                                <svg class="w-3.5 h-3.5 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                                Run Payroll
                            </button>
                        }

                        @* Computed: HR/Accountant/Admin can Approve or Reject *@
                        @if (periodStatus == "Computed" && (User.IsInRole("Admin") || User.IsInRole("Accountant") || User.IsInRole("HR")))
                        {
                            <button id="btnApprove" onclick="approvePeriod()"
                                    class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-green-700 bg-green-50 rounded-lg hover:bg-green-100 transition-colors">
                                <svg class="w-3.5 h-3.5 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                                Approve
                            </button>
                            <button onclick="openRejectModal()"
                                    class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-red-600 bg-red-50 rounded-lg hover:bg-red-100 transition-colors">
                                <svg class="w-3.5 h-3.5 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                                Reject
                            </button>
                        }

                        @* Approved: Admin can Release *@
                        @if (periodStatus == "Approved" && User.IsInRole("Admin"))
                        {
                            <button onclick="openReleaseModal()"
                                    class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-emerald-700 bg-emerald-50 rounded-lg hover:bg-emerald-100 transition-colors">
                                <svg class="w-3.5 h-3.5 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" /></svg>
                                Release Payroll
                            </button>
                        }

                        @* Status badge *@
                        <span class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-semibold border @badgeBg">
                            <span class="w-1.5 h-1.5 rounded-full bg-current"></span>
                            @badgeLabel
                        </span>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("Accountant"))
                    {
                        <button onclick="openCreatePeriod()"
                                class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-gray-700 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors">
                            <svg class="w-3.5 h-3.5 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                            New Period
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Payroll Table Card -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-4 sm:px-6 py-3 sm:py-4 border-b border-gray-100 bg-gradient-to-r from-gray-50 to-white">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                <div>
                    <h2 class="text-sm sm:text-base font-semibold text-gray-900">Payroll Calculation Details</h2>
                    <p class="text-xs sm:text-sm text-gray-500 mt-0.5" id="payrollSummaryCount">@Model.Payrolls.Count employees in this batch</p>
                </div>
                <div class="flex flex-row items-center gap-2 w-full sm:w-auto">
                    <select id="pageSizeSelect" onchange="currentPage=1; updateView()"
                            class="px-3 py-2 border border-gray-300 rounded-lg text-xs sm:text-sm bg-white focus:ring-2 focus:ring-blue-500">
                        <option value="10">10 per page</option>
                        <option value="25" selected>25 per page</option>
                        <option value="50">50 per page</option>
                        <option value="100">100 per page</option>
                    </select>
                    <div class="relative flex-1 sm:flex-none">
                        <div class="absolute inset-y-0 left-0 pl-2.5 sm:pl-3 flex items-center pointer-events-none">
                            <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" /></svg>
                        </div>
                        <input type="text" id="searchInput" onkeyup="updateView()" placeholder="Search employee..."
                               class="w-full sm:w-56 pl-8 sm:pl-10 pr-3 sm:pr-4 py-2 sm:py-2.5 border border-gray-300 rounded-lg sm:rounded-xl text-xs sm:text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all">
                    </div>
                </div>
            </div>
        </div>

        @if (!Model.Payrolls.Any())
        {
            <div class="flex flex-col items-center justify-center py-20 px-6">
                <div class="w-20 h-20 bg-blue-50 rounded-3xl flex items-center justify-center mb-6 shadow-sm border border-blue-100">
                    <svg class="w-10 h-10 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                </div>
                <h3 class="text-base font-bold text-gray-900">No Salary Data Available</h3>
                <p class="text-sm text-gray-500 mt-2 max-w-sm text-center">Select a payroll period and click <strong>Run Payroll</strong> to compute employee salaries.</p>
            </div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full" id="payrollTable">
                    <thead class="bg-gray-50/80">
                        <tr>
                            <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Employee</th>
                            <th class="px-4 sm:px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Basic Pay</th>
                            <th class="px-4 sm:px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">OT + Holiday</th>
                            <th class="px-4 sm:px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Allowances</th>
                            <th class="px-4 sm:px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Gross Pay</th>
                            <th class="px-4 sm:px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Deductions</th>
                            <th class="px-4 sm:px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Net Pay</th>
                            <th class="px-4 sm:px-6 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100 bg-white">
                        @foreach (var payroll in Model.Payrolls)
                        {
                            var initial = payroll.EmployeeName.Length > 0 ? payroll.EmployeeName[0].ToString() : "?";
                            <tr class="hover:bg-gray-50/50 transition-colors payroll-row">
                                <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap">
                                    <div class="flex items-center">
                                        <div class="w-8 h-8 sm:w-9 sm:h-9 rounded-full bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center mr-2 sm:mr-3 shadow-sm flex-shrink-0">
                                            <span class="text-xs font-bold text-white">@initial</span>
                                        </div>
                                        <div>
                                            <div class="text-xs sm:text-sm font-semibold text-gray-900 search-name">@payroll.EmployeeName</div>
                                            <div class="text-xs text-gray-500">@payroll.EmployeeCode</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap text-right text-sm text-gray-700 font-semibold">₱@((payroll.BasicPay ?? 0m).ToString("N2"))</td>
                                <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap text-right text-sm text-gray-600 font-medium">
                                    ₱@(((payroll.OvertimePay ?? 0m) + (payroll.HolidayPay ?? 0m)).ToString("N2"))
                                </td>
                                <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap text-right text-sm text-gray-600 font-medium">₱@((payroll.Allowances ?? 0m).ToString("N2"))</td>
                                <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap text-right text-sm font-bold text-gray-900">₱@payroll.GrossPay.ToString("N2")</td>
                                <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap text-right text-sm text-red-600 font-bold">-₱@payroll.TotalDeductions.ToString("N2")</td>
                                <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap text-right text-sm font-black text-blue-700">₱@payroll.NetPay.ToString("N2")</td>
                                <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap text-center">
                                    <button onclick='openBreakdown(@System.Text.Json.JsonSerializer.Serialize(payroll))'
                                            class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-blue-700 bg-blue-50 rounded-lg hover:bg-blue-100 transition-colors">
                                        View Details
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="bg-gray-50/80 border-t-2 border-gray-200">
                        <tr class="divide-x divide-gray-100">
                            <td class="px-4 sm:px-6 py-3 sm:py-4 text-sm font-black text-gray-900 uppercase tracking-wider">Batch Total</td>
                            <td class="px-4 sm:px-6 py-3 sm:py-4 text-right text-sm font-black text-gray-900">₱@Model.Payrolls.Sum(x => x.BasicPay ?? 0m).ToString("N2")</td>
                            <td class="px-4 sm:px-6 py-3 sm:py-4 text-right text-sm font-black text-gray-900">₱@Model.Payrolls.Sum(x => (x.OvertimePay ?? 0m) + (x.HolidayPay ?? 0m)).ToString("N2")</td>
                            <td class="px-4 sm:px-6 py-3 sm:py-4 text-right text-sm font-black text-gray-900">₱@Model.Payrolls.Sum(x => x.Allowances ?? 0m).ToString("N2")</td>
                            <td class="px-4 sm:px-6 py-3 sm:py-4 text-right text-sm font-black text-gray-900 bg-gray-100/50">₱@Model.Payrolls.Sum(x => x.GrossPay).ToString("N2")</td>
                            <td class="px-4 sm:px-6 py-3 sm:py-4 text-right text-sm font-black text-red-600 bg-red-50/30">-₱@Model.Payrolls.Sum(x => x.TotalDeductions).ToString("N2")</td>
                            <td class="px-4 sm:px-6 py-3 sm:py-4 text-right text-sm font-black text-blue-700 bg-blue-100/30">₱@Model.TotalPayrollCost.ToString("N2")</td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <!-- Pagination Footer -->
            <div class="px-4 sm:px-6 py-3 sm:py-4 border-t border-gray-100 bg-gray-50/50" id="paginationContainer">
                <div class="flex flex-col sm:flex-row items-center justify-between gap-3">
                    <div class="text-xs sm:text-sm text-gray-600" id="payrollPaginationInfo">Showing 0 to 0 of @Model.Payrolls.Count records</div>
                    <nav class="flex items-center gap-1 flex-wrap justify-center" id="payrollPaginationNav"></nav>
                </div>
            </div>
        }
<!-- ═══ Create Period Modal ═══ -->
<div id="createPeriodModal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-hidden="true">
    <div class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm transition-opacity" onclick="closePeriodModal()"></div>
    <div class="fixed inset-0 z-50 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-2 sm:p-4 text-center">
            <div class="relative transform overflow-hidden rounded-lg bg-white text-left shadow-xl transition-all w-full sm:w-[90%] md:w-[60%] lg:w-[40%] max-w-md mx-auto">
                <div class="flex items-center justify-between border-b border-gray-200 bg-white px-4 py-3 sm:px-6 sm:py-4">
                    <h3 class="text-base sm:text-lg font-semibold text-gray-900">New Payroll Period</h3>
                    <button type="button" onclick="closePeriodModal()" class="rounded-lg p-1.5 text-gray-400 hover:bg-gray-100 hover:text-gray-500">
                        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
                    </button>
                </div>
                <div class="px-4 py-4 sm:px-6 sm:py-5 md:px-6 md:py-6">
