@page
@model PayRex.Web.Pages.SalaryModel
@{
    ViewData["Title"] = "Salary Computation";
    var hasPeriod = Model.SelectedPeriodId.HasValue;
    var periodStatus = Model.SelectedPeriodStatus;
    var authCookie = HttpContext.Request.Cookies["PayRex.AuthToken"] ?? "";
    var (badgeBg, badgeLabel) = periodStatus switch {
        "Draft"    => ("bg-gray-100 text-gray-700",       "Draft"),
        "Computed" => ("bg-amber-50 text-amber-700",   "Pending Review"),
        "Approved" => ("bg-emerald-50 text-emerald-700",     "Approved"),
        "Released" => ("bg-blue-50 text-blue-700",       "Released"),
        _          => ("bg-gray-100 text-gray-500",       "Unknown")
    };
}

<input type="hidden" id="authToken" value="@authCookie" />
<div class="max-w-8xl mx-auto px-4 sm:px-6 lg:px-8 space-y-4 sm:space-y-6">
    <!-- Hero Header -->
    <div class="bg-gradient-to-r from-blue-50 via-white to-blue-50 rounded-xl sm:rounded-2xl border border-blue-100 shadow-sm overflow-hidden relative">
        <div class="absolute top-0 right-0 -mt-16 -mr-16 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
        <div class="absolute bottom-0 left-0 -mb-16 -ml-16 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-20"></div>
        <div class="px-4 py-5 sm:px-8 sm:py-8 relative z-10">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 sm:gap-4">
                <div>
                    <h1 class="text-xl sm:text-2xl lg:text-3xl font-extrabold text-gray-900 tracking-tight">Salary Computation</h1>
                    <p class="mt-1 sm:mt-2 text-sm sm:text-base text-gray-600">Manage and compute payroll for current periods</p>
                </div>
                <div class="flex items-center gap-2 sm:gap-3">
                    <span class="inline-flex items-center px-3 sm:px-4 py-1.5 sm:py-2 rounded-lg sm:rounded-xl text-xs sm:text-sm font-semibold bg-blue-100 text-blue-700">
                        <svg class="w-3 h-3 sm:w-4 sm:h-4 mr-1.5 sm:mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                        <span class="hidden sm:inline">Total: </span>₱@Model.TotalPayrollCost.ToString("N2")
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Workflow Guide - Collapsible -->
    <div class="bg-white rounded-xl sm:rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <button onclick="document.getElementById('workflowGuide').classList.toggle('hidden')" class="w-full px-4 sm:px-6 py-3 sm:py-4 flex items-center justify-between text-left bg-gradient-to-r from-gray-50 to-white">
            <div class="flex items-center gap-2">
                <svg class="w-4 h-4 sm:w-5 sm:h-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                <span class="text-sm sm:text-base font-semibold text-gray-900">Payroll Workflow Guide</span>
            </div>
            <svg class="w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </button>
        <div id="workflowGuide" class="hidden border-t border-gray-100 px-4 py-4">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <!-- Step 1 -->
                <div class="flex items-start gap-3">
                    <div class="w-6 h-6 rounded-full bg-gray-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                        <span class="text-xs font-medium text-gray-600">1</span>
                    </div>
                    <div>
                        <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">HR</p>
                        <p class="text-sm font-medium text-gray-900 mt-1">Draft → Computed</p>
                        <p class="text-xs text-gray-500 mt-1">Run payroll calculation</p>
                    </div>
                </div>
                <!-- Step 2 -->
                <div class="flex items-start gap-3">
                    <div class="w-6 h-6 rounded-full bg-gray-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                        <span class="text-xs font-medium text-gray-600">2</span>
                    </div>
                    <div>
                        <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Accountant/Admin</p>
                        <p class="text-sm font-medium text-gray-900 mt-1">Computed → Approved</p>
                        <p class="text-xs text-gray-500 mt-1">Review and approve payroll</p>
                    </div>
                </div>
                <!-- Step 3 -->
                <div class="flex items-start gap-3">
                    <div class="w-6 h-6 rounded-full bg-gray-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                        <span class="text-xs font-medium text-gray-600">3</span>
                    </div>
                    <div>
                        <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Admin</p>
                        <p class="text-sm font-medium text-gray-900 mt-1">Approved → Released</p>
                        <p class="text-xs text-gray-500 mt-1">Final release to employees</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Period Selector + Actions -->
    <div class="bg-white rounded-xl sm:rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-4 sm:px-6 py-3 sm:py-4 border-b border-gray-100 bg-gradient-to-r from-gray-50 to-white">
            <h2 class="text-sm sm:text-base font-semibold text-gray-900 flex items-center">
                <svg class="w-4 h-4 sm:w-5 sm:h-5 mr-1.5 sm:mr-2 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                Payroll Period
            </h2>
        </div>
        <div class="p-4">
            <div class="flex flex-col md:flex-row md:items-end gap-4">
                <div class="flex-1">
                    <label class="block text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">Select Period</label>
                    <select id="periodSelect" onchange="changePeriod(this.value)"
                            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-white">
                        <option value="">— Select a payroll period —</option>
                        @foreach (var p in Model.Periods)
                        {
                            var isSelected = p.PayrollPeriodId == Model.SelectedPeriodId ? "selected" : null;
                            <option value="@p.PayrollPeriodId" selected="@isSelected">
                                @p.PeriodName — @p.Status (@p.EmployeeCount employees)
                            </option>
                        }
                    </select>
                </div>

                <div class="flex flex-wrap items-center gap-2">
                    @if (hasPeriod)
                    {
                        @if (periodStatus == "Draft" && User.IsInRole("HR"))
                        {
                            <button id="btnRunPayroll" onclick="runPayroll()"
                                    class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                                Run Payroll
                            </button>
                        }

                        @if (periodStatus == "Computed" && (User.IsInRole("Admin") || User.IsInRole("Accountant")))
                        {
                            <button id="btnApprove" onclick="approvePeriod()"
                                    class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-white bg-emerald-600 rounded-lg hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                                Approve
                            </button>
                            <button onclick="openRejectModal()"
                                    class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-500">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" /></svg>
                                Reject
                            </button>
                        }

                        @if (periodStatus == "Approved" && User.IsInRole("Admin"))
                        {
                            <button onclick="openReleaseModal()"
                                    class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" /></svg>
                                Release
                            </button>
                        }

                        <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-medium @badgeBg">
                            @badgeLabel
                        </span>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("Accountant"))
                    {
                        <button onclick="openCreatePeriod()"
                                class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-500">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                            New Period
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Payroll Table -->
    <div class="bg-white rounded-xl sm:rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-4 sm:px-6 py-3 sm:py-4 border-b border-gray-100 bg-gradient-to-r from-gray-50 to-white">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                <div>
                    <h2 class="text-sm sm:text-base font-semibold text-gray-900">Payroll Details</h2>
                    <p class="text-xs sm:text-sm text-gray-500 mt-0.5" id="payrollSummaryCount">@Model.Payrolls.Count employees</p>
                </div>
                <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-2">
                    <select id="pageSizeSelect" onchange="currentPage=1; updateView()"
                            class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-white">
                        <option value="10">10 per page</option>
                        <option value="25" selected>25 per page</option>
                        <option value="50">50 per page</option>
                        <option value="100">100 per page</option>
                    </select>
                    <div class="relative">
                        <input type="text" id="searchInput" onkeyup="updateView()" placeholder="Search employee..."
                               class="w-full sm:w-64 pl-9 pr-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                        <svg class="w-4 h-4 text-gray-400 absolute left-3 top-2.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                    </div>
                </div>
            </div>
        </div>

        @if (!Model.Payrolls.Any())
        {
            <div class="text-center py-12">
                <div class="w-12 h-12 sm:w-16 sm:h-16 bg-blue-50 rounded-full flex items-center justify-center mx-auto mb-3 sm:mb-4">
                    <svg class="w-6 h-6 sm:w-8 sm:h-8 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                </div>
                <h3 class="text-sm sm:text-base text-gray-500 font-medium">No salary data available</h3>
                <p class="text-xs sm:text-sm text-gray-400 mt-1">Select a period and run payroll to compute salaries.</p>
            </div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50/80">
                        <tr>
                            <th class="px-4 sm:px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Employee</th>
                            <th class="px-4 sm:px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Basic</th>
                            <th class="px-4 sm:px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">OT/Holiday</th>
                            <th class="px-4 sm:px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Allowances</th>
                            <th class="px-4 sm:px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Gross</th>
                            <th class="px-4 sm:px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Deductions</th>
                            <th class="px-4 sm:px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Net</th>
                            <th class="px-4 sm:px-6 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-100">
                        @foreach (var payroll in Model.Payrolls)
                        {
                            var initial = payroll.EmployeeName.Length > 0 ? payroll.EmployeeName[0].ToString() : "?";
                            <tr class="hover:bg-gray-50/50 transition-colors payroll-row">
                                <td class="px-4 sm:px-6 py-3 sm:py-4 whitespace-nowrap">
                                    <div class="flex items-center">
                                        <div class="w-8 h-8 sm:w-9 sm:h-9 rounded-full overflow-hidden flex items-center justify-center mr-2 sm:mr-3 shadow-sm flex-shrink-0">
                                            <div class="w-8 h-8 sm:w-9 sm:h-9 rounded-full bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center">
                                                <span class="text-xs font-bold text-white">@initial</span>
                                            </div>
                                        </div>
                                        <div>
                                            <div class="text-xs sm:text-sm font-semibold text-gray-900 search-name">@payroll.EmployeeName</div>
                                            <div class="text-xs text-gray-500">ID: @payroll.EmployeeCode</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-4 sm:px-6 py-3 sm:py-4 text-right text-xs sm:text-sm text-gray-900">₱@((payroll.BasicPay ?? 0m).ToString("N2"))</td>
                                <td class="px-4 sm:px-6 py-3 sm:py-4 text-right text-xs sm:text-sm text-gray-900">₱@(((payroll.OvertimePay ?? 0m) + (payroll.HolidayPay ?? 0m)).ToString("N2"))</td>
                                <td class="px-4 sm:px-6 py-3 sm:py-4 text-right text-xs sm:text-sm text-gray-900">₱@((payroll.Allowances ?? 0m).ToString("N2"))</td>
                                <td class="px-4 sm:px-6 py-3 sm:py-4 text-right text-xs sm:text-sm font-semibold text-gray-900">₱@payroll.GrossPay.ToString("N2")</td>
                                <td class="px-4 sm:px-6 py-3 sm:py-4 text-right text-xs sm:text-sm text-red-600">-₱@payroll.TotalDeductions.ToString("N2")</td>
                                <td class="px-4 sm:px-6 py-3 sm:py-4 text-right text-xs sm:text-sm font-semibold text-gray-900">₱@payroll.NetPay.ToString("N2")</td>
                                <td class="px-4 sm:px-6 py-3 sm:py-4 text-center">
                                    <button onclick='openBreakdown(@System.Text.Json.JsonSerializer.Serialize(payroll))'
                                            class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-blue-700 bg-blue-50 rounded-lg hover:bg-blue-100 transition-colors">
                                        <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                                        View
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="bg-gray-50/80 border-t border-gray-200">
                        <tr>
                            <td class="px-4 sm:px-6 py-3 sm:py-4 text-xs sm:text-sm font-semibold text-gray-900">Total</td>
                            <td class="px-4 sm:px-6 py-3 sm:py-4 text-right text-xs sm:text-sm font-semibold text-gray-900">₱@Model.Payrolls.Sum(x => x.BasicPay ?? 0m).ToString("N2")</td>
                            <td class="px-4 sm:px-6 py-3 sm:py-4 text-right text-xs sm:text-sm font-semibold text-gray-900">₱@Model.Payrolls.Sum(x => (x.OvertimePay ?? 0m) + (x.HolidayPay ?? 0m)).ToString("N2")</td>
                            <td class="px-4 sm:px-6 py-3 sm:py-4 text-right text-xs sm:text-sm font-semibold text-gray-900">₱@Model.Payrolls.Sum(x => x.Allowances ?? 0m).ToString("N2")</td>
                            <td class="px-4 sm:px-6 py-3 sm:py-4 text-right text-xs sm:text-sm font-semibold text-gray-900">₱@Model.Payrolls.Sum(x => x.GrossPay).ToString("N2")</td>
                            <td class="px-4 sm:px-6 py-3 sm:py-4 text-right text-xs sm:text-sm font-semibold text-red-600">-₱@Model.Payrolls.Sum(x => x.TotalDeductions).ToString("N2")</td>
                            <td class="px-4 sm:px-6 py-3 sm:py-4 text-right text-xs sm:text-sm font-semibold text-gray-900">₱@Model.TotalPayrollCost.ToString("N2")</td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <!-- Pagination -->
            <div class="px-4 sm:px-6 py-3 sm:py-4 border-t border-gray-100 bg-gray-50/50" id="paginationContainer">
                <div class="flex flex-col sm:flex-row items-center justify-between gap-3">
                    <div class="text-xs sm:text-sm text-gray-600" id="payrollPaginationInfo"></div>
                    <nav class="flex items-center gap-1 flex-wrap justify-center" id="payrollPaginationNav"></nav>
                </div>
            </div>
        }
    </div>
</div>

<!-- Create Period Modal -->
<div id="createPeriodModal" tabindex="-1" aria-hidden="true" class="fixed inset-0 z-[100] hidden overflow-y-auto overflow-x-hidden p-4 md:p-5 flex items-center justify-center bg-gray-900/50 backdrop-blur-sm transition-opacity" onclick="if(event.target === this) closePeriodModal()">
    <div class="relative w-full max-w-md max-h-full">
        <!-- Modal content -->
        <div class="relative bg-white rounded-xl shadow dark:bg-gray-700">
            <!-- Modal header -->
            <div class="flex items-center justify-between p-4 md:p-5 border-b rounded-t dark:border-gray-600">
                <h3 class="text-xl font-semibold text-gray-900 dark:text-white">
                    New Payroll Period
                </h3>
                <button type="button" onclick="closePeriodModal()" class="end-2.5 text-gray-400 bg-transparent hover:bg-gray-200 hover:text-gray-900 rounded-lg text-sm w-8 h-8 ms-auto inline-flex justify-center items-center dark:hover:bg-gray-600 dark:hover:text-white">
                    <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
                    </svg>
                    <span class="sr-only">Close modal</span>
                </button>
            </div>
            <!-- Modal body -->
            <div class="p-4 md:p-5">
                <div class="space-y-4">
                    <div>
                        <label class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Period Name</label>
                        <input type="text" id="newPeriodName" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-600 dark:border-gray-500 dark:placeholder-gray-400 dark:text-white" placeholder="e.g. Feb 1-15, 2026">
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Start Date</label>
                            <input type="date" id="newPeriodStart" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-600 dark:border-gray-500 dark:text-white">
                        </div>
                        <div>
                            <label class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">End Date</label>
                            <input type="date" id="newPeriodEnd" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 dark:bg-gray-600 dark:border-gray-500 dark:text-white">
                        </div>
                    </div>
                </div>
                <div class="mt-6 flex justify-end gap-2 border-t border-gray-200 dark:border-gray-600 pt-4">
                    <button type="button" onclick="closePeriodModal()" class="text-gray-500 bg-white hover:bg-gray-100 focus:ring-4 focus:outline-none focus:ring-blue-300 rounded-lg border border-gray-200 text-sm font-medium px-5 py-2.5 hover:text-gray-900 focus:z-10 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-500 dark:hover:text-white dark:hover:bg-gray-600 dark:focus:ring-gray-600">Cancel</button>
                    <button type="button" onclick="submitCreatePeriod()" id="createPeriodBtn" class="text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800">Create</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Breakdown Modal -->
