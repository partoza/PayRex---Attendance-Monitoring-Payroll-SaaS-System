                        <div class="w-16 h-16 rounded-full bg-gradient-to-br from-blue-500 to-blue-700 flex items-center justify-center flex-shrink-0 shadow-lg ring-4 ring-white dark:ring-gray-800">
                            <span id="bdAvatar" class="text-2xl font-bold text-white"></span>
                        </div>
                        <div>
                            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-0.5">Employee Name</p>
                            <h4 id="bdName" class="text-2xl font-black text-gray-900 dark:text-white"></h4>
                            <p class="text-sm text-blue-600 font-bold dark:text-blue-400" id="bdPosition">Regular Staff</p>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                    <!-- Earnings Column -->
                    <div class="space-y-4">
                        <div class="flex items-center gap-2 mb-2 border-b border-gray-100 dark:border-gray-700 pb-2">
                            <div class="w-2 h-6 bg-emerald-500 rounded-full"></div>
                            <h5 class="text-sm font-black text-gray-900 dark:text-white uppercase tracking-widest">Earnings</h5>
                        </div>
                        <div class="space-y-1">
                            <div class="flex justify-between items-center py-2 px-3 hover:bg-gray-50 dark:hover:bg-gray-700/50 rounded-lg transition-colors border-b border-gray-50 dark:border-gray-700/30">
                                <span class="text-sm font-medium text-gray-600 dark:text-gray-400">Basic Pay</span>
                                <span class="text-sm font-bold text-gray-900 dark:text-white" id="bdBasic"></span>
                            </div>
                            <div id="bdRowOT" class="flex justify-between items-center py-2 px-3 hover:bg-gray-50 dark:hover:bg-gray-700/50 rounded-lg transition-colors border-b border-gray-50 dark:border-gray-700/30">
                                <span class="text-sm font-medium text-gray-600 dark:text-gray-400">Overtime Pay</span>
