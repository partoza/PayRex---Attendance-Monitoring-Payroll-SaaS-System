                    <button type="button" onclick="submitCreatePeriod()" id="createPeriodBtn" class="px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500">
                        Create Period
                    </button>
                </div>
            </div>
