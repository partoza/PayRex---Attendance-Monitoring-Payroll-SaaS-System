                            <p class="text-xs font-bold text-blue-600/60 dark:text-blue-400/60 uppercase">Reference No.</p>
                            <p id="bdCode" class="text-sm font-bold text-gray-900 dark:text-white">ID: EMP-XXXX</p>
                        </div>
                        <div class="text-right">
                             <p class="text-xs font-bold text-blue-600/60 dark:text-blue-400/60 uppercase">Period</p>
